 1007  05D0  21 2B 00     MULOOP:	LXI H,FP_TEMP                   ;Load L with address of LSW of FP TEMP (original
 1008  05D3  CD A0 11     	CALL FACXOP                     ;Value in FPOP). Move FP TEMP into FPOP.
 1009  05D6  CD E5 0F     	CALL FPMULT                     ;Multiply FPACC by FPOP. Result left in FPACC.
 1010  05D9  21 5F 00     	LXI H,EXP_COUNTER               ;Load L with address of EXPONENT COUNTER.
