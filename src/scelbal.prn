 3707  195C  21 47 00     SQR1:	LXI H,FPACC_SAVE                ;Else, load L with address of SQR APPROX
 3708  195F  54           	MOV D,H                         ;Set D to same page as H
 3709  1960  1E 24        	MVI E,024H                      ;And E with address of LAST SQR APPROX
 3710  1962  06 04        	MVI B,004H                      ;Set up register B as a number of bytes to move counter
 3711  1964  CD CB 0F     	CALL MOVEIT                     ;Transfer SQR APPROX into LAST SQR APPROX
 3712  1967  C3 26 19     	JMP SQRLOP                      ;Continue ops until approximation converges
 3713  196A  21 5F 00     SQRCNV:	LXI H,EXP_COUNTER               ;Load L with address of TEMP register. Fetch the
 3714  196D  7E           	MOV A,M                         ;Exponenent quotient store there into accumulator.
 3715  196E  21 4B 00     	LXI H,SCRATCH_1F                ;Change L to point to SQR APPROX exponent.
 3716  1971  86           	ADD M                           ;Add SQR APPROX exponent to quotient value.
 3717  1972  77           	MOV M,A                         ;Store sum back in SQR APPROX Exponent register.
 3718  1973  21 47 00     	LXI H,FPACC_SAVE                ;Load L with address of SQR APPROX. Transfer the
 3719  1976  C3 88 11     	JMP FLOAD                       ;SQR APPROX into FPACC as answer and exit.
