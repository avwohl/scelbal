 2331  0FF0  17           BRING1:	RAL                             ;If MSB is a one need to set up carrv bit for the negative
 2332  0FF1  C3 97 11     	JMP ROTR                        ;Number case. Then make special entry to ROTATR sub
 2333                     
 2334                                                       ;The following subroutine moves the contents of a string
 2335                                                       ;of memory locations from the address pointed to by
 2336                                                       ;CPU registers H & L to the address specified by the con-
 2337                                                       ;tents of registers D & E when the routine is entered. The
 2338                                                       ;process continues until the counter in register B is zero.
 2339                     
 2340  0FF4  7E           MOVEIT:	MOV A,M                         ;Fetch a word from memory string A
 2341  0FF5  23           	INX H                           ;Advance A string pointer (full 16-bit)
 2342  0FF6  CD F5 11     	CALL SWITCH                     ;Switch pointer to string B
 2343  0FF9  77           	MOV M,A                         ;Put word from string A into string B
 2344  0FFA  23           	INX H                           ;Advance B string pointer (full 16-bit)
 2345  0FFB  CD F5 11     	CALL SWITCH                     ;Switch pointer back to string A
 2346  0FFE  05           	DCR B                           ;Decrement loop counter
 2347  0FFF  C8           	RZ                              ;Return to calling routine when counter reaches zero
 2348  1000  C3 F4 0F     	JMP MOVEIT                      ;Else continue transfer operations
 2349                     
 2350                                                       ;The following subroutine SUBTRACTS the
 2351                                                       ;contents of the FLOATING POINT ACCUMULATOR from the
 2352                                                       ;contents of the FLOATING POINT OPERAND and
 2353                                                       ;leaves the result in the FPACC. The routine merely
 2354                                                       ;negates the value in the FPACC and then goes to the
 2355                                                       ;FPADD subroutine just presented.
 2356                     
 2357  1003  21 1F 00     FPSUB:	LXI H,FPACC                     ;Set L to address of LSW of FPACC
 2358  1006  06 03        	MVI B,003H                      ;Set precision counter
 2359  1008  CD 75 11     	CALL COMPLM                     ;Two's complement the value in the FPACC
 2360  100B  C3 66 0F     	JMP FPADD                       ;Now go add the negated value to perform subtraction!
 2361                     
 2362                                                       ;The first part of the FLOATING POINT MULTIPLI-
 2363                                                       ;CATION subroutine calls a subroutine to check the
 2364                                                       ;original signs of the numbers that are to be multi-
 2365                                                       ;plied and perform working register clearing functions.
 2366                                                       ;Next the exponents of the numbers to be multiplied
 2367                                                       ;are added together.
 2368                     
 2369  100E  CD 69 10     FPMULT:	CALL CKSIGN                     ;Call routine to set up registers & ck signs of numbers
 2370  1011  21 2A 00     ADDEXP:	LXI H,FPOP_EXP                  ;Set pointer to FPOP Exponent
 2371  1014  7E           	MOV A,M                         ;Fetch FPOP Exponent into the accumulator
 2372  1015  21 22 00     	LXI H,FPACC_EXP                 ;Change pointer to FPACC Exponent
 2373  1018  86           	ADD M                           ;Add FPACC Exponent to FPOP Exponent
 2374  1019  C6 01        	ADI 001H                        ;Add one more to total for algorithm compensation
 2375  101B  77           	MOV M,A                         ;Store result in FPACC Exponent location
 2376  101C  21 63 00     SETMCT:	LXI H,BITS_COUNTER              ;Change pointer to bit counter storage location
 2377  101F  36 17        	MVI M,017H                      ;Initialize bit counter to 23 decimal
 2378                     
 2379                                                       ;Next portion of the FPMULT routine is the iinplernen-
 2380                                                       ;tation of the algorithm illustrated in the flow chart
 2381                                                       ;above. This portion multiplies the values of the two
 2382                                                       ;mantissas. The final value is rounded off to leave the
 2383                                                       ;23 most significant bits as the answer that is stored
 2384                                                       ;back in the FPACC.
 2385                     
 2386  1021  21 21 00     MULTIP:	LXI H,FPACC_MSW                 ;Set pointer to MSW of FPACC mantissa
 2387  1024  06 03        	MVI B,003H                      ;Set precision counter
 2388  1026  CD 96 11     	CALL ROTATR                     ;Rotate FPACC (multiplier) RIGHT into carry bit
 2389  1029  DC B2 10     	CC ADOPPP                       ;If carry is a one, add multiplicand to partial-product
 2390  102C  21 34 00     	LXI H,FP_WORK_66                ;Set pointer to partial-product most significant byte
 2391  102F  06 06        	MVI B,006H                      ;Set precision counter (p-p register is double length)
 2392  1031  CD 96 11     	CALL ROTATR                     ;Shift partial-product RIGHT
 2393  1034  21 63 00     	LXI H,BITS_COUNTER              ;Set pointer to bit counter storage location
 2394  1037  4E           	MOV C,M                         ;Fetch current value of bit counter
 2395  1038  0D           	DCR C                           ;Decrement the value of the bit counter
 2396  1039  71           	MOV M,C                         ;Restore the updated bit counter to its storage location
 2397  103A  C2 21 10     	JNZ MULTIP                      ;If have not multiplied for 23 (deciinal) bits, keep going
 2398  103D  21 34 00     	LXI H,FP_WORK_66                ;If have done 23 (decimal) bits, set pntr to p-p MSW
 2399  1040  06 06        	MVI B,006H                      ;Set precision counter (for double length)
 2400  1042  CD 96 11     	CALL ROTATR                     ;Shift partial-product once more to the RIGHT
 2401  1045  21 31 00     	LXI H,FP_WORK_63                ;Set pointer to access 24'th bit in partial-product
 2402  1048  7E           	MOV A,M                         ;Fetch the byte containing the 24'th bit
 2403  1049  17           	RAL                             ;Position the 24'th bit to be MSB in the accumulator
 2404  104A  A7           	ANA A                           ;Set the CPU flags after to rotate operation and test to
 2405  104B  FC BE 10     	CM MROUND                       ;See if 24'th bit of p-p is a ONE. If so, must round-off
 2406  104E  21 1E 00     	LXI H,FPACC_LSW_M1              ;Now set up pointers
 2407  1051  5D           	MOV E,L                         ;To perform transfer
 2408  1052  54           	MOV D,H                         ;Of the multiplication results
 2409  1053  21 31 00     	LXI H,FP_WORK_63                ;From the partial-product location
 2410  1056  06 04        	MVI B,004H                      ;To the FPACC
 2411                     
 2412                     
 2413  1058  CD F4 0F     EXMLDV:	CALL MOVEIT                     ;Perform the transfer from p-p to FPACC
 2414  105B  06 00        	MVI B,000H                      ;Set up CPU register B to indicate regular normalization
 2415  105D  CD 0C 0F     	CALL FPNORM                     ;Normalize the result of multiplication
 2416  1060  21 62 00     	LXI H,MD_SIGNS                  ;Now set the pointer to the original SIGNS indicator
 2417  1063  7E           	MOV A,M                         ;Fetch the indicator
 2418  1064  A7           	ANA A                           ;Exercise the CPU flags
 2419  1065  C0           	RNZ                             ;If indicator is non-zero, answer is positive, can exit her
 2420  1066  C3 5E 0F     	JMP FPCOMP                      ;If not, answer must be negated, exit via 2's complement.
 2421                     
 2422                                                       ;The following portions of the FPMULT
 2423                                                       ;routine set up working locations in memory by clearing
 2424                                                       ;locations for an expanded FPOP area and the partial-produc
 2425                                                       ;area. Next, the signs of the two numbers to be multiplied
 2426                                                       ;are examined. Negative numbers are negated
 2427                                                       ;in preparation for the multiplication
 2428                                                       ;algorithm. A SIGNS indicator register is set up during
 2429                                                       ;this process to indicate whether the final result of the
 2430                                                       ;multiplication should be positive or negative. (Negative
 2431                                                       ;if original signs of the two numbers to be multiplied are
 2432                                                       ;different.)
 2433                     
 2434  1069  21 2F 00     CKSIGN:	LXI H,FP_WORK_AREA              ;Set pointer to start of partial-product working area
 2435  106C  06 08        	MVI B,008H                      ;Set up a loop counter in CPU register B
 2436  106E  AF           	XRA A                           ;Clear the accumulator
 2437                     
 2438  106F  77           CLRNEX:	MOV M,A                         ;Now clear out locations for the partial-product
 2439  1070  23           	INX H                           ;Working registers
 2440  1071  05           	DCR B                           ;Until the loop counter
 2441  1072  C2 6F 10     	JNZ CLRNEX                      ;Is zero
 2442  1075  06 04        CLROPL:	MVI B,004H                      ;Set a loop counter
 2443  1077  21 23 00     	LXI H,FPOP_EXT                  ;Set up pointer
 2444  107A  77           CLRNX1:	MOV M,A                         ;Clear out some extra registers so that the
 2445  107B  23           	INX H                           ;FPOP may be extended in length
 2446  107C  05           	DCR B                           ;Perform clearing ops until loop counter
 2447  107D  C2 7A 10     	JNZ CLRNX1                      ;Is zero
 2448  1080  21 62 00     	LXI H,MD_SIGNS                  ;Set pointer to M/D SIGNS indicator storage location
 2449  1083  36 01        	MVI M,001H                      ;Set initial value of SIGNS indicator to plus one
 2450  1085  21 21 00     	LXI H,FPACC_MSW                 ;Change pointer to MSW of FPACC
 2451  1088  7E           	MOV A,M                         ;Fetch MSW of mantissa into accumulator
 2452  1089  A7           	ANA A                           ;Test flags
 2453  108A  FA A1 10     	JM NEGFPA                       ;If MSB in MSW of FPACC is a one, number is negative
 2454  108D  21 29 00     OPSGNT:	LXI H,FPOP_MSW                  ;Set pointer to MSW of FPOP
 2455  1090  7E           	MOV A,M                         ;Fetch MSW of mantissa into accumulator
 2456  1091  A7           	ANA A                           ;Test flags
 2457  1092  F0           	RP                              ;Return to caller if number in FPOP is positive
 2458  1093  21 62 00     	LXI H,MD_SIGNS                  ;Else change pointer to M/D SIGNS indicator
 2459  1096  4E           	MOV C,M                         ;Fetch the value in the SIGNS indicator
 2460  1097  0D           	DCR C                           ;Decrement the value by one
 2461  1098  71           	MOV M,C                         ;Restore the new value back to storage location
 2462  1099  21 27 00     	LXI H,FPOP                      ;Set pointer to LSW of FPOP
 2463  109C  06 03        	MVI B,003H                      ;Set precision counter
 2464  109E  C3 75 11     	JMP COMPLM                      ;Two's complement value of FPOP & return to caller
 2465  10A1  21 62 00     NEGFPA:	LXI H,MD_SIGNS                  ;Set pointer to M/D SIGNS indicator
 2466  10A4  4E           	MOV C,M                         ;Fetch the value in the SIGNS indicator
 2467  10A5  0D           	DCR C                           ;Decrement the value by one
 2468  10A6  71           	MOV M,C                         ;Restore the new value back to storage location
 2469  10A7  21 1F 00     	LXI H,FPACC                     ;Set pointer to LSW of FPACC
 2470  10AA  06 03        	MVI B,003H                      ;Set precision counter
 2471  10AC  CD 75 11     	CALL COMPLM                     ;Two's complement value of FPACC
 2472  10AF  C3 8D 10     	JMP OPSGNT                      ;Proceed to check sign of FPOP
 2473                     
 2474                                                       ;The following subroutine adds the double length (six regis
 2475                                                       ;multiplicand in FPOP to the partial-product register when
 2476                                                       ;called on by the multiplication algorithm.
 2477                     
 2478  10B2  11 2F 00     ADOPPP:	LXI D,FP_WORK_61                ;Pointer to LSW of partial-product
 2479  10B5  54           	MOV D,H                         ;On same page as FPOP
 2480  10B6  21 26 00     	LXI H,FPOP_EXT_59               ;LSIV of FPOP which contains extended multiplicand
 2481  10B9  06 06        	MVI B,006H                      ;Set precision counter (double length working registers)
 2482  10BB  C3 64 11     	JMP ADDER                       ;Add multiplicand to partial-product & return to caller
 2483                     
 2484  10BE  06 03        MROUND:	MVI B,003H                      ;Set up precision counter
 2485  10C0  3E 40        	MVI A,040H                      ;Prepare to add one to 24'th bit of partial-product
 2486  10C2  86           	ADD M                           ;Add one to the 24'th bit of the partial-product
 2487  10C3  77           CROUND:	MOV M,A                         ;Restore the updated byte to memory
 2488  10C4  23           	INX H                           ;Advance the memory pointer to next most significant
 2489  10C5  3E 00        	MVI A,000H                      ;Byte of partial-product, then clear ACC without
 2490  10C7  8E           	ADC M                           ;Disturbing carry bit. Now perform add with carry to
 2491  10C8  05           	DCR B                           ;Propagate any rounding in the partial-product registers.
 2492  10C9  C2 C3 10     	JNZ CROUND                      ;If cotinter is not zero continue propagating any carry
 2493  10CC  77           	MOV M,A                         ;Restore final byte to memory
 2494  10CD  C9           	RET                             ;Exit to calling routine
 2495                     
 2496  10CE  CD 69 10     FPDIV:	CALL CKSIGN                     ;Call routine to set up registers & ck signs of numbers
 2497  10D1  21 21 00     	LXI H,FPACC_MSW                 ;Set pointer to MSW of FPACC (divisor)
 2498  10D4  7E           	MOV A,M                         ;Fetch MSW of FPACC to accumulator
 2499  10D5  A7           	ANA A                           ;Exercise CPU flags
 2500  10D6  CA B7 09     	JZ DVERR                        ;If MSW of FPACC is zero go display 'DZ' error message
 2501  10D9  21 2A 00     SUBEXP:	LXI H,FPOP_EXP                  ;Set pointer to FPOP (dividend) Exponent
 2502  10DC  7E           	MOV A,M                         ;Get FPOP Exponent into accumulator
 2503  10DD  21 22 00     	LXI H,FPACC_EXP                 ;Change pointer to FPACC (divisor) Exponent
 2504  10E0  96           	SUB M                           ;Subtract divisor exponent from dividend exponent
 2505  10E1  C6 01        	ADI 001H                        ;Add one for algorithm compensation
 2506  10E3  77           	MOV M,A                         ;Place result in FPACC Exponent
 2507  10E4  21 63 00     SETDCT:	LXI H,BITS_COUNTER              ;Set pointer to bit counter storage location
 2508  10E7  36 17        	MVI M,017H                      ;Initialize bit counter to 23 decimal
 2509                     
 2510                                                       ;Main division algorithm for mantissas
 2511                     
 2512  10E9  CD 4A 11     DIVIDE:	CALL SETSUB                     ;Go subtmct divisor from dividend
 2513  10EC  FA 00 11     	JM NOGO                         ;If result is negative then place a zero bit in quotient
 2514  10EF  11 27 00     	LXI D,FPOP                      ;If result zero or positive then move remainder after
 2515  10F2  21 26 00     	LXI H,FPOP_EXT_59               ;Subtraction from working area to become new dividend
 2516  10F5  06 03        	MVI B,003H                      ;Set up moving pointers and initialize precision counter
 2517  10F7  CD F4 0F     	CALL MOVEIT                     ;Perform the transfer
 2518  10FA  3E 01        	MVI A,001H                      ;Place a one into least significant bit of accumulator
 2519  10FC  1F           	RAR                             ;And rotate it out into the carry bit
 2520  10FD  C3 01 11     	JMP QUOROT                      ;Proceed to rotate the carry bit into the current quotient
 2521  1100  AF           NOGO:	XRA A                           ;When result is negative, put a zero in the carry bit, then
 2522  1101  21 97 15     QUOROT:	LXI H,AUX_SYMBOL_BUF            ;Set up pointer to LSW of quotient register
 2523  1104  06 03        	MVI B,003H                      ;Set precision counter
 2524  1106  CD 8D 11     	CALL ROTL                       ;Rotate carry bit into quotient by using special entry to
 2525  1109  21 27 00     	LXI H,FPOP                      ;ROTATL subroutine. Now set up pointer to dividend
 2526  110C  06 03        	MVI B,003H                      ;LSW and set precision counter
 2527  110E  CD 8C 11     	CALL ROTATL                     ;Rotate the current dividend to the left
 2528  1111  21 63 00     	LXI H,BITS_COUNTER              ;Set pointer to bit counter storage location
 2529  1114  4E           	MOV C,M                         ;Fetch the value of the bit counter
 2530  1115  0D           	DCR C                           ;Decrement the value by one
 2531  1116  71           	MOV M,C                         ;Restore the new counter value to storage
 2532  1117  C2 E9 10     	JNZ DIVIDE                      ;If bit counter is not zero, continue division process
 2533  111A  CD 4A 11     	CALL SETSUB                     ;After 23 (decimal) bits, do subtraction once more for
 2534  111D  FA 3F 11     	JM DVEXIT                       ;Possible rounding. Jump ahead if no rounding required.
 2535  1120  21 97 15     	LXI H,AUX_SYMBOL_BUF            ;If rounding required set pointer to LSW of quotient
 2536  1123  7E           	MOV A,M                         ;Fetch LSW of quotient to accumulator
 2537  1124  C6 01        	ADI 001H                        ;Add one to 23rd bit of quotient
 2538  1126  77           	MOV M,A                         ;Restore updated LSW of quotient
 2539  1127  3E 00        	MVI A,000H                      ;Clear accumulator without disturbing carry bit
 2540  1129  23           	INX H                           ;Advance pointer to next significant byte of quotient
 2541  112A  8E           	ADC M                           ;Propagate any carry as part of rounding process
 2542  112B  77           	MOV M,A                         ;Restore the updated byte of quotient
 2543  112C  3E 00        	MVI A,000H                      ;Clear ACC again without disturbing carry bit
 2544  112E  23           	INX H                           ;Advance pointer to MSW of quotient
 2545  112F  8E           	ADC M                           ;Propagate any carry to finish rounding process
 2546  1130  77           	MOV M,A                         ;Restore the updated byte of quotient
 2547  1131  F2 3F 11     	JP DVEXIT                       ;If most significant bit of quotient is zero, go finish up
 2548  1134  06 03        	MVI B,003H                      ;If not, set precision counter
 2549  1136  CD 96 11     	CALL ROTATR                     ;And rotate quotient to the right to clear the sign bit
 2550  1139  21 22 00     	LXI H,FPACC_EXP                 ;Set pointer to FPACC Exponent
 2551  113C  46           	MOV B,M                         ;Fetch FPACC exponent
 2552  113D  04           	INR B                           ;Increment the value to compensate for the rotate right
 2553  113E  70           	MOV M,B                         ;Restore the updated exponent value
 2554  113F  21 31 00     DVEXIT:	LXI H,FP_WORK_63                ;Set up pointers
 2555  1142  11 1E 00     	LXI D,FPACC_LSW_M1              ;To transfer the quotient into the FPACC
 2556  1145  06 04        	MVI B,004H                      ;Set precision counter
 2557                                                       ;THIS IS A CORRECTION FOUND IN THE NOTES
 2558  1147  C3 58 10     	JMP EXMLDV                      ;And exit through FPMULT routine at EXMLDV
 2559                     
 2560                                                       ;Subroutine to subtract divisor from dividend. Used by
 2561                                                       ;main DIVIDE subroutine.
 2562                     
 2563  114A  11 26 00     SETSUB:	LXI D,FPOP_EXT_59               ;Set pointer to LSW of working area
 2564  114D  54           	MOV D,H                         ;On same page as FPACC
 2565  114E  21 1F 00     	LXI H,FPACC                     ;Set pointer to LSW of FPACC (divisor)
 2566  1151  06 03        	MVI B,003H                      ;Set precision counter
 2567  1153  CD F4 0F     	CALL MOVEIT                     ;Perform transfer
 2568  1156  11 26 00     	LXI D,FPOP_EXT_59               ;Reset pointer to LSW of working area (now divisor)
 2569  1159  21 27 00     	LXI H,FPOP                      ;Reset pointer to LSW of FPOP (dividend)
 2570  115C  06 03        	MVI B,003H                      ;Set precision counter
 2571  115E  CD A0 11     	CALL SUBBER                     ;Subtract divisor from dividend
 2572  1161  7E           	MOV A,M                         ;Get MSW of the result of the subtraction operations
 2573  1162  A7           	ANA A                           ;Exercise CPU flags
 2574  1163  C9           	RET                             ;Return to caller with status
 2575  1164  A7           ADDER:	ANA A                           ;Initialize the carry bit to zero upon entry
 2576  1165  7E           ADDMOR:	MOV A,M                         ;Fetch byte from register group A
 2577  1166  CD F5 11     	CALL SWITCH                     ;Switch memory pointer to register group B
 2578  1169  8E           	ADC M                           ;Add byte from A to byte from B with carry
 2579  116A  77           	MOV M,A                         ;Leave result in register group B
 2580  116B  05           	DCR B                           ;Decrement number of bytes (precision) counter
 2581  116C  C8           	RZ                              ;Return to caller when all bytes in group processed
 2582  116D  23           	INX H                           ;Else advance pointer for register group B
 2583  116E  CD F5 11     	CALL SWITCH                     ;Switch memory pointer back to register group A
 2584  1171  23           	INX H                           ;Advance the pointer for register group A
 2585  1172  C3 65 11     	JMP ADDMOR                      ;Continue the multi-byte addition operation
 2586                     
 2587                                                       ;N'th precision two's complement (negate)
 2588                                                       ;subroutine. Performs a two's complement on the multi-byte
 2589                                                       ;registers tarting at the address pointed
 2590                                                       ; to by H & L (least significant byte) upon entry.
 2591                     
 2592  1175  7E           COMPLM:	MOV A,M                         ;Fetch the least significant byte of the number to ACC
 2593  1176  EE FF        	XRI 0FFH                        ;Exclusive OR to complement the byte
 2594  1178  C6 01        	ADI 001H                        ;Add one to form two's complement of byte
 2595  117A  77           MORCOM:	MOV M,A                         ;Restore the negated byte to memory
 2596  117B  1F           	RAR                             ;Save the carry bit
 2597  117C  57           	MOV D,A                         ;In CPU register D
 2598  117D  05           	DCR B                           ;Decrement number of bytes (precision) counter
 2599  117E  C8           	RZ                              ;Return to caller when all bytes in number processed
 2600  117F  23           	INX H                           ;Else advance the pointer
 2601  1180  7E           	MOV A,M                         ;Fetch the next byte of the number to ACC
 2602  1181  EE FF        	XRI 0FFH                        ;Exclusive OR to complement the byte
 2603  1183  5F           	MOV E,A                         ;Save complemented value in register E temporarily
 2604  1184  7A           	MOV A,D                         ;Restore previous carry status to ACC
 2605  1185  17           	RAL                             ;And rotate it out to the carry bit
 2606  1186  3E 00        	MVI A,000H                      ;Clear ACC without disturbing carry status
 2607  1188  8B           	ADC E                           ;Add in any carry to complemented value
 2608  1189  C3 7A 11     	JMP MORCOM                      ;Continue the two's complement procedure as req'd
 2609                     
 2610                                                       ;N'th precision rotate left subroutine. Rotates a multi-
 2611                                                       ;byte number left starting at the address initially
 2612                                                       ;specified by the contents of CPU registers H & L upon
 2613                                                       ;subroutine entry (LSW). First entry point will clear
 2614                                                       ;the carry bit before beginning rotate operations. Second
 2615                                                       ;entry point does not clear the carry bit.
 2616                     
 2617  118C  A7           ROTATL:	ANA A                           ;Clear the carry bit at this entry point
 2618  118D  7E           ROTL:	MOV A,M                         ;Fetch a byte from memory
 2619  118E  17           	RAL                             ;Rotate it left (bring carry into LSB, push MSB to carry)
 2620  118F  77           	MOV M,A                         ;Restore rotated word to memory
 2621  1190  05           	DCR B                           ;Decrement precision counter
 2622  1191  C8           	RZ                              ;Exit to caller when finished
 2623  1192  23           	INX H                           ;Else advance pointer to next byte
 2624  1193  C3 8D 11     	JMP ROTL                        ;Continue rotate left operations
 2625                     
 2626                     
 2627                                                       ;N'th precision rotate
 2628                                                       ;right subroutine. Opposite of
 2629                                                       ;above subroutine.
 2630                     
 2631  1196  A7           ROTATR:	ANA A                           ;Clear the carry bit at this entry point
 2632  1197  7E           ROTR:	MOV A,M                         ;Fetch a byte from memory
 2633  1198  1F           	RAR                             ;Rotate it right (carry into MSB, LSB to carry)
 2634  1199  77           	MOV M,A                         ;Restore rotated word to memory
 2635  119A  05           	DCR B                           ;Decrement precision counter
 2636  119B  C8           	RZ                              ;Exit to caller when finished
 2637  119C  2B           	DCX H                           ;Else decrement pointer to next byte
 2638  119D  C3 97 11     	JMP ROTR                        ;Continue rotate right operations
 2639                     
 2640                                                       ;N'th precision subtraction subroutine.
 2641                                                       ;Number starting at location pointed to by D & E (least
 2642                                                       ;significant byte) is subtracted from number starting at
 2643                                                       ;address specified by contents of H & L.
 2644                     
 2645  11A0  A7           SUBBER:	ANA A                           ;Initialize the carry bit to zero upon entry
 2646  11A1  7E           SUBTRA:	MOV A,M                         ;Fetch byte from register group A
 2647  11A2  CD F5 11     	CALL SWITCH                     ;Switch memory pointer to register group B
 2648  11A5  9E           	SBB M                           ;Subtract byte from group B ftom that in group A
 2649  11A6  77           	MOV M,A                         ;Leave result in register group B
 2650  11A7  05           	DCR B                           ;Decrement number of bytes (precision) counter
 2651  11A8  C8           	RZ                              ;Return to caller when all bytes in group processed
 2652  11A9  23           	INX H                           ;Else advance pointer for register group B
 2653  11AA  CD F5 11     	CALL SWITCH                     ;Switch memory pointer back to register group A
 2654  11AD  23           	INX H                           ;Advance the pointer for register group A
 2655  11AE  C3 A1 11     	JMP SUBTRA                      ;Continue the multi-byte subtraction operation
 2656                     
 2657                                                       ;The next subroutine will transfer the four byte
 2658                                                       ;register string (generally a number in floating point
 2659                                                       ;format) from the starting address pointed to by CPU
 2660                                                       ;registers H & L when the subroutine is entered to
 2661                                                       ;the FPACC (floating point accumulator registers).
 2662                     
 2663  11B1  11 1F 00     FLOAD:	LXI D,FPACC                     ;Set DE to address of least signficant byte of FPACC
 2664  11B4  06 04        	MVI B,004H                      ;Set precision counter to four bytes (mantissa bytes
 2665  11B6  C3 F4 0F     	JMP MOVEIT                      ;Plus Exponent) and exit via the transfer routine
 2666                     
 2667                                                       ;The next several subroutines are used to perform
