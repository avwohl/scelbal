 1240  078C  2E 98                   MVI	L,OFS_FA_STKPTR                   ;TOKEN VALUE. Cbange- L to F/A STACK pointer.
 1241  078E  26 16                   MVI	H,HIGH OLDPG26           ;** Load H with page of F/A STACK pointer.
 1242  0790  4E                      MOV	C,M                      ;Fetch the F/A STACK pointer value into register C.
 1243  0791  CD 1E 13                CALL	INDEXC                  ;Form the address to the top of the F/A STACK.
 1244  0794  70                      MOV	M,B                      ;Store the FUNCTION TOKEN VALUE in the F/A
 1245  0795  C3 AD 02                JMP	CLESYM                   ;STACK. Then exit by clearing the SYMBOL BUFFER.
 1246  0798  78           TABADR:	MOV	A,B                         ;Move the TEMP COUNTER value from B to ACC
 1247  0799  07           TABAD1:	RLC                             ;Multiply by four using this loop to form value equal
 1248  079A  0D                      DCR	C                        ;To number of bytes per entry (4) times current entry
 1249  079B  C2 99 07                JNZ	TABAD1                   ;In the FUNCTION LOOK-UP TABLE.
 1250  079E  85                      ADD	L                        ;Add this value to the starting address of the table.
 1251  079F  6F                      MOV	L,A                      ;Form pointer to next entry in table
 1252  07A0  D0                      RNC                          ;If no carry return to caller
 1253  07A1  24                      INR	H                        ;Else, increment H before
 1254  07A2  C9                      RET                          ;Returning to caller
 1255                     
 1256                     ;;; The label INTX SHOULD BE AT 07 243
 1257  07A3  2E 56        INTX:	MVI	L,OFS_FPACC_MSW                        ;Load L with address of MSW of the FPACC
 1258  07A5  26 01                   MVI	H,HIGH OLDPG1            ;** Load H with the page of the PPACC
 1259  07A7  7E                      MOV	A,M                      ;Fetch the MSW of the FPACC into the accumulator
 1260  07A8  A7                      ANA	A                        ;Test the sign of the number in the FPACC. If
 1261  07A9  F2 D7 07                JP	INT1                      ;Positive jump ahead to integerize
 1262  07AC  2E 0C                   MVI	L,OFS_FP_TEMP                   ;If negative, load L with address of FP TEMP registers
 1263  07AE  CD AD 12                CALL	FSTORE                  ;Store the value in the FPACC in FP TEMP
 1264  07B1  CD 00 10                CALL	FPFIX                   ;Convert the value in FPACC from floating point to
 1265  07B4  2E 53                   MVI	L,OFS_SYMBOL_BUF+3                   ;Fixed point. Load L with address of FPACC
 1266  07B6  36 00                   MVI	M,000H                   ;Extension register and clear it.
 1267  07B8  CD 34 10                CALL	FPFLT                   ;Convert fixed binary back to FP to integerize
 1268  07BB  2E 0C                   MVI	L,OFS_FP_TEMP                   ;Load L with address of FP TEMP registers
 1269  07BD  CD B6 12                CALL	OPLOAD                  ;Load the value in FP TEMP into FPOP
 1270  07C0  CD 1A 11                CALL	FPSUB                   ;Subtract integerized value from original
 1271  07C3  2E 56                   MVI	L,OFS_FPACC_MSW                   ;Set L to address of MSW of FPACC
 1272  07C5  7E                      MOV	A,M                      ;Fetch the MSW of the FPACC into the accumulator
 1273  07C6  A7                      ANA	A                        ;See if original value and integerized value the same
 1274  07C7  CA E1 07                JZ	INT2                      ;If so, have integer value in FP TEMP
 1275  07CA  2E 0C                   MVI	L,OFS_FP_TEMP                   ;Else, load L with address of FP TEMP registers
 1276  07CC  CD A4 12                CALL	FLOAD                   ;Restore FPACC to original (non-integerized) value
 1277  07CF  2E 14                   MVI	L,OFS_FP_CONST_NEG1                   ;Set L to register containing small value
 1278  07D1  CD BF 12                CALL	FACXOP                  ;Set up to add small value to original value in FPACC
 1279  07D4  CD 89 10                CALL	FPADD                   ;Perform the addition
 1280  07D7  CD 00 10     INT1:	CALL	FPFIX                        ;Convert the number in FPACC from floating point
 1281  07DA  2E 53                   MVI	L,OFS_SYMBOL_BUF+3                   ;To fixed point. Load L with address of FPACC
 1282  07DC  36 00                   MVI	M,000H                   ;Extension register and clear it. Now convert the number
 1283  07DE  C3 34 10                JMP	FPFLT                    ;Back to floating point to integerize it and exit to caller
 1284  07E1  2E 0C        INT2:	MVI	L,OFS_FP_TEMP                        ;Load L with address of FP TEMP registers. Transfer
 1285  07E3  C3 A4 12                JMP	FLOAD                    ;Number from FP TEMP (orig) to FPACC and return.
 1286  07E6  2E 56        ABSX:	MVI	L,OFS_FPACC_MSW                        ;Load L with address of MSW of the FPACC
 1287  07E8  26 01                   MVI	H,HIGH OLDPG1            ;** Set H to page of the FPACC
 1288  07EA  7E                      MOV	A,M                      ;Fetch the MSW of the FPACC into the accumulator
 1289  07EB  A7                      ANA	A                        ;Test the sign of the number to see if it is positive.
 1290  07EC  FA 82 10                JM	FPCOMP                    ;If negative, complement the number before returning.
 1291  07EF  C9                      RET                          ;Else, just return with absolute value in the FPACC.
 1292  07F0  2E 56        SGNX:	MVI	L,OFS_FPACC_MSW                        ;Load L with address of MSW of the FPACC
 1293  07F2  26 01                   MVI	H,HIGH OLDPG1            ;** Load H with the page of the FPACC
 1294  07F4  7E                      MOV	A,M                      ;Fetch the MSW of the FPACC into the accumulator
 1295  07F5  A7                      ANA	A                        ;Test to see if the FPACC is zero
 1296  07F6  C8                      RZ                           ;Return to caller if FPACC is zero
 1297  07F7  F2 A2 06                JP	FPONE                     ;If FPACC is positive, load +1.0 into FPACC and exit
 1298  07FA  2E 14                   MVI	L,OFS_FP_CONST_NEG1                   ;If FPACC is negative, set up to load -1.0 into the
 1299  07FC  C3 A4 12                JMP	FLOAD                    ;FPACC and exit to caller
 1300  07FF  CD 00 10     CHRX:	CALL	FPFIX                        ;Convert contents of FPACC from floating point to
 1301  0802  2E 54                   MVI	L,OFS_FPACC                   ;Fixed point. Load L with address of LSW of fixed
 1302  0804  7E                      MOV	A,M                      ;Value. Fetch this byte into the accumulator.
 1303  0805  CD 82 03                CALL	ECHO                    ;Display the value.
 1304  0808  2E 7F                   MVI	L,OFS_TAB_FLAG                   ;Set L to address of the TAB FLAG
 1305  080A  26 16                   MVI	H,HIGH OLDPG26           ;** Set H to page of the TAB FLAG
 1306  080C  36 FF                   MVI	M,0FFH                   ;Set TAB FLAG (to inhibit display of FP value)
 1307  080E  C9                      RET                          ;Exit to caller.
 1308  080F  CD 00 10     TABX:	CALL	FPFIX                        ;Convert contents of FPACC from floating point to
 1309  0812  2E 54        TAB1:	MVI	L,OFS_FPACC                        ;Fixed point. Load L with address of 1,SW of fixed
 1310  0814  7E                      MOV	A,M                      ;Value. Fetch this byte into the accumulator.
 1311  0815  2E 23                   MVI	L,OFS_COL_COUNTER                   ;Load L with address of COLUMN COUNTER
 1312  0817  96                      SUB	M                        ;Subtract value in C-OLUMN COUNTER from desired
 1313  0818  2E 7F                   MVI	L,OFS_TAB_FLAG                   ;TAB position. Load L with address of the TAB FLAG.
 1314  081A  26 16                   MVI	H,HIGH OLDPG26           ;** Set H to page of the TAB FLAG.
 1315  081C  36 FF                   MVI	M,0FFH                   ;Set TAB FLAG (to inhibit display of FP value)
 1316  081E  FA 8F 19                JM	BACKSP                    ;If beyond TAB point desired, simulate back spacing
 1317  0821  C8                      RZ                           ;Return to caller if at desired TAB location
 1318  0822  4F           TABC:	MOV	C,A                           ;Else, put difference count in register C
 1319  0823  3E A0                   MVI	A,0A0H                   ;Place ASCII code for space in ACC
 1320  0825  CD 82 03     TABLOP:	CALL	ECHO                       ;Display space on output device
 1321  0828  0D                      DCR	C                        ;Decrement displacement counter
 1322  0829  C2 25 08                JNZ	TABLOP                   ;If have not reached TAB position, continue to space
 1323  082C  C9                      RET                          ;Else, return to calling routine.
 1324                     
 1325                     ;;; The label STOSYM should be AT 10 055
 1326  082D  2E 81        STOSYM:	MVI	L,OFS_SYNTAX_PTR                      ;Load L with address of ARRAY FLAG
 1327  082F  26 17                   MVI	H,HIGH OLDPG27           ;** Load H with page of ARRAY FLAG
 1328  0831  7E                      MOV	A,M                      ;Fetch the value of the ARRAY FLAG into the ACC
 1329  0832  A7                      ANA	A                        ;Check to see if the flag is set indicating processing an
 1330  0833  CA 40 08                JZ	STOSY1                    ;Array variable value. Jump ahead if flag not set.
 1331  0836  36 00                   MVI	M,000H                   ;If ARRAY FLAG was set, clear it for next time.
 1332  0838  2E 84                   MVI	L,OFS_TEMP_ARRAY                   ;Then load L with address of array address storage loc
 1333  083A  6E                      MOV	L,M                      ;Fetch the array storage address as new pointer
 1334  083B  26 2F                   MVI	H,HIGH OLDPG57           ;tt Set H to ARRAY VALUES page   ****************
 1335  083D  C3 AD 12                JMP	FSTORE                   ;Store the array variable value and exit to caller.
 1336  0840  2E F8        STOSY1:	MVI	L,OFS_LOOKUP_CNT                      ;Load L with address of TEMP CNTR
 1337  0842  26 16                   MVI	H,HIGH OLDPG26           ;** Load H with page of TEMP CNTR
 1338  0844  36 00                   MVI	M,000H                   ;Initialize the TEMP CNTR by clearing it
 1339  0846  2E 50                   MVI	L,OFS_SYMBOL_BUF                   ;Load L with starting address of SYMBOL BUFFER
 1340  0848  16 17                   MVI	D,HIGH OLDPG27           ;** Load D with page of VARIABLES LOOK-UP table
 1341  084A  1E 88                   MVI	E,088H                   ;Load E with starting addr of VARIABLES LOOK-UP
 1342  084C  7E                      MOV	A,M                      ;Table. Fetch the (cc) for the SYMBOL BUFFER into
 1343  084D  FE 01                   CPI	001H                     ;The ACC and see if length of variable name is just one
 1344  084F  C2 56 08                JNZ	STOSY2                   ;Character. If not, skip next couple of instructions.
 1345  0852  2E 52                   MVI	L,OFS_SYMBOL_CHAR2                   ;Else, set pointer to second character location in the
 1346  0854  36 00                   MVI	M,000H                   ;SYMBOL BUFFER and set it to zero
 1347  0856  2E 51        STOSY2:	MVI	L,OFS_SYMBOL_CHAR1                      ;load L with address of first character in the SYMBOL
 1348  0858  26 16                   MVI	H,HIGH OLDPG26           ;** BUFFER. Load H with page of the buffer.
 1349  085A  CD EE 12                CALL	SWITCH                  ;Exchange pointer to buffer for pointer to VARIABLES
 1350  085D  7E                      MOV	A,M                      ;LOOK-UP table. Fetch first char in a name from the
 1351  085E  2C                      INR	L                        ;Table. Advance the pointer to second char in a name.
 1352  085F  46                      MOV	B,M                      ;Fetch the second character into register B.
 1353  0860  2C                      INR	L                        ;Advance the pointer to first byte of a value in the table.
 1354  0861  CD EE 12                CALL	SWITCH                  ;Exchange table pointer for pointer to SYMBOL BUFF
 1355  0864  BE                      CMP	M                        ;Compare first character in buffer against first character
 1356  0865  C2 6E 08                JNZ	STOSY3                   ;In table entry. If no match, try next entry in the table.
 1357  0868  2C                      INR	L                        ;If match, advance pointer to second character in buffer.
 1358  0869  78                      MOV	A,B                      ;Move second character obtained from table into ACC.
 1359  086A  BE                      CMP	M                        ;Compare second characters in table and buffer.
 1360  086B  CA 97 08                JZ	STOSY5                    ;If same, have found the variable name in the table.
 1361  086E  CD AE 06     STOSY3:	CALL	AD4DE                      ;Add four to pointer in registers D&E to skip over value
 1362  0871  2E F8                   MVI	L,OFS_LOOKUP_CNT                   ;Portion of entry in table. Load L with address of TEMP
 1363  0873  26 16                   MVI	H,HIGH OLDPG26           ;** CNTR. Load H with page of TEMP CNTR.
 1364  0875  46                      MOV	B,M                      ;Fetch the counter
 1365  0876  04                      INR	B                        ;Increment the counter
 1366  0877  70                      MOV	M,B                      ;Restore it to storage
 1367  0878  2E 3F                   MVI	L,OFS_SYMVAR_CNT                   ;Set L to address of VARIABLES CNTR (indicates
 1368  087A  26 17                   MVI	H,HIGH OLDPG27           ;** Number of variables currently in table.) Set H too
 1369  087C  78                      MOV	A,B                      ;Move the TEMP CNTR value into the ACC. (Number of
 1370  087D  BE                      CMP	M                        ;Entries checked.) Compare with number of entries in
 1371  087E  C2 56 08                JNZ	STOSY2                   ;The table. If have not checked all entries, try next one.
 1372  0881  2E 3F                   MVI	L,OFS_SYMVAR_CNT                   ;If have checked all entries, load L with address of the
 1373  0883  26 17                   MVI	H,HIGH OLDPG27           ;** VARIABLES CNTR. Set H too. Fetch the counter
 1374  0885  46                      MOV	B,M                      ;Value and incrernent it to account for
 1375  0886  04                      INR	B                        ;New variable nwne that will now be
 1376  0887  70                      MOV	M,B                      ;Added to the table. Save the new value.
 1377  0888  78                      MOV	A,B                      ;Place the new counter value into the accumulator
 1378  0889  FE 15                   CPI	015H                     ;And check to see that adding new variable name to the
 1379  088B  F2 92 02                JP	BIGERR                    ;Table will not cause table overflow. Big Error if it does!
 1380  088E  2E 51                   MVI	L,OFS_SYMBOL_CHAR1                   ;If room available in table, set L to address of first
 1381  0890  26 16                   MVI	H,HIGH OLDPG26           ;** Caracter in the SYMBOL BUFFER. Set H too.
 1382  0892  06 02                   MVI	B,002H                   ;Set a counter for number of characters to transfer.
 1383  0894  CD 0B 11                CALL	MOVEIT                  ;Move the variable name from buffer to table.
 1384  0897  CD EE 12     STOSY5:	CALL	SWITCH                     ;Exchange buffer pointer for table pointer.
 1385  089A  CD AD 12                CALL	FSTORE                  ;Transfer new mathematical value into the table.
 1386  089D  C3 AD 02                JMP	CLESYM                   ;Clear the SYMBOL BUFFER and exit to calling routine.
