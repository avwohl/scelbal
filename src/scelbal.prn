 2733  11FF  4E           	MOV C,M                         ;Load counter value into CPU register C
 2734  1200  0C           	INR C                           ;Exercise the counter in order
 2735  1201  0D           	DCR C                           ;To set CPU flags. If counter is non-zero, then indexing
 2736  1202  C2 0E 12     	JNZ NOT0                        ;Register (GETINP counter) is all set so jump ahead.
 2737  1205  6B           	MOV L,E                         ;But, if counter zero, then starting to process a new
 2738  1206  62           	MOV H,D                         ;Character string. Transfer char string buffer pointer into
 2739  1207  4E           	MOV C,M                         ;H & L and fetch the string's character count value (cc)
 2740  1208  0C           	INR C                           ;Increment the (cc) by one to take account of (cc) byte
 2741  1209  CD 22 12     	CALL INDEXC                     ;Add contents of regis C to H & L to point to end of the
