 3419                     ;;; PATCH NR.1
 3420  1734  21 1E 00     PATCH1:	LXI H,FPACC_LSW_M1
 3421  1737  36 00        	MVI M,000H
 3422  1739  21 25 00     	LXI H,FPOP_EXT_5B
 3423  173C  36 00        	MVI M,000H
 3424  173E  C9           	RET
 3425                     
 3426  173F  21 98 15     NEXT:	LXI H,AUX_SYMBOL_BUF            ;Load HL with start of AUX SYMBOL BUFFER
 3427  1742  36 00        	MVI M,000H                      ;Initialize AUX SYMBOL BUFFER by clearing first byte
 3428  1744  21 B6 15     	LXI H,SCAN_PTR                  ;Change L to address of SCAN pointer
 3429  1747  46           	MOV B,M                         ;Fetch pointer value to CPU register B
 3430  1748  04           	INR B                           ;Add one to the current pointer value
 3431  1749  21 B5 15     	LXI H,SYNTAX_PTR                ;Load L with address of NEXT pointer storage location
 3432  174C  70           	MOV M,B                         ;Place the updated SCAN pointer as the NEXT pointer
 3433  174D  21 B5 15     NEXT1:	LXI H,SYNTAX_PTR                ;Reset L to address of NEXT pointer storage location
 3434  1750  CD 7C 01     	CALL GETCHR                     ;Fetch the character pointed to by the NEXT pointer
 3435  1753  CA 5C 17     	JZ NEXT2                        ;If the character is a space, ignore it
 3436  1756  21 98 15     	LXI H,AUX_SYMBOL_BUF            ;Else, load L with start of AUX SYMBOL BUFFER
 3437  1759  CD AA 01     	CALL CONCT1                     ;Concatenate the character onto the AUX SYMBOL BF
 3438  175C  21 B5 15     NEXT2:	LXI H,SYNTAX_PTR                ;Reset L to address of NEXT pointer storage location
 3439  175F  CD E1 01     	CALL LOOP                       ;Advance the NEXT pointer and see if end of line
 3440  1762  C2 4D 17     	JNZ NEXT1                       ;Fetch next character in line if not end of line
 3441  1765  21 98 15     	LXI H,AUX_SYMBOL_BUF            ;When reach end of line, should have variable name
 3442  1768  7E           	MOV A,M                         ;In the AUX SYMBOL BUFFER. Fetch the (cc) for
 3443  1769  FE 01        	CPI 001H                        ;The buffer and see if variable name is just one letter
 3444  176B  C2 73 17     	JNZ NEXT3                       ;If more than one proceed directly to look for name
 3445  176E  21 34 00     	LXI H,FP_WORK_66                ;In FOR/NEXT STACK. If have just a one letter name
 3446  1771  36 00        	MVI M,000H                      ;Then set second character in buffer to zero
 3447  1773  21 B4 16     NEXT3:	LXI H,TEMP_085                  ;Load HL with address of FOR/NEXT STACK pointer
 3448  1776  7E           	MOV A,M                         ;Fetch the FOR/NEXT STACK pointer value to ACC
 3449  1777  07           	RLC                             ;Rotate value left to multiply by two. Then rotate it
 3450  1778  07           	RLC                             ;Left again to multiply by four for stack entry offset
 3451  1779  C6 02        	ADI 002H                        ;Add 2 to point to variable name in stack entry
 3452  177B  4F           	MOV C,A                         ;Save offset in C
 3453  177C  06 00        	MVI B,000H                      ;Clear B for 16-bit add
 3454  177E  21 94 16     	LXI H,FN_STACK                  ;Load HL with base of FOR/NEXT STACK
 3455  1781  09           	DAD B                           ;Add offset to get variable name location
 3456  1782  11 99 15     	LXI D,AUX_SYMBOL_BUF+1          ;Set DE to first character in the AUX SYMBOL BUFFER
 3457  1785  06 02        	MVI B,002H                      ;Set B to serve as a character counter
 3458  1787  CD D6 01     	CALL STRCPC                     ;See if variable name in the NEXT statement same as
 3459  178A  CA 94 17     	JZ NEXT4                        ;That stored in the top of the FOR/NEXT STACK
 3460  178D  3E C6        FORNXT:	MVI A,0C6H                      ;Load ACC with ASCII code for letter F
 3461  178F  0E CE        	MVI C,0CEH                      ;Load register C with ASCII code for letter N
 3462  1791  C3 72 01     	JMP ERROR                       ;Display For/Next (FN) error message if required
 3463  1794  21 24 16     NEXT4:	LXI H,USER_PGM_PTR              ;Load L with address of user program line pointer
 3464  1797  56           	MOV D,M                         ;Fetch the page portion of the line pointer into D
 3465  1798  2C           	INR L                           ;Advance the memory pointer
 3466  1799  5E           	MOV E,M                         ;Fetch the low portion of the line pointer into E
 3467  179A  2C           	INR L                           ;Advance pntr to AUXILIARY LINE POINTER storage
 3468  179B  72           	MOV M,D                         ;Location and store value of line pointer there too (page)
 3469  179C  2C           	INR L                           ;Advance pointer to second byte of AUXILIARY line
 3470  179D  73           	MOV M,E                         ;Pointer and store value of line pointer (low portion)
 3471  179E  21 B4 16     	LXI H,TEMP_085                  ;Load HL with address of FOR/NEXT STACK pointer
 3472  17A1  7E           	MOV A,M                         ;Fetch the FOR/NEXT STACK pointer value to ACC
 3473  17A2  07           	RLC                             ;Rotate value left to multiply by two. Then rotate it
 3474  17A3  07           	RLC                             ;Left again to multiply by four for stack entry offset
 3475  17A4  4F           	MOV C,A                         ;Save offset in C
 3476  17A5  06 00        	MVI B,000H                      ;Clear B for 16-bit add
 3477  17A7  21 94 16     	LXI H,FN_STACK                  ;Load HL with base of FOR/NEXT STACK
 3478  17AA  09           	DAD B                           ;Add offset to point to top of stack entry
 3479  17AB  56           	MOV D,M                         ;Fetch page address of the associated FOR line pointer
 3480  17AC  23           	INX H                           ;Advance the pointer
 3481  17AD  5E           	MOV E,M                         ;Fetch the low address value into E
 3482  17AE  21 24 16     	LXI H,USER_PGM_PTR              ;Program line pointer to the FOR statement line by
 3483  17B1  72           	MOV M,D                         ;Place the page value in the pointer storage location
 3484  17B2  23           	INX H                           ;Advance the memory pointer
 3485  17B3  73           	MOV M,E                         ;Place the low value in the pointer storage location
 3486  17B4  62           	MOV H,D                         ;Now set up H and L to point to the start of the
 3487  17B5  6B           	MOV L,E                         ;Associated FOR statement line in the user pgm buffer
 3488  17B6  11 38 15     	LXI D,LINE_INP_BUF              ;And set L to the gtart of the line input buffer
 3489  17B9  CD F5 08     	CALL MOVEC                      ;Move the associated FOR statement line into the input
 3490  17BC  21 87 00     	LXI H,KW_TO                     ;Line buffer. Set L to point to start of TO string which is
 3491  17BF  CD D0 09     	CALL INSTR                      ;Search the statement line for the occurrence of TO
 3492  17C2  7B           	MOV A,E                         ;Register E will be zero if TO not found. Move E to ACC
 3493  17C3  A7           	ANA A                           ;To make a test. If TO found then proceed to set up for
 3494  17C4  CA 8D 17     	JZ FORNXT                       ;Evaluation. If TO not found, then have error condition.
 3495  17C7  C6 02        	ADI 002H                        ;Advance the pointer over the characters in TO string
 3496  17C9  21 F2 15     	LXI H,EVAL_PTR                  ;Change L to point to EVAL pointer storage location
 3497  17CC  77           	MOV M,A                         ;Position for the EVAL subroutine (after TO string)
 3498  17CD  21 8A 00     	LXI H,KW_STEP                   ;Set L to point to start of STEP string which is stored
 3499  17D0  CD D0 09     	CALL INSTR                      ;Statement line for the occurrence of STEP
 3500  17D3  7B           	MOV A,E                         ;Register E will be zero if STEP not found. Move E to
 3501  17D4  A7           	ANA A                           ;The accumulator to make a test. If STEP found must
 3502  17D5  C2 F8 17     	JNZ NEXT5                       ;Evaluate expression after STEP to get STEP SIZE.
 3503  17D8  21 03 00     	LXI H,FP_CONST_1                ;Else, have an IMPLIED STEP SIZE of 1.0. Set pointer
 3504  17DB  CD B2 11     	CALL FLOAD                      ;Format and call subroutine to load FPACC with 1.0
 3505  17DE  21 6C 00     	LXI H,FN_STEP                   ;Set L to start of FOR/NEXT STEP SIZE storage loc.
 3506  17E1  CD BA 11     	CALL FSTORE                     ;Store the value 1.0 in the F/N STEP SIZE registers
 3507  17E4  21 38 15     	LXI H,LINE_INP_BUF              ;Change L to the start of the input line buffer
 3508  17E7  46           	MOV B,M                         ;Fetch the (cc) into CPU register B (length of FOR line)
 3509  17E8  21 F3 15     	LXI H,EVAL_FINISH               ;Change L to EVAL FINISH pointer stomge location
 3510  17EB  70           	MOV M,B                         ;Set the EVAL FINISH pointer to the end of the line
 3511  17EC  CD 71 02     	CALL EVAL                       ;Evaluate the LIMIT expression to obtain FOR LIMIT
 3512  17EF  21 70 00     	LXI H,FN_LIMIT                  ;Load L with address of start of F/N LIMIT registers
 3513  17F2  CD BA 11     	CALL FSTORE                     ;MGA 3/31/12 no lab here Store the FOR/NEXT LIMIT value
 3514  17F5  C3 1F 18     	JMP NEXT6                       ;Since have IMPLIED STEP jump ahead
 3515  17F8  1D           NEXT5:	DCR E                           ;MGA 3/21/12 lab here When have STEP directive, subtract one from pointer
 3516  17F9  21 F3 15     	LXI H,EVAL_FINISH               ;To get to character before S in STEP. Save this value in
 3517  17FC  73           	MOV M,E                         ;As evaluation end location when obtaining TO Iiinit
 3518  17FD  CD 71 02     	CALL EVAL                       ;Evaluate the LIMIT expression to obtain FOR LIMIT
 3519  1800  21 70 00     	LXI H,FN_LIMIT                  ;Load L with address of start of FIN LIMIT registers
 3520  1803  CD BA 11     	CALL FSTORE                     ;Store the FOR/NEXT LIMIT value
 3521  1806  21 F3 15     	LXI H,EVAL_FINISH               ;Reset L to EVAL FINISH pointer storage location
 3522  1809  7E           	MOV A,M                         ;Fetch the pointer value (character before S in STEP)
 3523  180A  C6 05        	ADI 005H                        ;Add five to change pointer to character after P in STEP
 3524  180C  2D           	DCR L                           ;Decrement L to point to EVAL (start) pointer
 3525  180D  77           	MOV M,A                         ;Set up the starting position for the EVAL subroutine
 3526  180E  21 38 15     	LXI H,LINE_INP_BUF              ; Load L with starting address of the line input buffer
 3527  1811  46           	MOV B,M                         ;Fetch the (cc) for the line input buffer (line length)
 3528  1812  21 F3 15     	LXI H,EVAL_FINISH               ;Change L to the EVAL FINISH storage location
 3529  1815  70           	MOV M,B                         ;Set the EVAL FINISH pointer
 3530  1816  CD 71 02     	CALL EVAL                       ;Evaluate the STEP SIZE expression
 3531  1819  21 6C 00     	LXI H,FN_STEP                   ;Load L with address of start of F/N STEP registers
 3532  181C  CD BA 11     	CALL FSTORE                     ;Store the FOR/NEXT STEP SIZE value
 3533  181F  21 98 15     NEXT6:	LXI H,AUX_SYMBOL_BUF            ;Load HL with address of AUX SYMBOL BUFFER
 3534  1822  36 00        	MVI M,000H                      ;Initialize AUX SYMBOL BUFFER with a zero byte
 3535  1824  21 9C 00     	LXI H,KW_FOR                    ;Set HL to start of FOR string in keyword table
 3536  1827  CD D0 09     	CALL INSTR                      ;Search the statement line for the FOR directive
 3537  182A  7B           	MOV A,E                         ;Register E will be zero if FOR not found. Move E to
 3538  182B  A7           	ANA A                           ;ACC and -make test to see if FOR directive located
 3539  182C  21 B6 15     	LXI H,SCAN_PTR                  ;Load L with address of SCAN pointer
 3540  182F  77           	MOV M,A                         ;Set up pointer to occurrence of FOR directive in line
 3541  1830  CA 8D 17     	JZ FORNXT                       ;If FOR not found, have an error condition
 3542  1833  C6 03        	ADI 003H                        ;If have FOR, add three to advance pointer over FOR
 3543  1835  21 B7 15     	LXI H,TOKEN_STORE               ;Set L to point to F/N pointer storage location
 3544  1838  77           	MOV M,A                         ;Set F/N pointer to character after FOR directive
 3545  1839  21 B7 15     NEXT7:	LXI H,TOKEN_STORE               ;Set L to point to FIN pointer storage location
 3546  183C  CD 7C 01     	CALL GETCHR                     ;Fetch a character from position pointed to by FIN pntr
 3547  183F  CA 4D 18     	JZ NEXT8                        ;If character is a space, ignore it
 3548  1842  FE BD        	CPI 0BDH                        ;Else, test to see if character is "=" sign
 3549  1844  CA 59 18     	JZ NEXT9                        ;If yes, have picked up variable name, jump ahead
 3550  1847  21 98 15     	LXI H,AUX_SYMBOL_BUF            ;If not, set L to the start of the AUX SYMBOL BUFFER
 3551  184A  CD AA 01     	CALL CONCT1                     ;And store the character in the AUX SYMBOL BUFFER
 3552  184D  21 B7 15     NEXT8:	LXI H,TOKEN_STORE               ;Load L with address of the F/N pointer
 3553  1850  CD E1 01     	CALL LOOP                       ;Increment the pointer and see if end of the line
 3554  1853  C2 39 18     	JNZ NEXT7                       ;If not, continue fetching characters
 3555  1856  C3 8D 17     	JMP FORNXT                      ;If end of line before "=" sign then have error condx
 3556  1859  21 B6 15     NEXT9:	LXI H,SCAN_PTR                  ;Load L with address of SCAN pointer
 3557  185C  7E           	MOV A,M                         ;Fetch pointer value to ACC (points to start of FOR
 3558  185D  C6 03        	ADI 003H                        ;Directive) and add three to move pointer over FOR
 3559  185F  21 F2 15     	LXI H,EVAL_PTR                  ;Directive. Change L to EVAL pointer storage location
 3560  1862  77           	MOV M,A                         ;Set EVAL pointer to character after FOR in line
 3561  1863  21 B7 15     	LXI H,TOKEN_STORE               ;Load L with address of FIN pointer storage location
 3562  1866  46           	MOV B,M                         ;Fetch pointer to register B (points to "=" sign) and
 3563  1867  05           	DCR B                           ;Decrement the pointer (to character before "=" sign)
 3564  1868  21 F3 15     	LXI H,EVAL_FINISH               ;Load L with address of EVAL FINISH pointer
 3565  186B  70           	MOV M,B                         ;Set EVAL FINISH pointer
 3566  186C  CD 71 02     	CALL EVAL                       ;Call subroutine to obtain current value of the variable
 3567  186F  21 6C 00     	LXI H,FN_STEP                   ;Load L with address of start of F/N STEP registers
 3568  1872  CD CA 11     	CALL FACXOP                     ;Call subroutine to set up FP registers for addition
 3569  1875  CD 67 0F     	CALL FPADD                      ;Add FIN STEP size to current VARIABLE value
 3570  1878  21 74 00     	LXI H,FN_TEMP                   ;Load L with address of FIN TEMP storage registers
 3571  187B  CD BA 11     	CALL FSTORE                     ;Save the result of the addition in F/N TEMP registers
 3572  187E  21 70 00     	LXI H,FN_LIMIT                  ;Load L with starting address of F/N LIMIT registers
 3573  1881  CD CA 11     	CALL FACXOP                     ;Call subroutine to set up FP registers for subtraction
 3574  1884  CD 04 10     	CALL FPSUB                      ;Subtract F/N LIMIT value from VARIABLE value
 3575  1887  21 6E 00     	LXI H,FN_STEP_C6                ;Set pointer to MSW of F/N STEP registers
 3576  188A  7E           	MOV A,M                         ;Fetch this value into the ACC
 3577  188B  A7           	ANA A                           ;Test to see if STEP value might be zero
 3578  188C  21 21 00     	LXI H,FPACC_MSW                 ;Load L with address of MSW of FPACC
 3579  188F  7E           	MOV A,M                         ;Fetch this value into the ACC
 3580  1890  CA 8D 17     	JZ FORNXT                       ;If STEP size was zero, then endless loop, an error condx
 3581  1893  FA B0 18     	JM NEXT11                       ;If STEP size less than zero make alternate test on limit
 3582  1896  A7           	ANA A                           ;Test the contents of the MSW of the FPACC
 3583  1897  FA B7 18     	JM NEXT12                       ;Continue FORINEXT loop if current variable value is
 3584  189A  CA B7 18     	JZ NEXT12                       ;Less than or equal to the F/N LIMIT value
 3585  189D  21 27 16     NEXT10:	LXI H,AUX_PGM_PTR+1             ;If out of LIMIT range, load HL with addr of the AUX
 3586  18A0  5E           	MOV E,M                         ;PGM LINE pointer low byte. Fetch low part into E
 3587  18A1  2B           	DCX H                           ;Decrement to AUX PGM LINE pointer high byte
 3588  18A2  56           	MOV D,M                         ;Fetch the page part into D
 3589  18A3  2B           	DCX H                           ;Decrement to USER PGM PTR low byte
 3590  18A4  73           	MOV M,E                         ;Copy AUX low byte to USER low byte
 3591  18A5  2B           	DCX H                           ;Decrement to USER PGM PTR high byte
 3592  18A6  72           	MOV M,D                         ;Copy AUX high byte to USER high byte
 3593  18A7  21 B4 16     	LXI H,TEMP_085                  ;Set HL to address of FOR/NEXT STACK pointer
 3594  18AA  46           	MOV B,M                         ;Fetch and decrement the
 3595  18AB  05           	DCR B                           ;FOR/NEXT STACK pointer value
 3596  18AC  70           	MOV M,B                         ;To perform effective popping operation
 3597  18AD  C3 12 0A     	JMP NXTLIN                      ;Statement line after NEXT statement is done next
 3598  18B0  A7           NEXT11:	ANA A                           ;When F/N STEP is negative, reverse test so that if the
 3599  18B1  F2 B7 18     	JP NEXT12                       ;Variable value is greater than or equal to the F/N LIMIT
 3600  18B4  C3 9D 18     	JMP NEXT10                      ;The FOR/NEXT loop continues. Else it is finished.
 3601  18B7  21 74 00     NEXT12:	LXI H,FN_TEMP                   ;Load L with address of FIN TEMP storage registers
 3602  18BA  CD B2 11     	CALL FLOAD                      ;Transfer the updated variable value to the FPACC
