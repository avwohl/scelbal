 4154  2DBC  26 16                   MVI	H,HIGH OLDPG26           ;** Set H to page of the LOOP COUNTER
 4155  2DBE  7E                      MOV	A,M                      ;Fetch the counter value to the ACC
 4156  2DBF  2E 3D                   MVI	L,OFS_SYMVAR_CNT-2                   ;Change L to the counter containing number of arrays
 4157  2DC1  26 17                   MVI	H,HIGH OLDPG27           ;** Set H to the proper page
