 3098  136D  2E 6E                   MVI	L,OFS_FP_WORK_6E                   ;For valid digit, set pointer to MSW of temporary
 3099  136F  4F                      MOV	C,A                      ;Decimal to binary holding registers. Save character in C.
 3100  1370  3E F8                   MVI	A,0F8H                   ;Form mask for sizing in accumulator. Now see if
 3101  1372  A6                      ANA	M                        ;Holding register has enough room for the conversion of
 3102  1373  C2 4D 13                JNZ	NINPUT                   ;Another digit. Ignore the input if no more room.
