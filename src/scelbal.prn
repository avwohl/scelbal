 2748  1215  62           	MOV H,D                         ;CPU registers H & L
 2749  1216  CD 22 12     	CALL INDEXC                     ;Add contents of register C to form indexed address of
 2750  1219  7E           	MOV A,M                         ;Next character to be fetched as input. Fetch the next
