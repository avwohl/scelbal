 3334  14F5  06 03                   MVI	B,003H                   ;Set precision counter
 3335  14F7  CD 0B 11                CALL	MOVEIT                  ;Move value in FPACC to output working register
 3336  14FA  2E 77                   MVI	L,OFS_FP_WORK_77                   ;Set pointer to MSW plus one of output working register
 3337  14FC  36 00                   MVI	M,000H                   ;Clear that location to 0
 3338  14FE  2E 74                   MVI	L,OFS_FP_WORK_74                   ;Set pointer to LSW of output working register
 3339  1500  06 03                   MVI	B,003H                   ;Set precision counter
 3340  1502  CD 7F 12                CALL	ROTATL                  ;Rotate register left once to compensate for sign bit
 3341  1505  CD 93 15                CALL	OUTX10                  ;Multiply output register by 10, overflow into N4SW+ 1
 3342  1508  2E 57        COMPEN:	MVI	L,OFS_FPACC_EXP                      ;Set pointer back to FPACC Exponent
 3343  150A  46                      MOV	B,M                      ;Compensate for any remainder in the binary exponent
 3344  150B  04                      INR	B                        ;By performing a rotate right on the output working
 3345  150C  70                      MOV	M,B                      ;Register until the binary exponent becomes zero
 3346  150D  CA 1A 15                JZ	OUTDIG                    ;Go output decimal digits when this loop is finished
 3347  1510  2E 77                   MVI	L,OFS_FP_WORK_77                   ;Binary exponent compensating loop. Setpointe'r to
 3348  1512  06 04                   MVI	B,004H                   ;Working register MSW+L. Set precision counter.
 3349  1514  CD 89 12                CALL	ROTATR                  ;Rotate working register to the right.
 3350  1517  C3 08 15                JMP	COMPEN                   ;Repeat loop as required.
 3351  151A  2E 47        OUTDIG:	MVI	L,OFS_OUT_DIG_CNT                      ;Set pointer to output digit counter storage location
 3352  151C  36 07                   MVI	M,007H                   ;Initialize to value of seven
 3353  151E  2E 77                   MVI	L,OFS_FP_WORK_77                   ;Change pointer to output working register MSW+L
 3354  1520  7E                      MOV	A,M                      ;Fetch MSW+L byte containing BCD of digit to be
 3355  1521  A7                      ANA	A                        ;Displayed. Test the contents of this byte.
