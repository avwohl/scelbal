 1034  0604  77           	MOV M,A                         ;Store value from top of F/A STACK into temp loc.
 1035  0605  A7           	ANA A                           ;Test to see if token value in top of stack was zero
 1036  0606  C8           	RZ                              ;If so, just had simple grouping parenthesis!
 1037  0607  FA DC 19     	JM PRIGH1                       ;@@ If token value minus, indicates array subscript
 1038  060A  FE 01        	CPI 001H                        ;For positive token value, look for appropriate function
 1039  060C  CA 89 06     	JZ INTX                         ;If token value for INTeger function, go do it.
 1040  060F  FE 02        	CPI 002H                        ;Else, see if token value for SIGN function.
 1041  0611  CA DA 06     	JZ SGNX                         ;If so, go do it.
 1042  0614  FE 03        	CPI 003H                        ;Else, see if token value for ABSolute function
 1043  0616  CA D1 06     	JZ ABSX                         ;If so, go do it.
 1044  0619  FE 04        	CPI 004H                        ;If not, see if token value for SQuare Root function
 1045  061B  CA DB 18     	JZ SQRX                         ;If so, go do it.
 1046  061E  FE 05        	CPI 005H                        ;If not, see if token value for TAB function
 1047  0620  CA F9 06     	JZ TABX                         ;If so, go do it.
 1048  0623  FE 06        	CPI 006H                        ;If not, see if token value for RaNDom function
 1049  0625  CA 80 19     	JZ RNDX                         ;If so, go find a random number.
 1050  0628  FE 07        	CPI 007H                        ;If not, see if token value for CHaRacter function
 1051  062A  CA E9 06     	JZ CHRX                         ;If so, go perform the function.
 1052  062D  FE 08        	CPI 008H                        ;Else, see if token for user defined machine language
 1053  062F  CA C5 00     	JZ UDEFX                        ;# Function. If so, perform the User DEfined Function
 1054  0632  76           	HLT                             ;Safety halt. Program should not reach this location!
