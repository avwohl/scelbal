 2775  1229  5D           DINPUT:	MOV E,L                         ;Save entry value of register L in E. (Pointer to buffer
 2776  122A  54           	MOV D,H                         ;Containing ASCII character string.) Do same for H to D.
 2777  122B  21 36 00     	LXI H,FP_WORK_68                ;Set L to start of decirnal-to-binary working area
 2778  122E  AF           	XRA A                           ;Clear the accumulator
 2779  122F  06 08        	MVI B,008H                      ;Set up a loop counter
 2780  1231  77           CLRNX2:	MOV M,A                         ;Deposit zero in working area to initialize
 2781  1232  2C           	INR L                           ;Advance the memory pointer
 2782  1233  05           	DCR B                           ;Decrement the loop counter
 2783  1234  C2 31 12     	JNZ CLRNX2                      ;Clear working area until loop counter is zero
 2784  1237  21 64 00     	LXI H,SIGN_IND2                 ;Set pointer to floating point temporary registers and
 2785  123A  06 04        	MVI B,004H                      ;Indicators working area. Set up a loop counter.
 2786  123C  77           CLRNX3:	MOV M,A                         ;Deposit zero in working area to initialize
 2787  123D  2C           	INR L                           ;Advance the memory pointer
 2788  123E  05           	DCR B                           ;Decrement the loop counter
 2789  123F  C2 3C 12     	JNZ CLRNX3                      ;Clear working area until loop counter is zero
 2790  1242  CD FD 11     	CALL GETINP                     ;Fetch a character from the ASCII chax string buffer
 2791  1245  FE AB        	CPI 0ABH                        ;(Typically the SYMBOL/TOKEN buffer). See if it is
 2792  1247  CA 53 12     	JZ NINPUT                       ;Code for + sign. Jump ahead if code for + sign.
 2793  124A  FE AD        	CPI 0ADH                        ;See if code for minus (-) sign.
 2794  124C  C2 56 12     	JNZ NOTPLM                      ;Jump ahead if not code for minus sign. If code for
 2795  124F  21 64 00     	LXI H,SIGN_IND2                 ;Minus sign, set pointer to MINUS flag storage location.
 2796  1252  77           	MOV M,A                         ;Set the MINUS flag to indicate a minus number
 2797  1253  CD FD 11     NINPUT:	CALL GETINP                     ;Fetch another character from the ASCII char string
 2798  1256  FE AE        NOTPLM:	CPI 0AEH                        ;See if character represents a period (decimal point) in
 2799  1258  CA 89 12     	JZ PERIOD                       ;Input string. Jump ahead if yes.
 2800  125B  FE C5        	CPI 0C5H                        ;If not period, see if code for E as in Exponent
 2801  125D  CA 9B 12     	JZ FNDEXP                       ;Jump ahead if yes.
 2802  1260  FE A0        	CPI 0A0H                        ;Else see if code for space.
 2803  1262  CA 53 12     	JZ NINPUT                       ;Ignore space character, go fetch another character.
 2804  1265  A7           	ANA A                           ;If none of the above see if zero byte
 2805  1266  CA D5 12     	JZ ENDINP                       ;Indicating end of input char string. If yes, jumn ahead.
 2806  1269  FE B0        	CPI 0B0H                        ;If not end of string, check to see
 2807  126B  FA C4 09     	JM NUMERR                       ;If character represents
 2808  126E  FE BA        	CPI 0BAH                        ;A valid decimal number (0 to 9)
 2809  1270  F2 C4 09     	JP NUMERR                       ;Display error message if not a valid digit at this point!
 2810  1273  21 3C 00     	LXI H,FP_WORK_6E                ;For valid digit, set pointer to MSW of temporary
 2811  1276  4F           	MOV C,A                         ;Decimal to binary holding registers. Save character in C.
 2812  1277  3E F8        	MVI A,0F8H                      ;Form mask for sizing in accumulator. Now see if
 2813  1279  A6           	ANA M                           ;Holding register has enough room for the conversion of
 2814  127A  C2 53 12     	JNZ NINPUT                      ;Another digit. Ignore the input if no more room.
 2815  127D  21 66 00     	LXI H,INP_DIG_CNT               ;If have room in register then set pointer to input digit
 2816  1280  46           	MOV B,M                         ;Counter location. Fetch the present value.
 2817  1281  04           	INR B                           ;Increment it to account for incoming digit.
 2818  1282  70           	MOV M,B                         ;Restore updated count to storage location.
 2819  1283  CD 43 13     	CALL DECBIN                     ;Call the DECimal to BINary conversion routine to add
 2820  1286  C3 53 12     	JMP NINPUT                      ;In the new digit in holding registers. Continue inputting.
 2821  1289  47           PERIOD:	MOV B,A                         ;Save character code in register B
 2822  128A  21 67 00     	LXI H,TEMP_STORE                ;Set pointer to PERIOD indicator storage location
 2823  128D  7E           	MOV A,M                         ;Fetch value in PERIOD indicator
 2824  128E  A7           	ANA A                           ;Exercise CPU flags
 2825  128F  C2 C4 09     	JNZ NUMERR                      ;If already have a period then display error message
 2826  1292  21 66 00     	LXI H,INP_DIG_CNT               ;If not, change pointer to digit counter storage location
 2827  1295  77           	MOV M,A                         ;Clear the digit counter back to zero
 2828  1296  2C           	INR L                           ;Advance pointer to PERIOD indicator
 2829  1297  70           	MOV M,B                         ;Set the PERIOD indicator
 2830  1298  C3 53 12     	JMP NINPUT                      ;Continue processing the input character string
 2831  129B  CD FD 11     FNDEXP:	CALL GETINP                     ;Get next character in Exponent
 2832  129E  FE AB        	CPI 0ABH                        ;See if it is code for + sign
 2833  12A0  CA AC 12     	JZ EXPINP                       ;Jump ahead if yes.
 2834  12A3  FE AD        	CPI 0ADH                        ;If not + sign, see if minus sign
 2835  12A5  C2 AF 12     	JNZ NOEXPS                      ;If not minus sign then jump ahead
 2836  12A8  21 65 00     	LXI H,EXP_SIGNS                 ;For minus sign, set pointer to EXP SIGN indicator
 2837  12AB  77           	MOV M,A                         ;Set the EXP SIGN indicator for a minus exponent
 2838  12AC  CD FD 11     EXPINP:	CALL GETINP                     ;Fetch the next character in the decimal exponent
 2839  12AF  A7           NOEXPS:	ANA A                           ;Exercise the CPU flags
 2840  12B0  CA D5 12     	JZ ENDINP                       ;If character inputted was zero, then end of input string
 2841  12B3  FE B0        	CPI 0B0H                        ;If not end of string, check to see
 2842  12B5  FA C4 09     	JM NUMERR                       ;If character represents
 2843  12B8  FE BA        	CPI 0BAH                        ;A valid decimal number (0 to 9)
 2844  12BA  F2 C4 09     	JP NUMERR                       ;Display error message if not a valid digit at this point!
 2845  12BD  E6 0F        	ANI 00FH                        ;Else trim the ASCII code to BCD
 2846  12BF  47           	MOV B,A                         ;And save in register B
 2847  12C0  21 3D 00     	LXI H,FP_WORK_6F                ;Set pointer to input exponent storage location
 2848  12C3  3E 03        	MVI A,003H                      ;Set accumulator equal to three
 2849  12C5  BE           	CMP M                           ;See if any previous digit in exponent greater than three
 2850  12C6  FA C4 09     	JM NUMERR                       ;Display error message if yes
 2851  12C9  4E           	MOV C,M                         ;Else save any previous value in register C
 2852  12CA  7E           	MOV A,M                         ;And also place any previous value in accumulator
 2853  12CB  A7           	ANA A                           ;Clear the carry bit with this instruction
 2854  12CC  17           	RAL                             ;Single precision multiply by ten algorithm
 2855  12CD  17           	RAL                             ;Two rotate lefts equals times four
 2856  12CE  81           	ADD C                           ;Adding in the digit makes total times five
 2857  12CF  17           	RAL                             ;Rotating left again equals times ten
 2858  12D0  80           	ADD B                           ;now add in digit just inputted
 2859  12D1  77           	MOV M,A                         ;Restore the value to exponent storage location
 2860  12D2  C3 AC 12     	JMP EXPINP                      ;Go get any additional exponent int)ut
 2861  12D5  21 64 00     ENDINP:	LXI H,SIGN_IND2                 ;Set pointer to mantissa SIGN indicator
 2862  12D8  7E           	MOV A,M                         ;Fetch the SIGN indicator to the acclimulator
 2863  12D9  A7           	ANA A                           ;Exercise the CPU flags
 2864  12DA  CA E5 12     	JZ FININP                       ;If SIGN indicator is zero, go finish up as nr is positive
 2865  12DD  21 3A 00     	LXI H,FP_WORK_6C                ;But, if indicator is non-zero, number is negative
 2866  12E0  06 03        	MVI B,003H                      ;Set pntr to LSW of storage registers, set precision entr
 2867  12E2  CD 76 11     	CALL COMPLM                     ;Negate the triple-precision number in holding registers
 2868  12E5  21 39 00     FININP:	LXI H,FP_WORK_6B                ;Set pointer to input storage LS~V minus one
 2869  12E8  AF           	XRA A                           ;Clear the accumulator
 2870  12E9  77           	MOV M,A                         ;Clear the LSW minus one location
 2871  12EA  54           	MOV D,H                         ;Set register D to floating point working page
 2872  12EB  11 1E 00     	LXI D,FPACC_LSW_M1              ;Set E to address of FPACC LSW minus one
 2873  12EE  06 04        	MVI B,004H                      ;Set precision counter
 2874  12F0  CD F5 0F     	CALL MOVEIT                     ;Move number from input register to FPACC
 2875  12F3  CD 0B 0F     	CALL FPFLT                      ;Now convert the binary fixed point to floating point
 2876  12F6  21 65 00     	LXI H,EXP_SIGNS                 ;Set pointer to Exponent SIGN indicator location
 2877  12F9  7E           	MOV A,M                         ;Fetch the value of the EXP SIGN indicator
 2878  12FA  A7           	ANA A                           ;Exercise the CPU flags
 2879  12FB  21 3D 00     	LXI H,FP_WORK_6F                ;Reset pointer to input exponent storage location
 2880  12FE  CA 07 13     	JZ POSEXP                       ;If EXP SIGN indicator zero, exponent is positive
 2881  1301  7E           	MOV A,M                         ;Else, exponent is negative so must negate
