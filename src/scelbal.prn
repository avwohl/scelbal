 3058                                                       ;Main Decimal INPUT subroutine to convert strings of
 3059                                                       ;ASCII characters representing decimal fixed or floating
 3060                                                       ;point numbers to binary floating point numbers.
 3061                     
 3062  1324  5D           DINPUT:	MOV	E,L                         ;Save entry value of register L in E. (Pointer to buffer
 3063  1325  54                      MOV	D,H                      ;Containing ASCII character string.) Do same for H to D.
 3064  1326  26 01                   MVI	H,HIGH OLDPG1            ;** Set H to page of floating point working registers
 3065  1328  2E 68                   MVI	L,OFS_FP_WORK_68                   ;Set L to start of decirnal-to-binary working area
 3066  132A  AF                      XRA	A                        ;Clear the accumulator
 3067  132B  06 08                   MVI	B,008H                   ;Set up a loop counter
 3068  132D  77           CLRNX2:	MOV	M,A                         ;Deposit zero in working area to initialize
 3069  132E  2C                      INR	L                        ;Advance the memory pointer
 3070  132F  05                      DCR	B                        ;Decrement the loop counter
 3071  1330  C2 2D 13                JNZ	CLRNX2                   ;Clear working area until loop counter is zero
 3072  1333  2E 43                   MVI	L,OFS_SIGN_IND2                   ;Set pointer to floating point temporary registers and
 3073  1335  06 04                   MVI	B,004H                   ;Indicators working area. Set up a loop counter.
 3074  1337  77           CLRNX3:	MOV	M,A                         ;Deposit zero in working area to initialize
 3075  1338  2C                      INR	L                        ;Advance the memory pointer
 3076  1339  05                      DCR	B                        ;Decrement the loop counter
 3077  133A  C2 37 13                JNZ	CLRNX3                   ;Clear working area until loop counter is zero
 3078  133D  CD F5 12                CALL	GETINP                  ;Fetch a character from the ASCII chax string buffer
 3079  1340  FE AB                   CPI	0ABH                     ;(Typically the SYMBOL/TOKEN buffer). See if it is
 3080  1342  CA 4D 13                JZ	NINPUT                    ;Code for + sign. Jump ahead if code for + sign.
 3081  1345  FE AD                   CPI	0ADH                     ;See if code for minus (-) sign.
 3082  1347  C2 50 13                JNZ	NOTPLM                   ;Jump ahead if not code for minus sign. If code for
 3083  134A  2E 43                   MVI	L,OFS_SIGN_IND2                   ;Minus sign, set pointer to MINUS flag storage location.
 3084  134C  77                      MOV	M,A                      ;Set the MINUS flag to indicate a minus number
