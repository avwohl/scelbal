  443  01BA  B8           	CMP B                           ;If they are not the same
  444  01BB  C0           	RNZ                             ;Return to caller with flags set to non-zero condition
  445  01BC  CD CC 11     	CALL SWITCH                     ;Else, exchange the pointers back to first string.
  446  01BF  CD DA 01     STRCPL:	CALL ADV                        ;Advance the pointer to string number 1 and fetch a
  447  01C2  7E           	MOV A,M                         ;Character from that string into the accumulator.
  448  01C3  CD CC 11     	CALL SWITCH                     ;Now switch the pointers to string number 2.
  449  01C6  CD DA 01     	CALL ADV                        ;Advance the pointer in line number 2.
  450  01C9  BE           STRCPE:	CMP M                           ;Compare char in stxing 1 (ACC) to string 2 (memory)
  451  01CA  C0           	RNZ                             ;If not equal, return to cauer with flags set to non-zero
  452  01CB  CD CC 11     	CALL SWITCH                     ;Else, exchange pointers to restore pntr to string 1
  453  01CE  05           	DCR B                           ;Decrement the string length counter in register B
  454  01CF  C2 BF 01     	JNZ STRCPL                      ;If not finiahed, continue testing entire string
  455  01D2  C9           	RET                             ;If complete match, return with flag in zero condition
  456  01D3  7E           STRCPC:	MOV A,M                         ;Fetch character pointed to by pointer to string 1
  457  01D4  CD CC 11     	CALL SWITCH                     ;Exchange pointer to examine string 2
  458  01D7  C3 C9 01     	JMP STRCPE                      ;Continue the string comparison loop
