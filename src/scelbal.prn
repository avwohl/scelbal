 2775  122D  AF           	XRA A                           ;Clear the accumulator
 2776  122E  06 08        	MVI B,008H                      ;Set up a loop counter
 2777  1230  77           CLRNX2:	MOV M,A                         ;Deposit zero in working area to initialize
 2778  1231  23           	INX H                           ;Advance the memory pointer
 2779  1232  05           	DCR B                           ;Decrement the loop counter
 2780  1233  C2 30 12     	JNZ CLRNX2                      ;Clear working area until loop counter is zero
 2781  1236  21 64 00     	LXI H,SIGN_IND2                 ;Set pointer to floating point temporary registers and
 2782  1239  06 04        	MVI B,004H                      ;Indicators working area. Set up a loop counter.
 2783  123B  77           CLRNX3:	MOV M,A                         ;Deposit zero in working area to initialize
 2784  123C  23           	INX H                           ;Advance the memory pointer
 2785  123D  05           	DCR B                           ;Decrement the loop counter
 2786  123E  C2 3B 12     	JNZ CLRNX3                      ;Clear working area until loop counter is zero
 2787  1241  CD FC 11     	CALL GETINP                     ;Fetch a character from the ASCII chax string buffer
