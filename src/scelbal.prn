 3721  1994  54           	MOV D,H                         ;Set D to same page as H
 3722  1995  1E 24        	MVI E,024H                      ;And E with address of LAST SQR APPROX
 3723  1997  06 04        	MVI B,004H                      ;Set up register B as a number of bytes to move counter
 3724  1999  CD F4 0F     	CALL MOVEIT                     ;Transfer SQR APPROX into LAST SQR APPROX
 3725  199C  C3 5B 19     	JMP SQRLOP                      ;Continue ops until approximation converges
 3726  199F  21 5F 00     SQRCNV:	LXI H,EXP_COUNTER               ;Load L with address of TEMP register. Fetch the
 3727  19A2  7E           	MOV A,M                         ;Exponenent quotient store there into accumulator.
 3728  19A3  21 4B 00     	LXI H,SCRATCH_1F                ;Change L to point to SQR APPROX exponent.
 3729  19A6  86           	ADD M                           ;Add SQR APPROX exponent to quotient value.
 3730  19A7  77           	MOV M,A                         ;Store sum back in SQR APPROX Exponent register.
 3731  19A8  21 47 00     	LXI H,FPACC_SAVE                ;Load L with address of SQR APPROX. Transfer the
 3732  19AB  C3 B1 11     	JMP FLOAD                       ;SQR APPROX into FPACC as answer and exit.
