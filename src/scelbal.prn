 1331  085C  A7           	ANA A                           ;Number character string. Fetch that value (cc).
 1332  085D  CA 47 0A     	JZ DIRECT                       ;DIRECT If line number blank, have a DIRECT statement!
 1333  0860  21 24 16     	LXI H,USER_PGM_PTR              ;If have a line number must get line in input buffer into
 1334  0863  36 1A        	MVI M,HIGH USER_PROG_BUF        ;User program buffer. Initialize pointer high byte
 1335  0865  23           	INX H                           ;This is a two byte pointer so after initializing page addr
 1336  0866  36 15        	MVI M,LOW USER_PROG_BUF         ;Initialize low byte also
