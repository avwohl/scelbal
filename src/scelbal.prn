 3490                     ;;; PATCH NR.1
 3491  17E7  AF           PATCH1:	XRA A                           ;Clear accumulator
 3492  17E8  32 1E 00     	STA FPACC_LSW_M1                ;Clear FPACC extension byte
 3493  17EB  32 25 00     	STA FPOP_EXT_5B                 ;Clear FPOP extension byte
 3494  17EE  C9           	RET
 3495                     
 3496  17EF  AF           NEXT:	XRA A                           ;Clear accumulator
 3497  17F0  32 47 16     	STA AUX_SYMBOL_BUF              ;Initialize AUX SYMBOL BUFFER by clearing first byte
 3498  17F3  21 65 16     	LXI H,SCAN_PTR                  ;Change L to address of SCAN pointer
 3499  17F6  46           	MOV B,M                         ;Fetch pointer value to CPU register B
 3500  17F7  04           	INR B                           ;Add one to the current pointer value
 3501  17F8  21 64 16     	LXI H,SYNTAX_PTR                ;Load L with address of NEXT pointer storage location
 3502  17FB  70           	MOV M,B                         ;Place the updated SCAN pointer as the NEXT pointer
 3503  17FC  21 64 16     NEXT1:	LXI H,SYNTAX_PTR                ;Reset L to address of NEXT pointer storage location
 3504  17FF  CD F2 01     	CALL GETCHR                     ;Fetch the character pointed to by the NEXT pointer
 3505  1802  CA 0B 18     	JZ NEXT2                        ;If the character is a space, ignore it
 3506  1805  21 47 16     	LXI H,AUX_SYMBOL_BUF            ;Else, load L with start of AUX SYMBOL BUFFER
 3507  1808  CD 1F 02     	CALL CONCT1                     ;Concatenate the character onto the AUX SYMBOL BF
 3508  180B  21 64 16     NEXT2:	LXI H,SYNTAX_PTR                ;Reset L to address of NEXT pointer storage location
 3509  180E  CD 5E 02     	CALL LOOP                       ;Advance the NEXT pointer and see if end of line
 3510  1811  C2 FC 17     	JNZ NEXT1                       ;Fetch next character in line if not end of line
 3511  1814  21 47 16     	LXI H,AUX_SYMBOL_BUF            ;When reach end of line, should have variable name
 3512  1817  7E           	MOV A,M                         ;In the AUX SYMBOL BUFFER. Fetch the (cc) for
 3513  1818  FE 01        	CPI 001H                        ;The buffer and see if variable name is just one letter
 3514  181A  C2 21 18     	JNZ NEXT3                       ;If more than one proceed directly to look for name
 3515  181D  AF           	XRA A                           ;In FOR/NEXT STACK. If have just a one letter name
 3516  181E  32 34 00     	STA FP_WORK_66                  ;Then set second character in buffer to zero
 3517  1821  21 67 17     NEXT3:	LXI H,TEMP_085                  ;Load HL with address of FOR/NEXT STACK pointer
 3518  1824  7E           	MOV A,M                         ;Fetch the FOR/NEXT STACK pointer value to ACC
 3519  1825  07           	RLC                             ;Rotate value left to multiply by two. Then rotate it
 3520  1826  07           	RLC                             ;Left again to multiply by four for stack entry offset
 3521  1827  C6 02        	ADI 002H                        ;Add 2 to point to variable name in stack entry
 3522  1829  4F           	MOV C,A                         ;Save offset in C
 3523  182A  06 00        	MVI B,000H                      ;Clear B for 16-bit add
 3524  182C  21 47 17     	LXI H,FN_STACK                  ;Load HL with base of FOR/NEXT STACK
 3525  182F  09           	DAD B                           ;Add offset to get variable name location
 3526  1830  11 48 16     	LXI D,AUX_SYMBOL_BUF+1          ;Set DE to first character in the AUX SYMBOL BUFFER
 3527  1833  06 02        	MVI B,002H                      ;Set B to serve as a character counter
 3528  1835  CD 55 02     	CALL STRCPC                     ;See if variable name in the NEXT statement same as
 3529  1838  CA 42 18     	JZ NEXT4                        ;That stored in the top of the FOR/NEXT STACK
 3530  183B  3E C6        FORNXT:	MVI A,0C6H                      ;Load ACC with ASCII code for letter F
 3531  183D  0E CE        	MVI C,0CEH                      ;Load register C with ASCII code for letter N
 3532  183F  C3 E8 01     	JMP ERROR                       ;Display For/Next (FN) error message if required
 3533  1842  21 D7 16     NEXT4:	LXI H,USER_PGM_PTR              ;Load L with address of user program line pointer
 3534  1845  5E           	MOV E,M                         ;Fetch the low portion of the line pointer into E (Intel order)
 3535  1846  23           	INX H                           ;Advance the memory pointer
 3536  1847  56           	MOV D,M                         ;Fetch the page portion of the line pointer into D
 3537  1848  23           	INX H                           ;Advance pntr to AUXILIARY LINE POINTER storage
 3538  1849  73           	MOV M,E                         ;Location and store value of line pointer there too (low) (Intel order)
 3539  184A  23           	INX H                           ;Advance pointer to second byte of AUXILIARY line
 3540  184B  72           	MOV M,D                         ;Pointer and store value of line pointer (page portion)
 3541  184C  21 67 17     	LXI H,TEMP_085                  ;Load HL with address of FOR/NEXT STACK pointer
 3542  184F  7E           	MOV A,M                         ;Fetch the FOR/NEXT STACK pointer value to ACC
 3543  1850  07           	RLC                             ;Rotate value left to multiply by two. Then rotate it
 3544  1851  07           	RLC                             ;Left again to multiply by four for stack entry offset
 3545  1852  4F           	MOV C,A                         ;Save offset in C
 3546  1853  06 00        	MVI B,000H                      ;Clear B for 16-bit add
 3547  1855  21 47 17     	LXI H,FN_STACK                  ;Load HL with base of FOR/NEXT STACK
 3548  1858  09           	DAD B                           ;Add offset to point to top of stack entry
 3549  1859  5E           	MOV E,M                         ;Fetch low address of the associated FOR line pointer (Intel order)
 3550  185A  23           	INX H                           ;Advance the pointer
 3551  185B  56           	MOV D,M                         ;Fetch the page address value into D
 3552  185C  21 D7 16     	LXI H,USER_PGM_PTR              ;Program line pointer to the FOR statement line by
 3553  185F  73           	MOV M,E                         ;Place the low value in the pointer storage location (Intel order)
 3554  1860  23           	INX H                           ;Advance the memory pointer
 3555  1861  72           	MOV M,D                         ;Place the page value in the pointer storage location
 3556  1862  62           	MOV H,D                         ;Now set up H and L to point to the start of the
 3557  1863  6B           	MOV L,E                         ;Associated FOR statement line in the user pgm buffer
 3558  1864  11 E7 15     	LXI D,LINE_INP_BUF              ;And set L to the gtart of the line input buffer
 3559  1867  CD 89 09     	CALL MOVEC                      ;Move the associated FOR statement line into the input
 3560  186A  21 FB 00     	LXI H,KW_TO                     ;Line buffer. Set L to point to start of TO string which is
 3561  186D  CD 67 0A     	CALL INSTR                      ;Search the statement line for the occurrence of TO
 3562  1870  7B           	MOV A,E                         ;Register E will be zero if TO not found. Move E to ACC
 3563  1871  A7           	ANA A                           ;To make a test. If TO found then proceed to set up for
 3564  1872  CA 3B 18     	JZ FORNXT                       ;Evaluation. If TO not found, then have error condition.
 3565  1875  C6 02        	ADI 002H                        ;Advance the pointer over the characters in TO string
 3566  1877  21 A1 16     	LXI H,EVAL_PTR                  ;Change L to point to EVAL pointer storage location
 3567  187A  77           	MOV M,A                         ;Position for the EVAL subroutine (after TO string)
 3568  187B  21 FE 00     	LXI H,KW_STEP                   ;Set L to point to start of STEP string which is stored
 3569  187E  CD 67 0A     	CALL INSTR                      ;Statement line for the occurrence of STEP
 3570  1881  7B           	MOV A,E                         ;Register E will be zero if STEP not found. Move E to
 3571  1882  A7           	ANA A                           ;The accumulator to make a test. If STEP found must
 3572  1883  C2 A6 18     	JNZ NEXT5                       ;Evaluate expression after STEP to get STEP SIZE.
 3573  1886  21 03 00     	LXI H,FP_CONST_1                ;Else, have an IMPLIED STEP SIZE of 1.0. Set pointer
 3574  1889  CD 67 12     	CALL FLOAD                      ;Format and call subroutine to load FPACC with 1.0
 3575  188C  21 E0 00     	LXI H,FN_STEP                   ;Set L to start of FOR/NEXT STEP SIZE storage loc.
 3576  188F  CD 6F 12     	CALL FSTORE                     ;Store the value 1.0 in the F/N STEP SIZE registers
 3577  1892  21 E7 15     	LXI H,LINE_INP_BUF              ;Change L to the start of the input line buffer
 3578  1895  46           	MOV B,M                         ;Fetch the (cc) into CPU register B (length of FOR line)
 3579  1896  21 A2 16     	LXI H,EVAL_FINISH               ;Change L to EVAL FINISH pointer stomge location
 3580  1899  70           	MOV M,B                         ;Set the EVAL FINISH pointer to the end of the line
 3581  189A  CD F5 02     	CALL EVAL                       ;Evaluate the LIMIT expression to obtain FOR LIMIT
 3582  189D  21 E4 00     	LXI H,FN_LIMIT                  ;Load L with address of start of F/N LIMIT registers
 3583  18A0  CD 6F 12     	CALL FSTORE                     ;MGA 3/31/12 no lab here Store the FOR/NEXT LIMIT value
 3584  18A3  C3 CD 18     	JMP NEXT6                       ;Since have IMPLIED STEP jump ahead
 3585  18A6  1D           NEXT5:	DCR E                           ;MGA 3/21/12 lab here When have STEP directive, subtract one from pointer
 3586  18A7  21 A2 16     	LXI H,EVAL_FINISH               ;To get to character before S in STEP. Save this value in
 3587  18AA  73           	MOV M,E                         ;As evaluation end location when obtaining TO Iiinit
 3588  18AB  CD F5 02     	CALL EVAL                       ;Evaluate the LIMIT expression to obtain FOR LIMIT
 3589  18AE  21 E4 00     	LXI H,FN_LIMIT                  ;Load L with address of start of FIN LIMIT registers
 3590  18B1  CD 6F 12     	CALL FSTORE                     ;Store the FOR/NEXT LIMIT value
 3591  18B4  21 A2 16     	LXI H,EVAL_FINISH               ;Reset L to EVAL FINISH pointer storage location
 3592  18B7  7E           	MOV A,M                         ;Fetch the pointer value (character before S in STEP)
 3593  18B8  C6 05        	ADI 005H                        ;Add five to change pointer to character after P in STEP
