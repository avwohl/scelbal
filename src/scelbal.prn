 3091  135C  CA 4D 13                JZ	NINPUT                    ;Ignore space character, go fetch another character.
 3092  135F  A7                      ANA	A                        ;If none of the above see if zero byte
 3093  1360  CA C9 13                JZ	ENDINP                    ;Indicating end of input char string. If yes, jumn ahead.
 3094  1363  FE B0                   CPI	0B0H                     ;If not end of string, check to see
 3095  1365  FA FD 0A                JM	NUMERR                    ;If character represents
 3096  1368  FE BA                   CPI	0BAH                     ;A valid decimal number (0 to 9)
