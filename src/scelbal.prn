 2950                                                       ;floating pojnt register loading and transfer operations.
 2951                     
 2952  12AD  5D           FSTORE:	MOV	E,L                         ;Transfer contents of register L to E
 2953  12AE  54                      MOV	D,H                      ;Transfer contents of register H to D
 2954  12AF  2E 54                   MVI	L,OFS_FPACC                   ;Set L to least significant byte of FPACC mantissa
 2955  12B1  26 01                   MVI	H,HIGH OLDPG1            ;** Set page to FPACC storage area
 2956  12B3  C3 BA 12                JMP	SETIT                    ;Go transfer FPACC contents to area pointed to by D&E
 2957  12B6  16 01        OPLOAD:	MVI	D,HIGH OLDPG1               ;** Set page to FPOP storage area
 2958  12B8  1E 5C                   MVI	E,05CH                   ;Set pointer to least significant byte of FPOP
 2959  12BA  06 04        SETIT:	MVI	B,004H                       ;Set precision counter. Transfer from H & L area to
 2960  12BC  C3 0B 11                JMP	MOVEIT                   ;Locations pointed to by D & E
 2961                     
 2962                                                       ;The next subroutine perforins a double transfer opera-
 2963                                                       ;tion. It first transfers the contents of the FPACC into
 2964                                                       ;the FPOP. It then transfers new data (as pointed to by
 2965                                                       ;H & L upon entry to the subroutine) into the FPACC.
 2966                     
 2967  12BF  CD CF 12     FACXOP:	CALL	SAVEHL                     ;Save contents of H & L upon entry to subroutine
 2968  12C2  2E 54                   MVI	L,OFS_FPACC                   ;Set pointer to FPACC LSW
 2969  12C4  26 01                   MVI	H,HIGH OLDPG1            ;** Set pointer to page of FPACC
 2970  12C6  CD B6 12                CALL	OPLOAD                  ;Transfer FPACC to FPOP
 2971  12C9  CD DF 12                CALL	RESTHL                  ;Recover original subroutine entry values for H & L
 2972  12CC  C3 A4 12                JMP	FLOAD                    ;Transfer registers pointed to by H & L into the FPACC
 2973                     
 2974                                                       ;Subroutine to save the contents of CPU registers D, E, H
 2975                                                       ;and L in a temporary storage area in memory.
 2976                     
 2977  12CF  7C           SAVEHL:	MOV	A,H                         ;Transfer value in H to ACC
 2978  12D0  45                      MOV	B,L                      ;And value in L to B
 2979  12D1  2E 80                   MVI	L,OFS_EVAL_CURRENT                   ;Now set L to start of tempomry storage locations
 2980  12D3  26 01                   MVI	H,HIGH OLDPG1            ;** And set H to storage area page
 2981  12D5  77                      MOV	M,A                      ;Save A (entry value of H) in memory
 2982  12D6  2C                      INR	L                        ;Advance pointer
 2983  12D7  70                      MOV	M,B                      ;Save B (entry value of L) in memory
 2984  12D8  2C                      INR	L                        ;Advance pointer
 2985  12D9  72                      MOV	M,D                      ;Save D in memory
 2986  12DA  2C                      INR	L                        ;Advance pointer
 2987  12DB  73                      MOV	M,E                      ;Save E in memory
 2988  12DC  67                      MOV	H,A                      ;Restore entry value of H
 2989  12DD  68                      MOV	L,B                      ;Restore entry value of L
 2990  12DE  C9                      RET                          ;Exit to calling routine
 2991                     
 2992                                                       ;Subroutine to restore the contents of CPU registers D,
 2993                                                       ;E, H and L from temporary storage in memory.
 2994                     
 2995  12DF  2E 80        RESTHL:	MVI	L,OFS_EVAL_CURRENT                      ;Set L to start of temporary storage locations
 2996  12E1  26 01                   MVI	H,HIGH OLDPG1            ;** Set H to storage area page
 2997  12E3  7E                      MOV	A,M                      ;Fetch stored value for li iii ACC
 2998  12E4  2C                      INR	L                        ;Advance pointer
 2999  12E5  46                      MOV	B,M                      ;Fetch stored value for L into B
