 2924                                                       ;Following subroutine is used
 2925                                                       ;to convert decimal charac-
 2926                                                       ;ters to binary fixed point forinat
 2927                                                       ;in a triple-precision format.
 2928                     
 2929  1342  CD D8 11     DECBIN:	CALL SAVEHL                     ;Save entry value of D, E, H and L in memory
 2930  1345  21 39 00     	LXI H,FP_WORK_6B                ;Set pointer to temporary storage location
 2931  1348  79           	MOV A,C                         ;Restore character inputted to accumulator
 2932  1349  E6 0F        	ANI 00FH                        ;Trim ASCII code to BCD
 2933  134B  77           	MOV M,A                         ;Store temporarily
 2934  134C  11 36 00     	LXI D,FP_WORK_68                ;Set pointer to working area LSW of multi-byte register
 2935  134F  21 3A 00     	LXI H,FP_WORK_6C                ;Set another pointer to LSW of conversion register
 2936  1352  54           	MOV D,H                         ;Make sure D set to page of working area
 2937  1353  06 03        	MVI B,003H                      ;Set precision counter
 2938  1355  CD F4 0F     	CALL MOVEIT                     ;Move original value of conversion register to working
 2939  1358  21 3A 00     	LXI H,FP_WORK_6C                ;Register. Reset pointer to LSW of conversion register.
 2940  135B  06 03        	MVI B,003H                      ;Set precision counter
 2941  135D  CD 8C 11     	CALL ROTATL                     ;Rotate register left, (Multiplies value by two.)
 2942  1360  21 3A 00     	LXI H,FP_WORK_6C                ;Reset pointer to LSW.
 2943  1363  06 03        	MVI B,003H                      ;Set precision counter
 2944  1365  CD 8C 11     	CALL ROTATL                     ;Multiply by two again (total now times four).
 2945  1368  11 3A 00     	LXI D,FP_WORK_6C                ;Set pointer to LSW of conversion register.
 2946  136B  21 36 00     	LXI H,FP_WORK_68                ;Set pointer to LSW of working register (original value).
 2947  136E  06 03        	MVI B,003H                      ;Set precision counter.
 2948  1370  CD 64 11     	CALL ADDER                      ;Add original value to rotated value (now times five).
 2949  1373  21 3A 00     	LXI H,FP_WORK_6C                ;Reset pointer to LSW
 2950  1376  06 03        	MVI B,003H                      ;Set precision counter
 2951  1378  CD 8C 11     	CALL ROTATL                     ;Multiply by two once more (total now times ten).
 2952  137B  21 38 00     	LXI H,FP_WORK_6A                ;Set pointer to clear working register locatiotis
 2953  137E  AF           	XRA A                           ;Clear the accumulator
 2954  137F  77           	MOV M,A                         ;Clear MSW of working register
