 3750  19D4  21 22 00     	LXI H,FPACC_EXP                 ;Load L with address of FPACC Exponent register
 3751  19D7  7E           	MOV A,M                         ;Fetch Exponent value into the accumulator
 3752  19D8  D6 10        	SUI 010H                        ;Subtract 16 (decimal) to effectively divide by 65,536
