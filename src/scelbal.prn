  422  01E4  3E C2        BIGERR:	MVI A,0C2H                      ;Load ASCII code for letters B and G to indicate BIG
  423  01E6  0E C7        	MVI C,0C7H                      ;ERROR (for when buffer, stack,etc., overflows).
  424  01E8  CD E4 02     ERROR:	CALL ECHO                       ;Call user provided display routine to print ASCII code
  425  01EB  79           	MOV A,C                         ;In accumulator. Transfer ASCII code from C to ACC
  426  01EC  CD E4 02     	CALL ECHO                       ;And repeat to display error codes.
  427  01EF  C3 33 0A     	JMP FINERR                      ;Go cpmplete error message (AT LINE) as required.
  428  01F2  7E           GETCHR:	MOV A,M                         ;Get pointer offset from memory location pointed to by H&L
  429  01F3  FE 50        	CPI 050H                        ;See if within range of line input buffer.
  430  01F5  F2 E4 01     	JP BIGERR                       ;If not then have an overflow condition = error.
  431  01F8  4F           	MOV C,A                         ;Save offset in C
  432  01F9  21 E7 15     	LXI H,LINE_INP_BUF              ;Load base address of LINE INPUT BUFFER
  433  01FC  06 00        	MVI B,000H                      ;Clear B for 16-bit add
  434  01FE  09           	DAD B                           ;Add offset (BC) to base address (HL)
  435  01FF  7E           	MOV A,M                         ;Fetch the character from the line input buffer.
  436  0200  FE A0        	CPI 0A0H                        ;See if it is ASCII code for space.
  437  0202  C9           	RET                             ;Return to caller with flags set according to comparison.
  438  0203  AF           CLESYM:	XRA A                           ;Clear the accumulator
  439  0204  32 37 16     	STA SYMBOL_BUF                  ;Place a zero byte at start of SYMBOL BUFFER.
  440  0207  C9           	RET                             ;To effectively clear the buffer. Then exit to caller.
