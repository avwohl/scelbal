 3641  1901  36 00        	MVI M,000H                      ;The value indicating end of expression. Call the
 3642  1903  CD C3 03     	CALL PARSER                     ;PARSER subroutine for final time for the expression.
 3643  1906  21 6B 00     	LXI H,ARITH_STKPTR              ;Change L to point to the ARITH STACK pointer.
 3644  1909  7E           	MOV A,M                         ;Fetch the ARITH STACK pointer value.
 3645  190A  FE 98        	CPI 098H                        ;Should indicate only one value (answer) in stack.
 3646  190C  C8           	RZ                              ;Exit with answer in FPACC if ARITH STACK is O.K.
 3647  190D  C3 52 08     	JMP SYNERR                      ;Else have a syntax error!
