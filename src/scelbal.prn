 2493  105B  C2 54 10                JNZ	LOOK0                    ;Continue checking to see if FPACC contains anything
 2494  105E  2E 57                   MVI	L,OFS_FPACC_EXP                   ;Until precision counter is zero. If reach here then
 2495  1060  AF                      XRA	A                        ;Reset pointer to FPACC Exponent. Clear the ACC and
 2496  1061  77                      MOV	M,A                      ;Clear out the FPACC Exponent. Value of FPACC is zip!
 2497  1062  C9                      RET                          ;Exit to calling routine
 2498  1063  2E 53        ACNONZ:	MVI	L,OFS_SYMBOL_BUF+3                      ;If FPACC has any value set pointer to LSW minus one
