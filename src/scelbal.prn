 1222  079F  6F                      MOV	L,A                      ;Form pointer to next entry in table
 1223  07A0  D0                      RNC                          ;If no carry return to caller
 1224  07A1  24                      INR	H                        ;Else, increment H before
 1225  07A2  C9                      RET                          ;Returning to caller
 1226                     
 1227                     ;;; The label INTX SHOULD BE AT 07 243
 1228  07A3  2E 56        INTX:	MVI	L,OFS_FPACC_MSW                        ;Load L with address of MSW of the FPACC
 1229  07A5  26 01                   MVI	H,HIGH OLDPG1            ;** Load H with the page of the PPACC
 1230  07A7  7E                      MOV	A,M                      ;Fetch the MSW of the FPACC into the accumulator
 1231  07A8  A7                      ANA	A                        ;Test the sign of the number in the FPACC. If
 1232  07A9  F2 D7 07                JP	INT1                      ;Positive jump ahead to integerize
 1233  07AC  2E 0C                   MVI	L,OFS_FP_TEMP                   ;If negative, load L with address of FP TEMP registers
 1234  07AE  CD AD 12                CALL	FSTORE                  ;Store the value in the FPACC in FP TEMP
 1235  07B1  CD 00 10                CALL	FPFIX                   ;Convert the value in FPACC from floating point to
 1236  07B4  2E 53                   MVI	L,OFS_SYMBOL_BUF+3                   ;Fixed point. Load L with address of FPACC
 1237  07B6  36 00                   MVI	M,000H                   ;Extension register and clear it.
 1238  07B8  CD 34 10                CALL	FPFLT                   ;Convert fixed binary back to FP to integerize
 1239  07BB  2E 0C                   MVI	L,OFS_FP_TEMP                   ;Load L with address of FP TEMP registers
 1240  07BD  CD B6 12                CALL	OPLOAD                  ;Load the value in FP TEMP into FPOP
 1241  07C0  CD 1A 11                CALL	FPSUB                   ;Subtract integerized value from original
 1242  07C3  2E 56                   MVI	L,OFS_FPACC_MSW                   ;Set L to address of MSW of FPACC
 1243  07C5  7E                      MOV	A,M                      ;Fetch the MSW of the FPACC into the accumulator
 1244  07C6  A7                      ANA	A                        ;See if original value and integerized value the same
 1245  07C7  CA E1 07                JZ	INT2                      ;If so, have integer value in FP TEMP
 1246  07CA  2E 0C                   MVI	L,OFS_FP_TEMP                   ;Else, load L with address of FP TEMP registers
 1247  07CC  CD A4 12                CALL	FLOAD                   ;Restore FPACC to original (non-integerized) value
 1248  07CF  2E 14                   MVI	L,OFS_FP_CONST_NEG1                   ;Set L to register containing small value
 1249  07D1  CD BF 12                CALL	FACXOP                  ;Set up to add small value to original value in FPACC
 1250  07D4  CD 89 10                CALL	FPADD                   ;Perform the addition
 1251  07D7  CD 00 10     INT1:	CALL	FPFIX                        ;Convert the number in FPACC from floating point
 1252  07DA  2E 53                   MVI	L,OFS_SYMBOL_BUF+3                   ;To fixed point. Load L with address of FPACC
 1253  07DC  36 00                   MVI	M,000H                   ;Extension register and clear it. Now convert the number
 1254  07DE  C3 34 10                JMP	FPFLT                    ;Back to floating point to integerize it and exit to caller
 1255  07E1  2E 0C        INT2:	MVI	L,OFS_FP_TEMP                        ;Load L with address of FP TEMP registers. Transfer
 1256  07E3  C3 A4 12                JMP	FLOAD                    ;Number from FP TEMP (orig) to FPACC and return.
 1257  07E6  2E 56        ABSX:	MVI	L,OFS_FPACC_MSW                        ;Load L with address of MSW of the FPACC
 1258  07E8  26 01                   MVI	H,HIGH OLDPG1            ;** Set H to page of the FPACC
 1259  07EA  7E                      MOV	A,M                      ;Fetch the MSW of the FPACC into the accumulator
 1260  07EB  A7                      ANA	A                        ;Test the sign of the number to see if it is positive.
 1261  07EC  FA 82 10                JM	FPCOMP                    ;If negative, complement the number before returning.
 1262  07EF  C9                      RET                          ;Else, just return with absolute value in the FPACC.
 1263  07F0  2E 56        SGNX:	MVI	L,OFS_FPACC_MSW                        ;Load L with address of MSW of the FPACC
 1264  07F2  26 01                   MVI	H,HIGH OLDPG1            ;** Load H with the page of the FPACC
 1265  07F4  7E                      MOV	A,M                      ;Fetch the MSW of the FPACC into the accumulator
 1266  07F5  A7                      ANA	A                        ;Test to see if the FPACC is zero
 1267  07F6  C8                      RZ                           ;Return to caller if FPACC is zero
 1268  07F7  F2 A2 06                JP	FPONE                     ;If FPACC is positive, load +1.0 into FPACC and exit
 1269  07FA  2E 14                   MVI	L,OFS_FP_CONST_NEG1                   ;If FPACC is negative, set up to load -1.0 into the
 1270  07FC  C3 A4 12                JMP	FLOAD                    ;FPACC and exit to caller
 1271  07FF  CD 00 10     CHRX:	CALL	FPFIX                        ;Convert contents of FPACC from floating point to
 1272  0802  2E 54                   MVI	L,OFS_FPACC                   ;Fixed point. Load L with address of LSW of fixed
 1273  0804  7E                      MOV	A,M                      ;Value. Fetch this byte into the accumulator.
 1274  0805  CD 82 03                CALL	ECHO                    ;Display the value.
 1275  0808  2E 7F                   MVI	L,OFS_TAB_FLAG                   ;Set L to address of the TAB FLAG
 1276  080A  26 16                   MVI	H,HIGH OLDPG26           ;** Set H to page of the TAB FLAG
 1277  080C  36 FF                   MVI	M,0FFH                   ;Set TAB FLAG (to inhibit display of FP value)
 1278  080E  C9                      RET                          ;Exit to caller.
 1279  080F  CD 00 10     TABX:	CALL	FPFIX                        ;Convert contents of FPACC from floating point to
 1280  0812  2E 54        TAB1:	MVI	L,OFS_FPACC                        ;Fixed point. Load L with address of 1,SW of fixed
 1281  0814  7E                      MOV	A,M                      ;Value. Fetch this byte into the accumulator.
 1282  0815  2E 23                   MVI	L,OFS_COL_COUNTER                   ;Load L with address of COLUMN COUNTER
 1283  0817  96                      SUB	M                        ;Subtract value in C-OLUMN COUNTER from desired
 1284  0818  2E 7F                   MVI	L,OFS_TAB_FLAG                   ;TAB position. Load L with address of the TAB FLAG.
 1285  081A  26 16                   MVI	H,HIGH OLDPG26           ;** Set H to page of the TAB FLAG.
 1286  081C  36 FF                   MVI	M,0FFH                   ;Set TAB FLAG (to inhibit display of FP value)
 1287  081E  FA 8F 19                JM	BACKSP                    ;If beyond TAB point desired, simulate back spacing
 1288  0821  C8                      RZ                           ;Return to caller if at desired TAB location
 1289  0822  4F           TABC:	MOV	C,A                           ;Else, put difference count in register C
 1290  0823  3E A0                   MVI	A,0A0H                   ;Place ASCII code for space in ACC
 1291  0825  CD 82 03     TABLOP:	CALL	ECHO                       ;Display space on output device
 1292  0828  0D                      DCR	C                        ;Decrement displacement counter
 1293  0829  C2 25 08                JNZ	TABLOP                   ;If have not reached TAB position, continue to space
 1294  082C  C9                      RET                          ;Else, return to calling routine.
 1295                     
 1296                     ;;; The label STOSYM should be AT 10 055
 1297  082D  2E 81        STOSYM:	MVI	L,OFS_SYNTAX_PTR                      ;Load L with address of ARRAY FLAG
 1298  082F  26 17                   MVI	H,HIGH OLDPG27           ;** Load H with page of ARRAY FLAG
 1299  0831  7E                      MOV	A,M                      ;Fetch the value of the ARRAY FLAG into the ACC
 1300  0832  A7                      ANA	A                        ;Check to see if the flag is set indicating processing an
 1301  0833  CA 40 08                JZ	STOSY1                    ;Array variable value. Jump ahead if flag not set.
 1302  0836  36 00                   MVI	M,000H                   ;If ARRAY FLAG was set, clear it for next time.
 1303  0838  2E 84                   MVI	L,OFS_TEMP_ARRAY                   ;Then load L with address of array address storage loc
 1304  083A  6E                      MOV	L,M                      ;Fetch the array storage address as new pointer
 1305  083B  26 2F                   MVI	H,HIGH OLDPG57           ;tt Set H to ARRAY VALUES page   ****************
 1306  083D  C3 AD 12                JMP	FSTORE                   ;Store the array variable value and exit to caller.
 1307  0840  2E F8        STOSY1:	MVI	L,OFS_LOOKUP_CNT                      ;Load L with address of TEMP CNTR
 1308  0842  26 16                   MVI	H,HIGH OLDPG26           ;** Load H with page of TEMP CNTR
 1309  0844  36 00                   MVI	M,000H                   ;Initialize the TEMP CNTR by clearing it
 1310  0846  2E 50                   MVI	L,OFS_SYMBOL_BUF                   ;Load L with starting address of SYMBOL BUFFER
 1311  0848  16 17                   MVI	D,HIGH OLDPG27           ;** Load D with page of VARIABLES LOOK-UP table
 1312  084A  1E 88                   MVI	E,OFS_VARIABLES_TBL                   ;Load E with starting addr of VARIABLES LOOK-UP
 1313  084C  7E                      MOV	A,M                      ;Table. Fetch the (cc) for the SYMBOL BUFFER into
 1314  084D  FE 01                   CPI	001H                     ;The ACC and see if length of variable name is just one
 1315  084F  C2 56 08                JNZ	STOSY2                   ;Character. If not, skip next couple of instructions.
 1316  0852  2E 52                   MVI	L,OFS_SYMBOL_CHAR2                   ;Else, set pointer to second character location in the
 1317  0854  36 00                   MVI	M,000H                   ;SYMBOL BUFFER and set it to zero
 1318  0856  2E 51        STOSY2:	MVI	L,OFS_SYMBOL_CHAR1                      ;load L with address of first character in the SYMBOL
 1319  0858  26 16                   MVI	H,HIGH OLDPG26           ;** BUFFER. Load H with page of the buffer.
 1320  085A  CD EE 12                CALL	SWITCH                  ;Exchange pointer to buffer for pointer to VARIABLES
 1321  085D  7E                      MOV	A,M                      ;LOOK-UP table. Fetch first char in a name from the
 1322  085E  2C                      INR	L                        ;Table. Advance the pointer to second char in a name.
 1323  085F  46                      MOV	B,M                      ;Fetch the second character into register B.
 1324  0860  2C                      INR	L                        ;Advance the pointer to first byte of a value in the table.
 1325  0861  CD EE 12                CALL	SWITCH                  ;Exchange table pointer for pointer to SYMBOL BUFF
 1326  0864  BE                      CMP	M                        ;Compare first character in buffer against first character
 1327  0865  C2 6E 08                JNZ	STOSY3                   ;In table entry. If no match, try next entry in the table.
 1328  0868  2C                      INR	L                        ;If match, advance pointer to second character in buffer.
 1329  0869  78                      MOV	A,B                      ;Move second character obtained from table into ACC.
 1330  086A  BE                      CMP	M                        ;Compare second characters in table and buffer.
 1331  086B  CA 97 08                JZ	STOSY5                    ;If same, have found the variable name in the table.
 1332  086E  CD AE 06     STOSY3:	CALL	AD4DE                      ;Add four to pointer in registers D&E to skip over value
 1333  0871  2E F8                   MVI	L,OFS_LOOKUP_CNT                   ;Portion of entry in table. Load L with address of TEMP
 1334  0873  26 16                   MVI	H,HIGH OLDPG26           ;** CNTR. Load H with page of TEMP CNTR.
 1335  0875  46                      MOV	B,M                      ;Fetch the counter
 1336  0876  04                      INR	B                        ;Increment the counter
 1337  0877  70                      MOV	M,B                      ;Restore it to storage
 1338  0878  2E 3F                   MVI	L,OFS_SYMVAR_CNT                   ;Set L to address of VARIABLES CNTR (indicates
 1339  087A  26 17                   MVI	H,HIGH OLDPG27           ;** Number of variables currently in table.) Set H too
 1340  087C  78                      MOV	A,B                      ;Move the TEMP CNTR value into the ACC. (Number of
 1341  087D  BE                      CMP	M                        ;Entries checked.) Compare with number of entries in
 1342  087E  C2 56 08                JNZ	STOSY2                   ;The table. If have not checked all entries, try next one.
 1343  0881  2E 3F                   MVI	L,OFS_SYMVAR_CNT                   ;If have checked all entries, load L with address of the
 1344  0883  26 17                   MVI	H,HIGH OLDPG27           ;** VARIABLES CNTR. Set H too. Fetch the counter
 1345  0885  46                      MOV	B,M                      ;Value and incrernent it to account for
 1346  0886  04                      INR	B                        ;New variable nwne that will now be
 1347  0887  70                      MOV	M,B                      ;Added to the table. Save the new value.
 1348  0888  78                      MOV	A,B                      ;Place the new counter value into the accumulator
 1349  0889  FE 15                   CPI	015H                     ;And check to see that adding new variable name to the
 1350  088B  F2 92 02                JP	BIGERR                    ;Table will not cause table overflow. Big Error if it does!
 1351  088E  2E 51                   MVI	L,OFS_SYMBOL_CHAR1                   ;If room available in table, set L to address of first
 1352  0890  26 16                   MVI	H,HIGH OLDPG26           ;** Caracter in the SYMBOL BUFFER. Set H too.
 1353  0892  06 02                   MVI	B,002H                   ;Set a counter for number of characters to transfer.
 1354  0894  CD 0B 11                CALL	MOVEIT                  ;Move the variable name from buffer to table.
 1355  0897  CD EE 12     STOSY5:	CALL	SWITCH                     ;Exchange buffer pointer for table pointer.
 1356  089A  CD AD 12                CALL	FSTORE                  ;Transfer new mathematical value into the table.
 1357  089D  C3 AD 02                JMP	CLESYM                   ;Clear the SYMBOL BUFFER and exit to calling routine.
 1358                     
 1359                                                       ;The subroutines below are used by some of the routines
 1360                                                       ;in this chapter as well as other parts of the program.
 1361                     
 1362  08A0  2E 50        SAVESY:	MVI	L,OFS_SYMBOL_BUF                      ;Load L with the address of the start of the SYMBOL
 1363  08A2  26 16                   MVI	H,HIGH OLDPG26           ;** BUFFER. Load H with the page of the buffer.
 1364  08A4  54                      MOV	D,H                      ;Load register D with the page of the AUX SYMBOL
 1365  08A5  1E 64                   MVI	E,OFS_SYMBOL_BUF_64                   ;BUFFER and set register E to start of that buffer.
 1366  08A7  C3 B1 08                JMP	MOVECP                   ;Transfer SYMBOL BF contents to AUX SYMBOL BF
 1367                     
 1368  08AA  2E 64        RESTSY:	MVI	L,OFS_FP_WORK+4                      ;Load L with address of start of AUX SYMBOL BUFF
 1369  08AC  26 16                   MVI	H,HIGH OLDPG26           ;** Load H with page of AUX SYMBOL BUFFER
 1370  08AE  54                      MOV	D,H                      ;Set D to page of SYMBOL BUFFER (same as H)
 1371  08AF  1E 50                   MVI	E,OFS_SYMBOL_BUF                   ;Load E with start of SYMBOL BUFFER
 1372  08B1  46           MOVECP:	MOV	B,M                         ;Load (cc) for source string (first byte in source buffer)
 1373  08B2  04                      INR	B                        ;Add one to (cc) to include (cc) byte itself
 1374  08B3  C3 0B 11                JMP	MOVEIT                   ;Move the source string to destination buffer
 1375                     
 1376                     ;;; The label Exec SHOULD BE AT 10 266 (This is the start of the code)
 1377  08B6  2E EA        EXEC:	MVI	L,OFS_MSG_READY                        ;Load L with address of READY message
 1378  08B8  26 01                   MVI	H,HIGH OLDPG1            ;** Load H with page of READY message
 1379  08BA  CD 51 03                CALL	TEXTC                   ;Call subroutine to display the READY message
 1380                     
 1381  08BD  2E 00        EXEC1:	MVI	L,OFS_LINE_INP_BUF           ;Load L with starting address of INPUT LINE BUFFER
 1382  08BF  26 16                   MVI	H,HIGH OLDPG26           ;** Load H with page of INPUT LINE BUFFER
 1383  08C1  CD 0C 03                CALL	STRIN                   ;Call subroutine to input a line into the buffer
 1384  08C4  7E                      MOV	A,M                      ;The STRIN subroutine will exit with pointer set to the
 1385  08C5  A7                      ANA	A                        ;CHARACTER COUNT for the line inputted. Fetch the
 1386  08C6  CA BD 08                JZ	EXEC1                     ;Value of the counter, if it is zero then line was blank.
 1387  08C9  2E DD                   MVI	L,OFS_KW_LIST                   ;Load L with address of LIST in look up table
 1388  08CB  26 01                   MVI	H,HIGH OLDPG1            ;Load H with address of LIST in look up table
 1389  08CD  16 16                   MVI	D,HIGH OLDPG26           ;Load D with page of line input buffer
 1390  08CF  1E 00                   MVI	E,OFS_LINE_INP_BUF                   ;Load E with start of line input buffer
 1391  08D1  CD DA 02                CALL	STRCP                   ;Call string compare subroutine to see if first word in
 1392  08D4  C2 EC 08                JNZ	NOLIST                   ;Input buffer is LIST. Jump 3 ahead if not LIST.
 1393  08D7  2E 00                   MVI	L,OFS_USER_PROG          ;If LIST, set up pointers to start of USER PROGRAM
 1394  08D9  26 1B                   MVI	H,BGNPGRAM               ;BUFFER. (Note user could alter this starting addr)   *****
 1395                     
 1396                                                       ;Next portion of program will LIST the contents of the
 1397                                                       ;USER PROGRAM BUFFER until an end of buffer
 1398                                                       ;(zero byte) indicator is detected.
 1399                     
 1400  08DB  7E           LIST:	MOV	A,M                           ;Fetch the first byte of a line in the USER PROGRAM
 1401  08DC  A7                      ANA	A                        ;BUFFER and see if it is zero. If so, have finished LIST
 1402  08DD  CA B6 08                JZ	EXEC                      ;So go back to start of Executive and display READY.
 1403  08E0  CD 51 03                CALL	TEXTC                   ;Else call subroutine to display a line of information
 1404  08E3  CD FF 02                CALL	ADV                     ;Now call subroutine to advance buffer pointer to
 1405  08E6  CD 61 03                CALL	CRLF                    ;Character count in next line. Also display a CR & LF.
 1406  08E9  C3 DB 08                JMP	LIST                     ;Continue LISTing process
 1407                     
 1408                                                       ;If line inputted by operator did not contain a LIST comman
 1409                                                       ;continue program to see if RUN or SCRatch command.
 1410                     
 1411  08EC  2E E2        NOLIST:	MVI	L,OFS_KW_RUN                      ;Load L with address of RUN in look up table
 1412  08EE  26 01                   MVI	H,HIGH OLDPG1            ;** Load H with address of RUN in look up table
 1413  08F0  1E 00                   MVI	E,OFS_LINE_INP_BUF                   ;Load E with start of line input buffer
 1414  08F2  16 16                   MVI	D,HIGH OLDPG26           ;** Load D with page of line input buffer
 1415  08F4  1E 00                   MVI	E,OFS_LINE_INP_BUF                   ;(Reserve 2 locs in case of patching by duplicating above)
 1416  08F6  CD DA 02                CALL	STRCP                   ;Call string compare subroutine to see if first word in
 1417  08F9  CA 38 0B                JZ	RUN                       ;Input buffer is RUN. Go to RUN routine if match.
 1418  08FC  16 16                   MVI	D,HIGH OLDPG26           ;** If not RUN command, reset address pointers back
 1419  08FE  1E 00                   MVI	E,OFS_LINE_INP_BUF                   ;To the start of the line input buffer
 1420  0900  2E E6                   MVI	L,OFS_KW_SCR                   ;Load L with address of SCR in look up table
 1421  0902  26 01                   MVI	H,HIGH OLDPG1            ;** Load H with page of SCR in look up table
 1422  0904  CD DA 02                CALL	STRCP                   ;Call string compare subroutine to see if first word in
 1423  0907  C2 39 09                JNZ	NOSCR                    ;Input buffer is SCR. If not then jump ahead.
 1424  090A  26 16                   MVI	H,HIGH OLDPG26           ;** If found SCR command then load memory pointer
 1425  090C  2E F4                   MVI	L,OFS_TEMP_F4                   ;With address of a pointer storage location. Set that
 1426  090E  36 1B                   MVI	M,BGNPGRAM               ;tt Storage location to page of start of USER PRO-  *******
 1427  0910  2C                      INR	L                        ;GRAM BUFFER. (Buffer start loc may be altered).
 1428  0911  36 00                   MVI	M,000H                   ;Then adv pntr and do same for low addr portion of pntr
 1429  0913  2E 3F                   MVI	L,OFS_SYMVAR_CNT                   ;Now set pointer to address of VARIABLES counter
 1430  0915  26 17                   MVI	H,HIGH OLDPG27           ;** Storage location. Initialize this counter by placing
 1431  0917  36 01                   MVI	M,001H                   ;The count of one into it. Now change the memory pntr
 1432                     ;MGA 3/31/12 put it back to 001; solves nested FOR/NEXT, but limits vars to 19
 1433                     ;   as the letter from James Tucker (1/77) mentioned
 1434                     ;   apparently, James didn't test FOR/NEXT; original Loboyko didn't have this
 1435                     ;;;           LMI 001                ;The count of one into it. Now change the memory pntr
 1436                     ;;; Apparently, in Page 3 of Issue 4 of Scelbal update (1/77) they say the above should change.
 1437                     ;;; This makes the SCR command clear the whole variable space, otherwise one space is lost.  
 1438  0919  2E 3D                   MVI	L,OFS_SYMVAR_CNT-2                   ;To storage location for number of dimensioned arrays
 1439  091B  36 00                   MVI	M,000H                   ;@@ And initialize to zero. (@@ = Substitute NOPs if
 1440  091D  2E 50                   MVI	L,OFS_SYMBOL_BUF                   ;@@ DIMension capability not used in package.) Also
 1441  091F  36 00                   MVI	M,000H                   ;@@ Initialize l'st byte of array name table to zero.
 1442  0921  2E 88                   MVI	L,OFS_OP_STKPTR                   ;Set pointer to storage location for the first byte of the
 1443  0923  36 00                   MVI	M,000H                   ;VARIABLES symbol table. Initialize it to zero too.
 1444  0925  2C                      INR	L                        ;Advance the pointer and zero the second location
 1445  0926  36 00                   MVI	M,000H                   ;In the Variables table also.
 1446  0928  26 1B                   MVI	H,BGNPGRAM               ;tt Load H with page of start of USER PROGRAM    **********
 1447  092A  2E 00                   MVI	L,OFS_USER_PROG          ;BUFFER. (Buffer start location could be altered.)
 1448  092C  36 00                   MVI	M,000H                   ;Clear first location to indicate end of user program.
 1449  092E  26 2F                   MVI	H,HIGH OLDPG57           ;@@ Load H with page of ARRAYS storage
 1450  0930  36 00        SCRLOP:	MVI	M,000H                      ;@@ And form a loop to clear out all the locations
 1451  0932  2C                      INR	L                        ;@@ On the ARRAYS storage page. (@@ These become
 1452  0933  C2 30 09                JNZ	SCRLOP                   ;@@ NOPs if DIMension capability deleted fm package.)
 1453  0936  C3 B6 08                JMP	EXEC                     ;SCRatch operations completed, go back to EXEC.
 1454                     
 1455                                                       ;If line inputted did not contain RUN or SCRatch com-
 1456                                                       ;mand, program continues by testing for SAVE or LOAD
 1457                                                       ;commands. If it does not find either of these com-
 1458                                                       ;mands, then operator did not input an executive com-
 1459                                                       ;mand. Program then sets up to see if the first entry in
 1460                                                       ;the line inputted is a LINE NUMBER.
 1461                     
 1462  0939  1E BA        NOSCR:	MVI	E,LOW KW_SAVE                       ;Load E with address of SAVE in look up table
 1463  093B  16 01                   MVI	D,HIGH OLDPG1            ;Load D with page of look up table
 1464  093D  26 16                   MVI	H,HIGH OLDPG26           ;Load H with page of input line buffer
 1465  093F  2E 00                   MVI	L,OFS_LINE_INP_BUF       ;Set L to start of input line buffer
 1466  0941  CD DA 02                CALL	STRCP                   ;Call string compare subroutine to see if first word in
 1467  0944  CA 00 02                JZ	SAVE                      ;tt Input buffer is SAVE. If so, go to user's SAVE rtn
 1468  0947  2E BF                   MVI	L,OFS_EVAL_FINISH                   ;If not SAVE then load L with address of LOAD in look
 1469  0949  26 01                   MVI	H,HIGH OLDPG1            ;Up table and load H with page of look up table
 1470  094B  16 16                   MVI	D,HIGH OLDPG26           ;Load D with page of input line buffer
 1471  094D  1E 00                   MVI	E,OFS_LINE_INP_BUF                   ;And L to start of input line buffer
 1472  094F  CD DA 02                CALL	STRCP                   ;Call string compare subroutine to see if first word in
 1473  0952  CA 00 02                JZ	LOAD                      ;tt Input buffer is LOAD. If so, go to user's LOAD rtn
 1474  0955  2E F0                   MVI	L,OFS_TEMP_F0                   ;If not LOAD then set pointer to address of storage loc
 1475  0957  26 16                   MVI	H,HIGH OLDPG26           ;** For USER PROGRAM BUFFER pointer. Initialize this
 1476  0959  36 1B                   MVI	M,BGNPGRAM               ;tt Pointer to the starting address of the program buffer.
 1477  095B  2C                      INR	L                        ;Advance memory pntr. Since pointer storage requires
 1478  095C  36 00                   MVI	M,000H                   ;Two locations, initialize the low addr portion also.
 1479  095E  CD 00 02                CALL	SYNTAX                  ;Call the SYNTAX subroutine to obtain a TOKEN indi-
 1480  0961  2E 83                   MVI	L,OFS_TOKEN_STORE                   ;Cator which will be stored in this location. Upon return
 1481  0963  26 16                   MVI	H,HIGH OLDPG26           ;** From SYNTAX subroutine set memory pointer to
 1482  0965  7E                      MOV	A,M                      ;The TOKEN indicator storage location and fetch the
 1483  0966  A7                      ANA	A                        ;Value of the TOKEN. If the value of the syntax TOKEN
 1484  0967  F2 71 09                JP	SYNTOK                    ;Is positive then have a valid entry.
 1485  096A  3E D3        SYNERR:	MVI	A,0D3H                      ;However, if SYNTAX returns a negative value TOKEN
 1486  096C  0E D9                   MVI	C,0D9H                   ;Then have an error condition. Set up the letters SY in
