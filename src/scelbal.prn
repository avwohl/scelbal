 2807  1272  21 3C 00     	LXI H,FP_WORK_6E                ;For valid digit, set pointer to MSW of temporary
 2808  1275  4F           	MOV C,A                         ;Decimal to binary holding registers. Save character in C.
 2809  1276  3E F8        	MVI A,0F8H                      ;Form mask for sizing in accumulator. Now see if
 2810  1278  A6           	ANA M                           ;Holding register has enough room for the conversion of
