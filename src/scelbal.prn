  185                     ;;; Counters and Indicators
  186                     ;;; =========================================================================
  187                     
  188                     EXP_COUNTER:                            ; Exponent counter
  189  005F  00           	DB	000H
  190                     COL_COUNTER:                            ; Column counter
  191  0060  00           	DB	000H
  192                     SIGN_IND1:                              ; Sign indicator 1
  193  0061  00           	DB	000H
  194                     MD_SIGNS:                               ; M/D signs indicator
  195  0062  00           	DB	000H
  196                     BITS_COUNTER:                           ; Bits counter
  197  0063  00           	DB	000H
  198                     SIGN_IND2:                              ; Sign indicator 2
  199  0064  00           	DB	000H
  200                     EXP_SIGNS:                              ; Exponent sign indicator
  201  0065  00           	DB	000H
  202                     INP_DIG_CNT:                            ; Input digit counter
  203  0066  00           	DB	000H
  204                     TEMP_STORE:                             ; Temporary storage
  205                     EXP_TEMP:                               ; Exponent temp (alias for TEMP_STORE)
  206  0067  00           	DB	000H
  207                     OUT_DIG_CNT:                            ; Output digit counter
  208  0068  00           	DB	000H
  209                     FP_MODE_IND:                            ; FP mode indicator
  210  0069  00           	DB	000H
  211                     GETINP_CNT:                             ; GETINP counter
  212  006A  00           	DB	000H
  213                     ARITH_STKPTR:                           ; Arithmetic stack pointer
  214  006B  00           	DB	000H
