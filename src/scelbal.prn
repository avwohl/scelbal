 3800  1A14  21 21 00     PRIGH1:	LXI H,FPACC_MSW                 ;Load L with address of the MSW in the FPACC
 3801  1A17  7E           	MOV A,M                         ;Fetch MSW of FPACC into the ACC.
 3802  1A18  A7           	ANA A                           ;Test to see if value in FPACC is positive.
 3803  1A19  FA 75 1A     	JM OUTRNG                       ;If not, go display error message.
 3804  1A1C  CD D3 0E     	CALL FPFIX                      ;If O.K. then convert floating point to fixed point
 3805  1A1F  21 1F 00     	LXI H,FPACC                     ;Load L with address of LSAL of converted value
 3806  1A22  7E           	MOV A,M                         ;Fetch the LSW of the value into the ACC
 3807  1A23  D6 01        	SUI 001H                        ;Subtract one from the value to establish proper
 3808  1A25  07           	RLC                             ;Origin for future ops. Now rotate the value twice
 3809  1A26  07           	RLC                             ;To effectively multiply by four. Save the
 3810  1A27  4F           	MOV C,A                         ;Calculated result in CPU register C
 3811  1A28  21 B6 15     	LXI H,TOKEN_STORE               ;Load HL with address of F/A STACK TEMP
 3812  1A2B  7E           	MOV A,M                         ;Fetch the value into the accumulator
 3813  1A2C  EE FF        	XRI 0FFH                        ;Complement the value
 3814  1A2E  07           	RLC                             ;Rotate the value twice to multiply by four (the number
 3815  1A2F  07           	RLC                             ;Of bytes per entry in the ARRAY VARIABLES table).
 3816  1A30  C5           	PUSH B                          ;Save calculated subscript offset
 3817  1A31  4F           	MOV C,A                         ;Put table offset in C
 3818  1A32  06 00        	MVI B,000H                      ;Clear B for 16-bit add
 3819  1A34  21 83 16     	LXI H,ARRAY_VAR                 ;Load HL with base of ARRAY VARIABLES table
 3820  1A37  09           	DAD B                           ;Add offset to point to table entry
 3821  1A38  23           	INX H                           ;Move past the name
 3822  1A39  23           	INX H                           ;Now pointing to array values base address
 3823  1A3A  7E           	MOV A,M                         ;Fetch array values base address
 3824  1A3B  C1           	POP B                           ;Restore subscript offset in C
 3825  1A3C  81           	ADD C                           ;Add subscript offset to array values base
 3826  1A3D  4F           	MOV C,A                         ;Save low byte of address
 3827  1A3E  06 00        	MVI B,000H                      ;Clear B for 16-bit add
 3828  1A40  21 13 1C     	LXI H,ARRAY_VALUES              ;Load HL with base of ARRAY VALUES
 3829  1A43  09           	DAD B                           ;Add offset to get final array element address
 3830  1A44  C3 B1 11     	JMP FLOAD                       ;Load floating point value into FPACC and exit.
 3831                     
