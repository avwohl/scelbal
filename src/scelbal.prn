  567                                                       ;Subroutine to display a character string on the system's
  568                                                       ;display device.
  569                     
  570  02B9  4E           TEXTC:	MOV C,M                         ;Fetch (cc) from the first location in the buffer (H & L
  571  02BA  7E           	MOV A,M                         ;Pointing there upon entry) into register B and ACC.
  572  02BB  A7           	ANA A                           ;Test the character count value.
  573  02BC  C8           	RZ                              ;No display if (cc) is zero.
  574  02BD  CD 5C 02     TEXTCL:	CALL ADV                        ;Advance pointer to next location in buffer
  575  02C0  7E           	MOV A,M                         ;Fetch a character from the buffer into ACC
  576  02C1  CD E4 02     	CALL ECHO                       ;Call the user's display driver subroutine
  577  02C4  0D           	DCR C                           ;Decrement the (cc)
  578  02C5  C2 BD 02     	JNZ TEXTCL                      ;If character counter not zero, continue display
  579  02C8  C9           	RET                             ;Exit to caller when (cc) is zero.
  580                     
  581                                                       ;Subroutine to provide carriage-return and line-feed
  582                                                       ;combination to system's display device. Routine also
  583                                                       ;initializes a column counter to zero. Column counter
  584                                                       ;is used by selected output routines to count the num-
  585                                                       ;ber of characters that have been displayed on a line.
  586                     
  587  02C9  3E 8D        CRLF:	MVI A,08DH                      ;Load ASCII code for carriage-return into ACC
  588  02CB  CD E4 02     	CALL ECHO                       ;Call user provided display driver subroutine
  589  02CE  3E 8A        	MVI A,08AH                      ;Load ASCII code for line-feed into ACC
  590  02D0  CD E4 02     	CALL ECHO                       ;Call user provided display driver subroutine
  591  02D3  21 63 00     	LXI H,COL_COUNTER               ;Set L to point to COLUMN COUNTER storage location
  592  02D6  36 01        	MVI M,001H                      ;Initialize COLUMN COUNTER to a value of one
  593  02D8  62           	MOV H,D                         ;Restore H from D (saved by ECHO subroutine)
  594  02D9  6B           	MOV L,E                         ;Restore L from E (saved by ECHO subroutine)
  595  02DA  C9           	RET                             ;Then exit to calling routine
  596                     
  597                                                       ;Subroutine to decrement double-byte value in CPU
  598                                                       ;registers H and L.
  599                     
  600  02DB  2B           DEC:	DCX H                           ;Decrement HL (16-bit decrement)
  601  02DC  C9           	RET                             ;Return to caller
  602                     DECNO:                                  ;(Label kept for compatibility)
  603                     
