 3009                                                       ;Subroutine to exchange the contents of H & L with
 3010                                                       ;D & E.
 3011                     
 3012  12EE  4C           SWITCH:	MOV	C,H                         ;Transfer register H to C temporarily
 3013  12EF  62                      MOV	H,D                      ;Place value of D into H
 3014  12F0  51                      MOV	D,C                      ;Now put former H from C into D
 3015  12F1  4D                      MOV	C,L                      ;Transfer register L to C temporarily
 3016  12F2  6B                      MOV	L,E                      ;Place value of E into L
 3017  12F3  59                      MOV	E,C                      ;Now put former L from C into E
 3018  12F4  C9                      RET                          ;Exit to calling routine
 3019  12F5  26 01        GETINP:	MVI	H,HIGH OLDPG1               ;** Set H to page of GETINP character counter
 3020  12F7  2E 90                   MVI	L,OFS_GETINP_CNT                   ;Set L to address of GETINP character counter
 3021  12F9  4E                      MOV	C,M                      ;Load counter value into CPU register C
 3022  12FA  0C                      INR	C                        ;Exercise the counter in order
 3023  12FB  0D                      DCR	C                        ;To set CPU flags. If counter is non-zero, then indexing
 3024  12FC  C2 08 13                JNZ	NOT0                     ;Register (GETINP counter) is all set so jump ahead.
 3025  12FF  6B                      MOV	L,E                      ;But, if counter zero, then starting to process a new
 3026  1300  62                      MOV	H,D                      ;Character string. Transfer char string buffer pointer into
 3027  1301  4E                      MOV	C,M                      ;H & L and fetch the string's character count value (cc)
 3028  1302  0C                      INR	C                        ;Increment the (cc) by one to take account of (cc) byte
 3029  1303  CD 1E 13                CALL	INDEXC                  ;Add contents of regis C to H & L to point to end of the
 3030  1306  36 00                   MVI	M,000H                   ;Character string in buffer and place a zero byte marker
 3031  1308  2E 90        NOT0:	MVI	L,OFS_GETINP_CNT                        ;Set L back to address of GETINP counter which is used
 3032  130A  26 01                   MVI	H,HIGH OLDPG1            ;** As an indexing value. Set H to correct page.
 3033  130C  4E                      MOV	C,M                      ;Fetch the value of GETINP counter into register C
 3034  130D  0C                      INR	C                        ;Increment the value in C
 3035  130E  71                      MOV	M,C                      ;Restore the updated value for future use
 3036  130F  6B                      MOV	L,E                      ;Bring the base address of the character string buffer into
 3037  1310  62                      MOV	H,D                      ;CPU registers H & L
 3038  1311  CD 1E 13                CALL	INDEXC                  ;Add contents of register C to form indexed address of
 3039  1314  7E                      MOV	A,M                      ;Next character to be fetched as input. Fetch the next
 3040  1315  A7                      ANA	A                        ;Character. Exercise the CPU flags.
 3041  1316  26 01                   MVI	H,HIGH OLDPG1            ;** Restore page pointer to floating point working area
 3042  1318  C0                      RNZ                          ;If character is non-zero, not end of string, exit to calle
 3043  1319  2E 90                   MVI	L,OFS_GETINP_CNT                   ;If zero character, must reset GETINP counter for next
 3044  131B  36 00                   MVI	M,000H                   ;String. Reset pointer and clear GETINP counter to zero
 3045  131D  C9                      RET                          ;Then exit to calling routine
 3046                     
 3047                                                       ;Following subroutine causes register C to be used as an
 3048                                                       ;indexing register. Value in C is added to address in H
 3049                                                       ;and L to form new address.
 3050                     
 3051  131E  7D           INDEXC:	MOV	A,L                         ;Place value from register L into accumulator
 3052  131F  81                      ADD	C                        ;Add quantity in register C
 3053  1320  6F                      MOV	L,A                      ;Restore updated value back to L
 3054  1321  D0                      RNC                          ;Exit to caller if no carry from addition
 3055  1322  24                      INR	H                        ;But, if have carry then must increment register H
 3056  1323  C9                      RET                          ;Before returning to calling routine
