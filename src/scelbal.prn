   16                     ;;;
   17                     ;;; SCELBAL is the only open-source, floating-point
   18                     ;;; high-level language ever implemented on Intel's first
   19                     ;;; general-purpose microprocessor, the 8008.  It was
   20                     ;;; published in book form:
   21                     ;;;
   22                     ;;;  SCELBAL: A Higher-Level Language for 8008/8080 Systems
   23                     ;;;
   24                     ;;; (Tiny BASIC only used 16-bit integers; the MCM\70
   25                     ;;; was a closed system; calculators implemented with 8008
   26                     ;;; were floating-point, but not high-level.)
   27                     ;;;
   28                     ;;; This version is modified to assemble with the
   29                     ;;; as8 assembler (using the -octal option)
   30                     ;;; for the Intel 8008 by Thomas E. Jones.
   31                     ;;; This current form is made up non-relocatable so that
   32                     ;;; locations of all code and data is identical to the
   33                     ;;; original SCELBAL documents and patches.  It should be
   34                     ;;; reasonable after debugging code to convert this to a
   35                     ;;; relocatable and ROMable code with variables in RAM.
   36                     ;;; This code originates from a version made by
   37                     ;;;
   38                     ;;;    Steve Loboyko in 2001.
   39                     ;;;
   40                     ;;; This version has all 3 patches for SCELBAL (the two
   41                     ;;; pasted in the original manual, and a third which was
   42                     ;;; written in SCELBAL UPDATE publication, as well as
   43                     ;;; a couple changes to constants which didn't actually
   44                     ;;; require a patch, just changes to bytes of data or
   45                     ;;; arguments to an instruction--one of these (Tucker) was
   46                     ;;; incorrect and restored to original by MGA March 2012).
   47                     ;;;
   48                     ;;; This comment must be incorporated with any version of SCELBAL
   49                     ;;; downloaded, distributed, posted or disemenated.
   50                     
   51                     
   52                     ;;; CP/M BDOS equates
   53                     BDOS:           EQU	0005H           ; BDOS entry point
   54                     C_READ:         EQU	1               ; Console input
   55                     C_WRITE:        EQU	2               ; Console output
   56                     P_TERMCPM:      EQU	0               ; Warm boot / exit
   57                     
   58                     ;;; =========================================================================
   59                     ;;; CP/M Entry Point
   60                     ;;; =========================================================================
   61                     
   62  0000  C3 AA 07     	JMP EXEC                        ; Jump to main entry point
   63                     
   64                     ;;; =========================================================================
   65                     ;;; Floating Point Constants
   66                     ;;; =========================================================================
   67                     
   68                     FP_CONST_1:                             ; Floating point constant +1.0
   69  0003  00 00 40 01  	DB	000H,000H,040H,001H
   70                     FP_CONST_NEG1:                          ; Floating point constant -1.0
   71  0007  00 00 C0 01  	DB	000H,000H,0C0H,001H
   72                     FP_CONST_10:                            ; Floating point constant +10.0
   73  000B  00 00 50 04  	DB	000H,000H,050H,004H
   74                     FP_CONST_0P1:                           ; Floating point constant +0.1
   75  000F  67 66 66 FD  	DB	067H,066H,066H,0FDH
   76                     RND_CONST1:                             ; Random number generator constant
   77  0013  01 50 72 02  	DB	001H,050H,072H,002H
   78                     RND_CONST2:                             ; Random number generator constant
   79  0017  03 68 6F 0C  	DB	003H,068H,06FH,00CH
   80                     
   81                     ;;; =========================================================================
   82                     ;;; Floating Point Accumulator and Operand
   83                     ;;; =========================================================================
   84                     
   85                     FPACC_EXT:                              ; FPACC extension (4 bytes)
   86  001B  00 00 00     	DB	000H,000H,000H
   87                     FPACC_LSW_M1:                           ; Last byte of FPACC extension (used as LSW-1)
   88  001E  00           	DB	000H
   89                     FPACC:                                  ; FPACC (LSW, NSW, MSW, Exponent)
   90                     FPACC_LSW:
   91  001F  00           	DB	000H
   92                     FPACC_NSW:
   93  0020  00           	DB	000H
   94                     FPACC_MSW:
   95  0021  00           	DB	000H
   96                     FPACC_EXP:
   97  0022  00           	DB	000H
   98                     FPOP_EXT:                               ; FPOP extension (4 bytes)
   99  0023  00 00        	DB	000H,000H
  100                     FPOP_EXT_5B:                            ; FPOP extension offset 2
  101  0025  00           	DB	000H
  102                     FPOP_EXT_59:                            ; Last byte of FPOP extension
  103  0026  00           	DB	000H
  104                     FPOP:                                   ; FPOP (LSW, NSW, MSW, Exponent)
  105                     FPOP_LSW:
  106  0027  00           	DB	000H
  107                     FPOP_NSW:
  108  0028  00           	DB	000H
  109                     FPOP_MSW:
  110  0029  00           	DB	000H
  111                     FPOP_EXP:
  112  002A  00           	DB	000H
  113                     
