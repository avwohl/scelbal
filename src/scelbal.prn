 3606  18A8  21 85 16     FOR5:	LXI H,TEMP_085                  ;Load HL with address of the FOR/NEXT STACK pointer
 3607  18AB  7E           	MOV A,M                         ;Fetch the stack pointer to the ACC.
 3608  18AC  07           	RLC                             ;Rotate it left to multiply by two, then rotate it again to
 3609  18AD  07           	RLC                             ;Multiply by four for stack entry offset
 3610  18AE  C6 02        	ADI 002H                        ;Add 2 to point to variable name location in stack entry
 3611  18B0  4F           	MOV C,A                         ;Save offset in C
 3612  18B1  06 00        	MVI B,000H                      ;Clear B for 16-bit add
 3613  18B3  11 65 16     	LXI D,FN_STACK                  ;Load DE with base of FOR/NEXT STACK
 3614  18B6  79           	MOV A,C                         ;Get offset
 3615  18B7  83           	ADD E                           ;Add to low byte of base
 3616  18B8  5F           	MOV E,A                         ;Result in E
 3617  18B9  78           	MOV A,B                         ;Get 0
 3618  18BA  8A           	ADC D                           ;Add carry to high byte
 3619  18BB  57           	MOV D,A                         ;Result in D (DE now points to stack location)
 3620  18BC  21 6A 15     	LXI H,AUX_SYMBOL_BUF+1          ;Load HL with first character in AUX SYMBOL BUFFER
 3621  18BF  06 02        	MVI B,002H                      ;Set up register B as a number of bytes to move counter.
 3622  18C1  CD CB 0F     	CALL MOVEIT                     ;Move the variable name into the FOR/NEXT STACK.
 3623  18C4  CD 18 07     	CALL STOSYM                     ;Store initial variable value in the VARIABLES TABLE.
 3624  18C7  C3 F3 09     	JMP NXTLIN                      ;Continue with next line in user program buffer.
 3625                     
 3626                     
 3627  18CA  AF           PARSEP:	XRA A                           ;Clear accumulator to indicate end of expression
 3628  18CB  32 83 15     	STA PARSER_TOKEN                ;Set PARSER TOKEN to zero. Call the
 3629  18CE  CD BF 03     	CALL PARSER                     ;PARSER subroutine for final time for the expression.
 3630  18D1  21 6B 00     	LXI H,ARITH_STKPTR              ;Change L to point to the ARITH STACK pointer.
 3631  18D4  7E           	MOV A,M                         ;Fetch the ARITH STACK pointer value.
 3632  18D5  FE 98        	CPI 098H                        ;Should indicate only one value (answer) in stack.
 3633  18D7  C8           	RZ                              ;Exit with answer in FPACC if ARITH STACK is O.K.
 3634  18D8  C3 3B 08     	JMP SYNERR                      ;Else have a syntax error!
