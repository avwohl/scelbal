 1542                                                       ;The following subroutine, used by various sections of
 1543                                                       ;SCELBAL, will search the LINE INPUT BUGGER for
 1544                                                       ;a character string which is contained in a buffer starting
 1545                                                       ;at the address pointed to by CPU registers H & L when
 1546                                                       ;the subroutine is entered.
 1547                     
 1548  09B8  11 09 15     INSTR:	LXI D,LINE_INP_BUF              ;Load DE with starting location of LINE INPUT BUFFER
 1549  09BB  CD E1 09     INSTR1:	CALL ADVDE                      ;Advancer D & E pointer to the next location (input
 1550  09BE  CD AF 11     	CALL SAVEHL                     ;Buffer). Now save contents of d, E, H & L vefore the
 1551  09C1  46           	MOV B,M                         ;Compare operations. Get length of TEST buffer in B.
 1552  09C2  CD DA 01     	CALL ADV                        ;Advance H & L buffer to first char in TEST buffer.
 1553  09C5  CD D3 01     	CALL STRCPC                     ;Compare contents of TEST buffer against input buffer
