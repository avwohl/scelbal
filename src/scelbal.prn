  642  0306  21 A1 16     	LXI H,EVAL_PTR                  ;Set L to address of EVAL pointer (start of expression)
  643  0309  46           	MOV B,M                         ;Fetch the EVAL pointer value into register B
  644  030A  21 63 16     	LXI H,EVAL_CURRENT              ;Set up a working pointer register in this location
  645  030D  70           	MOV M,B                         ;And initialize EVAL CURRENT pointer
  646  030E  21 63 16     SCAN1:	LXI H,EVAL_CURRENT              ;Load L with address of EVAL CURRENT pointer
  647  0311  CD F2 01     	CALL GETCHR                     ;Fetch a character in the expression being evaluated
  648  0314  CA 46 04     	JZ SCAN10                       ;If character is a space, jump out of this section
  649  0317  FE AB        	CPI 0ABH                        ;See if character is a "+" sign
  650  0319  C2 24 03     	JNZ SCAN2                       ;If not, continue checking for an operator
  651  031C  21 61 16     	LXI H,PARSER_TOKEN              ;If yes, set pointer to PARSER TOKEN storage location
  652  031F  36 01        	MVI M,001H                      ;Place TOKEN value for "+" sign in PARSER TOKEN
  653  0321  C3 51 03     	JMP SCANFN                      ;Go to PARSER subroutine entry point
  654  0324  FE AD        SCAN2:	CPI 0ADH                        ;See if character is a minus ("-") sign
  655  0326  C2 57 03     	JNZ SCAN4                       ;If not, continue checking for an operator
  656  0329  21 37 16     	LXI H,SYMBOL_BUF                ;If yes, check the length of the symbol stored in the
  657  032C  7E           	MOV A,M                         ;SYMBOL BUFFER by fetching the (cc) byte
  658  032D  A7           	ANA A                           ;And testing to see if (cc) is zero
  659  032E  C2 4C 03     	JNZ SCAN3                       ;If length not zero, then not a unary minus indicator
  660  0331  21 61 16     	LXI H,PARSER_TOKEN              ;Else, check to see if last operator was a right parenthesi
  661  0334  7E           	MOV A,M                         ;By fetching the value in the PARSER TOKEN storage
  662  0335  FE 07        	CPI 007H                        ;Location and seeing if it is token value for ")"
  663  0337  CA 4C 03     	JZ SCAN3                        ;If last operator was I')" then do not have a unary minus
  664  033A  FE 03        	CPI 003H                        ;Check to see if last operator was C4*~2
