 2753  121C  21 6A 00     	LXI H,GETINP_CNT                ;If zero character, must reset GETINP counter for next
 2754  121F  36 00        	MVI M,000H                      ;String. Reset pointer and clear GETINP counter to zero
 2755  1221  C9           	RET                             ;Then exit to calling routine
