 2814  1280  04           	INR B                           ;Increment it to account for incoming digit.
 2815  1281  70           	MOV M,B                         ;Restore updated count to storage location.
 2816  1282  CD 42 13     	CALL DECBIN                     ;Call the DECimal to BINary conversion routine to add
 2817  1285  C3 52 12     	JMP NINPUT                      ;In the new digit in holding registers. Continue inputting.
 2818  1288  47           PERIOD:	MOV B,A                         ;Save character code in register B
 2819  1289  21 67 00     	LXI H,TEMP_STORE                ;Set pointer to PERIOD indicator storage location
 2820  128C  7E           	MOV A,M                         ;Fetch value in PERIOD indicator
 2821  128D  A7           	ANA A                           ;Exercise CPU flags
 2822  128E  C2 C5 09     	JNZ NUMERR                      ;If already have a period then display error message
 2823  1291  21 66 00     	LXI H,INP_DIG_CNT               ;If not, change pointer to digit counter storage location
 2824  1294  77           	MOV M,A                         ;Clear the digit counter back to zero
 2825  1295  23           	INX H                           ;Advance pointer to PERIOD indicator
 2826  1296  70           	MOV M,B                         ;Set the PERIOD indicator
 2827  1297  C3 52 12     	JMP NINPUT                      ;Continue processing the input character string
 2828  129A  CD FC 11     FNDEXP:	CALL GETINP                     ;Get next character in Exponent
 2829  129D  FE AB        	CPI 0ABH                        ;See if it is code for + sign
