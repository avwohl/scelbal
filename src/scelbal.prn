 3637  18DB  21 2B 00     SQRX:	LXI H,FP_TEMP                   ;Load L with address of FP TEMP registers
 3638  18DE  CD 90 11     	CALL FSTORE                     ;[Argument of SQR(X)] into FP TEMP for storage.
 3639  18E1  21 21 00     	LXI H,FPACC_MSW                 ;Load L with MSW of FPACC
 3640  18E4  7E           	MOV A,M                         ;Fetch the MSW into the accumulator
 3641  18E5  A7           	ANA A                           ;Check the sign of the number in the FPACC
 3642  18E6  FA 79 19     	JM SQRERR                       ;If number negative, cannot take square root
 3643  18E9  CA 94 05     	JZ CFALSE                       ;If number is zero, return with zero value in FPACC
 3644  18EC  21 2E 00     	LXI H,FP_TEMP_0F                ;Load L with address of FP TEMP Exponent register
 3645  18EF  7E           	MOV A,M                         ;Fetch the Exponent value into the ACC
 3646  18F0  A7           	ANA A                           ;Check sign of the Fxponent
 3647  18F1  FA FD 18     	JM NEGEXP                       ;If Exponent less than zero, process negative Exponent
 3648  18F4  1F           	RAR                             ;If Exponent positive, rotate right to divide by two
 3649  18F5  47           	MOV B,A                         ;And save the result in CPU register B
 3650  18F6  3E 00        	MVI A,000H                      ;Clear the accumulator without disturbing Carry bit
 3651  18F8  17           	RAL                             ;Rotate Carry bit into the ACC to save remainder
 3652  18F9  77           	MOV M,A                         ;Store the remainder back in FP TEMP Exponent reg.
 3653  18FA  C3 0E 19     	JMP SQREXP                      ;Jump to continue processing
 3654  18FD  47           NEGEXP:	MOV B,A                         ;For negative Exponent, form two Is complement by
 3655  18FE  AF           	XRA A                           ;Placing the positive value in CPU register B, clearing
 3656  18FF  90           	SUB B                           ;The accumulator, and then subtracting B from the ACC
 3657  1900  A7           	ANA A                           ;Clear the Carry bit after the complementing operation
 3658  1901  1F           	RAR                             ;Rotate the value right to divide by two
 3659  1902  47           	MOV B,A                         ;Save the result in CPU register B
 3660  1903  3E 00        	MVI A,000H                      ;Clear the accumulator without disturbing Carry bit
 3661  1905  8F           	ADC A                           ;Add Carry bit to the accumulator as remainder
 3662  1906  77           	MOV M,A                         ;Store the remainder back in FP TEMP Exponent reg
 3663  1907  CA 0B 19     	JZ NOREMD                       ;If remainder was zero skip ahead. If not, increment the
 3664  190A  04           	INR B                           ;Result of the divide by two ops to compen for negative
 3665  190B  AF           NOREMD:	XRA A                           ;Clear the accumulator
 3666  190C  90           	SUB B                           ;Subtract the quotient of the divide by two op to
 3667  190D  47           	MOV B,A                         ;Form two's complement and save the result in register B
 3668  190E  21 5F 00     SQREXP:	LXI H,EXP_COUNTER               ;Load L with address of TEMP register
 3669  1911  70           	MOV M,B                         ;Store Fxponent quotient from above ops in TEMP
 3670  1912  21 03 00     	LXI H,FP_CONST_1                ;Load L with address of FP registers containing +1.0
 3671  1915  1E 1C        	MVI E,01CH                      ;Load E with address of SQR APPROX working registers
 3672  1917  54           	MOV D,H                         ;Set D to same page as H
 3673  1918  06 04        	MVI B,004H                      ;Set up register B as a number of bytes to move counter
 3674  191A  CD CB 0F     	CALL MOVEIT                     ;Transfer value +1.0 into SQR APPROX registers
 3675  191D  CD 94 05     	CALL CFALSE                     ;Now clear the FPACC registers
 3676  1920  21 4F 00     	LXI H,COL_024                   ;Load L with address of LAST SQR APPROX temp regs.
 3677  1923  CD 90 11     	CALL FSTORE                     ;Initialize the LAST SQR APPROX regs to value of zero
 3678  1926  21 47 00     SQRLOP:	LXI H,FPACC_SAVE                ;Load L with address of SQR APPROX working registers
 3679  1929  CD 88 11     	CALL FLOAD                      ;Transfer SQR APPROX into the FPACC
 3680  192C  21 2B 00     	LXI H,FP_TEMP                   ;Load L with address of SQR ARG storage registers
 3681  192F  CD 98 11     	CALL OPLOAD                     ;Transfer SQR ARG into the FPOP
 3682  1932  CD A5 10     	CALL FPDIV                      ;Divde SQR ARG by SQR APPROX (Fon-n X/A)
 3683  1935  21 47 00     	LXI H,FPACC_SAVE                ;Load L with address of SQR APPROX registers
 3684  1938  CD 98 11     	CALL OPLOAD                     ;Transfer SQR APPROX into the FPOP
 3685  193B  CD 3D 0F     	CALL FPADD                      ;Add to form value (X/A + A)
 3686  193E  21 22 00     	LXI H,FPACC_EXP                 ;Load L with address of FPACC Exponent register
 3687  1941  46           	MOV B,M                         ;Fetch Exponent value into CPU register B
 3688  1942  05           	DCR B                           ;Subtract one to effectively divide FPACC by two
 3689  1943  70           	MOV M,B                         ;Restore to memory. (Now have ((X/A + A) /2)
 3690  1944  21 47 00     	LXI H,FPACC_SAVE                ;Load L with address of SQR APPROX registers
 3691  1947  CD 90 11     	CALL FSTORE                     ;Store contents of FPACC as new SQR APPROX
 3692  194A  21 4F 00     	LXI H,COL_024                   ;Load L with address of LAST SQR APPROX registers
 3693  194D  CD 98 11     	CALL OPLOAD                     ;Transfer LAST SQR APPROX into the FPOP
 3694  1950  CD DA 0F     	CALL FPSUB                      ;Subtract (LAST SQR APPROX - SQR APPROX)
 3695  1953  21 22 00     	LXI H,FPACC_EXP                 ;Load L with address of FPACC Exponent
 3696  1956  7E           	MOV A,M                         ;Fetch the Exponent into the accumulator
 3697  1957  FE F7        	CPI 0F7H                        ;See if difference less than 2 to the minus ninth
