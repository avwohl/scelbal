 2883  1304  C6 01        	ADI 001H                        ;By performing this two's complement
 2884  1306  77           	MOV M,A                         ;Restore the negated value to exponent storage location
 2885  1307  21 67 00     POSEXP:	LXI H,TEMP_STORE                ;Set pointer to PERIOD indicator storage location
 2886  130A  7E           	MOV A,M                         ;Fetch the contents of the PERIOD indicator
 2887  130B  A7           	ANA A                           ;Exercise the CPU flags
