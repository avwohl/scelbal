 3732  1998  21 4F 00     	LXI H,SCRATCH_PAD2              ;Load L with address of SEED storage registers
 3733  199B  CD 90 11     	CALL FSTORE                     ;Store I (SEED * A) + C] in former SEED registers
 3734  199E  21 22 00     	LXI H,FPACC_EXP                 ;Load L with address of FPACC Exponent register
 3735  19A1  7E           	MOV A,M                         ;Fetch Exponent value into the accumulator
 3736  19A2  D6 10        	SUI 010H                        ;Subtract 16 (decimal) to effectively divide by 65,536
 3737  19A4  77           	MOV M,A                         ;Now FPACC = [((SEED * A) + C)/65,536]
 3738  19A5  CD AA 0E     	CALL FPFIX                      ;Convert floating to fixed point to obtain integer part
 3739  19A8  AF           	XRA A                           ;Clear accumulator
 3740  19A9  32 1E 00     	STA FPACC_LSW_M1                ;Clear the FPACC Extension register
 3741  19AC  32 22 00     	STA FPACC_EXP                   ;Clear the FPACC Exponent register
 3742  19AF  CD E1 0E     	CALL FPFLT                      ;Fetch INT(((SEED * A) + C)/65,536) into the FPACC
 3743  19B2  21 22 00     	LXI H,FPACC_EXP                 ;Load L with address of FPACC Exponent
 3744  19B5  7E           	MOV A,M                         ;Fetch FPACC Exponent into the accumulator
 3745  19B6  C6 10        	ADI 010H                        ;Add 16 (decimal) to effectively multiply by 65,536
 3746  19B8  77           	MOV M,A                         ;(65,536 * INT[ ((SEED * A) + C)/65,5361) in FPACC
 3747  19B9  21 4F 00     	LXI H,SCRATCH_PAD2              ;Load L with address of [(SEED * A) + C]
 3748  19BC  CD 98 11     	CALL OPLOAD                     ;Transfer it into FPOP. Subtract FPACC to form
 3749  19BF  CD DA 0F     	CALL FPSUB                      ;[(SEED * A) + C] MOD 65,536
 3750  19C2  21 4F 00     	LXI H,SCRATCH_PAD2              ;Load L with address of former SEED registers
 3751  19C5  CD 90 11     	CALL FSTORE                     ;Store SEED MOD 65,536 in place of [(SEED * A) + Cl
 3752  19C8  21 22 00     	LXI H,FPACC_EXP                 ;Load L with address of FPACC Exponent
 3753  19CB  7E           	MOV A,M                         ;Fetch FPACC Exponent into the ACC and subtract
 3754  19CC  D6 10        	SUI 010H                        ;16 (decimal) to form (SEED MOD 65,536)/65,536
 3755  19CE  77           	MOV M,A                         ;So that random number in FPACC is between
 3756  19CF  C9           	RET                             ;0.0 and +1.0 and exit to calling routine
