 3874  1EC5  FA 29 1F     	JM OUTRNG                       ;If not, go display error message.
 3875  1EC8  CD 59 0F     	CALL FPFIX                      ;If O.K. then convert floating point to fixed point
 3876  1ECB  21 1F 00     	LXI H,FPACC                     ;Load L with address of LSAL of converted value
 3877  1ECE  7E           	MOV A,M                         ;Fetch the LSW of the value into the ACC
 3878  1ECF  D6 01        	SUI 001H                        ;Subtract one from the value to establish proper
 3879  1ED1  07           	RLC                             ;Origin for future ops. Now rotate the value twice
 3880  1ED2  07           	RLC                             ;To effectively multiply by four. Save the
 3881  1ED3  4F           	MOV C,A                         ;Calculated result in CPU register C
 3882  1ED4  21 66 16     	LXI H,TOKEN_STORE               ;Load HL with address of F/A STACK TEMP
