  994  05B2  21 1F 00     	LXI H,FPACC                     ;Fixed point. Load L with address of LSW of fixed nr
  995  05B5  46           	MOV B,M                         ;Fetch the LSW into CPU register B.
  996  05B6  21 5F 00     	LXI H,EXP_COUNTER               ;Set L to address of EXPONENT COUNTER
  997  05B9  70           	MOV M,B                         ;Place the fixed value in the EXP CNTR to indicate
  998  05BA  21 27 00     	LXI H,FPOP                      ;Number of multiplications needed (power). Now set HL
  999  05BD  11 2B 00     	LXI D,FP_TEMP                   ;to LSW of FPOP and DE to address of FP TEMP (LSW)
 1000  05C0  06 04        	MVI B,004H                      ;Set transfer (precision) counter. Call subroutine to move
 1001  05C2  CD CB 0F     	CALL MOVEIT                     ;Contents of FPOP into FP TEMP registers to save
 1002  05C5  CD 8E 05     	CALL FPONE                      ;Original value of FPOP. Now set FPACC to +1.0.
