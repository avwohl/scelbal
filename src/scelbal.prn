 3656  191A  7E           	MOV A,M                         ;Fetch the MSW into the accumulator
 3657  191B  A7           	ANA A                           ;Check the sign of the number in the FPACC
 3658  191C  FA AF 19     	JM SQRERR                       ;If number negative, cannot take square root
 3659  191F  CA 9D 05     	JZ CFALSE                       ;If number is zero, return with zero value in FPACC
 3660  1922  21 2E 00     	LXI H,FP_TEMP_0F                ;Load L with address of FP TEMP Exponent register
 3661  1925  7E           	MOV A,M                         ;Fetch the Exponent value into the ACC
 3662  1926  A7           	ANA A                           ;Check sign of the Fxponent
 3663  1927  FA 33 19     	JM NEGEXP                       ;If Exponent less than zero, process negative Exponent
 3664  192A  1F           	RAR                             ;If Exponent positive, rotate right to divide by two
 3665  192B  47           	MOV B,A                         ;And save the result in CPU register B
 3666  192C  3E 00        	MVI A,000H                      ;Clear the accumulator without disturbing Carry bit
 3667  192E  17           	RAL                             ;Rotate Carry bit into the ACC to save remainder
 3668  192F  77           	MOV M,A                         ;Store the remainder back in FP TEMP Exponent reg.
 3669  1930  C3 44 19     	JMP SQREXP                      ;Jump to continue processing
 3670  1933  47           NEGEXP:	MOV B,A                         ;For negative Exponent, form two Is complement by
 3671  1934  AF           	XRA A                           ;Placing the positive value in CPU register B, clearing
 3672  1935  90           	SUB B                           ;The accumulator, and then subtracting B from the ACC
 3673  1936  A7           	ANA A                           ;Clear the Carry bit after the complementing operation
 3674  1937  1F           	RAR                             ;Rotate the value right to divide by two
 3675  1938  47           	MOV B,A                         ;Save the result in CPU register B
 3676  1939  3E 00        	MVI A,000H                      ;Clear the accumulator without disturbing Carry bit
 3677  193B  8F           	ADC A                           ;Add Carry bit to the accumulator as remainder
 3678  193C  77           	MOV M,A                         ;Store the remainder back in FP TEMP Exponent reg
 3679  193D  CA 41 19     	JZ NOREMD                       ;If remainder was zero skip ahead. If not, increment the
 3680  1940  04           	INR B                           ;Result of the divide by two ops to compen for negative
 3681  1941  AF           NOREMD:	XRA A                           ;Clear the accumulator
 3682  1942  90           	SUB B                           ;Subtract the quotient of the divide by two op to
 3683  1943  47           	MOV B,A                         ;Form two's complement and save the result in register B
 3684  1944  21 5F 00     SQREXP:	LXI H,EXP_COUNTER               ;Load L with address of TEMP register
 3685  1947  70           	MOV M,B                         ;Store Fxponent quotient from above ops in TEMP
