 2915  128C  77                      MOV	M,A                      ;Restore rotated word to memory
 2916  128D  05                      DCR	B                        ;Decrement precision counter
 2917  128E  C8                      RZ                           ;Exit to caller when finished
 2918  128F  2D                      DCR	L                        ;Else decrement pointer to next byte
 2919  1290  C3 8A 12                JMP	ROTR                     ;Continue rotate right operations
 2920                     
 2921                                                       ;N'th precision subtraction subroutine.
 2922                                                       ;Number starting at location pointed to by D & E (least
 2923                                                       ;significant byte) is subtracted from number starting at
 2924                                                       ;address specified by contents of H & L.
 2925                     
 2926  1293  A7           SUBBER:	ANA	A                           ;Initialize the carry bit to zero upon entry
 2927  1294  7E           SUBTRA:	MOV	A,M                         ;Fetch byte from register group A
 2928  1295  CD EE 12                CALL	SWITCH                  ;Switch memory pointer to register group B
 2929  1298  9E                      SBB	M                        ;Subtract byte from group B ftom that in group A
 2930  1299  77                      MOV	M,A                      ;Leave result in register group B
 2931  129A  05                      DCR	B                        ;Decrement number of bytes (precision) counter
 2932  129B  C8                      RZ                           ;Return to caller when all bytes in group processed
 2933  129C  2C                      INR	L                        ;Else advance pointer for register group B
 2934  129D  CD EE 12                CALL	SWITCH                  ;Switch memory pointer back to register group A
 2935  12A0  2C                      INR	L                        ;Advance the pointer for register group A
 2936  12A1  C3 94 12                JMP	SUBTRA                   ;Continue the multi-byte subtraction operation
