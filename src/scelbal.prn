 3803  1A15  21 21 00     PRIGH1:	LXI H,FPACC_MSW                 ;Load L with address of the MSW in the FPACC
 3804  1A18  7E           	MOV A,M                         ;Fetch MSW of FPACC into the ACC.
 3805  1A19  A7           	ANA A                           ;Test to see if value in FPACC is positive.
 3806  1A1A  FA 76 1A     	JM OUTRNG                       ;If not, go display error message.
 3807  1A1D  CD D4 0E     	CALL FPFIX                      ;If O.K. then convert floating point to fixed point
 3808  1A20  21 1F 00     	LXI H,FPACC                     ;Load L with address of LSAL of converted value
 3809  1A23  7E           	MOV A,M                         ;Fetch the LSW of the value into the ACC
 3810  1A24  D6 01        	SUI 001H                        ;Subtract one from the value to establish proper
 3811  1A26  07           	RLC                             ;Origin for future ops. Now rotate the value twice
 3812  1A27  07           	RLC                             ;To effectively multiply by four. Save the
 3813  1A28  4F           	MOV C,A                         ;Calculated result in CPU register C
 3814  1A29  21 B7 15     	LXI H,TOKEN_STORE               ;Load HL with address of F/A STACK TEMP
 3815  1A2C  7E           	MOV A,M                         ;Fetch the value into the accumulator
 3816  1A2D  EE FF        	XRI 0FFH                        ;Complement the value
 3817  1A2F  07           	RLC                             ;Rotate the value twice to multiply by four (the number
 3818  1A30  07           	RLC                             ;Of bytes per entry in the ARRAY VARIABLES table).
 3819  1A31  C5           	PUSH B                          ;Save calculated subscript offset
 3820  1A32  4F           	MOV C,A                         ;Put table offset in C
 3821  1A33  06 00        	MVI B,000H                      ;Clear B for 16-bit add
 3822  1A35  21 84 16     	LXI H,ARRAY_VAR                 ;Load HL with base of ARRAY VARIABLES table
 3823  1A38  09           	DAD B                           ;Add offset to point to table entry
 3824  1A39  23           	INX H                           ;Move past the name
 3825  1A3A  23           	INX H                           ;Now pointing to array values base address
 3826  1A3B  7E           	MOV A,M                         ;Fetch array values base address
 3827  1A3C  C1           	POP B                           ;Restore subscript offset in C
 3828  1A3D  81           	ADD C                           ;Add subscript offset to array values base
 3829  1A3E  4F           	MOV C,A                         ;Save low byte of address
 3830  1A3F  06 00        	MVI B,000H                      ;Clear B for 16-bit add
 3831  1A41  21 14 1C     	LXI H,ARRAY_VALUES              ;Load HL with base of ARRAY VALUES
 3832  1A44  09           	DAD B                           ;Add offset to get final array element address
