 2757                                                       ;Following subroutine causes register C to be used as an
 2758                                                       ;indexing register. Value in C is added to address in H
 2759                                                       ;and L to form new address.
 2760                     
 2761  1222  7D           INDEXC:	MOV A,L                         ;Place value from register L into accumulator
