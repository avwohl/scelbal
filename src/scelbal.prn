 4164  2DD2  26 16                   MVI	H,HIGH OLDPG26           ;** Set H to page of the LOOP COUNTER
 4165  2DD4  46                      MOV	B,M                      ;Fetch the value in the LOOP COUNTER into the ACC
 4166  2DD5  0E 02                   MVI	C,002H                   ;Set up counter in register C future ops
 4167  2DD7  2E 4C                   MVI	L,OFS_ARRAY_VAR                   ;Load L with address of ARRAY VARIABLES
 4168  2DD9  26 17                   MVI	H,HIGH OLDPG27           ;** Table less four). Set H to page of the table.
