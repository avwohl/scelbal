 2343  1034  FA 43 10     	JM LINEUP                       ;If so, can align exponents. Go do it.
 2344  1037  7E           	MOV A,M                         ;If not, find out which number is largest. Fetch FPOP
 2345  1038  21 22 00     	LXI H,FPACC_EXP                 ;Exponent into ACC. Change pointer to FPACC Exp.
 2346  103B  96           	SUB M                           ;Subtract FPACC from FPOP. If result is negative then
 2347  103C  F8           	RM                              ;was larger. Return with answer in FPACC.
 2348  103D  21 1F 00     	LXI H,FPACC                     ;If result was positive, larger value in FPOP. Set pointers
 2349  1040  C3 0B 10     	JMP MOVOP                       ;To transfer FPOP into FPACC and then exit to caller.
 2350  1043  7E           LINEUP:	MOV A,M                         ;Fetch FPOP Exponent into accumulator.
 2351  1044  21 22 00     	LXI H,FPACC_EXP                 ;Change pointer to FPACC Exponent.
 2352  1047  96           	SUB M                           ;Subtract FPACC Exponent from FPOP Exponent. If
 2353  1048  FA 59 10     	JM SHIFT0                       ;Result is negative FPACC is larger. Go shift FPOP.
 2354  104B  4F           	MOV C,A                         ;If result positive FPOP larger, must shift FPACC. Store
 2355  104C  21 22 00     MORACC:	LXI H,FPACC_EXP                 ;Difference count in C. Reset pointer to FPACC Exp
 2356  104F  CD 81 10     	CALL SHLOOP                     ;Call the SHift LOOP to rotate FPACC mantissa RIGHT
 2357  1052  0D           	DCR C                           ;And INCREMENT Exponent. Decr difference counter
 2358  1053  C2 4C 10     	JNZ MORACC                      ;Continue rotate operations until diff counter is zero
 2359  1056  C3 64 10     	JMP SHACOP                      ;Go do final alignment and perform addition process
 2360  1059  4F           SHIFT0:	MOV C,A                         ;Routine to shift FPOP. Set difference count into reg. C
 2361  105A  21 2A 00     MOROP:	LXI H,FPOP_EXP                  ;Set pointer to FPOP Exponent.
 2362  105D  CD 81 10     	CALL SHLOOP                     ;Call the SHift LOOP to rotate FPOP mantissa RIGHT
 2363  1060  0C           	INR C                           ;And INCREMENT Exponent. Then incr difference cntr
 2364  1061  C2 5A 10     	JNZ MOROP                       ;Continue rotate opemtions until diff counter is zero
 2365                     ;;; The below two instructions are changed by PATCH NR.1
 2366                     ;;;SHACOP:    LLI 123                ;Set pointer to FPACC LSW minus one to provide extra
 2367                     ;;;           LMI 000                ;Byte for addition ops. Clear that location to zero.
 2368  1064  CD E7 17     SHACOP:	CALL PATCH1                     ; patch 1 initializes FP extension bytes
 2369  1067  7F           	MOV A,A
 2370                     
 2371                     ;;;           LLI 133
 2372                     ;;;           LMI 000                ;THIS IS PATCH #1
 2373  1068  21 22 00     	LXI H,FPACC_EXP                 ;Change pointer to FPACC Exponent
 2374  106B  CD 81 10     	CALL SHLOOP                     ;Rotate FPACC mantissa RIGHT & Increment Exponent
 2375  106E  21 2A 00     	LXI H,FPOP_EXP                  ;Change pointer to FPOP Exponent
 2376  1071  CD 81 10     	CALL SHLOOP                     ;Rotate FPOP mantissa RIGHT & Increment Exponent
 2377  1074  11 1E 00     	LXI D,FPACC_LSW_M1              ;Pointers to LSW minus one for both FPACC & FPOP
 2378  1077  06 04        	MVI B,004H                      ;(FPOP already set after SHLOOP). Set precision counter
 2379  1079  CD 1A 12     	CALL ADDER                      ;Call quad precision ADDITION subroutine.
 2380  107C  06 00        	MVI B,000H                      ;Set CPU register B to indicate standard normalization
 2381  107E  C3 9A 0F     	JMP FPNORM                      ;Go normalize the result and exit to caller.
 2382  1081  46           SHLOOP:	MOV B,M                         ;Shifting loop. First fetch Exponent currently being
 2383  1082  04           	INR B                           ;Pointed to and Increment the value by one.
 2384  1083  70           	MOV M,B                         ;Return the updated Exponent value to memory.
 2385  1084  2B           	DCX H                           ;Decrement the pointer to mantissa portion MSW
 2386  1085  06 04        	MVI B,004H                      ;Set precision counter
 2387  1087  7E           FSHIFT:	MOV A,M                         ;Fetch MSW of mantissa
 2388  1088  A7           	ANA A                           ;Set CPU flags after load ops
 2389  1089  F2 4C 12     	JP ROTATR                       ;If MSB not a one can do normal rotate ops
 2390  108C  17           BRING1:	RAL                             ;If MSB is a one need to set up carrv bit for the negative
 2391  108D  C3 4D 12     	JMP ROTR                        ;Number case. Then make special entry to ROTATR sub
 2392                     
 2393                                                       ;The following subroutine moves the contents of a string
 2394                                                       ;of memory locations from the address pointed to by
 2395                                                       ;CPU registers H & L to the address specified by the con-
 2396                                                       ;tents of registers D & E when the routine is entered. The
 2397                                                       ;process continues until the counter in register B is zero.
 2398                     
 2399  1090  7E           MOVEIT:	MOV A,M                         ;Fetch a word from memory string A
 2400  1091  23           	INX H                           ;Advance A string pointer (full 16-bit)
 2401  1092  CD AB 12     	CALL SWITCH                     ;Switch pointer to string B
 2402  1095  77           	MOV M,A                         ;Put word from string A into string B
 2403  1096  23           	INX H                           ;Advance B string pointer (full 16-bit)
 2404  1097  CD AB 12     	CALL SWITCH                     ;Switch pointer back to string A
 2405  109A  05           	DCR B                           ;Decrement loop counter
 2406  109B  C8           	RZ                              ;Return to calling routine when counter reaches zero
 2407  109C  C3 90 10     	JMP MOVEIT                      ;Else continue transfer operations
 2408                     
 2409                                                       ;The following subroutine SUBTRACTS the
 2410                                                       ;contents of the FLOATING POINT ACCUMULATOR from the
 2411                                                       ;contents of the FLOATING POINT OPERAND and
 2412                                                       ;leaves the result in the FPACC. The routine merely
 2413                                                       ;negates the value in the FPACC and then goes to the
 2414                                                       ;FPADD subroutine just presented.
 2415                     
 2416  109F  21 1F 00     FPSUB:	LXI H,FPACC                     ;Set L to address of LSW of FPACC
 2417  10A2  06 03        	MVI B,003H                      ;Set precision counter
 2418  10A4  CD 2B 12     	CALL COMPLM                     ;Two's complement the value in the FPACC
 2419  10A7  C3 03 10     	JMP FPADD                       ;Now go add the negated value to perform subtraction!
 2420                     
 2421                                                       ;The first part of the FLOATING POINT MULTIPLI-
 2422                                                       ;CATION subroutine calls a subroutine to check the
 2423                                                       ;original signs of the numbers that are to be multi-
 2424                                                       ;plied and perform working register clearing functions.
 2425                                                       ;Next the exponents of the numbers to be multiplied
 2426                                                       ;are added together.
 2427                     
 2428  10AA  CD 0A 11     FPMULT:	CALL CKSIGN                     ;Call routine to set up registers & ck signs of numbers
 2429  10AD  21 2A 00     ADDEXP:	LXI H,FPOP_EXP                  ;Set pointer to FPOP Exponent
 2430  10B0  7E           	MOV A,M                         ;Fetch FPOP Exponent into the accumulator
 2431  10B1  36 00        	MVI M,000H                      ;Clear FPOP_EXP for 6-byte extended add (byte 5)
 2432  10B3  23           	INX H                           ;Point to FP_TEMP[0]
 2433  10B4  36 00        	MVI M,000H                      ;Clear FP_TEMP[0] for 6-byte extended add (byte 6)
 2434  10B6  21 22 00     	LXI H,FPACC_EXP                 ;Change pointer to FPACC Exponent
 2435  10B9  86           	ADD M                           ;Add FPACC Exponent to FPOP Exponent
 2436  10BA  C6 01        	ADI 001H                        ;Add one more to total for algorithm compensation
 2437  10BC  77           	MOV M,A                         ;Store result in FPACC Exponent location
 2438  10BD  21 66 00     SETMCT:	LXI H,BITS_COUNTER              ;Change pointer to bit counter storage location
 2439  10C0  36 17        	MVI M,017H                      ;Initialize bit counter to 23 decimal
 2440                     
 2441                                                       ;Next portion of the FPMULT routine is the iinplernen-
 2442                                                       ;tation of the algorithm illustrated in the flow chart
 2443                                                       ;above. This portion multiplies the values of the two
 2444                                                       ;mantissas. The final value is rounded off to leave the
 2445                                                       ;23 most significant bits as the answer that is stored
 2446                                                       ;back in the FPACC.
 2447                     
 2448  10C2  21 21 00     MULTIP:	LXI H,FPACC_MSW                 ;Set pointer to MSW of FPACC mantissa
 2449  10C5  06 03        	MVI B,003H                      ;Set precision counter
 2450  10C7  CD 4C 12     	CALL ROTATR                     ;Rotate FPACC (multiplier) RIGHT into carry bit
 2451  10CA  DC 53 11     	CC ADOPPP                       ;If carry is a one, add multiplicand to partial-product
 2452  10CD  21 34 00     	LXI H,FP_WORK_66                ;Set pointer to partial-product most significant byte
 2453  10D0  06 06        	MVI B,006H                      ;Set precision counter (p-p register is double length)
 2454  10D2  CD 4C 12     	CALL ROTATR                     ;Shift partial-product RIGHT
 2455  10D5  21 66 00     	LXI H,BITS_COUNTER              ;Set pointer to bit counter storage location
 2456  10D8  4E           	MOV C,M                         ;Fetch current value of bit counter
 2457  10D9  0D           	DCR C                           ;Decrement the value of the bit counter
 2458  10DA  71           	MOV M,C                         ;Restore the updated bit counter to its storage location
 2459  10DB  C2 C2 10     	JNZ MULTIP                      ;If have not multiplied for 23 (deciinal) bits, keep going
 2460  10DE  21 34 00     	LXI H,FP_WORK_66                ;If have done 23 (decimal) bits, set pntr to p-p MSW
 2461  10E1  06 06        	MVI B,006H                      ;Set precision counter (for double length)
 2462  10E3  CD 4C 12     	CALL ROTATR                     ;Shift partial-product once more to the RIGHT
 2463  10E6  21 2F 00     	LXI H,FP_WORK_61                ;Set pointer to access 24'th bit in partial-product
 2464  10E9  7E           	MOV A,M                         ;Fetch the byte containing the 24'th bit
 2465  10EA  17           	RAL                             ;Position the 24'th bit to be MSB in the accumulator
 2466  10EB  A7           	ANA A                           ;Set the CPU flags after to rotate operation and test to
 2467  10EC  FC 5E 11     	CM MROUND                       ;See if 24'th bit of p-p is a ONE. If so, must round-off
 2468  10EF  21 1E 00     	LXI H,FPACC_LSW_M1              ;Now set up pointers
 2469  10F2  5D           	MOV E,L                         ;To perform transfer
 2470  10F3  54           	MOV D,H                         ;Of the multiplication results
 2471  10F4  21 2F 00     	LXI H,FP_WORK_61                ;From the partial-product location
 2472  10F7  06 04        	MVI B,004H                      ;To the FPACC
 2473                     
 2474                     
 2475  10F9  CD 90 10     EXMLDV:	CALL MOVEIT                     ;Perform the transfer from p-p to FPACC
 2476  10FC  06 00        	MVI B,000H                      ;Set up CPU register B to indicate regular normalization
 2477  10FE  CD 9A 0F     	CALL FPNORM                     ;Normalize the result of multiplication
 2478  1101  21 65 00     	LXI H,MD_SIGNS                  ;Now set the pointer to the original SIGNS indicator
 2479  1104  7E           	MOV A,M                         ;Fetch the indicator
 2480  1105  A7           	ANA A                           ;Exercise the CPU flags
 2481  1106  C0           	RNZ                             ;If indicator is non-zero, answer is positive, can exit her
 2482  1107  C3 FB 0F     	JMP FPCOMP                      ;If not, answer must be negated, exit via 2's complement.
 2483                     
 2484                                                       ;The following portions of the FPMULT
 2485                                                       ;routine set up working locations in memory by clearing
 2486                                                       ;locations for an expanded FPOP area and the partial-produc
 2487                                                       ;area. Next, the signs of the two numbers to be multiplied
 2488                                                       ;are examined. Negative numbers are negated
 2489                                                       ;in preparation for the multiplication
 2490                                                       ;algorithm. A SIGNS indicator register is set up during
 2491                                                       ;this process to indicate whether the final result of the
 2492                                                       ;multiplication should be positive or negative. (Negative
 2493                                                       ;if original signs of the two numbers to be multiplied are
 2494                                                       ;different.)
 2495                     
 2496  110A  21 2F 00     CKSIGN:	LXI H,FP_WORK_AREA              ;Set pointer to start of partial-product working area
 2497  110D  06 08        	MVI B,008H                      ;Set up a loop counter in CPU register B
 2498  110F  AF           	XRA A                           ;Clear the accumulator
 2499                     
 2500  1110  77           CLRNEX:	MOV M,A                         ;Now clear out locations for the partial-product
 2501  1111  23           	INX H                           ;Working registers
 2502  1112  05           	DCR B                           ;Until the loop counter
 2503  1113  C2 10 11     	JNZ CLRNEX                      ;Is zero
 2504  1116  06 04        CLROPL:	MVI B,004H                      ;Set a loop counter
 2505  1118  21 23 00     	LXI H,FPOP_EXT                  ;Set up pointer
 2506  111B  77           CLRNX1:	MOV M,A                         ;Clear out some extra registers so that the
 2507  111C  23           	INX H                           ;FPOP may be extended in length
 2508  111D  05           	DCR B                           ;Perform clearing ops until loop counter
 2509  111E  C2 1B 11     	JNZ CLRNX1                      ;Is zero
 2510  1121  21 65 00     	LXI H,MD_SIGNS                  ;Set pointer to M/D SIGNS indicator storage location
 2511  1124  36 01        	MVI M,001H                      ;Set initial value of SIGNS indicator to plus one
 2512  1126  21 21 00     	LXI H,FPACC_MSW                 ;Change pointer to MSW of FPACC
 2513  1129  7E           	MOV A,M                         ;Fetch MSW of mantissa into accumulator
 2514  112A  A7           	ANA A                           ;Test flags
 2515  112B  FA 42 11     	JM NEGFPA                       ;If MSB in MSW of FPACC is a one, number is negative
 2516  112E  21 29 00     OPSGNT:	LXI H,FPOP_MSW                  ;Set pointer to MSW of FPOP
 2517  1131  7E           	MOV A,M                         ;Fetch MSW of mantissa into accumulator
 2518  1132  A7           	ANA A                           ;Test flags
 2519  1133  F0           	RP                              ;Return to caller if number in FPOP is positive
 2520  1134  21 65 00     	LXI H,MD_SIGNS                  ;Else change pointer to M/D SIGNS indicator
 2521  1137  4E           	MOV C,M                         ;Fetch the value in the SIGNS indicator
 2522  1138  0D           	DCR C                           ;Decrement the value by one
 2523  1139  71           	MOV M,C                         ;Restore the new value back to storage location
 2524  113A  21 27 00     	LXI H,FPOP                      ;Set pointer to LSW of FPOP
 2525  113D  06 03        	MVI B,003H                      ;Set precision counter
 2526  113F  C3 2B 12     	JMP COMPLM                      ;Two's complement value of FPOP & return to caller
 2527  1142  21 65 00     NEGFPA:	LXI H,MD_SIGNS                  ;Set pointer to M/D SIGNS indicator
 2528  1145  4E           	MOV C,M                         ;Fetch the value in the SIGNS indicator
 2529  1146  0D           	DCR C                           ;Decrement the value by one
 2530  1147  71           	MOV M,C                         ;Restore the new value back to storage location
 2531  1148  21 1F 00     	LXI H,FPACC                     ;Set pointer to LSW of FPACC
 2532  114B  06 03        	MVI B,003H                      ;Set precision counter
 2533  114D  CD 2B 12     	CALL COMPLM                     ;Two's complement value of FPACC
 2534  1150  C3 2E 11     	JMP OPSGNT                      ;Proceed to check sign of FPOP
 2535                     
 2536                                                       ;The following subroutine adds the double length (six regis
 2537                                                       ;multiplicand in FPOP to the partial-product register when
 2538                                                       ;called on by the multiplication algorithm.
 2539                     
 2540  1153  11 2F 00     ADOPPP:	LXI D,FP_WORK_61                ;Pointer to LSW of partial-product
 2541  1156  21 26 00     	LXI H,FPOP_EXT_59               ;LSW of FPOP which contains extended multiplicand
 2542  1159  06 06        	MVI B,006H                      ;Set precision counter (double length working registers)
 2543  115B  C3 1A 12     	JMP ADDER                       ;Add multiplicand to partial-product & return to caller
 2544                     
 2545  115E  06 03        MROUND:	MVI B,003H                      ;Set up precision counter
 2546  1160  3E 40        	MVI A,040H                      ;Prepare to add one to 24'th bit of partial-product
 2547  1162  86           	ADD M                           ;Add one to the 24'th bit of the partial-product
 2548  1163  77           CROUND:	MOV M,A                         ;Restore the updated byte to memory
 2549  1164  23           	INX H                           ;Advance the memory pointer to next most significant
 2550  1165  3E 00        	MVI A,000H                      ;Byte of partial-product, then clear ACC without
 2551  1167  8E           	ADC M                           ;Disturbing carry bit. Now perform add with carry to
 2552  1168  05           	DCR B                           ;Propagate any rounding in the partial-product registers.
 2553  1169  C2 63 11     	JNZ CROUND                      ;If cotinter is not zero continue propagating any carry
 2554  116C  77           	MOV M,A                         ;Restore final byte to memory
 2555  116D  C9           	RET                             ;Exit to calling routine
 2556                     
 2557  116E  CD 0A 11     FPDIV:	CALL CKSIGN                     ;Call routine to set up registers & ck signs of numbers
 2558  1171  21 21 00     	LXI H,FPACC_MSW                 ;Set pointer to MSW of FPACC (divisor)
 2559  1174  7E           	MOV A,M                         ;Fetch MSW of FPACC to accumulator
 2560  1175  A7           	ANA A                           ;Exercise CPU flags
 2561  1176  CA 4D 0A     	JZ DVERR                        ;If MSW of FPACC is zero go display 'DZ' error message
 2562  1179  21 2A 00     SUBEXP:	LXI H,FPOP_EXP                  ;Set pointer to FPOP (dividend) Exponent
 2563  117C  7E           	MOV A,M                         ;Get FPOP Exponent into accumulator
 2564  117D  21 22 00     	LXI H,FPACC_EXP                 ;Change pointer to FPACC (divisor) Exponent
 2565  1180  96           	SUB M                           ;Subtract divisor exponent from dividend exponent
 2566  1181  C6 01        	ADI 001H                        ;Add one for algorithm compensation
 2567  1183  77           	MOV M,A                         ;Place result in FPACC Exponent
 2568  1184  21 66 00     SETDCT:	LXI H,BITS_COUNTER              ;Set pointer to bit counter storage location
 2569  1187  36 17        	MVI M,017H                      ;Initialize bit counter to 23 decimal
 2570  1189  21 47 16     	LXI H,AUX_SYMBOL_BUF            ;Clear quotient register before division
 2571  118C  AF           	XRA A                           ;Clear accumulator
 2572  118D  77           	MOV M,A                         ;Clear LSW of quotient
 2573  118E  23           	INX H
 2574  118F  77           	MOV M,A                         ;Clear NSW of quotient
 2575  1190  23           	INX H
 2576  1191  77           	MOV M,A                         ;Clear MSW of quotient
 2577                     
 2578                                                       ;Main division algorithm for mantissas
 2579                     
 2580  1192  CD 01 12     DIVIDE:	CALL SETSUB                     ;Go subtract divisor from dividend
 2581  1195  FA A9 11     	JM NOGO                         ;If result is negative then place a zero bit in quotient
 2582  1198  11 27 00     	LXI D,FPOP                      ;If result zero or positive then move remainder after
 2583  119B  21 47 00     	LXI H,DIV_WORK                  ;Subtraction from working area to become new dividend
 2584  119E  06 03        	MVI B,003H                      ;Set up moving pointers and initialize precision counter
 2585  11A0  CD 90 10     	CALL MOVEIT                     ;Perform the transfer
 2586  11A3  3E 01        	MVI A,001H                      ;Place a one into least significant bit of accumulator
 2587  11A5  1F           	RAR                             ;And rotate it out into the carry bit
 2588  11A6  C3 AA 11     	JMP QUOROT                      ;Proceed to rotate the carry bit into the current quotient
 2589  11A9  AF           NOGO:	XRA A                           ;When result is negative, put a zero in the carry bit, then
 2590  11AA  21 47 16     QUOROT:	LXI H,AUX_SYMBOL_BUF            ;Set up pointer to LSW of quotient register
 2591  11AD  06 03        	MVI B,003H                      ;Set precision counter
 2592  11AF  CD 43 12     	CALL ROTL                       ;Rotate carry bit into quotient by using special entry to
 2593  11B2  21 27 00     	LXI H,FPOP                      ;ROTATL subroutine. Now set up pointer to dividend
 2594  11B5  06 03        	MVI B,003H                      ;LSW and set precision counter
 2595  11B7  CD 42 12     	CALL ROTATL                     ;Rotate the current dividend to the left
 2596  11BA  21 66 00     	LXI H,BITS_COUNTER              ;Set pointer to bit counter storage location
 2597  11BD  4E           	MOV C,M                         ;Fetch the value of the bit counter
 2598  11BE  0D           	DCR C                           ;Decrement the value by one
 2599  11BF  71           	MOV M,C                         ;Restore the new counter value to storage
 2600  11C0  C2 92 11     	JNZ DIVIDE                      ;If bit counter is not zero, continue division process
 2601  11C3  CD 01 12     	CALL SETSUB                     ;After 23 (decimal) bits, do subtraction once more for
 2602  11C6  FA E8 11     	JM DVEXIT                       ;Possible rounding. Jump ahead if no rounding required.
 2603  11C9  21 47 16     	LXI H,AUX_SYMBOL_BUF            ;If rounding required set pointer to LSW of quotient
 2604  11CC  7E           	MOV A,M                         ;Fetch LSW of quotient to accumulator
 2605  11CD  C6 01        	ADI 001H                        ;Add one to 23rd bit of quotient
 2606  11CF  77           	MOV M,A                         ;Restore updated LSW of quotient
 2607  11D0  3E 00        	MVI A,000H                      ;Clear accumulator without disturbing carry bit
 2608  11D2  23           	INX H                           ;Advance pointer to next significant byte of quotient
 2609  11D3  8E           	ADC M                           ;Propagate any carry as part of rounding process
 2610  11D4  77           	MOV M,A                         ;Restore the updated byte of quotient
 2611  11D5  3E 00        	MVI A,000H                      ;Clear ACC again without disturbing carry bit
 2612  11D7  23           	INX H                           ;Advance pointer to MSW of quotient
 2613  11D8  8E           	ADC M                           ;Propagate any carry to finish rounding process
 2614  11D9  77           	MOV M,A                         ;Restore the updated byte of quotient
 2615  11DA  F2 E8 11     	JP DVEXIT                       ;If most significant bit of quotient is zero, go finish up
 2616  11DD  06 03        	MVI B,003H                      ;If not, set precision counter
 2617  11DF  CD 4C 12     	CALL ROTATR                     ;And rotate quotient to the right to clear the sign bit
 2618  11E2  21 22 00     	LXI H,FPACC_EXP                 ;Set pointer to FPACC Exponent
 2619  11E5  46           	MOV B,M                         ;Fetch FPACC exponent
 2620  11E6  04           	INR B                           ;Increment the value to compensate for the rotate right
 2621  11E7  70           	MOV M,B                         ;Restore the updated exponent value
 2622  11E8  21 47 16     DVEXIT:	LXI H,AUX_SYMBOL_BUF            ;Set up pointers to quotient
 2623  11EB  11 1F 00     	LXI D,FPACC                     ;To transfer the quotient into the FPACC
 2624  11EE  06 03        	MVI B,003H                      ;Set precision counter (3 bytes for mantissa)
 2625  11F0  CD 90 10     	CALL MOVEIT                     ;Perform the transfer
 2626  11F3  06 00        	MVI B,000H                      ;Set up CPU register B to indicate regular normalization
 2627  11F5  CD 9A 0F     	CALL FPNORM                     ;Normalize the result of division
 2628  11F8  21 65 00     	LXI H,MD_SIGNS                  ;Now set the pointer to the original SIGNS indicator
 2629  11FB  7E           	MOV A,M                         ;Fetch the indicator
 2630  11FC  A7           	ANA A                           ;Exercise the CPU flags
 2631  11FD  C0           	RNZ                             ;If indicator is non-zero, answer is positive, can exit here
 2632  11FE  C3 FB 0F     	JMP FPCOMP                      ;If not, answer must be negated, exit via 2's complement
 2633                     
 2634                                                       ;Subroutine to subtract divisor from dividend. Used by
 2635                                                       ;main DIVIDE subroutine.
 2636                     
 2637  1201  11 47 00     SETSUB:	LXI D,DIV_WORK                  ;Set pointer to LSW of working area (was FPOP_EXT_59)
 2638  1204  21 1F 00     	LXI H,FPACC                     ;Set pointer to LSW of FPACC (divisor)
 2639  1207  06 03        	MVI B,003H                      ;Set precision counter
 2640  1209  CD 90 10     	CALL MOVEIT                     ;Perform transfer
 2641  120C  11 47 00     	LXI D,DIV_WORK                  ;Reset pointer to LSW of working area (now divisor)
 2642  120F  21 27 00     	LXI H,FPOP                      ;Reset pointer to LSW of FPOP (dividend)
 2643  1212  06 03        	MVI B,003H                      ;Set precision counter
 2644  1214  CD 56 12     	CALL SUBBER                     ;Subtract divisor from dividend
 2645  1217  7E           	MOV A,M                         ;Get MSW of the result of the subtraction operations
 2646  1218  A7           	ANA A                           ;Exercise CPU flags
 2647  1219  C9           	RET                             ;Return to caller with status
 2648  121A  A7           ADDER:	ANA A                           ;Initialize the carry bit to zero upon entry
 2649  121B  7E           ADDMOR:	MOV A,M                         ;Fetch byte from register group A
 2650  121C  CD AB 12     	CALL SWITCH                     ;Switch memory pointer to register group B
 2651  121F  8E           	ADC M                           ;Add byte from A to byte from B with carry
 2652  1220  77           	MOV M,A                         ;Leave result in register group B
 2653  1221  05           	DCR B                           ;Decrement number of bytes (precision) counter
 2654  1222  C8           	RZ                              ;Return to caller when all bytes in group processed
 2655  1223  23           	INX H                           ;Else advance pointer for register group B
 2656  1224  CD AB 12     	CALL SWITCH                     ;Switch memory pointer back to register group A
 2657  1227  23           	INX H                           ;Advance the pointer for register group A
 2658  1228  C3 1B 12     	JMP ADDMOR                      ;Continue the multi-byte addition operation
 2659                     
 2660                                                       ;N'th precision two's complement (negate)
 2661                                                       ;subroutine. Performs a two's complement on the multi-byte
 2662                                                       ;registers tarting at the address pointed
 2663                                                       ; to by H & L (least significant byte) upon entry.
 2664                     
 2665  122B  7E           COMPLM:	MOV A,M                         ;Fetch the least significant byte of the number to ACC
 2666  122C  EE FF        	XRI 0FFH                        ;Exclusive OR to complement the byte
 2667  122E  C6 01        	ADI 001H                        ;Add one to form two's complement of byte
 2668  1230  77           MORCOM:	MOV M,A                         ;Restore the negated byte to memory
 2669  1231  1F           	RAR                             ;Save the carry bit
 2670  1232  57           	MOV D,A                         ;In CPU register D
 2671  1233  05           	DCR B                           ;Decrement number of bytes (precision) counter
 2672  1234  C8           	RZ                              ;Return to caller when all bytes in number processed
 2673  1235  23           	INX H                           ;Else advance the pointer
 2674  1236  7E           	MOV A,M                         ;Fetch the next byte of the number to ACC
 2675  1237  EE FF        	XRI 0FFH                        ;Exclusive OR to complement the byte
 2676  1239  5F           	MOV E,A                         ;Save complemented value in register E temporarily
 2677  123A  7A           	MOV A,D                         ;Restore previous carry status to ACC
 2678  123B  17           	RAL                             ;And rotate it out to the carry bit
 2679  123C  3E 00        	MVI A,000H                      ;Clear ACC without disturbing carry status
 2680  123E  8B           	ADC E                           ;Add in any carry to complemented value
 2681  123F  C3 30 12     	JMP MORCOM                      ;Continue the two's complement procedure as req'd
 2682                     
 2683                                                       ;N'th precision rotate left subroutine. Rotates a multi-
 2684                                                       ;byte number left starting at the address initially
 2685                                                       ;specified by the contents of CPU registers H & L upon
 2686                                                       ;subroutine entry (LSW). First entry point will clear
 2687                                                       ;the carry bit before beginning rotate operations. Second
 2688                                                       ;entry point does not clear the carry bit.
 2689                     
 2690  1242  A7           ROTATL:	ANA A                           ;Clear the carry bit at this entry point
 2691  1243  7E           ROTL:	MOV A,M                         ;Fetch a byte from memory
 2692  1244  17           	RAL                             ;Rotate it left (bring carry into LSB, push MSB to carry)
 2693  1245  77           	MOV M,A                         ;Restore rotated word to memory
 2694  1246  05           	DCR B                           ;Decrement precision counter
 2695  1247  C8           	RZ                              ;Exit to caller when finished
 2696  1248  23           	INX H                           ;Else advance pointer to next byte
 2697  1249  C3 43 12     	JMP ROTL                        ;Continue rotate left operations
 2698                     
 2699                     
 2700                                                       ;N'th precision rotate
 2701                                                       ;right subroutine. Opposite of
 2702                                                       ;above subroutine.
 2703                     
 2704  124C  A7           ROTATR:	ANA A                           ;Clear the carry bit at this entry point
 2705  124D  7E           ROTR:	MOV A,M                         ;Fetch a byte from memory
 2706  124E  1F           	RAR                             ;Rotate it right (carry into MSB, LSB to carry)
 2707  124F  77           	MOV M,A                         ;Restore rotated word to memory
 2708  1250  05           	DCR B                           ;Decrement precision counter
 2709  1251  C8           	RZ                              ;Exit to caller when finished
 2710  1252  2B           	DCX H                           ;Else decrement pointer to next byte
 2711  1253  C3 4D 12     	JMP ROTR                        ;Continue rotate right operations
 2712                     
 2713                                                       ;N'th precision subtraction subroutine.
 2714                                                       ;Number starting at location pointed to by D & E (least
 2715                                                       ;significant byte) is subtracted from number starting at
 2716                                                       ;address specified by contents of H & L.
 2717                     
 2718  1256  A7           SUBBER:	ANA A                           ;Initialize the carry bit to zero upon entry
 2719  1257  7E           SUBTRA:	MOV A,M                         ;Fetch byte from register group A
 2720  1258  CD AB 12     	CALL SWITCH                     ;Switch memory pointer to register group B
 2721  125B  9E           	SBB M                           ;Subtract byte from group B ftom that in group A
 2722  125C  77           	MOV M,A                         ;Leave result in register group B
 2723  125D  05           	DCR B                           ;Decrement number of bytes (precision) counter
 2724  125E  C8           	RZ                              ;Return to caller when all bytes in group processed
 2725  125F  23           	INX H                           ;Else advance pointer for register group B
 2726  1260  CD AB 12     	CALL SWITCH                     ;Switch memory pointer back to register group A
 2727  1263  23           	INX H                           ;Advance the pointer for register group A
 2728  1264  C3 57 12     	JMP SUBTRA                      ;Continue the multi-byte subtraction operation
 2729                     
 2730                                                       ;The next subroutine will transfer the four byte
 2731                                                       ;register string (generally a number in floating point
 2732                                                       ;format) from the starting address pointed to by CPU
 2733                                                       ;registers H & L when the subroutine is entered to
 2734                                                       ;the FPACC (floating point accumulator registers).
 2735                     
 2736  1267  11 1F 00     FLOAD:	LXI D,FPACC                     ;Set DE to address of least signficant byte of FPACC
 2737  126A  06 04        	MVI B,004H                      ;Set precision counter to four bytes (mantissa bytes
 2738  126C  C3 90 10     	JMP MOVEIT                      ;Plus Exponent) and exit via the transfer routine
 2739                     
 2740                                                       ;The next several subroutines are used to perform
 2741                                                       ;floating pojnt register loading and transfer operations.
 2742                     
 2743  126F  5D           FSTORE:	MOV E,L                         ;Transfer contents of register L to E
 2744  1270  54           	MOV D,H                         ;Transfer contents of register H to D
 2745  1271  21 1F 00     	LXI H,FPACC                     ;Set L to least significant byte of FPACC mantissa
 2746  1274  C3 7A 12     	JMP SETIT                       ;Go transfer FPACC contents to area pointed to by D&E
 2747  1277  11 27 00     OPLOAD:	LXI D,FPOP                      ;Set DE to least significant byte of FPOP
 2748  127A  06 04        SETIT:	MVI B,004H                      ;Set precision counter. Transfer from H & L area to
 2749  127C  C3 90 10     	JMP MOVEIT                      ;Locations pointed to by D & E
 2750                     
 2751                                                       ;The next subroutine perforins a double transfer opera-
 2752                                                       ;tion. It first transfers the contents of the FPACC into
 2753                                                       ;the FPOP. It then transfers new data (as pointed to by
 2754                                                       ;H & L upon entry to the subroutine) into the FPACC.
 2755                     
 2756  127F  CD 8E 12     FACXOP:	CALL SAVEHL                     ;Save contents of H & L upon entry to subroutine
 2757  1282  21 1F 00     	LXI H,FPACC                     ;Set pointer to FPACC LSW
 2758  1285  CD 77 12     	CALL OPLOAD                     ;Transfer FPACC to FPOP
 2759  1288  CD 9D 12     	CALL RESTHL                     ;Recover original subroutine entry values for H & L
 2760  128B  C3 67 12     	JMP FLOAD                       ;Transfer registers pointed to by H & L into the FPACC
 2761                     
 2762                                                       ;Subroutine to save the contents of CPU registers D, E, H
 2763                                                       ;and L in a temporary storage area in memory.
 2764                     
 2765  128E  7C           SAVEHL:	MOV A,H                         ;Transfer value in H to ACC
 2766  128F  45           	MOV B,L                         ;And value in L to B
 2767  1290  21 5E 00     	LXI H,TEMP_REGS                 ;Set HL to start of temporary storage locations
 2768  1293  77           	MOV M,A                         ;Save A (entry value of H) in memory
 2769  1294  23           	INX H                           ;Advance pointer
 2770  1295  70           	MOV M,B                         ;Save B (entry value of L) in memory
 2771  1296  23           	INX H                           ;Advance pointer
 2772  1297  72           	MOV M,D                         ;Save D in memory
 2773  1298  23           	INX H                           ;Advance pointer
 2774  1299  73           	MOV M,E                         ;Save E in memory
 2775  129A  67           	MOV H,A                         ;Restore entry value of H
 2776  129B  68           	MOV L,B                         ;Restore entry value of L
 2777  129C  C9           	RET                             ;Exit to calling routine
 2778                     
 2779                                                       ;Subroutine to restore the contents of CPU registers D,
 2780                                                       ;E, H and L from temporary storage in memory.
 2781                     
 2782  129D  21 5E 00     RESTHL:	LXI H,TEMP_REGS                 ;Set HL to start of temporary storage locations
 2783  12A0  7E           	MOV A,M                         ;Fetch stored value for H into ACC
 2784  12A1  23           	INX H                           ;Advance pointer
 2785  12A2  46           	MOV B,M                         ;Fetch stored value for L into B
 2786  12A3  23           	INX H                           ;Advance pointer
 2787  12A4  56           	MOV D,M                         ;Fetch stored value for D
 2788  12A5  23           	INX H                           ;Advance pointer
 2789  12A6  5E           	MOV E,M                         ;Fetch stored value for E
 2790  12A7  67           	MOV H,A                         ;Restore saved value for H
 2791  12A8  68           	MOV L,B                         ;Restore saved value for L
 2792  12A9  7E           	MOV A,M                         ;Leave stored value for E in ACC
 2793  12AA  C9           	RET                             ;Exit to calling routine
 2794                     
 2795                                                       ;Subroutine to exchange the contents of H & L with
 2796                                                       ;D & E.
 2797                     
 2798  12AB  4C           SWITCH:	MOV C,H                         ;Transfer register H to C temporarily
 2799  12AC  62           	MOV H,D                         ;Place value of D into H
 2800  12AD  51           	MOV D,C                         ;Now put former H from C into D
 2801  12AE  4D           	MOV C,L                         ;Transfer register L to C temporarily
 2802  12AF  6B           	MOV L,E                         ;Place value of E into L
 2803  12B0  59           	MOV E,C                         ;Now put former L from C into E
 2804  12B1  C9           	RET                             ;Exit to calling routine
 2805  12B2  21 6E 00     GETINP:	LXI H,GETINP_CNT                ;Set HL to address of GETINP character counter
 2806  12B5  4E           	MOV C,M                         ;Load counter value into CPU register C
 2807  12B6  0C           	INR C                           ;Exercise the counter in order
 2808  12B7  0D           	DCR C                           ;To set CPU flags. If counter is non-zero, then indexing
 2809  12B8  C2 C4 12     	JNZ NOT0                        ;Register (GETINP counter) is all set so jump ahead.
 2810  12BB  6B           	MOV L,E                         ;But, if counter zero, then starting to process a new
 2811  12BC  62           	MOV H,D                         ;Character string. Transfer char string buffer pointer into
 2812  12BD  4E           	MOV C,M                         ;H & L and fetch the string's character count value (cc)
 2813  12BE  0C           	INR C                           ;Increment the (cc) by one to take account of (cc) byte
 2814  12BF  CD D7 12     	CALL INDEXC                     ;Add contents of regis C to H & L to point to end of the
 2815  12C2  36 00        	MVI M,000H                      ;Character string in buffer and place a zero byte marker
 2816  12C4  21 6E 00     NOT0:	LXI H,GETINP_CNT                ;Set L back to address of GETINP counter which is used
 2817  12C7  4E           	MOV C,M                         ;Fetch the value of GETINP counter into register C
 2818  12C8  0C           	INR C                           ;Increment the value in C
 2819  12C9  71           	MOV M,C                         ;Restore the updated value for future use
 2820  12CA  6B           	MOV L,E                         ;Bring the base address of the character string buffer into
 2821  12CB  62           	MOV H,D                         ;CPU registers H & L
 2822  12CC  CD D7 12     	CALL INDEXC                     ;Add contents of register C to form indexed address of
 2823  12CF  7E           	MOV A,M                         ;Next character to be fetched as input. Fetch the next
 2824  12D0  A7           	ANA A                           ;Character. Exercise the CPU flags.
 2825  12D1  C0           	RNZ                             ;If character is non-zero, not end of string, exit to caller
 2826  12D2  AF           	XRA A                           ;If zero character, must reset GETINP counter for next
 2827  12D3  32 6E 00     	STA GETINP_CNT                  ;String. Clear GETINP counter to zero
 2828  12D6  C9           	RET                             ;Then exit to calling routine
 2829                     
 2830                                                       ;Following subroutine causes register C to be used as an
 2831                                                       ;indexing register. Value in C is added to address in H
 2832                                                       ;and L to form new address.
 2833                     
 2834  12D7  7D           INDEXC:	MOV A,L                         ;Place value from register L into accumulator
 2835  12D8  81           	ADD C                           ;Add quantity in register C
 2836  12D9  6F           	MOV L,A                         ;Restore updated value back to L
 2837  12DA  D0           	RNC                             ;Exit to caller if no carry from addition
 2838  12DB  24           	INR H                           ;But, if have carry then must increment register H
 2839  12DC  C9           	RET                             ;Before returning to calling routine
