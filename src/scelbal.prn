 1311  082C  CD B8 01     	CALL STRCP                      ;Call string compare subroutine to see if first word in
 1312  082F  CA B6 00     	JZ SAVE                         ;tt Input buffer is SAVE. If so, go to user's SAVE rtn
 1313  0832  21 7D 00     	LXI H,KW_LOAD                   ;If not SAVE then load HL with address of LOAD
 1314  0835  11 38 15     	LXI D,LINE_INP_BUF              ;And DE to start of input line buffer
 1315  0838  CD B8 01     	CALL STRCP                      ;Call string compare subroutine to see if first word in
