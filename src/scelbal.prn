 2361  0FEF  86           	ADD M                           ;Add FPACC Exponent to FPOP Exponent
 2362  0FF0  C6 01        	ADI 001H                        ;Add one more to total for algorithm compensation
 2363  0FF2  77           	MOV M,A                         ;Store result in FPACC Exponent location
 2364  0FF3  21 63 00     SETMCT:	LXI H,BITS_COUNTER              ;Change pointer to bit counter storage location
 2365  0FF6  36 17        	MVI M,017H                      ;Initialize bit counter to 23 decimal
 2366                     
 2367                                                       ;Next portion of the FPMULT routine is the iinplernen-
 2368                                                       ;tation of the algorithm illustrated in the flow chart
 2369                                                       ;above. This portion multiplies the values of the two
 2370                                                       ;mantissas. The final value is rounded off to leave the
 2371                                                       ;23 most significant bits as the answer that is stored
 2372                                                       ;back in the FPACC.
 2373                     
 2374  0FF8  21 21 00     MULTIP:	LXI H,FPACC_MSW                 ;Set pointer to MSW of FPACC mantissa
 2375  0FFB  06 03        	MVI B,003H                      ;Set precision counter
 2376  0FFD  CD 6D 11     	CALL ROTATR                     ;Rotate FPACC (multiplier) RIGHT into carry bit
 2377  1000  DC 89 10     	CC ADOPPP                       ;If carry is a one, add multiplicand to partial-product
 2378  1003  21 34 00     	LXI H,FP_WORK_66                ;Set pointer to partial-product most significant byte
 2379  1006  06 06        	MVI B,006H                      ;Set precision counter (p-p register is double length)
 2380  1008  CD 6D 11     	CALL ROTATR                     ;Shift partial-product RIGHT
 2381  100B  21 63 00     	LXI H,BITS_COUNTER              ;Set pointer to bit counter storage location
 2382  100E  4E           	MOV C,M                         ;Fetch current value of bit counter
 2383  100F  0D           	DCR C                           ;Decrement the value of the bit counter
 2384  1010  71           	MOV M,C                         ;Restore the updated bit counter to its storage location
 2385  1011  C2 F8 0F     	JNZ MULTIP                      ;If have not multiplied for 23 (deciinal) bits, keep going
 2386  1014  21 34 00     	LXI H,FP_WORK_66                ;If have done 23 (decimal) bits, set pntr to p-p MSW
 2387  1017  06 06        	MVI B,006H                      ;Set precision counter (for double length)
 2388  1019  CD 6D 11     	CALL ROTATR                     ;Shift partial-product once more to the RIGHT
 2389  101C  21 31 00     	LXI H,FP_WORK_63                ;Set pointer to access 24'th bit in partial-product
 2390  101F  7E           	MOV A,M                         ;Fetch the byte containing the 24'th bit
 2391  1020  17           	RAL                             ;Position the 24'th bit to be MSB in the accumulator
 2392  1021  A7           	ANA A                           ;Set the CPU flags after to rotate operation and test to
 2393  1022  FC 95 10     	CM MROUND                       ;See if 24'th bit of p-p is a ONE. If so, must round-off
 2394  1025  21 1E 00     	LXI H,FPACC_LSW_M1              ;Now set up pointers
 2395  1028  5D           	MOV E,L                         ;To perform transfer
 2396  1029  54           	MOV D,H                         ;Of the multiplication results
 2397  102A  21 31 00     	LXI H,FP_WORK_63                ;From the partial-product location
 2398  102D  06 04        	MVI B,004H                      ;To the FPACC
 2399                     
 2400                     
 2401  102F  CD CB 0F     EXMLDV:	CALL MOVEIT                     ;Perform the transfer from p-p to FPACC
 2402  1032  06 00        	MVI B,000H                      ;Set up CPU register B to indicate regular normalization
 2403  1034  CD E3 0E     	CALL FPNORM                     ;Normalize the result of multiplication
 2404  1037  21 62 00     	LXI H,MD_SIGNS                  ;Now set the pointer to the original SIGNS indicator
 2405  103A  7E           	MOV A,M                         ;Fetch the indicator
 2406  103B  A7           	ANA A                           ;Exercise the CPU flags
 2407  103C  C0           	RNZ                             ;If indicator is non-zero, answer is positive, can exit her
 2408  103D  C3 35 0F     	JMP FPCOMP                      ;If not, answer must be negated, exit via 2's complement.
 2409                     
 2410                                                       ;The following portions of the FPMULT
 2411                                                       ;routine set up working locations in memory by clearing
 2412                                                       ;locations for an expanded FPOP area and the partial-produc
 2413                                                       ;area. Next, the signs of the two numbers to be multiplied
 2414                                                       ;are examined. Negative numbers are negated
 2415                                                       ;in preparation for the multiplication
 2416                                                       ;algorithm. A SIGNS indicator register is set up during
 2417                                                       ;this process to indicate whether the final result of the
 2418                                                       ;multiplication should be positive or negative. (Negative
 2419                                                       ;if original signs of the two numbers to be multiplied are
 2420                                                       ;different.)
 2421                     
 2422  1040  21 2F 00     CKSIGN:	LXI H,FP_WORK_AREA              ;Set pointer to start of partial-product working area
 2423  1043  06 08        	MVI B,008H                      ;Set up a loop counter in CPU register B
 2424  1045  AF           	XRA A                           ;Clear the accumulator
 2425                     
 2426  1046  77           CLRNEX:	MOV M,A                         ;Now clear out locations for the partial-product
 2427  1047  23           	INX H                           ;Working registers
 2428  1048  05           	DCR B                           ;Until the loop counter
 2429  1049  C2 46 10     	JNZ CLRNEX                      ;Is zero
 2430  104C  06 04        CLROPL:	MVI B,004H                      ;Set a loop counter
 2431  104E  21 23 00     	LXI H,FPOP_EXT                  ;Set up pointer
 2432  1051  77           CLRNX1:	MOV M,A                         ;Clear out some extra registers so that the
 2433  1052  23           	INX H                           ;FPOP may be extended in length
 2434  1053  05           	DCR B                           ;Perform clearing ops until loop counter
 2435  1054  C2 51 10     	JNZ CLRNX1                      ;Is zero
 2436  1057  21 62 00     	LXI H,MD_SIGNS                  ;Set pointer to M/D SIGNS indicator storage location
 2437  105A  36 01        	MVI M,001H                      ;Set initial value of SIGNS indicator to plus one
 2438  105C  21 21 00     	LXI H,FPACC_MSW                 ;Change pointer to MSW of FPACC
 2439  105F  7E           	MOV A,M                         ;Fetch MSW of mantissa into accumulator
 2440  1060  A7           	ANA A                           ;Test flags
 2441  1061  FA 78 10     	JM NEGFPA                       ;If MSB in MSW of FPACC is a one, number is negative
 2442  1064  21 29 00     OPSGNT:	LXI H,FPOP_MSW                  ;Set pointer to MSW of FPOP
 2443  1067  7E           	MOV A,M                         ;Fetch MSW of mantissa into accumulator
 2444  1068  A7           	ANA A                           ;Test flags
 2445  1069  F0           	RP                              ;Return to caller if number in FPOP is positive
 2446  106A  21 62 00     	LXI H,MD_SIGNS                  ;Else change pointer to M/D SIGNS indicator
 2447  106D  4E           	MOV C,M                         ;Fetch the value in the SIGNS indicator
 2448  106E  0D           	DCR C                           ;Decrement the value by one
 2449  106F  71           	MOV M,C                         ;Restore the new value back to storage location
 2450  1070  21 27 00     	LXI H,FPOP                      ;Set pointer to LSW of FPOP
 2451  1073  06 03        	MVI B,003H                      ;Set precision counter
 2452  1075  C3 4C 11     	JMP COMPLM                      ;Two's complement value of FPOP & return to caller
 2453  1078  21 62 00     NEGFPA:	LXI H,MD_SIGNS                  ;Set pointer to M/D SIGNS indicator
 2454  107B  4E           	MOV C,M                         ;Fetch the value in the SIGNS indicator
 2455  107C  0D           	DCR C                           ;Decrement the value by one
 2456  107D  71           	MOV M,C                         ;Restore the new value back to storage location
 2457  107E  21 1F 00     	LXI H,FPACC                     ;Set pointer to LSW of FPACC
 2458  1081  06 03        	MVI B,003H                      ;Set precision counter
 2459  1083  CD 4C 11     	CALL COMPLM                     ;Two's complement value of FPACC
 2460  1086  C3 64 10     	JMP OPSGNT                      ;Proceed to check sign of FPOP
 2461                     
 2462                                                       ;The following subroutine adds the double length (six regis
 2463                                                       ;multiplicand in FPOP to the partial-product register when
 2464                                                       ;called on by the multiplication algorithm.
 2465                     
 2466  1089  11 2F 00     ADOPPP:	LXI D,FP_WORK_61                ;Pointer to LSW of partial-product
 2467  108C  54           	MOV D,H                         ;On same page as FPOP
 2468  108D  21 26 00     	LXI H,FPOP_EXT_59               ;LSIV of FPOP which contains extended multiplicand
 2469  1090  06 06        	MVI B,006H                      ;Set precision counter (double length working registers)
 2470  1092  C3 3B 11     	JMP ADDER                       ;Add multiplicand to partial-product & return to caller
 2471                     
 2472  1095  06 03        MROUND:	MVI B,003H                      ;Set up precision counter
 2473  1097  3E 40        	MVI A,040H                      ;Prepare to add one to 24'th bit of partial-product
 2474  1099  86           	ADD M                           ;Add one to the 24'th bit of the partial-product
 2475  109A  77           CROUND:	MOV M,A                         ;Restore the updated byte to memory
 2476  109B  23           	INX H                           ;Advance the memory pointer to next most significant
 2477  109C  3E 00        	MVI A,000H                      ;Byte of partial-product, then clear ACC without
 2478  109E  8E           	ADC M                           ;Disturbing carry bit. Now perform add with carry to
 2479  109F  05           	DCR B                           ;Propagate any rounding in the partial-product registers.
 2480  10A0  C2 9A 10     	JNZ CROUND                      ;If cotinter is not zero continue propagating any carry
 2481  10A3  77           	MOV M,A                         ;Restore final byte to memory
 2482  10A4  C9           	RET                             ;Exit to calling routine
 2483                     
 2484  10A5  CD 40 10     FPDIV:	CALL CKSIGN                     ;Call routine to set up registers & ck signs of numbers
 2485  10A8  21 21 00     	LXI H,FPACC_MSW                 ;Set pointer to MSW of FPACC (divisor)
 2486  10AB  7E           	MOV A,M                         ;Fetch MSW of FPACC to accumulator
 2487  10AC  A7           	ANA A                           ;Exercise CPU flags
 2488  10AD  CA 9E 09     	JZ DVERR                        ;If MSW of FPACC is zero go display 'DZ' error message
 2489  10B0  21 2A 00     SUBEXP:	LXI H,FPOP_EXP                  ;Set pointer to FPOP (dividend) Exponent
 2490  10B3  7E           	MOV A,M                         ;Get FPOP Exponent into accumulator
 2491  10B4  21 22 00     	LXI H,FPACC_EXP                 ;Change pointer to FPACC (divisor) Exponent
 2492  10B7  96           	SUB M                           ;Subtract divisor exponent from dividend exponent
 2493  10B8  C6 01        	ADI 001H                        ;Add one for algorithm compensation
 2494  10BA  77           	MOV M,A                         ;Place result in FPACC Exponent
 2495  10BB  21 63 00     SETDCT:	LXI H,BITS_COUNTER              ;Set pointer to bit counter storage location
 2496  10BE  36 17        	MVI M,017H                      ;Initialize bit counter to 23 decimal
 2497                     
 2498                                                       ;Main division algorithm for mantissas
 2499                     
 2500  10C0  CD 21 11     DIVIDE:	CALL SETSUB                     ;Go subtmct divisor from dividend
 2501  10C3  FA D7 10     	JM NOGO                         ;If result is negative then place a zero bit in quotient
 2502  10C6  11 27 00     	LXI D,FPOP                      ;If result zero or positive then move remainder after
 2503  10C9  21 26 00     	LXI H,FPOP_EXT_59               ;Subtraction from working area to become new dividend
 2504  10CC  06 03        	MVI B,003H                      ;Set up moving pointers and initialize precision counter
 2505  10CE  CD CB 0F     	CALL MOVEIT                     ;Perform the transfer
 2506  10D1  3E 01        	MVI A,001H                      ;Place a one into least significant bit of accumulator
 2507  10D3  1F           	RAR                             ;And rotate it out into the carry bit
 2508  10D4  C3 D8 10     	JMP QUOROT                      ;Proceed to rotate the carry bit into the current quotient
 2509  10D7  AF           NOGO:	XRA A                           ;When result is negative, put a zero in the carry bit, then
 2510  10D8  21 69 15     QUOROT:	LXI H,AUX_SYMBOL_BUF            ;Set up pointer to LSW of quotient register
 2511  10DB  06 03        	MVI B,003H                      ;Set precision counter
 2512  10DD  CD 64 11     	CALL ROTL                       ;Rotate carry bit into quotient by using special entry to
 2513  10E0  21 27 00     	LXI H,FPOP                      ;ROTATL subroutine. Now set up pointer to dividend
 2514  10E3  06 03        	MVI B,003H                      ;LSW and set precision counter
 2515  10E5  CD 63 11     	CALL ROTATL                     ;Rotate the current dividend to the left
 2516  10E8  21 63 00     	LXI H,BITS_COUNTER              ;Set pointer to bit counter storage location
 2517  10EB  4E           	MOV C,M                         ;Fetch the value of the bit counter
 2518  10EC  0D           	DCR C                           ;Decrement the value by one
 2519  10ED  71           	MOV M,C                         ;Restore the new counter value to storage
 2520  10EE  C2 C0 10     	JNZ DIVIDE                      ;If bit counter is not zero, continue division process
 2521  10F1  CD 21 11     	CALL SETSUB                     ;After 23 (decimal) bits, do subtraction once more for
 2522  10F4  FA 16 11     	JM DVEXIT                       ;Possible rounding. Jump ahead if no rounding required.
 2523  10F7  21 69 15     	LXI H,AUX_SYMBOL_BUF            ;If rounding required set pointer to LSW of quotient
 2524  10FA  7E           	MOV A,M                         ;Fetch LSW of quotient to accumulator
 2525  10FB  C6 01        	ADI 001H                        ;Add one to 23rd bit of quotient
 2526  10FD  77           	MOV M,A                         ;Restore updated LSW of quotient
 2527  10FE  3E 00        	MVI A,000H                      ;Clear accumulator without disturbing carry bit
 2528  1100  23           	INX H                           ;Advance pointer to next significant byte of quotient
 2529  1101  8E           	ADC M                           ;Propagate any carry as part of rounding process
 2530  1102  77           	MOV M,A                         ;Restore the updated byte of quotient
 2531  1103  3E 00        	MVI A,000H                      ;Clear ACC again without disturbing carry bit
 2532  1105  23           	INX H                           ;Advance pointer to MSW of quotient
 2533  1106  8E           	ADC M                           ;Propagate any carry to finish rounding process
 2534  1107  77           	MOV M,A                         ;Restore the updated byte of quotient
 2535  1108  F2 16 11     	JP DVEXIT                       ;If most significant bit of quotient is zero, go finish up
 2536  110B  06 03        	MVI B,003H                      ;If not, set precision counter
 2537  110D  CD 6D 11     	CALL ROTATR                     ;And rotate quotient to the right to clear the sign bit
 2538  1110  21 22 00     	LXI H,FPACC_EXP                 ;Set pointer to FPACC Exponent
 2539  1113  46           	MOV B,M                         ;Fetch FPACC exponent
 2540  1114  04           	INR B                           ;Increment the value to compensate for the rotate right
 2541  1115  70           	MOV M,B                         ;Restore the updated exponent value
 2542  1116  21 31 00     DVEXIT:	LXI H,FP_WORK_63                ;Set up pointers
 2543  1119  11 1E 00     	LXI D,FPACC_LSW_M1              ;To transfer the quotient into the FPACC
 2544  111C  06 04        	MVI B,004H                      ;Set precision counter
 2545                                                       ;THIS IS A CORRECTION FOUND IN THE NOTES
 2546  111E  C3 2F 10     	JMP EXMLDV                      ;And exit through FPMULT routine at EXMLDV
 2547                     
 2548                                                       ;Subroutine to subtract divisor from dividend. Used by
 2549                                                       ;main DIVIDE subroutine.
 2550                     
 2551  1121  11 26 00     SETSUB:	LXI D,FPOP_EXT_59               ;Set pointer to LSW of working area
 2552  1124  54           	MOV D,H                         ;On same page as FPACC
 2553  1125  21 1F 00     	LXI H,FPACC                     ;Set pointer to LSW of FPACC (divisor)
 2554  1128  06 03        	MVI B,003H                      ;Set precision counter
 2555  112A  CD CB 0F     	CALL MOVEIT                     ;Perform transfer
 2556  112D  11 26 00     	LXI D,FPOP_EXT_59               ;Reset pointer to LSW of working area (now divisor)
 2557  1130  21 27 00     	LXI H,FPOP                      ;Reset pointer to LSW of FPOP (dividend)
 2558  1133  06 03        	MVI B,003H                      ;Set precision counter
 2559  1135  CD 77 11     	CALL SUBBER                     ;Subtract divisor from dividend
 2560  1138  7E           	MOV A,M                         ;Get MSW of the result of the subtraction operations
 2561  1139  A7           	ANA A                           ;Exercise CPU flags
 2562  113A  C9           	RET                             ;Return to caller with status
 2563  113B  A7           ADDER:	ANA A                           ;Initialize the carry bit to zero upon entry
 2564  113C  7E           ADDMOR:	MOV A,M                         ;Fetch byte from register group A
 2565  113D  CD CC 11     	CALL SWITCH                     ;Switch memory pointer to register group B
 2566  1140  8E           	ADC M                           ;Add byte from A to byte from B with carry
 2567  1141  77           	MOV M,A                         ;Leave result in register group B
 2568  1142  05           	DCR B                           ;Decrement number of bytes (precision) counter
 2569  1143  C8           	RZ                              ;Return to caller when all bytes in group processed
 2570  1144  23           	INX H                           ;Else advance pointer for register group B
 2571  1145  CD CC 11     	CALL SWITCH                     ;Switch memory pointer back to register group A
 2572  1148  23           	INX H                           ;Advance the pointer for register group A
 2573  1149  C3 3C 11     	JMP ADDMOR                      ;Continue the multi-byte addition operation
 2574                     
 2575                                                       ;N'th precision two's complement (negate)
 2576                                                       ;subroutine. Performs a two's complement on the multi-byte
 2577                                                       ;registers tarting at the address pointed
 2578                                                       ; to by H & L (least significant byte) upon entry.
 2579                     
 2580  114C  7E           COMPLM:	MOV A,M                         ;Fetch the least significant byte of the number to ACC
 2581  114D  EE FF        	XRI 0FFH                        ;Exclusive OR to complement the byte
 2582  114F  C6 01        	ADI 001H                        ;Add one to form two's complement of byte
 2583  1151  77           MORCOM:	MOV M,A                         ;Restore the negated byte to memory
 2584  1152  1F           	RAR                             ;Save the carry bit
 2585  1153  57           	MOV D,A                         ;In CPU register D
 2586  1154  05           	DCR B                           ;Decrement number of bytes (precision) counter
 2587  1155  C8           	RZ                              ;Return to caller when all bytes in number processed
 2588  1156  23           	INX H                           ;Else advance the pointer
 2589  1157  7E           	MOV A,M                         ;Fetch the next byte of the number to ACC
 2590  1158  EE FF        	XRI 0FFH                        ;Exclusive OR to complement the byte
 2591  115A  5F           	MOV E,A                         ;Save complemented value in register E temporarily
 2592  115B  7A           	MOV A,D                         ;Restore previous carry status to ACC
 2593  115C  17           	RAL                             ;And rotate it out to the carry bit
 2594  115D  3E 00        	MVI A,000H                      ;Clear ACC without disturbing carry status
 2595  115F  8B           	ADC E                           ;Add in any carry to complemented value
 2596  1160  C3 51 11     	JMP MORCOM                      ;Continue the two's complement procedure as req'd
 2597                     
 2598                                                       ;N'th precision rotate left subroutine. Rotates a multi-
 2599                                                       ;byte number left starting at the address initially
 2600                                                       ;specified by the contents of CPU registers H & L upon
 2601                                                       ;subroutine entry (LSW). First entry point will clear
 2602                                                       ;the carry bit before beginning rotate operations. Second
 2603                                                       ;entry point does not clear the carry bit.
 2604                     
 2605  1163  A7           ROTATL:	ANA A                           ;Clear the carry bit at this entry point
 2606  1164  7E           ROTL:	MOV A,M                         ;Fetch a byte from memory
 2607  1165  17           	RAL                             ;Rotate it left (bring carry into LSB, push MSB to carry)
 2608  1166  77           	MOV M,A                         ;Restore rotated word to memory
 2609  1167  05           	DCR B                           ;Decrement precision counter
 2610  1168  C8           	RZ                              ;Exit to caller when finished
 2611  1169  23           	INX H                           ;Else advance pointer to next byte
 2612  116A  C3 64 11     	JMP ROTL                        ;Continue rotate left operations
 2613                     
 2614                     
 2615                                                       ;N'th precision rotate
 2616                                                       ;right subroutine. Opposite of
 2617                                                       ;above subroutine.
 2618                     
 2619  116D  A7           ROTATR:	ANA A                           ;Clear the carry bit at this entry point
 2620  116E  7E           ROTR:	MOV A,M                         ;Fetch a byte from memory
 2621  116F  1F           	RAR                             ;Rotate it right (carry into MSB, LSB to carry)
 2622  1170  77           	MOV M,A                         ;Restore rotated word to memory
 2623  1171  05           	DCR B                           ;Decrement precision counter
 2624  1172  C8           	RZ                              ;Exit to caller when finished
 2625  1173  2B           	DCX H                           ;Else decrement pointer to next byte
 2626  1174  C3 6E 11     	JMP ROTR                        ;Continue rotate right operations
 2627                     
 2628                                                       ;N'th precision subtraction subroutine.
 2629                                                       ;Number starting at location pointed to by D & E (least
 2630                                                       ;significant byte) is subtracted from number starting at
 2631                                                       ;address specified by contents of H & L.
 2632                     
 2633  1177  A7           SUBBER:	ANA A                           ;Initialize the carry bit to zero upon entry
 2634  1178  7E           SUBTRA:	MOV A,M                         ;Fetch byte from register group A
 2635  1179  CD CC 11     	CALL SWITCH                     ;Switch memory pointer to register group B
 2636  117C  9E           	SBB M                           ;Subtract byte from group B ftom that in group A
 2637  117D  77           	MOV M,A                         ;Leave result in register group B
 2638  117E  05           	DCR B                           ;Decrement number of bytes (precision) counter
 2639  117F  C8           	RZ                              ;Return to caller when all bytes in group processed
 2640  1180  23           	INX H                           ;Else advance pointer for register group B
 2641  1181  CD CC 11     	CALL SWITCH                     ;Switch memory pointer back to register group A
 2642  1184  23           	INX H                           ;Advance the pointer for register group A
 2643  1185  C3 78 11     	JMP SUBTRA                      ;Continue the multi-byte subtraction operation
 2644                     
 2645                                                       ;The next subroutine will transfer the four byte
 2646                                                       ;register string (generally a number in floating point
 2647                                                       ;format) from the starting address pointed to by CPU
 2648                                                       ;registers H & L when the subroutine is entered to
 2649                                                       ;the FPACC (floating point accumulator registers).
 2650                     
 2651  1188  11 1F 00     FLOAD:	LXI D,FPACC                     ;Set DE to address of least signficant byte of FPACC
 2652  118B  06 04        	MVI B,004H                      ;Set precision counter to four bytes (mantissa bytes
 2653  118D  C3 CB 0F     	JMP MOVEIT                      ;Plus Exponent) and exit via the transfer routine
 2654                     
 2655                                                       ;The next several subroutines are used to perform
 2656                                                       ;floating pojnt register loading and transfer operations.
 2657                     
 2658  1190  5D           FSTORE:	MOV E,L                         ;Transfer contents of register L to E
 2659  1191  54           	MOV D,H                         ;Transfer contents of register H to D
 2660  1192  21 1F 00     	LXI H,FPACC                     ;Set L to least significant byte of FPACC mantissa
 2661  1195  C3 9B 11     	JMP SETIT                       ;Go transfer FPACC contents to area pointed to by D&E
 2662  1198  11 27 00     OPLOAD:	LXI D,FPOP                      ;Set DE to least significant byte of FPOP
 2663  119B  06 04        SETIT:	MVI B,004H                      ;Set precision counter. Transfer from H & L area to
 2664  119D  C3 CB 0F     	JMP MOVEIT                      ;Locations pointed to by D & E
 2665                     
 2666                                                       ;The next subroutine perforins a double transfer opera-
 2667                                                       ;tion. It first transfers the contents of the FPACC into
 2668                                                       ;the FPOP. It then transfers new data (as pointed to by
 2669                                                       ;H & L upon entry to the subroutine) into the FPACC.
 2670                     
 2671  11A0  CD AF 11     FACXOP:	CALL SAVEHL                     ;Save contents of H & L upon entry to subroutine
 2672  11A3  21 1F 00     	LXI H,FPACC                     ;Set pointer to FPACC LSW
 2673  11A6  CD 98 11     	CALL OPLOAD                     ;Transfer FPACC to FPOP
 2674  11A9  CD BE 11     	CALL RESTHL                     ;Recover original subroutine entry values for H & L
 2675  11AC  C3 88 11     	JMP FLOAD                       ;Transfer registers pointed to by H & L into the FPACC
 2676                     
 2677                                                       ;Subroutine to save the contents of CPU registers D, E, H
 2678                                                       ;and L in a temporary storage area in memory.
 2679                     
 2680  11AF  7C           SAVEHL:	MOV A,H                         ;Transfer value in H to ACC
 2681  11B0  45           	MOV B,L                         ;And value in L to B
 2682  11B1  21 5B 00     	LXI H,TEMP_REGS                 ;Set HL to start of temporary storage locations
 2683  11B4  77           	MOV M,A                         ;Save A (entry value of H) in memory
 2684  11B5  23           	INX H                           ;Advance pointer
 2685  11B6  70           	MOV M,B                         ;Save B (entry value of L) in memory
 2686  11B7  23           	INX H                           ;Advance pointer
 2687  11B8  72           	MOV M,D                         ;Save D in memory
 2688  11B9  23           	INX H                           ;Advance pointer
 2689  11BA  73           	MOV M,E                         ;Save E in memory
 2690  11BB  67           	MOV H,A                         ;Restore entry value of H
 2691  11BC  68           	MOV L,B                         ;Restore entry value of L
 2692  11BD  C9           	RET                             ;Exit to calling routine
 2693                     
 2694                                                       ;Subroutine to restore the contents of CPU registers D,
 2695                                                       ;E, H and L from temporary storage in memory.
 2696                     
