 3786  19DC  21 21 00     PRIGH1:	LXI H,FPACC_MSW                 ;Load L with address of the MSW in the FPACC
 3787  19DF  7E           	MOV A,M                         ;Fetch MSW of FPACC into the ACC.
 3788  19E0  A7           	ANA A                           ;Test to see if value in FPACC is positive.
 3789  19E1  FA 3D 1A     	JM OUTRNG                       ;If not, go display error message.
 3790  19E4  CD AA 0E     	CALL FPFIX                      ;If O.K. then convert floating point to fixed point
 3791  19E7  21 1F 00     	LXI H,FPACC                     ;Load L with address of LSAL of converted value
 3792  19EA  7E           	MOV A,M                         ;Fetch the LSW of the value into the ACC
 3793  19EB  D6 01        	SUI 001H                        ;Subtract one from the value to establish proper
 3794  19ED  07           	RLC                             ;Origin for future ops. Now rotate the value twice
 3795  19EE  07           	RLC                             ;To effectively multiply by four. Save the
 3796  19EF  4F           	MOV C,A                         ;Calculated result in CPU register C
 3797  19F0  21 88 15     	LXI H,TOKEN_STORE               ;Load HL with address of F/A STACK TEMP
 3798  19F3  7E           	MOV A,M                         ;Fetch the value into the accumulator
 3799  19F4  EE FF        	XRI 0FFH                        ;Complement the value
 3800  19F6  07           	RLC                             ;Rotate the value twice to multiply by four (the number
 3801  19F7  07           	RLC                             ;Of bytes per entry in the ARRAY VARIABLES table).
 3802  19F8  C5           	PUSH B                          ;Save calculated subscript offset
 3803  19F9  4F           	MOV C,A                         ;Put table offset in C
 3804  19FA  06 00        	MVI B,000H                      ;Clear B for 16-bit add
 3805  19FC  21 55 16     	LXI H,ARRAY_VAR                 ;Load HL with base of ARRAY VARIABLES table
 3806  19FF  09           	DAD B                           ;Add offset to point to table entry
 3807  1A00  23           	INX H                           ;Move past the name
 3808  1A01  23           	INX H                           ;Now pointing to array values base address
 3809  1A02  7E           	MOV A,M                         ;Fetch array values base address
 3810  1A03  C1           	POP B                           ;Restore subscript offset in C
 3811  1A04  81           	ADD C                           ;Add subscript offset to array values base
 3812  1A05  4F           	MOV C,A                         ;Save low byte of address
 3813  1A06  06 00        	MVI B,000H                      ;Clear B for 16-bit add
 3814  1A08  21 DB 1B     	LXI H,ARRAY_VALUES              ;Load HL with base of ARRAY VALUES
 3815  1A0B  09           	DAD B                           ;Add offset to get final array element address
 3816  1A0C  C3 88 11     	JMP FLOAD                       ;Load floating point value into FPACC and exit.
 3817                     
 3818                     
 3819  1A0F  21 87 15     FUNAR2:	LXI H,SCAN_PTR                  ;Load HL with address of TEMP COUNTER
 3820  1A12  46           	MOV B,M                         ;Fetch the counter value
 3821  1A13  04           	INR B                           ;Increment the value
 3822  1A14  70           	MOV M,B                         ;Restore the value to memory
 3823  1A15  0E 02        	MVI C,002H                      ;Initialize register C to a value of two for future ops
 3824  1A17  21 55 16     	LXI H,ARRAY_VAR                 ;Load L with address of start of ARRAY VARIABLES
 3825  1A1A  CD 7E 06     	CALL TABADR                     ;Calculate address of start of next narne in table.
 3826  1A1D  11 59 15     	LXI D,SYMBOL_BUF                ;Set E to starting address of the SYMBOL BUFFER
 3827  1A20  CD B5 01     	CALL STRCP                      ;Compare name in ARRAY VARIABLES table to the
 3828  1A23  CA 34 1A     	JZ FUNAR3                       ;Contents of the SYMBOL BUFFER. If match, go set up
 3829  1A26  21 87 15     	LXI H,SCAN_PTR                  ;Array token value. Else, reset HL to TEMP COUNTER
 3830  1A29  7E           	MOV A,M                         ;Fetch the counter value into the accumulator.
 3831  1A2A  21 41 16     	LXI H,NUM_DIM_ARRAYS            ;Change HL to number of arrays storage location.
 3832  1A2D  BE           	CMP M                           ;Compare number of entries checked against number
 3833  1A2E  C2 0F 1A     	JNZ FUNAR2                      ;Possible. Keep searching table if not finished.
 3834  1A31  C3 64 06     	JMP FAERR                       ;If finished and no match than have F/A error condx.
 3835  1A34  21 87 15     FUNAR3:	LXI H,SCAN_PTR                  ;Load HL with address of TEMP COUNTER
 3836  1A37  AF           	XRA A                           ;Clear the accumulator. Subtract the value in the TEMP
 3837  1A38  9E           	SBB M                           ;COUNTER from zero to obtain two's complement.
 3838  1A39  77           	MOV M,A                         ;Place this back in counter location as ARRAY TOKEN
 3839  1A3A  C3 6F 06     	JMP FUNAR4                      ;VALUE (negative). Go place the value on F/A STACK.
