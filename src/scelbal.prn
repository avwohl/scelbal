 1352  0868  21 B5 15     GETAUX:	LXI H,SYNTAX_PTR                ;Set memory pointer to line character pointer storage
 1353  086B  36 01        	MVI M,001H                      ;To point to the 1'st character in a line
 1354  086D  21 1C 16     	LXI H,AUX_LINENUM               ;Set memory pointer to addr of start of auxiliary line
 1355  0870  36 00        	MVI M,000H                      ;Number storage area and initialize first byte to zero
 1356  0872  21 B5 15     GETAU0:	LXI H,SYNTAX_PTR                ;Set memory pointer to line character pointer storage loc
 1357  0875  CD 20 09     	CALL GETCHP                     ;Fetch a char in line pointed to by line pointer
 1358  0878  CA 8B 08     	JZ GETAU1                       ;If character is a space, skip it by going to advance pntrs
 1359  087B  FE B0        	CPI 0B0H                        ;If not a space check to see if character represents a
 1360  087D  FA 9E 08     	JM GETAU2                       ;Valid decimal digit in the range 0 to 9 by testing the
 1361  0880  FE BA        	CPI 0BAH                        ;ASCII code value obtained. If not a deciznal digit then
 1362  0882  F2 9E 08     	JP GETAU2                       ;Assume have obtained the line number. Go process.
