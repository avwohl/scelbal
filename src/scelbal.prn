 3728  19CA  FA 5D 1A     	JM SQRERR                       ;If number negative, cannot take square root
 3729  19CD  CA 38 06     	JZ CFALSE                       ;If number is zero, return with zero value in FPACC
 3730  19D0  21 2E 00     	LXI H,FP_TEMP_0F                ;Load L with address of FP TEMP Exponent register
 3731  19D3  7E           	MOV A,M                         ;Fetch the Exponent value into the ACC
 3732  19D4  A7           	ANA A                           ;Check sign of the Fxponent
 3733  19D5  FA E1 19     	JM NEGEXP                       ;If Exponent less than zero, process negative Exponent
 3734  19D8  1F           	RAR                             ;If Exponent positive, rotate right to divide by two
 3735  19D9  47           	MOV B,A                         ;And save the result in CPU register B
 3736  19DA  3E 00        	MVI A,000H                      ;Clear the accumulator without disturbing Carry bit
 3737  19DC  17           	RAL                             ;Rotate Carry bit into the ACC to save remainder
 3738  19DD  77           	MOV M,A                         ;Store the remainder back in FP TEMP Exponent reg.
 3739  19DE  C3 F2 19     	JMP SQREXP                      ;Jump to continue processing
 3740  19E1  47           NEGEXP:	MOV B,A                         ;For negative Exponent, form two Is complement by
 3741  19E2  AF           	XRA A                           ;Placing the positive value in CPU register B, clearing
 3742  19E3  90           	SUB B                           ;The accumulator, and then subtracting B from the ACC
 3743  19E4  A7           	ANA A                           ;Clear the Carry bit after the complementing operation
 3744  19E5  1F           	RAR                             ;Rotate the value right to divide by two
 3745  19E6  47           	MOV B,A                         ;Save the result in CPU register B
 3746  19E7  3E 00        	MVI A,000H                      ;Clear the accumulator without disturbing Carry bit
 3747  19E9  8F           	ADC A                           ;Add Carry bit to the accumulator as remainder
 3748  19EA  77           	MOV M,A                         ;Store the remainder back in FP TEMP Exponent reg
 3749  19EB  CA EF 19     	JZ NOREMD                       ;If remainder was zero skip ahead. If not, increment the
 3750  19EE  04           	INR B                           ;Result of the divide by two ops to compen for negative
