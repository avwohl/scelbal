 3161  1408  2E 88        FPX10:	MVI	L,OFS_OP_STKPTR                       ;Set pointer to registers containing floating point
 3162  140A  26 01                   MVI	H,HIGH OLDPG1            ;** Binary representation of 10 (decimal).
 3163  140C  CD BF 12                CALL	FACXOP                  ;Transfer FPACC to FPOP and 10 (dec) to FPACC
 3164  140F  CD 26 11                CALL	FPMULT                  ;Multiply FPOP (formerly FPACC) by 10 (decimal)
 3165  1412  2E 6F                   MVI	L,OFS_FP_WORK_6F                   ;Set pointer to decimal exponent storage location
 3166  1414  4E                      MOV	C,M                      ;Fetch the exponent value
 3167  1415  0D                      DCR	C                        ;Decrement
 3168  1416  71                      MOV	M,C                      ;Restore to storage
 3169  1417  C2 08 14                JNZ	FPX10                    ;If exponent value is not zero, continue multiplication
 3170  141A  C9                      RET                          ;When exponent is zero can exit. Conversion completed.
 3171                     
 3172                                                       ;Following subroutine will multiply the floating point
 3173                                                       ;binary number stored in PPACC by 0.1 times the value
 3174                                                       ;(negative) stored in the decimal exponent storage location
 3175                     
 3176                     MINEXP:
 3177  141B  2E 8C        FPD10:	MVI	L,OFS_FP_CONST_0P1                       ;Set pointer to registers containing floating point
 3178  141D  26 01                   MVI	H,HIGH OLDPG1            ;** Binary representation of 0.1 (decimal).
 3179  141F  CD BF 12                CALL	FACXOP                  ;Transfer FPACC to FPOP and 0.1 (dec) to FPACC
 3180  1422  CD 26 11                CALL	FPMULT                  ;Multitply FPOP (formerly FPACC) by 0.1 (decimal)
 3181  1425  2E 6F                   MVI	L,OFS_FP_WORK_6F                   ;Set pointer to decimal exponent storage location
 3182  1427  46                      MOV	B,M                      ;Fetch the exponent value
 3183  1428  04                      INR	B                        ;Increment
 3184  1429  70                      MOV	M,B                      ;Restore to storage
 3185  142A  C2 1B 14                JNZ	FPD10                    ;If exponent value is not zero, continue multiplication
 3186  142D  C9                      RET                          ;When exponent is zero can exit. Conversion completed.
 3187                     
 3188                                                       ;Following subroutine is used
 3189                                                       ;to convert decimal charac-
 3190                                                       ;ters to binary fixed point forinat
 3191                                                       ;in a triple-precision format.
 3192                     
 3193  142E  CD CF 12     DECBIN:	CALL	SAVEHL                     ;Save entry value of D, E, H and L in memory
 3194  1431  2E 6B                   MVI	L,OFS_FP_WORK_6B                   ;Set pointer to temporary storage location
 3195  1433  79                      MOV	A,C                      ;Restore character inputted to accumulator
 3196  1434  E6 0F                   ANI	00FH                     ;Trim ASCII code to BCD
 3197  1436  77                      MOV	M,A                      ;Store temporarily
 3198  1437  1E 68                   MVI	E,OFS_FP_WORK_68                   ;Set pointer to working area LSW of multi-byte register
 3199  1439  2E 6C                   MVI	L,OFS_FP_WORK_6C                   ;Set another pointer to LSW of conversion register
 3200  143B  54                      MOV	D,H                      ;Make sure D set to page of working area
 3201  143C  06 03                   MVI	B,003H                   ;Set precision counter
 3202  143E  CD 0B 11                CALL	MOVEIT                  ;Move original value of conversion register to working
 3203  1441  2E 6C                   MVI	L,OFS_FP_WORK_6C                   ;Register. Reset pointer to LSW of conversion register.
 3204  1443  06 03                   MVI	B,003H                   ;Set precision counter
 3205  1445  CD 7F 12                CALL	ROTATL                  ;Rotate register left, (Multiplies value by two.)
 3206  1448  2E 6C                   MVI	L,OFS_FP_WORK_6C                   ;Reset pointer to LSW.
 3207  144A  06 03                   MVI	B,003H                   ;Set precision counter
 3208  144C  CD 7F 12                CALL	ROTATL                  ;Multiply by two again (total now times four).
 3209  144F  1E 6C                   MVI	E,OFS_FP_WORK_6C                   ;Set pointer to LSW of conversion register.
 3210  1451  2E 68                   MVI	L,OFS_FP_WORK_68                   ;Set pointer to LSW of working register (original value).
 3211  1453  06 03                   MVI	B,003H                   ;Set precision counter.
 3212  1455  CD 57 12                CALL	ADDER                   ;Add original value to rotated value (now times five).
 3213  1458  2E 6C                   MVI	L,OFS_FP_WORK_6C                   ;Reset pointer to LSW
 3214  145A  06 03                   MVI	B,003H                   ;Set precision counter
 3215  145C  CD 7F 12                CALL	ROTATL                  ;Multiply by two once more (total now times ten).
 3216  145F  2E 6A                   MVI	L,OFS_FP_WORK_6A                   ;Set pointer to clear working register locatiotis
 3217  1461  AF                      XRA	A                        ;Clear the accumulator
 3218  1462  77                      MOV	M,A                      ;Clear MSW of working register
 3219  1463  2D                      DCR	L                        ;Decrement pointer
 3220  1464  77                      MOV	M,A                      ;Clear next byte
 3221  1465  2E 6B                   MVI	L,OFS_FP_WORK_6B                   ;Set pointer to current digit storage location
 3222  1467  7E                      MOV	A,M                      ;Fetch the current digit
 3223  1468  2E 68                   MVI	L,OFS_FP_WORK_68                   ;Change pointer to LSW of working register
 3224  146A  77                      MOV	M,A                      ;Deposit the current digit in LSW of working register
 3225  146B  1E 6C                   MVI	E,OFS_FP_WORK_6C                   ;Set pointer to conversion register LSW
 3226  146D  06 03                   MVI	B,003H                   ;Set precision counter
 3227  146F  CD 57 12                CALL	ADDER                   ;Add current digit to conversion register to complete
 3228  1472  C3 DF 12                JMP	RESTHL                   ;Conversion. Exit to caller by restoring CPU registers.
 3229  1475  26 01        FPOUT:	MVI	H,HIGH OLDPG1                ;** Set H to working area for floating point routines
 3230  1477  2E 6F                   MVI	L,OFS_FP_WORK_6F                   ;Set pointer to decimal exponent storage location
 3231  1479  36 00                   MVI	M,000H                   ;Initialize storage location to zero
 3232  147B  2E 56                   MVI	L,OFS_FPACC_MSW                   ;Change pointer to FPACC (number to be outputted)
 3233  147D  7E                      MOV	A,M                      ;And fetch MSW of FPACC
 3234  147E  A7                      ANA	A                        ;Test the contents of MSW of FPACC
 3235  147F  FA 87 14                JM	OUTNEG                    ;If most significant bit of MSW is a one, have a minus nr.
 3236  1482  3E A0                   MVI	A,0A0H                   ;Else number is positive, set ASCII code for space for a
 3237  1484  C3 90 14                JMP	AHEAD1                   ;Positive number and go display a space
 3238  1487  2E 54        OUTNEG:	MVI	L,OFS_FPACC                      ;If number in FPACC is negative must negate in order
 3239  1489  06 03                   MVI	B,003H                   ;To display. Set pntr to LSW of FPACC & set prec. cntr.
 3240  148B  CD 68 12                CALL	COMPLM                  ;Negate the number in the FPACC to make it positive
 3241  148E  3E AD                   MVI	A,0ADH                   ;But load ACC with ASCII code for minus sign
 3242  1490  CD 82 03     AHEAD1:	CALL	ECHO                       ;Call user display driver to output space or minus sign
 3243  1493  2E 48                   MVI	L,OFS_FP_MODE_IND                   ;Set pointer to FIXED/FLOAT indicator
 3244  1495  7E                      MOV	A,M                      ;Fetch value of FIXED/FLOAT indicator
 3245  1496  A7                      ANA	A                        ;Test contents of indicator. If contents are zero, calling
 3246  1497  CA AB 14                JZ	OUTFLT                    ;Routine has directed floating point output format.
 3247  149A  2E 57                   MVI	L,OFS_FPACC_EXP                   ;If indicator non-zero, fixed point fonnat requested if
 3248  149C  3E 17                   MVI	A,017H                   ;Possible. Point to FPACC Exponent. Put 23 decimal in
 3249  149E  46                      MOV	B,M                      ;Accumulator. Fetch FPACC Exponent into register B
 3250  149F  04                      INR	B                        ;And exercise the register to test its
 3251  14A0  05                      DCR	B                        ;Original contents. If FPACC Exponent is negative in
 3252  14A1  FA AB 14                JM	OUTFLT                    ;Value then go to floating point output forrnat. If value
 3253  14A4  90                      SUB	B                        ;Is positive, subtract value from 23 (decimal). If result
 3254  14A5  FA AB 14                JM	OUTFLT                    ;Negative, number is too big to use fixed format.
 3255  14A8  C3 B9 14                JMP	OUTFIX                   ;Else, can use fixed format so skip next routine
 3256  14AB  2E 48        OUTFLT:	MVI	L,OFS_FP_MODE_IND                      ;Set pointer to FIXED/FLOAT indicator.
 3257  14AD  36 00                   MVI	M,000H                   ;Clear indicator to indicate floating point output format
 3258  14AF  3E B0                   MVI	A,0B0H                   ;Load ASCII code for '0' into accumulator
 3259  14B1  CD 82 03                CALL	ECHO                    ;Call user display driver to output '0' as first character
 3260  14B4  3E AE                   MVI	A,0AEH                   ;Number string. Now load ASCII code for decimal point.
 3261  14B6  CD 82 03                CALL	ECHO                    ;Call user display driver to output '.'as second character.
 3262  14B9  2E 57        OUTFIX:	MVI	L,OFS_FPACC_EXP                      ;Set pointer to FPACC Exponent
 3263  14BB  3E FF                   MVI	A,0FFH                   ;Load accumulator with minus one
 3264  14BD  86                      ADD	M                        ;Add value in FPACC Exponent
 3265  14BE  77                      MOV	M,A                      ;Restore compensated exponent value
 3266                     
 3267                                                       ;Next portion of routine establishes the value for the
 3268                                                       ;decimal exponent that will be outputted by processing
 3269                                                       ;the binary exponent value in the FPACC.
 3270                     
 3271  14BF  F2 DE 14     DECEXT:	JP	DECEXD                       ;If compensated exponent value is zero or positive
 3272  14C2  3E 04                   MVI	A,004H                   ;Then go multiply FPACC by 0.1 (decimal). Else,
 3273  14C4  86                      ADD	M                        ;Add four to the exponent value.
 3274  14C5  F2 F0 14                JP	DECOUT                    ;If exponent now zero or positive, ready to output
 3275  14C8  2E 88                   MVI	L,OFS_OP_STKPTR                   ;If exponent negative, multiply FPACC by 10 (decimal)
 3276  14CA  26 01                   MVI	H,HIGH OLDPG1            ;** Set pointer to registers holding 10 (dec) in binary
 3277  14CC  CD BF 12                CALL	FACXOP                  ;Floating point format. Set up for multiplication.
 3278  14CF  CD 26 11                CALL	FPMULT                  ;Perform the multiplication. Answer in FPACC.
 3279  14D2  2E 6F                   MVI	L,OFS_FP_WORK_6F                   ;Set pointer to decimal exponent storage location.
 3280  14D4  4E                      MOV	C,M                      ;Each time the FPACC is multiplied by ten, need to
 3281  14D5  0D                      DCR	C                        ;Decrement the value in the decinial exponent storage
 3282  14D6  71                      MOV	M,C                      ;Location. (This establishes decimal exponent value!)
 3283  14D7  2E 57        DECREP:	MVI	L,OFS_FPACC_EXP                      ;Reset pointer to FPACC Exponent
 3284  14D9  7E                      MOV	A,M                      ;Fetch value in exponent
 3285  14DA  A7                      ANA	A                        ;Test value
 3286  14DB  C3 BF 14                JMP	DECEXT                   ;Repeat process as required
 3287  14DE  2E 8C        DECEXD:	MVI	L,OFS_FP_CONST_0P1                      ;If exponent is positive, multiply FPACC by 0.1
 3288  14E0  26 01                   MVI	H,HIGH OLDPG1            ;** Set pointer to registers holding 0.1 dec in binary
 3289  14E2  CD BF 12                CALL	FACXOP                  ;Floating point format. Set up for multipli(-ation.
 3290  14E5  CD 26 11                CALL	FPMULT                  ;Perform the multiplication. Answer in FPACC.
 3291  14E8  2E 6F                   MVI	L,OFS_FP_WORK_6F                   ;Set pointer to decimal exponent storage location.
 3292  14EA  46                      MOV	B,M                      ;Each time the FPACC is multiplied by one tenth, need
 3293  14EB  04                      INR	B                        ;To increment the value in the decimal exponent storage
 3294  14EC  70                      MOV	M,B                      ;Location. (This establishes decimal exponent value!)
 3295  14ED  C3 D7 14                JMP	DECREP                   ;Repeat process as required
 3296                     
 3297                                                       ;The next section outputs the mantissa
 3298                                                       ;(or fixed point number) by converting the value remaining
 3299                                                       ;in the FPACC (after the decimal exponent equivalent has
 3300                                                       ;been extracted from the original value if required by the
 3301                                                       ;previous routines) to a string of decirnal digits.
 3302  14F0  1E 74        DECOUT:	MVI	E,074H                      ;Set pointer to LSW of output working register
 3303  14F2  54                      MOV	D,H                      ;Set D to same page value as H
 3304  14F3  2E 54                   MVI	L,OFS_FPACC                   ;Set pointer to LSW of FPACC
 3305  14F5  06 03                   MVI	B,003H                   ;Set precision counter
 3306  14F7  CD 0B 11                CALL	MOVEIT                  ;Move value in FPACC to output working register
 3307  14FA  2E 77                   MVI	L,OFS_FP_WORK_77                   ;Set pointer to MSW plus one of output working register
 3308  14FC  36 00                   MVI	M,000H                   ;Clear that location to 0
 3309  14FE  2E 74                   MVI	L,OFS_FP_WORK_74                   ;Set pointer to LSW of output working register
 3310  1500  06 03                   MVI	B,003H                   ;Set precision counter
 3311  1502  CD 7F 12                CALL	ROTATL                  ;Rotate register left once to compensate for sign bit
 3312  1505  CD 93 15                CALL	OUTX10                  ;Multiply output register by 10, overflow into N4SW+ 1
 3313  1508  2E 57        COMPEN:	MVI	L,OFS_FPACC_EXP                      ;Set pointer back to FPACC Exponent
 3314  150A  46                      MOV	B,M                      ;Compensate for any remainder in the binary exponent
 3315  150B  04                      INR	B                        ;By performing a rotate right on the output working
 3316  150C  70                      MOV	M,B                      ;Register until the binary exponent becomes zero
 3317  150D  CA 1A 15                JZ	OUTDIG                    ;Go output decimal digits when this loop is finished
 3318  1510  2E 77                   MVI	L,OFS_FP_WORK_77                   ;Binary exponent compensating loop. Setpointe'r to
 3319  1512  06 04                   MVI	B,004H                   ;Working register MSW+L. Set precision counter.
 3320  1514  CD 89 12                CALL	ROTATR                  ;Rotate working register to the right.
 3321  1517  C3 08 15                JMP	COMPEN                   ;Repeat loop as required.
 3322  151A  2E 47        OUTDIG:	MVI	L,OFS_OUT_DIG_CNT                      ;Set pointer to output digit counter storage location
 3323  151C  36 07                   MVI	M,007H                   ;Initialize to value of seven
 3324  151E  2E 77                   MVI	L,OFS_FP_WORK_77                   ;Change pointer to output working register MSW+L
 3325  1520  7E                      MOV	A,M                      ;Fetch MSW+L byte containing BCD of digit to be
 3326  1521  A7                      ANA	A                        ;Displayed. Test the contents of this byte.
 3327  1522  CA 75 15                JZ	ZERODG                    ;If zero jump to ZERODG routine.
 3328  1525  2E 77        OUTDGS:	MVI	L,OFS_FP_WORK_77                      ;Reset pointer to working register MSW+L
 3329  1527  7E                      MOV	A,M                      ;Fetch BCD of digit to be outputted
 3330  1528  A7                      ANA	A                        ;Exercise CPU flags
 3331  1529  C2 45 15                JNZ	OUTDGX                   ;If not zero, go display the digit
 3332  152C  2E 48                   MVI	L,OFS_FP_MODE_IND                   ;If zero, change pointer to FIXED/FLOAT indicator
 3333  152E  7E                      MOV	A,M                      ;Fetch the indicator into the accumulator
 3334  152F  A7                      ANA	A                        ;Test value of indicator
 3335  1530  CA 44 15                JZ	OUTZER                    ;If in floating point mode, go display the digit
 3336  1533  2E 6F                   MVI	L,OFS_FP_WORK_6F                   ;Else change pointer to decimal exponent storage
 3337  1535  4E                      MOV	C,M                      ;Location, which, for fixed point, will have a positive
 3338  1536  0D                      DCR	C                        ;Value for all digits before the decimal point. Decrement
 3339  1537  0C                      INR	C                        ;And increment to exercise flags. See if count is positive.
 3340  1538  F2 44 15                JP	OUTZER                    ;If positive, must display any zero digit.
 3341  153B  2E 76                   MVI	L,OFS_FP_WORK_76                   ;If not, change pointer to MSW of working register
 3342  153D  7E                      MOV	A,M                      ;And test to see if any significant digits coming up
 3343  153E  E6 E0                   ANI	0E0H                     ;By forming a mask and testing for presence of bits
 3344  1540  C2 44 15                JNZ	OUTZER                   ;If more significant digits coming up soon, display the
 3345  1543  C9                      RET                          ;Zero digit. Else, exit to calling routine. Finished.
 3346  1544  AF           OUTZER:	XRA	A                           ;Clear the accumulator to restore zero digit value
 3347  1545  C6 B0        OUTDGX:	ADI	0B0H                        ;Add 260 (octal) to BCD code in ACC to form ASCII
 3348  1547  CD 82 03                CALL	ECHO                    ;Code and call the user's display driver subroutine
 3349  154A  2E 48        DECRDG:	MVI	L,OFS_FP_MODE_IND                      ;Set pointer to FIXED/FLOAT indicator storage
 3350  154C  7E                      MOV	A,M                      ;Fetch the indicator to the accumulator
 3351  154D  A7                      ANA	A                        ;Exercise the CPU flags
 3352  154E  C2 5F 15                JNZ	CKDECP                   ;If indicator non-zero, doing fixed point output
 3353  1551  2E 47                   MVI	L,OFS_OUT_DIG_CNT                   ;Else, get output digit counter
 3354  1553  4E                      MOV	C,M
 3355  1554  0D                      DCR	C                        ;Decrement the digit counter & restore to storage
 3356  1555  71                      MOV	M,C
 3357  1556  CA C0 15                JZ	EXPOUT                    ;When digit counter is zero, go take care of exponent
 3358  1559  CD 93 15     PUSHIT:	CALL	OUTX10                     ;Else push next BCD digit out of working register
 3359  155C  C3 25 15                JMP	OUTDGS                   ;And continue the outputting process
 3360  155F  2E 6F        CKDECP:	MVI	L,OFS_FP_WORK_6F                      ;For fixed point output, decimal exponent serves as
 3361  1561  4E                      MOV	C,M                      ;Counter for number of digits before decimal point
 3362  1562  0D                      DCR	C                        ;Fetch the counter and decrement it to account for
 3363  1563  71                      MOV	M,C                      ;Current digit being processed. Restore to storage.
 3364  1564  C2 6C 15                JNZ	NODECP                   ;If count does not go to zero, jump ahead.
 3365  1567  3E AE                   MVI	A,0AEH                   ;When count reaches zero, load ASCII code for period
 3366  1569  CD 82 03                CALL	ECHO                    ;And call user's display driver to display decimal point
 3367  156C  2E 47        NODECP:	MVI	L,OFS_OUT_DIG_CNT                      ;Set pointer to output digit counter storage location
 3368  156E  4E                      MOV	C,M                      ;Fetch the digit counter
 3369  156F  0D                      DCR	C                        ;Decrement the value
 3370  1570  71                      MOV	M,C                      ;Restore to storage
 3371  1571  C8                      RZ                           ;If counter reaches zero, exit to caller. Finished.
 3372  1572  C3 59 15                JMP	PUSHIT                   ;Else continue to output the number.
 3373  1575  2E 6F        ZERODG:	MVI	L,OFS_FP_WORK_6F                      ;If first digit of floating point number is a zero, set
 3374  1577  4E                      MOV	C,M                      ;Pointer to decimal exponent storage location.
 3375  1578  0D                      DCR	C                        ;Decrement the value to compensate for skipping
 3376  1579  71                      MOV	M,C                      ;Display of first digit. Restore to storage.
 3377  157A  2E 76                   MVI	L,OFS_FP_WORK_76                   ;Change pointer to MSW of output working register
 3378  157C  7E                      MOV	A,M                      ;Fetch MSW of output working register
 3379  157D  A7                      ANA	A                        ;Test the contents
 3380  157E  C2 4A 15                JNZ	DECRDG                   ;If non-zero, continue outputting
 3381  1581  2D                      DCR	L                        ;Else decrement pointer to next byte in working register
 3382  1582  7E                      MOV	A,M                      ;Fetch its contents
 3383  1583  A7                      ANA	A                        ;Test
 3384  1584  C2 4A 15                JNZ	DECRDG                   ;If non-zero, continue outputting
 3385  1587  2D                      DCR	L                        ;Else decrement pointer to LSW of working register
 3386  1588  7E                      MOV	A,M                      ;Fetch its contents
 3387  1589  A7                      ANA	A                        ;Test
 3388  158A  C2 4A 15                JNZ	DECRDG                   ;If non-zero, continue outputting
 3389  158D  2E 6F                   MVI	L,OFS_FP_WORK_6F                   ;If decimal mantissa is zero, set pointer to decirnal
 3390  158F  77                      MOV	M,A                      ;Exponent storage and clear it
 3391  1590  C3 4A 15                JMP	DECRDG                   ;Finish outputting
 3392                     
 3393                                                       ;Following routine multiplies the binary number in the
 3394                                                       ;output working register by ten to push the most signifi-
 3395                                                       ;cant digit out to the MSW+L byte.
 3396                     
 3397  1593  2E 77        OUTX10:	MVI	L,OFS_FP_WORK_77                      ;Set pointer to work ing register M SW+ 1
 3398  1595  36 00                   MVI	M,000H                   ;Clear it in preparation for receiving next digit pushed
 3399  1597  2E 74                   MVI	L,OFS_FP_WORK_74                   ;Into it. Change pointer to working register LSW.
 3400  1599  54                      MOV	D,H                      ;Set up register D to same page as H.
 3401  159A  1E 70                   MVI	E,070H                   ;Set second pointer to LSW of second working register
 3402  159C  06 04                   MVI	B,004H                   ;Set precision counter
 3403  159E  CD 0B 11                CALL	MOVEIT                  ;Move first working register into second
 3404  15A1  2E 74                   MVI	L,OFS_FP_WORK_74                   ;Reset pointer to LSW of first working register
 3405  15A3  06 04                   MVI	B,004H                   ;Set precision counter
 3406  15A5  CD 7F 12                CALL	ROTATL                  ;Rotate contents of first working register left (X 2)
 3407  15A8  2E 74                   MVI	L,OFS_FP_WORK_74                   ;Reset pointer to LSW
 3408  15AA  06 04                   MVI	B,004H                   ;Reset precision counter
 3409  15AC  CD 7F 12                CALL	ROTATL                  ;Rotate contents left again (X 4)
 3410  15AF  2E 70                   MVI	L,OFS_FP_WORK_70                   ;Set pointer to LSW of original value in 2'nd register
 3411  15B1  1E 74                   MVI	E,074H                   ;Set pointer to LSW of rotated value
 3412  15B3  06 04                   MVI	B,004H                   ;Set precision counter
 3413  15B5  CD 57 12                CALL	ADDER                   ;Add rotated value to original value (X 5)
 3414  15B8  2E 74                   MVI	L,OFS_FP_WORK_74                   ;Reset pointer to LSW of first working register
 3415  15BA  06 04                   MVI	B,004H                   ;Set precision counter
 3416  15BC  CD 7F 12                CALL	ROTATL                  ;Rotate contents left again (X 10)
 3417  15BF  C9                      RET                          ;Exit to calling routine
 3418                     
 3419                                                       ;The final group of routines in the floating point output
 3420                                                       ;section take care of outputting the decimal exponent
 3421                                                       ;portion of floating point numbers.
 3422                     
 3423  15C0  2E 6F        EXPOUT:	MVI	L,OFS_FP_WORK_6F                      ;Set pointer to decimal exponent storage location
 3424  15C2  7E                      MOV	A,M                      ;Fetch value to the accumulator
 3425  15C3  A7                      ANA	A                        ;Test the value
 3426  15C4  C8                      RZ                           ;If zero, then no exponent portion. Exit to caller.
 3427  15C5  3E C5                   MVI	A,0C5H                   ;Else, load ACC with ASCII code for letter E.
 3428  15C7  CD 82 03                CALL	ECHO                    ;Display E for Exponent via user's display driver rtn
 3429  15CA  7E                      MOV	A,M                      ;Get decimal exponent value back into ACC
 3430  15CB  A7                      ANA	A                        ;Test again
 3431  15CC  FA D4 15                JM	EXOUTN                    ;If value is negative, skip ahead
 3432  15CF  3E AB                   MVI	A,0ABH                   ;If positive, load ASCII code for + sign
 3433  15D1  C3 DB 15                JMP	AHEAD2                   ;Jump to display the + sign
 3434  15D4  EE FF        EXOUTN:	XRI	0FFH                        ;When decimal exponent is negative, must negate
 3435  15D6  C6 01                   ADI	001H                     ;Value for display purposes. Perform two's complement
 3436  15D8  77                      MOV	M,A                      ;And restore the negated value to storage location
 3437  15D9  3E AD                   MVI	A,0ADH                   ;Load ASCII code for minus sign
 3438  15DB  CD 82 03     AHEAD2:	CALL	ECHO                       ;Display the ASCII character in ACC
 3439  15DE  06 00                   MVI	B,000H                   ;Clear register B
 3440  15E0  7E                      MOV	A,M                      ;Fetch the decimal exponent value back into ACC
 3441  15E1  D6 0A        SUB12:	SUI	00AH                         ;Subtract 10 (decimal) from value in ACC
 3442  15E3  FA EB 15                JM	TOMUCH                    ;Break out of loop when accumulator goes negative
 3443  15E6  77                      MOV	M,A                      ;Else restore value to storage location
 3444  15E7  04                      INR	B                        ;Increment register B as a counter
 3445  15E8  C3 E1 15                JMP	SUB12                    ;Repeat loop to form tens value of decimal exponent
 3446  15EB  3E B0        TOMUCH:	MVI	A,0B0H                      ;Load base ASCII value for digit into the accumulator
 3447  15ED  80                      ADD	B                        ;Add to the count in B to forin tens digit of decimal
 3448  15EE  CD 82 03                CALL	ECHO                    ;Exponent. Display via user's driver subroutine
 3449  15F1  7E                      MOV	A,M                      ;Fetch remainder of decimal exponent value
 3450  15F2  C6 B0                   ADI	0B0H                     ;Add in ASCII base value to form final digit
 3451  15F4  CD 82 03                CALL	ECHO                    ;Display second digit of decirnal exponent
 3452  15F7  C9                      RET                          ;Finished outputting. Return to caller.
 3453                     ;;; The above RETURN SHOULD BE AT 25 367
 3454                     
 3455                     ;;; NOW OPEN AREA UP TO 26 000 CAN BE USED FOR PATCHING...
 3456                     
 3457                     	ORG	01600H
