 1745  0B14  46                      MOV	B,M                      ;Compare operations. Get length of TEST buffer in B.
 1746  0B15  CD FF 02                CALL	ADV                     ;Advance H & L buffer to first char in TEST buffer.
 1747  0B18  CD F8 02                CALL	STRCPC                  ;Compare contents of TEST buffer against input buffer
 1748  0B1B  CA DF 12                JZ	RESTHL                    ;For length B. If match, restore pntrs and exit to caller.
 1749  0B1E  CD DF 12                CALL	RESTHL                  ;If no match, restore pointers for loop test.
 1750  0B21  2E 00                   MVI	L,OFS_LINE_INP_BUF                   ;Load L with start of input buffer (to get the char cntr).
 1751  0B23  26 16                   MVI	H,HIGH OLDPG26           ;**Load H with page of input buffer.
 1752  0B25  7E                      MOV	A,M                      ;Get length of buffer (cc) into the accumulator.
 1753  0B26  BB                      CMP	E                        ;Compare with current input buffer pointer value.
 1754  0B27  CA 31 0B                JZ	INSTR2                    ;If at end of buffer, jump ahead.
 1755  0B2A  CD DF 12                CALL	RESTHL                  ;Else restore test string address (H&L) and input buffer
 1756  0B2D  C3 0E 0B                JMP	INSTR1                   ;Address (D&E). Look gor occurrence of test string in ln.
 1757  0B30  76                      HLT                          ;Safety halt. If program reaches here have system failure.
