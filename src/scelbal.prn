 2505  1070  46                      MOV	B,M                      ;The value of the Exponent and decrement it by one
 2506  1071  05                      DCR	B                        ;To compensate for the rotate left of the mantissa
 2507  1072  70                      MOV	M,B                      ;Restore the new value of the Exponent
 2508  1073  C3 63 10                JMP	ACNONZ                   ;Continue rotating ops to normalize the FPACC
 2509  1076  2E 56        ACCSET:	MVI	L,OFS_FPACC_MSW                      ;Set pntr to FPACC MSW. Now must provide room for
 2510  1078  06 03                   MVI	B,003H                   ;Sign bit in nonnalized FPACC. Set precision counter.
 2511  107A  CD 89 12                CALL	ROTATR                  ;Rotate the FPACC once to the right now.
 2512  107D  2E 40        RESIGN:	MVI	L,OFS_SIGN_IND1                      ;Set the pointer to SIGN indicator storage location
 2513  107F  7E                      MOV	A,M                      ;Fetch the original sign of the FPACC
 2514  1080  A7                      ANA	A                        ;Set CPU flags
 2515  1081  F0                      RP                           ;If original sign of FPACC was positive, can exit now.
 2516                     
