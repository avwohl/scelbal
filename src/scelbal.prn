 2330  0FEA  06 04        	MVI B,004H                      ;Set precision counter
 2331  0FEC  7E           FSHIFT:	MOV A,M                         ;Fetch MSW of mantissa
 2332  0FED  A7           	ANA A                           ;Set CPU flags after load ops
 2333  0FEE  F2 97 11     	JP ROTATR                       ;If MSB not a one can do normal rotate ops
 2334  0FF1  17           BRING1:	RAL                             ;If MSB is a one need to set up carrv bit for the negative
 2335  0FF2  C3 98 11     	JMP ROTR                        ;Number case. Then make special entry to ROTATR sub
 2336                     
 2337                                                       ;The following subroutine moves the contents of a string
 2338                                                       ;of memory locations from the address pointed to by
 2339                                                       ;CPU registers H & L to the address specified by the con-
 2340                                                       ;tents of registers D & E when the routine is entered. The
 2341                                                       ;process continues until the counter in register B is zero.
 2342                     
 2343  0FF5  7E           MOVEIT:	MOV A,M                         ;Fetch a word from memory string A
 2344  0FF6  23           	INX H                           ;Advance A string pointer (full 16-bit)
 2345  0FF7  CD F6 11     	CALL SWITCH                     ;Switch pointer to string B
 2346  0FFA  77           	MOV M,A                         ;Put word from string A into string B
 2347  0FFB  23           	INX H                           ;Advance B string pointer (full 16-bit)
 2348  0FFC  CD F6 11     	CALL SWITCH                     ;Switch pointer back to string A
 2349  0FFF  05           	DCR B                           ;Decrement loop counter
 2350  1000  C8           	RZ                              ;Return to calling routine when counter reaches zero
 2351  1001  C3 F5 0F     	JMP MOVEIT                      ;Else continue transfer operations
 2352                     
 2353                                                       ;The following subroutine SUBTRACTS the
 2354                                                       ;contents of the FLOATING POINT ACCUMULATOR from the
 2355                                                       ;contents of the FLOATING POINT OPERAND and
 2356                                                       ;leaves the result in the FPACC. The routine merely
 2357                                                       ;negates the value in the FPACC and then goes to the
 2358                                                       ;FPADD subroutine just presented.
 2359                     
 2360  1004  21 1F 00     FPSUB:	LXI H,FPACC                     ;Set L to address of LSW of FPACC
 2361  1007  06 03        	MVI B,003H                      ;Set precision counter
 2362  1009  CD 76 11     	CALL COMPLM                     ;Two's complement the value in the FPACC
 2363  100C  C3 67 0F     	JMP FPADD                       ;Now go add the negated value to perform subtraction!
 2364                     
 2365                                                       ;The first part of the FLOATING POINT MULTIPLI-
 2366                                                       ;CATION subroutine calls a subroutine to check the
 2367                                                       ;original signs of the numbers that are to be multi-
 2368                                                       ;plied and perform working register clearing functions.
 2369                                                       ;Next the exponents of the numbers to be multiplied
 2370                                                       ;are added together.
 2371                     
 2372  100F  CD 6A 10     FPMULT:	CALL CKSIGN                     ;Call routine to set up registers & ck signs of numbers
 2373  1012  21 2A 00     ADDEXP:	LXI H,FPOP_EXP                  ;Set pointer to FPOP Exponent
 2374  1015  7E           	MOV A,M                         ;Fetch FPOP Exponent into the accumulator
 2375  1016  21 22 00     	LXI H,FPACC_EXP                 ;Change pointer to FPACC Exponent
 2376  1019  86           	ADD M                           ;Add FPACC Exponent to FPOP Exponent
 2377  101A  C6 01        	ADI 001H                        ;Add one more to total for algorithm compensation
 2378  101C  77           	MOV M,A                         ;Store result in FPACC Exponent location
 2379  101D  21 63 00     SETMCT:	LXI H,BITS_COUNTER              ;Change pointer to bit counter storage location
 2380  1020  36 17        	MVI M,017H                      ;Initialize bit counter to 23 decimal
 2381                     
 2382                                                       ;Next portion of the FPMULT routine is the iinplernen-
 2383                                                       ;tation of the algorithm illustrated in the flow chart
 2384                                                       ;above. This portion multiplies the values of the two
 2385                                                       ;mantissas. The final value is rounded off to leave the
 2386                                                       ;23 most significant bits as the answer that is stored
 2387                                                       ;back in the FPACC.
 2388                     
 2389  1022  21 21 00     MULTIP:	LXI H,FPACC_MSW                 ;Set pointer to MSW of FPACC mantissa
 2390  1025  06 03        	MVI B,003H                      ;Set precision counter
 2391  1027  CD 97 11     	CALL ROTATR                     ;Rotate FPACC (multiplier) RIGHT into carry bit
 2392  102A  DC B3 10     	CC ADOPPP                       ;If carry is a one, add multiplicand to partial-product
 2393  102D  21 34 00     	LXI H,FP_WORK_66                ;Set pointer to partial-product most significant byte
 2394  1030  06 06        	MVI B,006H                      ;Set precision counter (p-p register is double length)
 2395  1032  CD 97 11     	CALL ROTATR                     ;Shift partial-product RIGHT
 2396  1035  21 63 00     	LXI H,BITS_COUNTER              ;Set pointer to bit counter storage location
 2397  1038  4E           	MOV C,M                         ;Fetch current value of bit counter
 2398  1039  0D           	DCR C                           ;Decrement the value of the bit counter
 2399  103A  71           	MOV M,C                         ;Restore the updated bit counter to its storage location
 2400  103B  C2 22 10     	JNZ MULTIP                      ;If have not multiplied for 23 (deciinal) bits, keep going
 2401  103E  21 34 00     	LXI H,FP_WORK_66                ;If have done 23 (decimal) bits, set pntr to p-p MSW
 2402  1041  06 06        	MVI B,006H                      ;Set precision counter (for double length)
 2403  1043  CD 97 11     	CALL ROTATR                     ;Shift partial-product once more to the RIGHT
 2404  1046  21 31 00     	LXI H,FP_WORK_63                ;Set pointer to access 24'th bit in partial-product
 2405  1049  7E           	MOV A,M                         ;Fetch the byte containing the 24'th bit
 2406  104A  17           	RAL                             ;Position the 24'th bit to be MSB in the accumulator
 2407  104B  A7           	ANA A                           ;Set the CPU flags after to rotate operation and test to
 2408  104C  FC BF 10     	CM MROUND                       ;See if 24'th bit of p-p is a ONE. If so, must round-off
 2409  104F  21 1E 00     	LXI H,FPACC_LSW_M1              ;Now set up pointers
 2410  1052  5D           	MOV E,L                         ;To perform transfer
 2411  1053  54           	MOV D,H                         ;Of the multiplication results
 2412  1054  21 31 00     	LXI H,FP_WORK_63                ;From the partial-product location
 2413  1057  06 04        	MVI B,004H                      ;To the FPACC
 2414                     
 2415                     
 2416  1059  CD F5 0F     EXMLDV:	CALL MOVEIT                     ;Perform the transfer from p-p to FPACC
 2417  105C  06 00        	MVI B,000H                      ;Set up CPU register B to indicate regular normalization
 2418  105E  CD 0D 0F     	CALL FPNORM                     ;Normalize the result of multiplication
 2419  1061  21 62 00     	LXI H,MD_SIGNS                  ;Now set the pointer to the original SIGNS indicator
 2420  1064  7E           	MOV A,M                         ;Fetch the indicator
 2421  1065  A7           	ANA A                           ;Exercise the CPU flags
 2422  1066  C0           	RNZ                             ;If indicator is non-zero, answer is positive, can exit her
 2423  1067  C3 5F 0F     	JMP FPCOMP                      ;If not, answer must be negated, exit via 2's complement.
 2424                     
 2425                                                       ;The following portions of the FPMULT
 2426                                                       ;routine set up working locations in memory by clearing
 2427                                                       ;locations for an expanded FPOP area and the partial-produc
 2428                                                       ;area. Next, the signs of the two numbers to be multiplied
 2429                                                       ;are examined. Negative numbers are negated
 2430                                                       ;in preparation for the multiplication
 2431                                                       ;algorithm. A SIGNS indicator register is set up during
 2432                                                       ;this process to indicate whether the final result of the
 2433                                                       ;multiplication should be positive or negative. (Negative
 2434                                                       ;if original signs of the two numbers to be multiplied are
 2435                                                       ;different.)
 2436                     
 2437  106A  21 2F 00     CKSIGN:	LXI H,FP_WORK_AREA              ;Set pointer to start of partial-product working area
 2438  106D  06 08        	MVI B,008H                      ;Set up a loop counter in CPU register B
 2439  106F  AF           	XRA A                           ;Clear the accumulator
 2440                     
 2441  1070  77           CLRNEX:	MOV M,A                         ;Now clear out locations for the partial-product
 2442  1071  2C           	INR L                           ;Working registers
 2443  1072  05           	DCR B                           ;Until the loop counter
 2444  1073  C2 70 10     	JNZ CLRNEX                      ;Is zero
 2445  1076  06 04        CLROPL:	MVI B,004H                      ;Set a loop counter
 2446  1078  21 23 00     	LXI H,FPOP_EXT                  ;Set up pointer
 2447  107B  77           CLRNX1:	MOV M,A                         ;Clear out some extra registers so that the
 2448  107C  2C           	INR L                           ;FPOP may be extended in length
 2449  107D  05           	DCR B                           ;Perform clearing ops until loop counter
 2450  107E  C2 7B 10     	JNZ CLRNX1                      ;Is zero
 2451  1081  21 62 00     	LXI H,MD_SIGNS                  ;Set pointer to M/D SIGNS indicator storage location
 2452  1084  36 01        	MVI M,001H                      ;Set initial value of SIGNS indicator to plus one
 2453  1086  21 21 00     	LXI H,FPACC_MSW                 ;Change pointer to MSW of FPACC
 2454  1089  7E           	MOV A,M                         ;Fetch MSW of mantissa into accumulator
 2455  108A  A7           	ANA A                           ;Test flags
 2456  108B  FA A2 10     	JM NEGFPA                       ;If MSB in MSW of FPACC is a one, number is negative
 2457  108E  21 29 00     OPSGNT:	LXI H,FPOP_MSW                  ;Set pointer to MSW of FPOP
 2458  1091  7E           	MOV A,M                         ;Fetch MSW of mantissa into accumulator
 2459  1092  A7           	ANA A                           ;Test flags
 2460  1093  F0           	RP                              ;Return to caller if number in FPOP is positive
 2461  1094  21 62 00     	LXI H,MD_SIGNS                  ;Else change pointer to M/D SIGNS indicator
 2462  1097  4E           	MOV C,M                         ;Fetch the value in the SIGNS indicator
 2463  1098  0D           	DCR C                           ;Decrement the value by one
 2464  1099  71           	MOV M,C                         ;Restore the new value back to storage location
 2465  109A  21 27 00     	LXI H,FPOP                      ;Set pointer to LSW of FPOP
 2466  109D  06 03        	MVI B,003H                      ;Set precision counter
 2467  109F  C3 76 11     	JMP COMPLM                      ;Two's complement value of FPOP & return to caller
 2468  10A2  21 62 00     NEGFPA:	LXI H,MD_SIGNS                  ;Set pointer to M/D SIGNS indicator
 2469  10A5  4E           	MOV C,M                         ;Fetch the value in the SIGNS indicator
 2470  10A6  0D           	DCR C                           ;Decrement the value by one
 2471  10A7  71           	MOV M,C                         ;Restore the new value back to storage location
 2472  10A8  21 1F 00     	LXI H,FPACC                     ;Set pointer to LSW of FPACC
 2473  10AB  06 03        	MVI B,003H                      ;Set precision counter
 2474  10AD  CD 76 11     	CALL COMPLM                     ;Two's complement value of FPACC
 2475  10B0  C3 8E 10     	JMP OPSGNT                      ;Proceed to check sign of FPOP
 2476                     
 2477                                                       ;The following subroutine adds the double length (six regis
 2478                                                       ;multiplicand in FPOP to the partial-product register when
 2479                                                       ;called on by the multiplication algorithm.
 2480                     
 2481  10B3  11 2F 00     ADOPPP:	LXI D,FP_WORK_61                ;Pointer to LSW of partial-product
 2482  10B6  54           	MOV D,H                         ;On same page as FPOP
 2483  10B7  21 26 00     	LXI H,FPOP_EXT_59               ;LSIV of FPOP which contains extended multiplicand
 2484  10BA  06 06        	MVI B,006H                      ;Set precision counter (double length working registers)
 2485  10BC  C3 65 11     	JMP ADDER                       ;Add multiplicand to partial-product & return to caller
 2486                     
 2487  10BF  06 03        MROUND:	MVI B,003H                      ;Set up precision counter
 2488  10C1  3E 40        	MVI A,040H                      ;Prepare to add one to 24'th bit of partial-product
 2489  10C3  86           	ADD M                           ;Add one to the 24'th bit of the partial-product
 2490  10C4  77           CROUND:	MOV M,A                         ;Restore the updated byte to memory
 2491  10C5  2C           	INR L                           ;Advance the memory pointer to next most significant
 2492  10C6  3E 00        	MVI A,000H                      ;Byte of partial-product, then clear ACC without
 2493  10C8  8E           	ADC M                           ;Disturbing carry bit. Now perform add with carry to
 2494  10C9  05           	DCR B                           ;Propagate any rounding in the partial-product registers.
 2495  10CA  C2 C4 10     	JNZ CROUND                      ;If cotinter is not zero continue propagating any carry
 2496  10CD  77           	MOV M,A                         ;Restore final byte to memory
 2497  10CE  C9           	RET                             ;Exit to calling routine
 2498                     
 2499  10CF  CD 6A 10     FPDIV:	CALL CKSIGN                     ;Call routine to set up registers & ck signs of numbers
 2500  10D2  21 21 00     	LXI H,FPACC_MSW                 ;Set pointer to MSW of FPACC (divisor)
 2501  10D5  7E           	MOV A,M                         ;Fetch MSW of FPACC to accumulator
 2502  10D6  A7           	ANA A                           ;Exercise CPU flags
 2503  10D7  CA B6 09     	JZ DVERR                        ;If MSW of FPACC is zero go display 'DZ' error message
 2504  10DA  21 2A 00     SUBEXP:	LXI H,FPOP_EXP                  ;Set pointer to FPOP (dividend) Exponent
 2505  10DD  7E           	MOV A,M                         ;Get FPOP Exponent into accumulator
 2506  10DE  21 22 00     	LXI H,FPACC_EXP                 ;Change pointer to FPACC (divisor) Exponent
 2507  10E1  96           	SUB M                           ;Subtract divisor exponent from dividend exponent
 2508  10E2  C6 01        	ADI 001H                        ;Add one for algorithm compensation
 2509  10E4  77           	MOV M,A                         ;Place result in FPACC Exponent
 2510  10E5  21 63 00     SETDCT:	LXI H,BITS_COUNTER              ;Set pointer to bit counter storage location
 2511  10E8  36 17        	MVI M,017H                      ;Initialize bit counter to 23 decimal
 2512                     
 2513                                                       ;Main division algorithm for mantissas
 2514                     
 2515  10EA  CD 4B 11     DIVIDE:	CALL SETSUB                     ;Go subtmct divisor from dividend
 2516  10ED  FA 01 11     	JM NOGO                         ;If result is negative then place a zero bit in quotient
 2517  10F0  11 27 00     	LXI D,FPOP                      ;If result zero or positive then move remainder after
 2518  10F3  21 26 00     	LXI H,FPOP_EXT_59               ;Subtraction from working area to become new dividend
 2519  10F6  06 03        	MVI B,003H                      ;Set up moving pointers and initialize precision counter
 2520  10F8  CD F5 0F     	CALL MOVEIT                     ;Perform the transfer
 2521  10FB  3E 01        	MVI A,001H                      ;Place a one into least significant bit of accumulator
 2522  10FD  1F           	RAR                             ;And rotate it out into the carry bit
 2523  10FE  C3 02 11     	JMP QUOROT                      ;Proceed to rotate the carry bit into the current quotient
 2524  1101  AF           NOGO:	XRA A                           ;When result is negative, put a zero in the carry bit, then
 2525  1102  21 98 15     QUOROT:	LXI H,AUX_SYMBOL_BUF            ;Set up pointer to LSW of quotient register
 2526  1105  06 03        	MVI B,003H                      ;Set precision counter
 2527  1107  CD 8E 11     	CALL ROTL                       ;Rotate carry bit into quotient by using special entry to
 2528  110A  21 27 00     	LXI H,FPOP                      ;ROTATL subroutine. Now set up pointer to dividend
 2529  110D  06 03        	MVI B,003H                      ;LSW and set precision counter
 2530  110F  CD 8D 11     	CALL ROTATL                     ;Rotate the current dividend to the left
 2531  1112  21 63 00     	LXI H,BITS_COUNTER              ;Set pointer to bit counter storage location
 2532  1115  4E           	MOV C,M                         ;Fetch the value of the bit counter
 2533  1116  0D           	DCR C                           ;Decrement the value by one
 2534  1117  71           	MOV M,C                         ;Restore the new counter value to storage
 2535  1118  C2 EA 10     	JNZ DIVIDE                      ;If bit counter is not zero, continue division process
 2536  111B  CD 4B 11     	CALL SETSUB                     ;After 23 (decimal) bits, do subtraction once more for
 2537  111E  FA 40 11     	JM DVEXIT                       ;Possible rounding. Jump ahead if no rounding required.
 2538  1121  21 98 15     	LXI H,AUX_SYMBOL_BUF            ;If rounding required set pointer to LSW of quotient
 2539  1124  7E           	MOV A,M                         ;Fetch LSW of quotient to accumulator
 2540  1125  C6 01        	ADI 001H                        ;Add one to 23rd bit of quotient
 2541  1127  77           	MOV M,A                         ;Restore updated LSW of quotient
 2542  1128  3E 00        	MVI A,000H                      ;Clear accumulator without disturbing carry bit
 2543  112A  2C           	INR L                           ;Advance pointer to next significant byte of quotient
 2544  112B  8E           	ADC M                           ;Propagate any carry as part of rounding process
 2545  112C  77           	MOV M,A                         ;Restore the updated byte of quotient
 2546  112D  3E 00        	MVI A,000H                      ;Clear ACC again without disturbing carry bit
 2547  112F  2C           	INR L                           ;Advance pointer to MSW of quotient
 2548  1130  8E           	ADC M                           ;Propagate any carry to finish rounding process
 2549  1131  77           	MOV M,A                         ;Restore the updated byte of quotient
 2550  1132  F2 40 11     	JP DVEXIT                       ;If most significant bit of quotient is zero, go finish up
 2551  1135  06 03        	MVI B,003H                      ;If not, set precision counter
 2552  1137  CD 97 11     	CALL ROTATR                     ;And rotate quotient to the right to clear the sign bit
 2553  113A  21 22 00     	LXI H,FPACC_EXP                 ;Set pointer to FPACC Exponent
 2554  113D  46           	MOV B,M                         ;Fetch FPACC exponent
 2555  113E  04           	INR B                           ;Increment the value to compensate for the rotate right
 2556  113F  70           	MOV M,B                         ;Restore the updated exponent value
 2557  1140  21 31 00     DVEXIT:	LXI H,FP_WORK_63                ;Set up pointers
 2558  1143  11 1E 00     	LXI D,FPACC_LSW_M1              ;To transfer the quotient into the FPACC
 2559  1146  06 04        	MVI B,004H                      ;Set precision counter
 2560                                                       ;THIS IS A CORRECTION FOUND IN THE NOTES
 2561  1148  C3 59 10     	JMP EXMLDV                      ;And exit through FPMULT routine at EXMLDV
 2562                     
 2563                                                       ;Subroutine to subtract divisor from dividend. Used by
 2564                                                       ;main DIVIDE subroutine.
 2565                     
 2566  114B  11 26 00     SETSUB:	LXI D,FPOP_EXT_59               ;Set pointer to LSW of working area
 2567  114E  54           	MOV D,H                         ;On same page as FPACC
 2568  114F  21 1F 00     	LXI H,FPACC                     ;Set pointer to LSW of FPACC (divisor)
 2569  1152  06 03        	MVI B,003H                      ;Set precision counter
 2570  1154  CD F5 0F     	CALL MOVEIT                     ;Perform transfer
 2571  1157  11 26 00     	LXI D,FPOP_EXT_59               ;Reset pointer to LSW of working area (now divisor)
 2572  115A  21 27 00     	LXI H,FPOP                      ;Reset pointer to LSW of FPOP (dividend)
 2573  115D  06 03        	MVI B,003H                      ;Set precision counter
 2574  115F  CD A1 11     	CALL SUBBER                     ;Subtract divisor from dividend
 2575  1162  7E           	MOV A,M                         ;Get MSW of the result of the subtraction operations
 2576  1163  A7           	ANA A                           ;Exercise CPU flags
 2577  1164  C9           	RET                             ;Return to caller with status
 2578  1165  A7           ADDER:	ANA A                           ;Initialize the carry bit to zero upon entry
 2579  1166  7E           ADDMOR:	MOV A,M                         ;Fetch byte from register group A
 2580  1167  CD F6 11     	CALL SWITCH                     ;Switch memory pointer to register group B
 2581  116A  8E           	ADC M                           ;Add byte from A to byte from B with carry
 2582  116B  77           	MOV M,A                         ;Leave result in register group B
 2583  116C  05           	DCR B                           ;Decrement number of bytes (precision) counter
 2584  116D  C8           	RZ                              ;Return to caller when all bytes in group processed
 2585  116E  2C           	INR L                           ;Else advance pointer for register group B
 2586  116F  CD F6 11     	CALL SWITCH                     ;Switch memory pointer back to register group A
 2587  1172  2C           	INR L                           ;Advance the pointer for register group A
 2588  1173  C3 66 11     	JMP ADDMOR                      ;Continue the multi-byte addition operation
 2589                     
 2590                                                       ;N'th precision two's complement (negate)
 2591                                                       ;subroutine. Performs a two's complement on the multi-byte
 2592                                                       ;registers tarting at the address pointed
 2593                                                       ; to by H & L (least significant byte) upon entry.
 2594                     
 2595  1176  7E           COMPLM:	MOV A,M                         ;Fetch the least significant byte of the number to ACC
 2596  1177  EE FF        	XRI 0FFH                        ;Exclusive OR to complement the byte
 2597  1179  C6 01        	ADI 001H                        ;Add one to form two's complement of byte
 2598  117B  77           MORCOM:	MOV M,A                         ;Restore the negated byte to memory
 2599  117C  1F           	RAR                             ;Save the carry bit
 2600  117D  57           	MOV D,A                         ;In CPU register D
 2601  117E  05           	DCR B                           ;Decrement number of bytes (precision) counter
 2602  117F  C8           	RZ                              ;Return to caller when all bytes in number processed
 2603  1180  2C           	INR L                           ;Else advance the pointer
 2604  1181  7E           	MOV A,M                         ;Fetch the next byte of the number to ACC
 2605  1182  EE FF        	XRI 0FFH                        ;Exclusive OR to complement the byte
 2606  1184  5F           	MOV E,A                         ;Save complemented value in register E temporarily
 2607  1185  7A           	MOV A,D                         ;Restore previous carry status to ACC
 2608  1186  17           	RAL                             ;And rotate it out to the carry bit
 2609  1187  3E 00        	MVI A,000H                      ;Clear ACC without disturbing carry status
 2610  1189  8B           	ADC E                           ;Add in any carry to complemented value
 2611  118A  C3 7B 11     	JMP MORCOM                      ;Continue the two's complement procedure as req'd
 2612                     
 2613                                                       ;N'th precision rotate left subroutine. Rotates a multi-
 2614                                                       ;byte number left starting at the address initially
 2615                                                       ;specified by the contents of CPU registers H & L upon
 2616                                                       ;subroutine entry (LSW). First entry point will clear
 2617                                                       ;the carry bit before beginning rotate operations. Second
 2618                                                       ;entry point does not clear the carry bit.
 2619                     
 2620  118D  A7           ROTATL:	ANA A                           ;Clear the carry bit at this entry point
 2621  118E  7E           ROTL:	MOV A,M                         ;Fetch a byte from memory
 2622  118F  17           	RAL                             ;Rotate it left (bring carry into LSB, push MSB to carry)
 2623  1190  77           	MOV M,A                         ;Restore rotated word to memory
 2624  1191  05           	DCR B                           ;Decrement precision counter
 2625  1192  C8           	RZ                              ;Exit to caller when finished
 2626  1193  2C           	INR L                           ;Else advance pointer to next byte
 2627  1194  C3 8E 11     	JMP ROTL                        ;Continue rotate left operations
 2628                     
 2629                     
 2630                                                       ;N'th precision rotate
 2631                                                       ;right subroutine. Opposite of
 2632                                                       ;above subroutine.
 2633                     
 2634  1197  A7           ROTATR:	ANA A                           ;Clear the carry bit at this entry point
 2635  1198  7E           ROTR:	MOV A,M                         ;Fetch a byte from memory
 2636  1199  1F           	RAR                             ;Rotate it right (carry into MSB, LSB to carry)
 2637  119A  77           	MOV M,A                         ;Restore rotated word to memory
 2638  119B  05           	DCR B                           ;Decrement precision counter
 2639  119C  C8           	RZ                              ;Exit to caller when finished
 2640  119D  2D           	DCR L                           ;Else decrement pointer to next byte
 2641  119E  C3 98 11     	JMP ROTR                        ;Continue rotate right operations
 2642                     
 2643                                                       ;N'th precision subtraction subroutine.
 2644                                                       ;Number starting at location pointed to by D & E (least
 2645                                                       ;significant byte) is subtracted from number starting at
 2646                                                       ;address specified by contents of H & L.
 2647                     
 2648  11A1  A7           SUBBER:	ANA A                           ;Initialize the carry bit to zero upon entry
 2649  11A2  7E           SUBTRA:	MOV A,M                         ;Fetch byte from register group A
 2650  11A3  CD F6 11     	CALL SWITCH                     ;Switch memory pointer to register group B
 2651  11A6  9E           	SBB M                           ;Subtract byte from group B ftom that in group A
 2652  11A7  77           	MOV M,A                         ;Leave result in register group B
 2653  11A8  05           	DCR B                           ;Decrement number of bytes (precision) counter
 2654  11A9  C8           	RZ                              ;Return to caller when all bytes in group processed
 2655  11AA  2C           	INR L                           ;Else advance pointer for register group B
 2656  11AB  CD F6 11     	CALL SWITCH                     ;Switch memory pointer back to register group A
 2657  11AE  2C           	INR L                           ;Advance the pointer for register group A
 2658  11AF  C3 A2 11     	JMP SUBTRA                      ;Continue the multi-byte subtraction operation
 2659                     
 2660                                                       ;The next subroutine will transfer the four byte
 2661                                                       ;register string (generally a number in floating point
 2662                                                       ;format) from the starting address pointed to by CPU
 2663                                                       ;registers H & L when the subroutine is entered to
 2664                                                       ;the FPACC (floating point accumulator registers).
 2665                     
 2666  11B2  11 1F 00     FLOAD:	LXI D,FPACC                     ;Set DE to address of least signficant byte of FPACC
 2667  11B5  06 04        	MVI B,004H                      ;Set precision counter to four bytes (mantissa bytes
 2668  11B7  C3 F5 0F     	JMP MOVEIT                      ;Plus Exponent) and exit via the transfer routine
 2669                     
 2670                                                       ;The next several subroutines are used to perform
 2671                                                       ;floating pojnt register loading and transfer operations.
 2672                     
 2673  11BA  5D           FSTORE:	MOV E,L                         ;Transfer contents of register L to E
 2674  11BB  54           	MOV D,H                         ;Transfer contents of register H to D
 2675  11BC  21 1F 00     	LXI H,FPACC                     ;Set L to least significant byte of FPACC mantissa
 2676  11BF  C3 C5 11     	JMP SETIT                       ;Go transfer FPACC contents to area pointed to by D&E
 2677  11C2  11 27 00     OPLOAD:	LXI D,FPOP                      ;Set DE to least significant byte of FPOP
 2678  11C5  06 04        SETIT:	MVI B,004H                      ;Set precision counter. Transfer from H & L area to
 2679  11C7  C3 F5 0F     	JMP MOVEIT                      ;Locations pointed to by D & E
 2680                     
 2681                                                       ;The next subroutine perforins a double transfer opera-
 2682                                                       ;tion. It first transfers the contents of the FPACC into
 2683                                                       ;the FPOP. It then transfers new data (as pointed to by
 2684                                                       ;H & L upon entry to the subroutine) into the FPACC.
 2685                     
 2686  11CA  CD D9 11     FACXOP:	CALL SAVEHL                     ;Save contents of H & L upon entry to subroutine
 2687  11CD  21 1F 00     	LXI H,FPACC                     ;Set pointer to FPACC LSW
 2688  11D0  CD C2 11     	CALL OPLOAD                     ;Transfer FPACC to FPOP
 2689  11D3  CD E8 11     	CALL RESTHL                     ;Recover original subroutine entry values for H & L
 2690  11D6  C3 B2 11     	JMP FLOAD                       ;Transfer registers pointed to by H & L into the FPACC
 2691                     
 2692                                                       ;Subroutine to save the contents of CPU registers D, E, H
 2693                                                       ;and L in a temporary storage area in memory.
 2694                     
 2695  11D9  7C           SAVEHL:	MOV A,H                         ;Transfer value in H to ACC
 2696  11DA  45           	MOV B,L                         ;And value in L to B
 2697  11DB  21 5B 00     	LXI H,TEMP_REGS                 ;Set HL to start of temporary storage locations
 2698  11DE  77           	MOV M,A                         ;Save A (entry value of H) in memory
 2699  11DF  23           	INX H                           ;Advance pointer
 2700  11E0  70           	MOV M,B                         ;Save B (entry value of L) in memory
 2701  11E1  23           	INX H                           ;Advance pointer
 2702  11E2  72           	MOV M,D                         ;Save D in memory
 2703  11E3  23           	INX H                           ;Advance pointer
 2704  11E4  73           	MOV M,E                         ;Save E in memory
 2705  11E5  67           	MOV H,A                         ;Restore entry value of H
 2706  11E6  68           	MOV L,B                         ;Restore entry value of L
 2707  11E7  C9           	RET                             ;Exit to calling routine
 2708                     
 2709                                                       ;Subroutine to restore the contents of CPU registers D,
 2710                                                       ;E, H and L from temporary storage in memory.
 2711                     
 2712  11E8  21 5B 00     RESTHL:	LXI H,TEMP_REGS                 ;Set HL to start of temporary storage locations
 2713  11EB  7E           	MOV A,M                         ;Fetch stored value for H into ACC
 2714  11EC  23           	INX H                           ;Advance pointer
 2715  11ED  46           	MOV B,M                         ;Fetch stored value for L into B
 2716  11EE  23           	INX H                           ;Advance pointer
 2717  11EF  56           	MOV D,M                         ;Fetch stored value for D
 2718  11F0  23           	INX H                           ;Advance pointer
 2719  11F1  5E           	MOV E,M                         ;Fetch stored value for E
 2720  11F2  67           	MOV H,A                         ;Restore saved value for H
 2721  11F3  68           	MOV L,B                         ;Restore saved value for L
 2722  11F4  7E           	MOV A,M                         ;Leave stored value for E in ACC
 2723  11F5  C9           	RET                             ;Exit to calling routine
 2724                     
 2725                                                       ;Subroutine to exchange the contents of H & L with
 2726                                                       ;D & E.
 2727                     
 2728  11F6  4C           SWITCH:	MOV C,H                         ;Transfer register H to C temporarily
 2729  11F7  62           	MOV H,D                         ;Place value of D into H
 2730  11F8  51           	MOV D,C                         ;Now put former H from C into D
 2731  11F9  4D           	MOV C,L                         ;Transfer register L to C temporarily
 2732  11FA  6B           	MOV L,E                         ;Place value of E into L
 2733  11FB  59           	MOV E,C                         ;Now put former L from C into E
 2734  11FC  C9           	RET                             ;Exit to calling routine
 2735  11FD  21 6A 00     GETINP:	LXI H,GETINP_CNT                ;Set HL to address of GETINP character counter
 2736  1200  4E           	MOV C,M                         ;Load counter value into CPU register C
 2737  1201  0C           	INR C                           ;Exercise the counter in order
 2738  1202  0D           	DCR C                           ;To set CPU flags. If counter is non-zero, then indexing
 2739  1203  C2 0F 12     	JNZ NOT0                        ;Register (GETINP counter) is all set so jump ahead.
 2740  1206  6B           	MOV L,E                         ;But, if counter zero, then starting to process a new
 2741  1207  62           	MOV H,D                         ;Character string. Transfer char string buffer pointer into
 2742  1208  4E           	MOV C,M                         ;H & L and fetch the string's character count value (cc)
 2743  1209  0C           	INR C                           ;Increment the (cc) by one to take account of (cc) byte
 2744  120A  CD 23 12     	CALL INDEXC                     ;Add contents of regis C to H & L to point to end of the
 2745  120D  36 00        	MVI M,000H                      ;Character string in buffer and place a zero byte marker
 2746  120F  21 6A 00     NOT0:	LXI H,GETINP_CNT                ;Set L back to address of GETINP counter which is used
 2747  1212  4E           	MOV C,M                         ;Fetch the value of GETINP counter into register C
 2748  1213  0C           	INR C                           ;Increment the value in C
 2749  1214  71           	MOV M,C                         ;Restore the updated value for future use
 2750  1215  6B           	MOV L,E                         ;Bring the base address of the character string buffer into
 2751  1216  62           	MOV H,D                         ;CPU registers H & L
 2752  1217  CD 23 12     	CALL INDEXC                     ;Add contents of register C to form indexed address of
 2753  121A  7E           	MOV A,M                         ;Next character to be fetched as input. Fetch the next
 2754  121B  A7           	ANA A                           ;Character. Exercise the CPU flags.
 2755  121C  C0           	RNZ                             ;If character is non-zero, not end of string, exit to caller
 2756  121D  21 6A 00     	LXI H,GETINP_CNT                ;If zero character, must reset GETINP counter for next
 2757  1220  36 00        	MVI M,000H                      ;String. Reset pointer and clear GETINP counter to zero
 2758  1222  C9           	RET                             ;Then exit to calling routine
 2759                     
 2760                                                       ;Following subroutine causes register C to be used as an
 2761                                                       ;indexing register. Value in C is added to address in H
 2762                                                       ;and L to form new address.
 2763                     
 2764  1223  7D           INDEXC:	MOV A,L                         ;Place value from register L into accumulator
 2765  1224  81           	ADD C                           ;Add quantity in register C
 2766  1225  6F           	MOV L,A                         ;Restore updated value back to L
 2767  1226  D0           	RNC                             ;Exit to caller if no carry from addition
 2768  1227  24           	INR H                           ;But, if have carry then must increment register H
 2769  1228  C9           	RET                             ;Before returning to calling routine
