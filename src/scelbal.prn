  479                                                       ;The following subroutine is used to
  480                                                       ;input characters from the system's
  481                                                       ;input device (such as a keyboard)
  482                                                       ;into the LINE INPUT BUFFER. Routine has limited
  483                                                       ;editing capability included.
  484                                                       ;(Rubout = delete previous character(s) entered.)
  485  01E6  0E 00        STRIN:	MVI C,000H                      ;Initialize register C to zero.
  486  01E8  CD 66 02     STRIN1:	CALL CINPUT                     ;Call user provided device input subroutine to fetch one
  487  01EB  FE FF        	CPI 0FFH                        ;Character from the input device. Is it ASCII code for
  488  01ED  C2 FF 01     	JNZ NOTDEL                      ;Rubout? Skip to next section if not rubout.
  489  01F0  3E DC        	MVI A,0DCH                      ;Else, load ASCII code for backslash into ACC.
  490  01F2  CD 58 02     	CALL ECHO                       ;Call user display driver to present backslash as a delete
  491  01F5  0D           	DCR C                           ;Indicator. Now decrement the input character counter.
  492  01F6  FA E6 01     	JM STRIN                        ;If at beginning of line do NOT decrement H and L.
  493  01F9  CD 4F 02     	CALL DEC                        ;Else, decrement H & L line pointer to erase previous
  494  01FC  C3 E8 01     	JMP STRIN1                      ;Entry, then go back for a new input.
  495  01FF  FE 83        NOTDEL:	CPI 083H                        ;See if character inputted was'CONTROL C'
  496  0201  CA 7D 09     	JZ CTRLC                        ;If so, stop inputting and go back to the EXECutive
  497  0204  FE 8D        	CPI 08DH                        ;If not, see if character was carriage-return
  498  0206  CA 1C 02     	JZ STRINF                       ;If so, have end of line of input
  499  0209  FE 8A        	CPI 08AH                        ;If not, see if character was line-feed
  500  020B  CA E8 01     	JZ STRIN1                       ;If so, ignore the input, get another character
  501  020E  CD DA 01     	CALL ADV                        ;If none of the above, advance contents of H & L
  502  0211  0C           	INR C                           ;Increment the character counter
  503  0212  77           	MOV M,A                         ;Store the new character in the line input buffer
  504  0213  79           	MOV A,C                         ;Put new character count in the accumulator
  505  0214  FE 50        	CPI 050H                        ;Make sure maximum buffer size not exceeded
  506  0216  F2 6C 01     	JP BIGERR                       ;If buffer size exceeded, go display BG error message
  507  0219  C3 E8 01     	JMP STRIN1                      ;Else can go back to look for next input
  508  021C  41           STRINF:	MOV B,C                         ;Transfer character count from C to B
  509  021D  CD 25 02     	CALL SUBHL                      ;Subtract B from H & L to get starting address of
  510  0220  71           	MOV M,C                         ;The string and place the character count (cc) there
  511  0221  CD 3D 02     	CALL CRLF                       ;Provide a line ending CR & LF combination on the
  512  0224  C9           	RET                             ;Display device. Then exit to caller.
