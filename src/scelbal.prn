 2671  11BA  54           	MOV D,H                         ;Transfer contents of register H to D
 2672  11BB  21 1F 00     	LXI H,FPACC                     ;Set L to least significant byte of FPACC mantissa
 2673  11BE  C3 C4 11     	JMP SETIT                       ;Go transfer FPACC contents to area pointed to by D&E
