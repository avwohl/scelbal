  443                                                       ;Subroutine to concatenate (append) a character to the
  444                                                       ;SYMBOL BUFFER. Character must be alphanumeric.
  445                     
  446  0208  FE C1        CONCTA:	CPI 0C1H                        ;See if character code less than that for letter A.
  447  020A  FA 12 02     	JM CONCTN                       ;If so, go see if it is numeric.
  448  020D  FE DB        	CPI 0DBH                        ;See if character code greater than that for letter Z.
  449  020F  FA 1C 02     	JM CONCTS                       ;If not, have valid alphabetical character.
  450  0212  FE B0        CONCTN:	CPI 0B0H                        ;Else, see if character in valid numeric range.
  451  0214  FA 2A 02     	JM CONCTE                       ;If not, have an error condition.
  452  0217  FE BA        	CPI 0BAH                        ;Continue to check for valid number.
  453  0219  F2 2A 02     	JP CONCTE                       ;If not, have an error condition.
  454  021C  21 37 16     CONCTS:	LXI H,SYMBOL_BUF                ;If character alphanumeric, can concatenate. Set pointer
  455  021F  4E           CONCT1:	MOV C,M                         ;Fetch old character count in SYMBOL BUFFER.
  456  0220  0C           	INR C                           ;Increment the value to account for adding new
  457  0221  71           	MOV M,C                         ;Character to the buffer. Restore updated (cc).
  458  0222  47           	MOV B,A                         ;Save character to be appended in register B.
  459  0223  CD D7 12     	CALL INDEXC                     ;Add (cc) to address in H & L to get new end of buffer
  460  0226  70           	MOV M,B                         ;Address and append the new character to buffer
  461  0227  3E 00        	MVI A,000H                      ;Clear the accumulator
  462  0229  C9           	RET                             ;Exit to caller
  463  022A  C3 E9 08     CONCTE:	JMP SYNERR                      ;If character to be appended not alphanumeric, ERROR!
  464                     
  465                                                       ;Subroutine to compare
  466                                                       ;character strings pointed to by
  467                                                       ;register pairs D & E and H & L.
  468                     
  469  022D  7E           STRCP:	MOV A,M                         ;Fetch (cc) of first string.
  470  022E  CD AB 12     	CALL SWITCH                     ;Switch pointers and fetch length of second string (cc)
  471  0231  46           	MOV B,M                         ;Into register B. Compare the lengths of the two strings.
  472  0232  B8           	CMP B                           ;If they are not the same
  473  0233  C0           	RNZ                             ;Return to caller with flags set to non-zero condition
  474  0234  CD AB 12     	CALL SWITCH                     ;Else, exchange the pointers back to first string.
  475  0237  CD 5C 02     STRCPL:	CALL ADV                        ;Advance the pointer to string number 1 and fetch a
  476  023A  7E           	MOV A,M                         ;Character from that string into the accumulator.
  477  023B  CD AB 12     	CALL SWITCH                     ;Now switch the pointers to string number 2.
  478  023E  CD 5C 02     	CALL ADV                        ;Advance the pointer in line number 2.
  479  0241  C5           STRCPE:	PUSH B                          ;Save BC (B has string length counter)
  480  0242  4F           	MOV C,A                         ;Save char from string 1 in C
  481  0243  E6 7F        	ANI 07FH                        ;Mask off bit 7 from string 1 char
  482  0245  47           	MOV B,A                         ;Save masked char in B
  483  0246  7E           	MOV A,M                         ;Get char from string 2
  484  0247  E6 7F        	ANI 07FH                        ;Mask off bit 7 from string 2 char
  485  0249  B8           	CMP B                           ;Compare masked characters
  486  024A  79           	MOV A,C                         ;Restore original char to A (for other uses)
  487  024B  C1           	POP B                           ;Restore BC
  488  024C  C0           	RNZ                             ;If not equal, return to caller with flags set to non-zero
  489  024D  CD AB 12     	CALL SWITCH                     ;Else, exchange pointers to restore pntr to string 1
  490  0250  05           	DCR B                           ;Decrement the string length counter in register B
  491  0251  C2 37 02     	JNZ STRCPL                      ;If not finiahed, continue testing entire string
  492  0254  C9           	RET                             ;If complete match, return with flag in zero condition
  493  0255  7E           STRCPC:	MOV A,M                         ;Fetch character pointed to by pointer to string 1
  494  0256  CD AB 12     	CALL SWITCH                     ;Exchange pointer to examine string 2
  495  0259  C3 41 02     	JMP STRCPE                      ;Continue the string comparison loop
  496                     
  497                                                       ;Subroutine to advance the two byte
  498                                                       ;value in CPU registers H and L.
  499                     
  500  025C  23           ADV:	INX H                           ;Advance HL pointer (16-bit increment)
  501  025D  C9           	RET                             ;Return to caller
  502                     
  503                                                       ;Subroutine to advance a buffer pointer
  504                                                       ;and test to see if the end of the buffer
  505                                                       ;has been reached.
  506                     
  507  025E  46           LOOP:	MOV B,M                         ;Fetch memory location pointed to by H & L into B.
  508  025F  04           	INR B                           ;Increment the value.
  509  0260  70           	MOV M,B                         ;Restore it back to memory.
  510  0261  21 E7 15     	LXI H,LINE_INP_BUF              ;Change pointer to start of INPUT LINE BUFFER
  511  0264  7E           	MOV A,M                         ;Fetch buffer length (cc) value into the accumulator
  512  0265  05           	DCR B                           ;Make value in B original value
  513  0266  B8           	CMP B                           ;See if buffer length same as that in B
  514  0267  C9           	RET                             ;Return with flags yielding results of the comparison
  515                     
  516                                                       ;The following subroutine is used to
  517                                                       ;input characters from the system's
  518                                                       ;input device (such as a keyboard)
  519                                                       ;into the LINE INPUT BUFFER. Routine has limited
  520                                                       ;editing capability included.
  521                                                       ;(Rubout = delete previous character(s) entered.)
  522  0268  0E 00        STRIN:	MVI C,000H                      ;Initialize register C to zero.
  523  026A  CD F2 02     STRIN1:	CALL CINPUT                     ;Call user provided device input subroutine to fetch one
  524  026D  FE FF        	CPI 0FFH                        ;Character from the input device. Is it ASCII code for
  525  026F  CA 77 02     	JZ DORUB                        ;Rubout (DEL=0x7F + 0x80)? Go handle delete.
  526  0272  FE 88        	CPI 088H                        ;Also check for backspace (BS=0x08 + 0x80)
  527  0274  C2 86 02     	JNZ NOTDEL                      ;Skip to next section if not delete.
  528                     DORUB:
  529  0277  3E DC        	MVI A,0DCH                      ;Else, load ASCII code for backslash into ACC.
  530  0279  CD E4 02     	CALL ECHO                       ;Call user display driver to present backslash as a delete
  531  027C  0D           	DCR C                           ;Indicator. Now decrement the input character counter.
  532  027D  FA 68 02     	JM STRIN                        ;If at beginning of line do NOT decrement H and L.
  533  0280  CD DB 02     	CALL DEC                        ;Else, decrement H & L line pointer to erase previous
  534  0283  C3 6A 02     	JMP STRIN1                      ;Entry, then go back for a new input.
  535  0286  FE 83        NOTDEL:	CPI 083H                        ;See if character inputted was CONTROL C (0x03+0x80)
  536  0288  CA 2C 0A     	JZ CTRLC                        ;If so, stop inputting and go back to the EXECutive
  537  028B  FE 9A        	CPI 09AH                        ;See if character was Ctrl-Z/EOF (0x1A+0x80)
  538  028D  CA A8 02     	JZ STRINF                       ;If so, treat as end of line (EOF from pipe)
  539  0290  FE 8D        	CPI 08DH                        ;If not, see if character was carriage-return (0x0D+0x80)
  540  0292  CA A8 02     	JZ STRINF                       ;If so, have end of line of input
  541  0295  FE 8A        	CPI 08AH                        ;If not, see if character was line-feed (0x0A+0x80)
  542  0297  CA 6A 02     	JZ STRIN1                       ;If so, ignore the input, get another character
  543  029A  CD 5C 02     	CALL ADV                        ;If none of the above, advance contents of H & L
  544  029D  0C           	INR C                           ;Increment the character counter
  545  029E  77           	MOV M,A                         ;Store the new character in the line input buffer
  546  029F  79           	MOV A,C                         ;Put new character count in the accumulator
  547  02A0  FE 50        	CPI 050H                        ;Make sure maximum buffer size not exceeded
  548  02A2  F2 E4 01     	JP BIGERR                       ;If buffer size exceeded, go display BG error message
  549  02A5  C3 6A 02     	JMP STRIN1                      ;Else can go back to look for next input
  550  02A8  41           STRINF:	MOV B,C                         ;Transfer character count from C to B
  551  02A9  CD B1 02     	CALL SUBHL                      ;Subtract B from H & L to get starting address of
  552  02AC  71           	MOV M,C                         ;The string and place the character count (cc) there
  553  02AD  CD C9 02     	CALL CRLF                       ;Provide a line ending CR & LF combination on the
  554  02B0  C9           	RET                             ;Display device. Then exit to caller.
  555                     
  556                                                       ;Subroutine to subtract contents of CPU register B from
  557                                                       ;the two byte value in CPU registers H & L.
  558                     
  559  02B1  7D           SUBHL:	MOV A,L                         ;Load contents of register L into the accumulator
  560  02B2  90           	SUB B                           ;Subtract the contents of register B
  561  02B3  6F           	MOV L,A                         ;Store result in L
  562  02B4  7C           	MOV A,H                         ;Get H
  563  02B5  DE 00        	SBI 000H                        ;Subtract borrow (carry) from H
  564  02B7  67           	MOV H,A                         ;Store result in H
  565  02B8  C9           	RET                             ;Return to caller.
