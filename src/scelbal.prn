 2873  12F5  21 65 00     	LXI H,EXP_SIGNS                 ;Set pointer to Exponent SIGN indicator location
 2874  12F8  7E           	MOV A,M                         ;Fetch the value of the EXP SIGN indicator
 2875  12F9  A7           	ANA A                           ;Exercise the CPU flags
 2876  12FA  21 3D 00     	LXI H,FP_WORK_6F                ;Reset pointer to input exponent storage location
 2877  12FD  CA 06 13     	JZ POSEXP                       ;If EXP SIGN indicator zero, exponent is positive
 2878  1300  7E           	MOV A,M                         ;Else, exponent is negative so must negate
