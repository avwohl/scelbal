 3225  1434  E6 0F                   ANI	00FH                     ;Trim ASCII code to BCD
 3226  1436  77                      MOV	M,A                      ;Store temporarily
 3227  1437  1E 68                   MVI	E,068H                   ;Set pointer to working area LSW of multi-byte register
 3228  1439  2E 6C                   MVI	L,OFS_FP_WORK_6C                   ;Set another pointer to LSW of conversion register
 3229  143B  54                      MOV	D,H                      ;Make sure D set to page of working area
 3230  143C  06 03                   MVI	B,003H                   ;Set precision counter
 3231  143E  CD 0B 11                CALL	MOVEIT                  ;Move original value of conversion register to working
 3232  1441  2E 6C                   MVI	L,OFS_FP_WORK_6C                   ;Register. Reset pointer to LSW of conversion register.
 3233  1443  06 03                   MVI	B,003H                   ;Set precision counter
 3234  1445  CD 7F 12                CALL	ROTATL                  ;Rotate register left, (Multiplies value by two.)
 3235  1448  2E 6C                   MVI	L,OFS_FP_WORK_6C                   ;Reset pointer to LSW.
 3236  144A  06 03                   MVI	B,003H                   ;Set precision counter
 3237  144C  CD 7F 12                CALL	ROTATL                  ;Multiply by two again (total now times four).
 3238  144F  1E 6C                   MVI	E,06CH                   ;Set pointer to LSW of conversion register.
 3239  1451  2E 68                   MVI	L,OFS_FP_WORK_68                   ;Set pointer to LSW of working register (original value).
 3240  1453  06 03                   MVI	B,003H                   ;Set precision counter.
 3241  1455  CD 57 12                CALL	ADDER                   ;Add original value to rotated value (now times five).
 3242  1458  2E 6C                   MVI	L,OFS_FP_WORK_6C                   ;Reset pointer to LSW
 3243  145A  06 03                   MVI	B,003H                   ;Set precision counter
 3244  145C  CD 7F 12                CALL	ROTATL                  ;Multiply by two once more (total now times ten).
 3245  145F  2E 6A                   MVI	L,OFS_FP_WORK_6A                   ;Set pointer to clear working register locatiotis
 3246  1461  AF                      XRA	A                        ;Clear the accumulator
 3247  1462  77                      MOV	M,A                      ;Clear MSW of working register
 3248  1463  2D                      DCR	L                        ;Decrement pointer
 3249  1464  77                      MOV	M,A                      ;Clear next byte
 3250  1465  2E 6B                   MVI	L,OFS_FP_WORK_6B                   ;Set pointer to current digit storage location
 3251  1467  7E                      MOV	A,M                      ;Fetch the current digit
 3252  1468  2E 68                   MVI	L,OFS_FP_WORK_68                   ;Change pointer to LSW of working register
 3253  146A  77                      MOV	M,A                      ;Deposit the current digit in LSW of working register
 3254  146B  1E 6C                   MVI	E,06CH                   ;Set pointer to conversion register LSW
 3255  146D  06 03                   MVI	B,003H                   ;Set precision counter
 3256  146F  CD 57 12                CALL	ADDER                   ;Add current digit to conversion register to complete
 3257  1472  C3 DF 12                JMP	RESTHL                   ;Conversion. Exit to caller by restoring CPU registers.
 3258  1475  26 01        FPOUT:	MVI	H,HIGH OLDPG1                ;** Set H to working area for floating point routines
 3259  1477  2E 6F                   MVI	L,OFS_FP_WORK_6F                   ;Set pointer to decimal exponent storage location
 3260  1479  36 00                   MVI	M,000H                   ;Initialize storage location to zero
 3261  147B  2E 56                   MVI	L,OFS_FPACC_MSW                   ;Change pointer to FPACC (number to be outputted)
 3262  147D  7E                      MOV	A,M                      ;And fetch MSW of FPACC
 3263  147E  A7                      ANA	A                        ;Test the contents of MSW of FPACC
 3264  147F  FA 87 14                JM	OUTNEG                    ;If most significant bit of MSW is a one, have a minus nr.
 3265  1482  3E A0                   MVI	A,0A0H                   ;Else number is positive, set ASCII code for space for a
 3266  1484  C3 90 14                JMP	AHEAD1                   ;Positive number and go display a space
 3267  1487  2E 54        OUTNEG:	MVI	L,OFS_FPACC                      ;If number in FPACC is negative must negate in order
 3268  1489  06 03                   MVI	B,003H                   ;To display. Set pntr to LSW of FPACC & set prec. cntr.
 3269  148B  CD 68 12                CALL	COMPLM                  ;Negate the number in the FPACC to make it positive
 3270  148E  3E AD                   MVI	A,0ADH                   ;But load ACC with ASCII code for minus sign
 3271  1490  CD 82 03     AHEAD1:	CALL	ECHO                       ;Call user display driver to output space or minus sign
 3272  1493  2E 48                   MVI	L,OFS_FP_MODE_IND                   ;Set pointer to FIXED/FLOAT indicator
 3273  1495  7E                      MOV	A,M                      ;Fetch value of FIXED/FLOAT indicator
 3274  1496  A7                      ANA	A                        ;Test contents of indicator. If contents are zero, calling
 3275  1497  CA AB 14                JZ	OUTFLT                    ;Routine has directed floating point output format.
 3276  149A  2E 57                   MVI	L,OFS_FPACC_EXP                   ;If indicator non-zero, fixed point fonnat requested if
 3277  149C  3E 17                   MVI	A,017H                   ;Possible. Point to FPACC Exponent. Put 23 decimal in
 3278  149E  46                      MOV	B,M                      ;Accumulator. Fetch FPACC Exponent into register B
 3279  149F  04                      INR	B                        ;And exercise the register to test its
 3280  14A0  05                      DCR	B                        ;Original contents. If FPACC Exponent is negative in
 3281  14A1  FA AB 14                JM	OUTFLT                    ;Value then go to floating point output forrnat. If value
 3282  14A4  90                      SUB	B                        ;Is positive, subtract value from 23 (decimal). If result
 3283  14A5  FA AB 14                JM	OUTFLT                    ;Negative, number is too big to use fixed format.
 3284  14A8  C3 B9 14                JMP	OUTFIX                   ;Else, can use fixed format so skip next routine
 3285  14AB  2E 48        OUTFLT:	MVI	L,OFS_FP_MODE_IND                      ;Set pointer to FIXED/FLOAT indicator.
 3286  14AD  36 00                   MVI	M,000H                   ;Clear indicator to indicate floating point output format
 3287  14AF  3E B0                   MVI	A,0B0H                   ;Load ASCII code for '0' into accumulator
 3288  14B1  CD 82 03                CALL	ECHO                    ;Call user display driver to output '0' as first character
 3289  14B4  3E AE                   MVI	A,0AEH                   ;Number string. Now load ASCII code for decimal point.
 3290  14B6  CD 82 03                CALL	ECHO                    ;Call user display driver to output '.'as second character.
 3291  14B9  2E 57        OUTFIX:	MVI	L,OFS_FPACC_EXP                      ;Set pointer to FPACC Exponent
 3292  14BB  3E FF                   MVI	A,0FFH                   ;Load accumulator with minus one
 3293  14BD  86                      ADD	M                        ;Add value in FPACC Exponent
 3294  14BE  77                      MOV	M,A                      ;Restore compensated exponent value
 3295                     
 3296                                                       ;Next portion of routine establishes the value for the
 3297                                                       ;decimal exponent that will be outputted by processing
 3298                                                       ;the binary exponent value in the FPACC.
 3299                     
 3300  14BF  F2 DE 14     DECEXT:	JP	DECEXD                       ;If compensated exponent value is zero or positive
 3301  14C2  3E 04                   MVI	A,004H                   ;Then go multiply FPACC by 0.1 (decimal). Else,
 3302  14C4  86                      ADD	M                        ;Add four to the exponent value.
