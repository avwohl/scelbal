 2763  1224  6F           	MOV L,A                         ;Restore updated value back to L
 2764  1225  D0           	RNC                             ;Exit to caller if no carry from addition
 2765  1226  24           	INR H                           ;But, if have carry then must increment register H
 2766  1227  C9           	RET                             ;Before returning to calling routine
