  119  002B  00 00 00     	DB	000H,000H,000H
  120                     FP_TEMP_0F:                             ; FP_TEMP exponent byte (offset 3)
  121  002E  00           	DB	000H
  122                     FP_WORK_AREA:                           ; Floating point working area (24 bytes)
  123                     FP_WORK_61:                             ; Offset 0 of work area
  124  002F  00           	DB	000H
  125                     FP_WORK_62:
  126  0030  00           	DB	000H
  127                     FP_WORK_63:
  128  0031  00           	DB	000H
  129                     FP_WORK_64:
  130  0032  00           	DB	000H
  131                     FP_WORK_65:
  132  0033  00           	DB	000H
  133                     FP_WORK_66:
  134  0034  00           	DB	000H
  135                     FP_WORK_67:
  136  0035  00           	DB	000H
  137                     FP_WORK_68:
  138  0036  00           	DB	000H
  139                     FP_WORK_69:
  140  0037  00           	DB	000H
  141                     FP_WORK_6A:
  142  0038  00           	DB	000H
  143                     FP_WORK_6B:
  144  0039  00           	DB	000H
  145                     FP_WORK_6C:
  146  003A  00           	DB	000H
  147                     FP_WORK_6D:
  148  003B  00           	DB	000H
  149                     FP_WORK_6E:
  150  003C  00           	DB	000H
  151                     FP_WORK_6F:
  152  003D  00           	DB	000H
  153                     FP_WORK_70:
  154  003E  00           	DB	000H
  155                     FP_WORK_71:
  156  003F  00           	DB	000H
  157                     FP_WORK_72:
  158  0040  00           	DB	000H
  159                     FP_WORK_73:
  160  0041  00           	DB	000H
  161                     FP_WORK_74:
  162  0042  00           	DB	000H
  163                     FP_WORK_75:
  164  0043  00           	DB	000H
  165                     FP_WORK_76:
  166  0044  00           	DB	000H
  167                     FP_WORK_77:
  168  0045  00           	DB	000H
  169                     FP_WORK_78:
  170  0046  00           	DB	000H
  171                     FPACC_SAVE:                             ; FPACC save area (4 bytes)
  172  0047  00 00 00 00  	DB	000H,000H,000H,000H
  173                     SCRATCH_PAD1:                           ; Scratch pad area (4 bytes)
  174                     SCRATCH_1F:                             ; Alias for SCRATCH_PAD1
  175  004B  00 00 00 00  	DB	000H,000H,000H,000H
  176                     SCRATCH_PAD2:                           ; Scratch pad area (12 bytes)
  177                     COL_024:                                ; Column counter / SQR approx temp
  178  004F  00 00 00 00  	DB	000H,000H,000H,000H
  179  0053  00 00 00 00  	DB	000H,000H,000H,000H
  180  0057  00 00 00 00  	DB	000H,000H,000H,000H
  181                     TEMP_REGS:                              ; Temporary register storage (D,E,H,L)
  182  005B  00 00 00 00  	DB	000H,000H,000H,000H
