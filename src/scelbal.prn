  666  033F  FE 05        	CPI 005H                        ;Check to see if last operator was exponentiation
  667  0341  CA E9 08     	JZ SYNERR                       ;If yes, then have a syntax error
  668  0344  21 37 16     	LXI H,SYMBOL_BUF                ;If none of the above, then minus sign is unary, put
  669  0347  36 01        	MVI M,001H                      ;Character string representing the
  670  0349  23           	INX H                           ;Value zero in the SYMBOL BUFFER in string format
  671  034A  36 B0        	MVI M,0B0H                      ;(Character count (cc) followed by ASCII code for zero)
