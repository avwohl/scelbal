 3881  1A8C  0E 02        	MVI C,002H                      ;Set up counter in register C for future ops
 3882  1A8E  21 55 16     	LXI H,ARRAY_VAR                 ;Load L with address of start of ARRAY VARIABLES
 3883  1A91  CD 7E 06     	CALL TABADR                     ;Calculate the address of next entry in the table
 3884  1A94  11 59 15     	LXI D,SYMBOL_BUF                ;Load DE with starting address of SYMBOL BUFF
 3885  1A97  CD B5 01     	CALL STRCP                      ;Compare entry in table against contents of SYMBOL BF
 3886  1A9A  CA AB 1A     	JZ ARRAY7                       ;If match, have found array name in the table.
 3887  1A9D  21 FE 15     	LXI H,LOOP_COUNTER              ;Else, set HL to address of the LOOP COUNTER
 3888  1AA0  7E           	MOV A,M                         ;Fetch the counter value to the ACC
 3889  1AA1  21 41 16     	LXI H,NUM_DIM_ARRAYS            ;Change HL to counter containing number of arrays
 3890  1AA4  BE           	CMP M                           ;Compare number of arrays to count in LOOP CNTR
 3891  1AA5  C2 86 1A     	JNZ ARRAY6                      ;If more entries in the table, continue looking for match
 3892  1AA8  C3 64 06     	JMP FAERR                       ;If no matching name in table then have an error condx.
 3893  1AAB  CD 69 02     ARRAY7:	CALL EVAL                       ;Call subroutine to evaluate subscript expression
 3894  1AAE  CD AA 0E     	CALL FPFIX                      ;Convert the subscript value obtained to fixed forrnat
 3895  1AB1  21 FE 15     	LXI H,LOOP_COUNTER              ;Load L with address of LOOP COUNTER
