 2856  12D0  77           	MOV M,A                         ;Restore the value to exponent storage location
 2857  12D1  C3 AB 12     	JMP EXPINP                      ;Go get any additional exponent int)ut
 2858  12D4  21 64 00     ENDINP:	LXI H,SIGN_IND2                 ;Set pointer to mantissa SIGN indicator
 2859  12D7  7E           	MOV A,M                         ;Fetch the SIGN indicator to the acclimulator
 2860  12D8  A7           	ANA A                           ;Exercise the CPU flags
