 2927                                                       ;Following subroutine is used
 2928                                                       ;to convert decimal charac-
 2929                                                       ;ters to binary fixed point forinat
 2930                                                       ;in a triple-precision format.
 2931                     
 2932  1343  CD D9 11     DECBIN:	CALL SAVEHL                     ;Save entry value of D, E, H and L in memory
 2933  1346  21 39 00     	LXI H,FP_WORK_6B                ;Set pointer to temporary storage location
 2934  1349  79           	MOV A,C                         ;Restore character inputted to accumulator
 2935  134A  E6 0F        	ANI 00FH                        ;Trim ASCII code to BCD
 2936  134C  77           	MOV M,A                         ;Store temporarily
 2937  134D  11 36 00     	LXI D,FP_WORK_68                ;Set pointer to working area LSW of multi-byte register
 2938  1350  21 3A 00     	LXI H,FP_WORK_6C                ;Set another pointer to LSW of conversion register
 2939  1353  54           	MOV D,H                         ;Make sure D set to page of working area
 2940  1354  06 03        	MVI B,003H                      ;Set precision counter
 2941  1356  CD F5 0F     	CALL MOVEIT                     ;Move original value of conversion register to working
 2942  1359  21 3A 00     	LXI H,FP_WORK_6C                ;Register. Reset pointer to LSW of conversion register.
 2943  135C  06 03        	MVI B,003H                      ;Set precision counter
 2944  135E  CD 8D 11     	CALL ROTATL                     ;Rotate register left, (Multiplies value by two.)
 2945  1361  21 3A 00     	LXI H,FP_WORK_6C                ;Reset pointer to LSW.
 2946  1364  06 03        	MVI B,003H                      ;Set precision counter
 2947  1366  CD 8D 11     	CALL ROTATL                     ;Multiply by two again (total now times four).
 2948  1369  11 3A 00     	LXI D,FP_WORK_6C                ;Set pointer to LSW of conversion register.
 2949  136C  21 36 00     	LXI H,FP_WORK_68                ;Set pointer to LSW of working register (original value).
 2950  136F  06 03        	MVI B,003H                      ;Set precision counter.
 2951  1371  CD 65 11     	CALL ADDER                      ;Add original value to rotated value (now times five).
 2952  1374  21 3A 00     	LXI H,FP_WORK_6C                ;Reset pointer to LSW
 2953  1377  06 03        	MVI B,003H                      ;Set precision counter
 2954  1379  CD 8D 11     	CALL ROTATL                     ;Multiply by two once more (total now times ten).
 2955  137C  21 38 00     	LXI H,FP_WORK_6A                ;Set pointer to clear working register locatiotis
 2956  137F  AF           	XRA A                           ;Clear the accumulator
 2957  1380  77           	MOV M,A                         ;Clear MSW of working register
 2958  1381  2D           	DCR L                           ;Decrement pointer
 2959  1382  77           	MOV M,A                         ;Clear next byte
 2960  1383  21 39 00     	LXI H,FP_WORK_6B                ;Set pointer to current digit storage location
 2961  1386  7E           	MOV A,M                         ;Fetch the current digit
 2962  1387  21 36 00     	LXI H,FP_WORK_68                ;Change pointer to LSW of working register
 2963  138A  77           	MOV M,A                         ;Deposit the current digit in LSW of working register
 2964  138B  11 3A 00     	LXI D,FP_WORK_6C                ;Set pointer to conversion register LSW
 2965  138E  06 03        	MVI B,003H                      ;Set precision counter
 2966  1390  CD 65 11     	CALL ADDER                      ;Add current digit to conversion register to complete
 2967  1393  C3 E8 11     	JMP RESTHL                      ;Conversion. Exit to caller by restoring CPU registers.
 2968  1396  21 3D 00     FPOUT:	LXI H,FP_WORK_6F                ;Set HL to decimal exponent storage location
 2969  1399  36 00        	MVI M,000H                      ;Initialize storage location to zero
 2970  139B  21 21 00     	LXI H,FPACC_MSW                 ;Change pointer to FPACC (number to be outputted)
 2971  139E  7E           	MOV A,M                         ;And fetch MSW of FPACC
 2972  139F  A7           	ANA A                           ;Test the contents of MSW of FPACC
 2973  13A0  FA A8 13     	JM OUTNEG                       ;If most significant bit of MSW is a one, have a minus nr.
 2974  13A3  3E A0        	MVI A,0A0H                      ;Else number is positive, set ASCII code for space for a
 2975  13A5  C3 B2 13     	JMP AHEAD1                      ;Positive number and go display a space
 2976  13A8  21 1F 00     OUTNEG:	LXI H,FPACC                     ;If number in FPACC is negative must negate in order
 2977  13AB  06 03        	MVI B,003H                      ;To display. Set pntr to LSW of FPACC & set prec. cntr.
 2978  13AD  CD 76 11     	CALL COMPLM                     ;Negate the number in the FPACC to make it positive
 2979  13B0  3E AD        	MVI A,0ADH                      ;But load ACC with ASCII code for minus sign
 2980  13B2  CD 60 02     AHEAD1:	CALL ECHO                       ;Call user display driver to output space or minus sign
 2981  13B5  21 69 00     	LXI H,FP_MODE_IND               ;Set pointer to FIXED/FLOAT indicator
 2982  13B8  7E           	MOV A,M                         ;Fetch value of FIXED/FLOAT indicator
 2983  13B9  A7           	ANA A                           ;Test contents of indicator. If contents are zero, calling
 2984  13BA  CA CF 13     	JZ OUTFLT                       ;Routine has directed floating point output format.
 2985  13BD  21 22 00     	LXI H,FPACC_EXP                 ;If indicator non-zero, fixed point fonnat requested if
 2986  13C0  3E 17        	MVI A,017H                      ;Possible. Point to FPACC Exponent. Put 23 decimal in
 2987  13C2  46           	MOV B,M                         ;Accumulator. Fetch FPACC Exponent into register B
 2988  13C3  04           	INR B                           ;And exercise the register to test its
 2989  13C4  05           	DCR B                           ;Original contents. If FPACC Exponent is negative in
 2990  13C5  FA CF 13     	JM OUTFLT                       ;Value then go to floating point output forrnat. If value
 2991  13C8  90           	SUB B                           ;Is positive, subtract value from 23 (decimal). If result
 2992  13C9  FA CF 13     	JM OUTFLT                       ;Negative, number is too big to use fixed format.
 2993  13CC  C3 DE 13     	JMP OUTFIX                      ;Else, can use fixed format so skip next routine
 2994  13CF  21 69 00     OUTFLT:	LXI H,FP_MODE_IND               ;Set pointer to FIXED/FLOAT indicator.
 2995  13D2  36 00        	MVI M,000H                      ;Clear indicator to indicate floating point output format
 2996  13D4  3E B0        	MVI A,0B0H                      ;Load ASCII code for '0' into accumulator
 2997  13D6  CD 60 02     	CALL ECHO                       ;Call user display driver to output '0' as first character
 2998  13D9  3E AE        	MVI A,0AEH                      ;Number string. Now load ASCII code for decimal point.
 2999  13DB  CD 60 02     	CALL ECHO                       ;Call user display driver to output '.'as second character.
 3000  13DE  21 22 00     OUTFIX:	LXI H,FPACC_EXP                 ;Set pointer to FPACC Exponent
 3001  13E1  3E FF        	MVI A,0FFH                      ;Load accumulator with minus one
 3002  13E3  86           	ADD M                           ;Add value in FPACC Exponent
 3003  13E4  77           	MOV M,A                         ;Restore compensated exponent value
 3004                     
 3005                                                       ;Next portion of routine establishes the value for the
 3006                                                       ;decimal exponent that will be outputted by processing
 3007                                                       ;the binary exponent value in the FPACC.
 3008                     
 3009  13E5  F2 05 14     DECEXT:	JP DECEXD                       ;If compensated exponent value is zero or positive
 3010  13E8  3E 04        	MVI A,004H                      ;Then go multiply FPACC by 0.1 (decimal). Else,
 3011  13EA  86           	ADD M                           ;Add four to the exponent value.
 3012  13EB  F2 17 14     	JP DECOUT                       ;If exponent now zero or positive, ready to output
 3013  13EE  21 0B 00     	LXI H,FP_CONST_10               ;If exponent negative, multiply FPACC by 10 (decimal)
 3014  13F1  CD CA 11     	CALL FACXOP                     ;Floating point format. Set up for multiplication.
 3015  13F4  CD 0F 10     	CALL FPMULT                     ;Perform the multiplication. Answer in FPACC.
 3016  13F7  21 3D 00     	LXI H,FP_WORK_6F                ;Set pointer to decimal exponent storage location.
 3017  13FA  4E           	MOV C,M                         ;Each time the FPACC is multiplied by ten, need to
 3018  13FB  0D           	DCR C                           ;Decrement the value in the decinial exponent storage
 3019  13FC  71           	MOV M,C                         ;Location. (This establishes decimal exponent value!)
 3020  13FD  21 22 00     DECREP:	LXI H,FPACC_EXP                 ;Reset pointer to FPACC Exponent
 3021  1400  7E           	MOV A,M                         ;Fetch value in exponent
 3022  1401  A7           	ANA A                           ;Test value
 3023  1402  C3 E5 13     	JMP DECEXT                      ;Repeat process as required
 3024  1405  21 0F 00     DECEXD:	LXI H,FP_CONST_0P1              ;If exponent is positive, multiply FPACC by 0.1
 3025  1408  CD CA 11     	CALL FACXOP                     ;Floating point format. Set up for multipli(-ation.
 3026  140B  CD 0F 10     	CALL FPMULT                     ;Perform the multiplication. Answer in FPACC.
 3027  140E  21 3D 00     	LXI H,FP_WORK_6F                ;Set pointer to decimal exponent storage location.
 3028  1411  46           	MOV B,M                         ;Each time the FPACC is multiplied by one tenth, need
 3029  1412  04           	INR B                           ;To increment the value in the decimal exponent storage
 3030  1413  70           	MOV M,B                         ;Location. (This establishes decimal exponent value!)
 3031  1414  C3 FD 13     	JMP DECREP                      ;Repeat process as required
 3032                     
 3033                                                       ;The next section outputs the mantissa
 3034                                                       ;(or fixed point number) by converting the value remaining
 3035                                                       ;in the FPACC (after the decimal exponent equivalent has
 3036                                                       ;been extracted from the original value if required by the
 3037                                                       ;previous routines) to a string of decirnal digits.
 3038  1417  1E 74        DECOUT:	MVI E,074H                      ;Set pointer to LSW of output working register
 3039  1419  54           	MOV D,H                         ;Set D to same page value as H
 3040  141A  21 1F 00     	LXI H,FPACC                     ;Set pointer to LSW of FPACC
 3041  141D  06 03        	MVI B,003H                      ;Set precision counter
 3042  141F  CD F5 0F     	CALL MOVEIT                     ;Move value in FPACC to output working register
 3043  1422  21 45 00     	LXI H,FP_WORK_77                ;Set pointer to MSW plus one of output working register
 3044  1425  36 00        	MVI M,000H                      ;Clear that location to 0
 3045  1427  21 42 00     	LXI H,FP_WORK_74                ;Set pointer to LSW of output working register
 3046  142A  06 03        	MVI B,003H                      ;Set precision counter
 3047  142C  CD 8D 11     	CALL ROTATL                     ;Rotate register left once to compensate for sign bit
 3048  142F  CD CC 14     	CALL OUTX10                     ;Multiply output register by 10, overflow into N4SW+ 1
 3049  1432  21 22 00     COMPEN:	LXI H,FPACC_EXP                 ;Set pointer back to FPACC Exponent
 3050  1435  46           	MOV B,M                         ;Compensate for any remainder in the binary exponent
 3051  1436  04           	INR B                           ;By performing a rotate right on the output working
 3052  1437  70           	MOV M,B                         ;Register until the binary exponent becomes zero
 3053  1438  CA 46 14     	JZ OUTDIG                       ;Go output decimal digits when this loop is finished
 3054  143B  21 45 00     	LXI H,FP_WORK_77                ;Binary exponent compensating loop. Setpointe'r to
 3055  143E  06 04        	MVI B,004H                      ;Working register MSW+L. Set precision counter.
 3056  1440  CD 97 11     	CALL ROTATR                     ;Rotate working register to the right.
 3057  1443  C3 32 14     	JMP COMPEN                      ;Repeat loop as required.
 3058  1446  21 68 00     OUTDIG:	LXI H,OUT_DIG_CNT               ;Set pointer to output digit counter storage location
 3059  1449  36 07        	MVI M,007H                      ;Initialize to value of seven
 3060  144B  21 45 00     	LXI H,FP_WORK_77                ;Change pointer to output working register MSW+L
 3061  144E  7E           	MOV A,M                         ;Fetch MSW+L byte containing BCD of digit to be
 3062  144F  A7           	ANA A                           ;Displayed. Test the contents of this byte.
 3063  1450  CA AB 14     	JZ ZERODG                       ;If zero jump to ZERODG routine.
 3064  1453  21 45 00     OUTDGS:	LXI H,FP_WORK_77                ;Reset pointer to working register MSW+L
 3065  1456  7E           	MOV A,M                         ;Fetch BCD of digit to be outputted
 3066  1457  A7           	ANA A                           ;Exercise CPU flags
 3067  1458  C2 77 14     	JNZ OUTDGX                      ;If not zero, go display the digit
 3068  145B  21 69 00     	LXI H,FP_MODE_IND               ;If zero, change pointer to FIXED/FLOAT indicator
 3069  145E  7E           	MOV A,M                         ;Fetch the indicator into the accumulator
 3070  145F  A7           	ANA A                           ;Test value of indicator
 3071  1460  CA 76 14     	JZ OUTZER                       ;If in floating point mode, go display the digit
 3072  1463  21 3D 00     	LXI H,FP_WORK_6F                ;Else change pointer to decimal exponent storage
 3073  1466  4E           	MOV C,M                         ;Location, which, for fixed point, will have a positive
 3074  1467  0D           	DCR C                           ;Value for all digits before the decimal point. Decrement
 3075  1468  0C           	INR C                           ;And increment to exercise flags. See if count is positive.
 3076  1469  F2 76 14     	JP OUTZER                       ;If positive, must display any zero digit.
 3077  146C  21 44 00     	LXI H,FP_WORK_76                ;If not, change pointer to MSW of working register
 3078  146F  7E           	MOV A,M                         ;And test to see if any significant digits coming up
 3079  1470  E6 E0        	ANI 0E0H                        ;By forming a mask and testing for presence of bits
 3080  1472  C2 76 14     	JNZ OUTZER                      ;If more significant digits coming up soon, display the
 3081  1475  C9           	RET                             ;Zero digit. Else, exit to calling routine. Finished.
 3082  1476  AF           OUTZER:	XRA A                           ;Clear the accumulator to restore zero digit value
 3083  1477  C6 B0        OUTDGX:	ADI 0B0H                        ;Add 260 (octal) to BCD code in ACC to form ASCII
 3084  1479  CD 60 02     	CALL ECHO                       ;Code and call the user's display driver subroutine
 3085  147C  21 69 00     DECRDG:	LXI H,FP_MODE_IND               ;Set pointer to FIXED/FLOAT indicator storage
 3086  147F  7E           	MOV A,M                         ;Fetch the indicator to the accumulator
 3087  1480  A7           	ANA A                           ;Exercise the CPU flags
 3088  1481  C2 93 14     	JNZ CKDECP                      ;If indicator non-zero, doing fixed point output
 3089  1484  21 68 00     	LXI H,OUT_DIG_CNT               ;Else, get output digit counter
 3090  1487  4E           	MOV C,M
 3091  1488  0D           	DCR C                           ;Decrement the digit counter & restore to storage
 3092  1489  71           	MOV M,C
 3093  148A  CA FF 14     	JZ EXPOUT                       ;When digit counter is zero, go take care of exponent
 3094  148D  CD CC 14     PUSHIT:	CALL OUTX10                     ;Else push next BCD digit out of working register
 3095  1490  C3 53 14     	JMP OUTDGS                      ;And continue the outputting process
 3096  1493  21 3D 00     CKDECP:	LXI H,FP_WORK_6F                ;For fixed point output, decimal exponent serves as
 3097  1496  4E           	MOV C,M                         ;Counter for number of digits before decimal point
 3098  1497  0D           	DCR C                           ;Fetch the counter and decrement it to account for
 3099  1498  71           	MOV M,C                         ;Current digit being processed. Restore to storage.
 3100  1499  C2 A1 14     	JNZ NODECP                      ;If count does not go to zero, jump ahead.
 3101  149C  3E AE        	MVI A,0AEH                      ;When count reaches zero, load ASCII code for period
 3102  149E  CD 60 02     	CALL ECHO                       ;And call user's display driver to display decimal point
 3103  14A1  21 68 00     NODECP:	LXI H,OUT_DIG_CNT               ;Set pointer to output digit counter storage location
 3104  14A4  4E           	MOV C,M                         ;Fetch the digit counter
 3105  14A5  0D           	DCR C                           ;Decrement the value
 3106  14A6  71           	MOV M,C                         ;Restore to storage
 3107  14A7  C8           	RZ                              ;If counter reaches zero, exit to caller. Finished.
 3108  14A8  C3 8D 14     	JMP PUSHIT                      ;Else continue to output the number.
 3109  14AB  21 3D 00     ZERODG:	LXI H,FP_WORK_6F                ;If first digit of floating point number is a zero, set
 3110  14AE  4E           	MOV C,M                         ;Pointer to decimal exponent storage location.
 3111  14AF  0D           	DCR C                           ;Decrement the value to compensate for skipping
 3112  14B0  71           	MOV M,C                         ;Display of first digit. Restore to storage.
 3113  14B1  21 44 00     	LXI H,FP_WORK_76                ;Change pointer to MSW of output working register
 3114  14B4  7E           	MOV A,M                         ;Fetch MSW of output working register
 3115  14B5  A7           	ANA A                           ;Test the contents
 3116  14B6  C2 7C 14     	JNZ DECRDG                      ;If non-zero, continue outputting
 3117  14B9  2D           	DCR L                           ;Else decrement pointer to next byte in working register
 3118  14BA  7E           	MOV A,M                         ;Fetch its contents
 3119  14BB  A7           	ANA A                           ;Test
 3120  14BC  C2 7C 14     	JNZ DECRDG                      ;If non-zero, continue outputting
 3121  14BF  2D           	DCR L                           ;Else decrement pointer to LSW of working register
 3122  14C0  7E           	MOV A,M                         ;Fetch its contents
 3123  14C1  A7           	ANA A                           ;Test
 3124  14C2  C2 7C 14     	JNZ DECRDG                      ;If non-zero, continue outputting
 3125  14C5  21 3D 00     	LXI H,FP_WORK_6F                ;If decimal mantissa is zero, set pointer to decirnal
 3126  14C8  77           	MOV M,A                         ;Exponent storage and clear it
 3127  14C9  C3 7C 14     	JMP DECRDG                      ;Finish outputting
 3128                     
 3129                                                       ;Following routine multiplies the binary number in the
 3130                                                       ;output working register by ten to push the most signifi-
 3131                                                       ;cant digit out to the MSW+L byte.
 3132                     
 3133  14CC  21 45 00     OUTX10:	LXI H,FP_WORK_77                ;Set pointer to work ing register M SW+ 1
 3134  14CF  36 00        	MVI M,000H                      ;Clear it in preparation for receiving next digit pushed
 3135  14D1  21 42 00     	LXI H,FP_WORK_74                ;Into it. Change pointer to working register LSW.
 3136  14D4  54           	MOV D,H                         ;Set up register D to same page as H.
 3137  14D5  1E 70        	MVI E,070H                      ;Set second pointer to LSW of second working register
 3138  14D7  06 04        	MVI B,004H                      ;Set precision counter
 3139  14D9  CD F5 0F     	CALL MOVEIT                     ;Move first working register into second
 3140  14DC  21 42 00     	LXI H,FP_WORK_74                ;Reset pointer to LSW of first working register
 3141  14DF  06 04        	MVI B,004H                      ;Set precision counter
 3142  14E1  CD 8D 11     	CALL ROTATL                     ;Rotate contents of first working register left (X 2)
 3143  14E4  21 42 00     	LXI H,FP_WORK_74                ;Reset pointer to LSW
 3144  14E7  06 04        	MVI B,004H                      ;Reset precision counter
 3145  14E9  CD 8D 11     	CALL ROTATL                     ;Rotate contents left again (X 4)
 3146  14EC  21 3E 00     	LXI H,FP_WORK_70                ;Set pointer to LSW of original value in 2'nd register
 3147  14EF  1E 74        	MVI E,074H                      ;Set pointer to LSW of rotated value
 3148  14F1  06 04        	MVI B,004H                      ;Set precision counter
 3149  14F3  CD 65 11     	CALL ADDER                      ;Add rotated value to original value (X 5)
 3150  14F6  21 42 00     	LXI H,FP_WORK_74                ;Reset pointer to LSW of first working register
 3151  14F9  06 04        	MVI B,004H                      ;Set precision counter
 3152  14FB  CD 8D 11     	CALL ROTATL                     ;Rotate contents left again (X 10)
 3153  14FE  C9           	RET                             ;Exit to calling routine
 3154                     
 3155                                                       ;The final group of routines in the floating point output
 3156                                                       ;section take care of outputting the decimal exponent
 3157                                                       ;portion of floating point numbers.
 3158                     
 3159  14FF  21 3D 00     EXPOUT:	LXI H,FP_WORK_6F                ;Set pointer to decimal exponent storage location
 3160  1502  7E           	MOV A,M                         ;Fetch value to the accumulator
 3161  1503  A7           	ANA A                           ;Test the value
 3162  1504  C8           	RZ                              ;If zero, then no exponent portion. Exit to caller.
 3163  1505  3E C5        	MVI A,0C5H                      ;Else, load ACC with ASCII code for letter E.
 3164  1507  CD 60 02     	CALL ECHO                       ;Display E for Exponent via user's display driver rtn
 3165  150A  7E           	MOV A,M                         ;Get decimal exponent value back into ACC
 3166  150B  A7           	ANA A                           ;Test again
 3167  150C  FA 14 15     	JM EXOUTN                       ;If value is negative, skip ahead
 3168  150F  3E AB        	MVI A,0ABH                      ;If positive, load ASCII code for + sign
 3169  1511  C3 1B 15     	JMP AHEAD2                      ;Jump to display the + sign
 3170  1514  EE FF        EXOUTN:	XRI 0FFH                        ;When decimal exponent is negative, must negate
 3171  1516  C6 01        	ADI 001H                        ;Value for display purposes. Perform two's complement
 3172  1518  77           	MOV M,A                         ;And restore the negated value to storage location
 3173  1519  3E AD        	MVI A,0ADH                      ;Load ASCII code for minus sign
 3174  151B  CD 60 02     AHEAD2:	CALL ECHO                       ;Display the ASCII character in ACC
 3175  151E  06 00        	MVI B,000H                      ;Clear register B
 3176  1520  7E           	MOV A,M                         ;Fetch the decimal exponent value back into ACC
 3177  1521  D6 0A        SUB12:	SUI 00AH                        ;Subtract 10 (decimal) from value in ACC
 3178  1523  FA 2B 15     	JM TOMUCH                       ;Break out of loop when accumulator goes negative
 3179  1526  77           	MOV M,A                         ;Else restore value to storage location
 3180  1527  04           	INR B                           ;Increment register B as a counter
 3181  1528  C3 21 15     	JMP SUB12                       ;Repeat loop to form tens value of decimal exponent
 3182  152B  3E B0        TOMUCH:	MVI A,0B0H                      ;Load base ASCII value for digit into the accumulator
 3183  152D  80           	ADD B                           ;Add to the count in B to forin tens digit of decimal
 3184  152E  CD 60 02     	CALL ECHO                       ;Exponent. Display via user's driver subroutine
 3185  1531  7E           	MOV A,M                         ;Fetch remainder of decimal exponent value
 3186  1532  C6 B0        	ADI 0B0H                        ;Add in ASCII base value to form final digit
 3187  1534  CD 60 02     	CALL ECHO                       ;Display second digit of decirnal exponent
 3188  1537  C9           	RET                             ;Finished outputting. Return to caller.
