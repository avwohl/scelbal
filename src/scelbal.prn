 2998  13C1  21 0B 00     	LXI H,FP_CONST_10               ;If exponent negative, multiply FPACC by 10 (decimal)
 2999  13C4  CD A0 11     	CALL FACXOP                     ;Floating point format. Set up for multiplication.
 3000  13C7  CD E5 0F     	CALL FPMULT                     ;Perform the multiplication. Answer in FPACC.
 3001  13CA  21 3D 00     	LXI H,FP_WORK_6F                ;Set pointer to decimal exponent storage location.
 3002  13CD  4E           	MOV C,M                         ;Each time the FPACC is multiplied by ten, need to
 3003  13CE  0D           	DCR C                           ;Decrement the value in the decinial exponent storage
 3004  13CF  71           	MOV M,C                         ;Location. (This establishes decimal exponent value!)
 3005  13D0  21 22 00     DECREP:	LXI H,FPACC_EXP                 ;Reset pointer to FPACC Exponent
 3006  13D3  7E           	MOV A,M                         ;Fetch value in exponent
 3007  13D4  A7           	ANA A                           ;Test value
 3008  13D5  C3 B8 13     	JMP DECEXT                      ;Repeat process as required
 3009  13D8  21 0F 00     DECEXD:	LXI H,FP_CONST_0P1              ;If exponent is positive, multiply FPACC by 0.1
 3010  13DB  CD A0 11     	CALL FACXOP                     ;Floating point format. Set up for multipli(-ation.
 3011  13DE  CD E5 0F     	CALL FPMULT                     ;Perform the multiplication. Answer in FPACC.
 3012  13E1  21 3D 00     	LXI H,FP_WORK_6F                ;Set pointer to decimal exponent storage location.
 3013  13E4  46           	MOV B,M                         ;Each time the FPACC is multiplied by one tenth, need
 3014  13E5  04           	INR B                           ;To increment the value in the decimal exponent storage
 3015  13E6  70           	MOV M,B                         ;Location. (This establishes decimal exponent value!)
 3016  13E7  C3 D0 13     	JMP DECREP                      ;Repeat process as required
 3017                     
 3018                                                       ;The next section outputs the mantissa
 3019                                                       ;(or fixed point number) by converting the value remaining
 3020                                                       ;in the FPACC (after the decimal exponent equivalent has
 3021                                                       ;been extracted from the original value if required by the
 3022                                                       ;previous routines) to a string of decirnal digits.
 3023  13EA  1E 74        DECOUT:	MVI E,074H                      ;Set pointer to LSW of output working register
 3024  13EC  54           	MOV D,H                         ;Set D to same page value as H
 3025  13ED  21 1F 00     	LXI H,FPACC                     ;Set pointer to LSW of FPACC
 3026  13F0  06 03        	MVI B,003H                      ;Set precision counter
 3027  13F2  CD CB 0F     	CALL MOVEIT                     ;Move value in FPACC to output working register
 3028  13F5  AF           	XRA A                           ;Clear accumulator
 3029  13F6  32 45 00     	STA FP_WORK_77                  ;Clear MSW plus one of output working register
 3030  13F9  21 42 00     	LXI H,FP_WORK_74                ;Set pointer to LSW of output working register
 3031  13FC  06 03        	MVI B,003H                      ;Set precision counter
 3032  13FE  CD 63 11     	CALL ROTATL                     ;Rotate register left once to compensate for sign bit
 3033  1401  CD 9E 14     	CALL OUTX10                     ;Multiply output register by 10, overflow into N4SW+ 1
 3034  1404  21 22 00     COMPEN:	LXI H,FPACC_EXP                 ;Set pointer back to FPACC Exponent
 3035  1407  46           	MOV B,M                         ;Compensate for any remainder in the binary exponent
 3036  1408  04           	INR B                           ;By performing a rotate right on the output working
 3037  1409  70           	MOV M,B                         ;Register until the binary exponent becomes zero
 3038  140A  CA 18 14     	JZ OUTDIG                       ;Go output decimal digits when this loop is finished
 3039  140D  21 45 00     	LXI H,FP_WORK_77                ;Binary exponent compensating loop. Setpointe'r to
 3040  1410  06 04        	MVI B,004H                      ;Working register MSW+L. Set precision counter.
 3041  1412  CD 6D 11     	CALL ROTATR                     ;Rotate working register to the right.
 3042  1415  C3 04 14     	JMP COMPEN                      ;Repeat loop as required.
 3043  1418  21 68 00     OUTDIG:	LXI H,OUT_DIG_CNT               ;Set pointer to output digit counter storage location
 3044  141B  36 07        	MVI M,007H                      ;Initialize to value of seven
 3045  141D  21 45 00     	LXI H,FP_WORK_77                ;Change pointer to output working register MSW+L
 3046  1420  7E           	MOV A,M                         ;Fetch MSW+L byte containing BCD of digit to be
 3047  1421  A7           	ANA A                           ;Displayed. Test the contents of this byte.
 3048  1422  CA 7D 14     	JZ ZERODG                       ;If zero jump to ZERODG routine.
 3049  1425  21 45 00     OUTDGS:	LXI H,FP_WORK_77                ;Reset pointer to working register MSW+L
 3050  1428  7E           	MOV A,M                         ;Fetch BCD of digit to be outputted
 3051  1429  A7           	ANA A                           ;Exercise CPU flags
 3052  142A  C2 49 14     	JNZ OUTDGX                      ;If not zero, go display the digit
 3053  142D  21 69 00     	LXI H,FP_MODE_IND               ;If zero, change pointer to FIXED/FLOAT indicator
 3054  1430  7E           	MOV A,M                         ;Fetch the indicator into the accumulator
 3055  1431  A7           	ANA A                           ;Test value of indicator
 3056  1432  CA 48 14     	JZ OUTZER                       ;If in floating point mode, go display the digit
 3057  1435  21 3D 00     	LXI H,FP_WORK_6F                ;Else change pointer to decimal exponent storage
 3058  1438  4E           	MOV C,M                         ;Location, which, for fixed point, will have a positive
 3059  1439  0D           	DCR C                           ;Value for all digits before the decimal point. Decrement
 3060  143A  0C           	INR C                           ;And increment to exercise flags. See if count is positive.
 3061  143B  F2 48 14     	JP OUTZER                       ;If positive, must display any zero digit.
 3062  143E  21 44 00     	LXI H,FP_WORK_76                ;If not, change pointer to MSW of working register
 3063  1441  7E           	MOV A,M                         ;And test to see if any significant digits coming up
 3064  1442  E6 E0        	ANI 0E0H                        ;By forming a mask and testing for presence of bits
 3065  1444  C2 48 14     	JNZ OUTZER                      ;If more significant digits coming up soon, display the
 3066  1447  C9           	RET                             ;Zero digit. Else, exit to calling routine. Finished.
 3067  1448  AF           OUTZER:	XRA A                           ;Clear the accumulator to restore zero digit value
 3068  1449  C6 B0        OUTDGX:	ADI 0B0H                        ;Add 260 (octal) to BCD code in ACC to form ASCII
 3069  144B  CD 58 02     	CALL ECHO                       ;Code and call the user's display driver subroutine
 3070  144E  21 69 00     DECRDG:	LXI H,FP_MODE_IND               ;Set pointer to FIXED/FLOAT indicator storage
 3071  1451  7E           	MOV A,M                         ;Fetch the indicator to the accumulator
 3072  1452  A7           	ANA A                           ;Exercise the CPU flags
 3073  1453  C2 65 14     	JNZ CKDECP                      ;If indicator non-zero, doing fixed point output
 3074  1456  21 68 00     	LXI H,OUT_DIG_CNT               ;Else, get output digit counter
 3075  1459  4E           	MOV C,M
 3076  145A  0D           	DCR C                           ;Decrement the digit counter & restore to storage
 3077  145B  71           	MOV M,C
 3078  145C  CA D0 14     	JZ EXPOUT                       ;When digit counter is zero, go take care of exponent
 3079  145F  CD 9E 14     PUSHIT:	CALL OUTX10                     ;Else push next BCD digit out of working register
 3080  1462  C3 25 14     	JMP OUTDGS                      ;And continue the outputting process
 3081  1465  21 3D 00     CKDECP:	LXI H,FP_WORK_6F                ;For fixed point output, decimal exponent serves as
 3082  1468  4E           	MOV C,M                         ;Counter for number of digits before decimal point
 3083  1469  0D           	DCR C                           ;Fetch the counter and decrement it to account for
 3084  146A  71           	MOV M,C                         ;Current digit being processed. Restore to storage.
 3085  146B  C2 73 14     	JNZ NODECP                      ;If count does not go to zero, jump ahead.
 3086  146E  3E AE        	MVI A,0AEH                      ;When count reaches zero, load ASCII code for period
 3087  1470  CD 58 02     	CALL ECHO                       ;And call user's display driver to display decimal point
 3088  1473  21 68 00     NODECP:	LXI H,OUT_DIG_CNT               ;Set pointer to output digit counter storage location
 3089  1476  4E           	MOV C,M                         ;Fetch the digit counter
 3090  1477  0D           	DCR C                           ;Decrement the value
 3091  1478  71           	MOV M,C                         ;Restore to storage
 3092  1479  C8           	RZ                              ;If counter reaches zero, exit to caller. Finished.
 3093  147A  C3 5F 14     	JMP PUSHIT                      ;Else continue to output the number.
 3094  147D  21 3D 00     ZERODG:	LXI H,FP_WORK_6F                ;If first digit of floating point number is a zero, set
 3095  1480  4E           	MOV C,M                         ;Pointer to decimal exponent storage location.
 3096  1481  0D           	DCR C                           ;Decrement the value to compensate for skipping
 3097  1482  71           	MOV M,C                         ;Display of first digit. Restore to storage.
 3098  1483  21 44 00     	LXI H,FP_WORK_76                ;Change pointer to MSW of output working register
 3099  1486  7E           	MOV A,M                         ;Fetch MSW of output working register
 3100  1487  A7           	ANA A                           ;Test the contents
 3101  1488  C2 4E 14     	JNZ DECRDG                      ;If non-zero, continue outputting
 3102  148B  2B           	DCX H                           ;Else decrement pointer to next byte in working register
 3103  148C  7E           	MOV A,M                         ;Fetch its contents
 3104  148D  A7           	ANA A                           ;Test
 3105  148E  C2 4E 14     	JNZ DECRDG                      ;If non-zero, continue outputting
 3106  1491  2B           	DCX H                           ;Else decrement pointer to LSW of working register
 3107  1492  7E           	MOV A,M                         ;Fetch its contents
 3108  1493  A7           	ANA A                           ;Test
 3109  1494  C2 4E 14     	JNZ DECRDG                      ;If non-zero, continue outputting
 3110  1497  21 3D 00     	LXI H,FP_WORK_6F                ;If decimal mantissa is zero, set pointer to decirnal
 3111  149A  77           	MOV M,A                         ;Exponent storage and clear it
 3112  149B  C3 4E 14     	JMP DECRDG                      ;Finish outputting
 3113                     
 3114                                                       ;Following routine multiplies the binary number in the
 3115                                                       ;output working register by ten to push the most signifi-
 3116                                                       ;cant digit out to the MSW+L byte.
 3117                     
 3118  149E  AF           OUTX10:	XRA A                           ;Clear accumulator
 3119  149F  32 45 00     	STA FP_WORK_77                  ;Clear MSW+1 in preparation for receiving next digit
 3120  14A2  21 42 00     	LXI H,FP_WORK_74                ;Set pointer to working register LSW.
 3121  14A5  54           	MOV D,H                         ;Set up register D to same page as H.
 3122  14A6  1E 70        	MVI E,070H                      ;Set second pointer to LSW of second working register
 3123  14A8  06 04        	MVI B,004H                      ;Set precision counter
 3124  14AA  CD CB 0F     	CALL MOVEIT                     ;Move first working register into second
 3125  14AD  21 42 00     	LXI H,FP_WORK_74                ;Reset pointer to LSW of first working register
 3126  14B0  06 04        	MVI B,004H                      ;Set precision counter
 3127  14B2  CD 63 11     	CALL ROTATL                     ;Rotate contents of first working register left (X 2)
 3128  14B5  21 42 00     	LXI H,FP_WORK_74                ;Reset pointer to LSW
 3129  14B8  06 04        	MVI B,004H                      ;Reset precision counter
 3130  14BA  CD 63 11     	CALL ROTATL                     ;Rotate contents left again (X 4)
 3131  14BD  21 3E 00     	LXI H,FP_WORK_70                ;Set pointer to LSW of original value in 2'nd register
 3132  14C0  1E 74        	MVI E,074H                      ;Set pointer to LSW of rotated value
 3133  14C2  06 04        	MVI B,004H                      ;Set precision counter
 3134  14C4  CD 3B 11     	CALL ADDER                      ;Add rotated value to original value (X 5)
 3135  14C7  21 42 00     	LXI H,FP_WORK_74                ;Reset pointer to LSW of first working register
 3136  14CA  06 04        	MVI B,004H                      ;Set precision counter
 3137  14CC  CD 63 11     	CALL ROTATL                     ;Rotate contents left again (X 10)
 3138  14CF  C9           	RET                             ;Exit to calling routine
 3139                     
 3140                                                       ;The final group of routines in the floating point output
 3141                                                       ;section take care of outputting the decimal exponent
 3142                                                       ;portion of floating point numbers.
 3143                     
 3144  14D0  21 3D 00     EXPOUT:	LXI H,FP_WORK_6F                ;Set pointer to decimal exponent storage location
 3145  14D3  7E           	MOV A,M                         ;Fetch value to the accumulator
 3146  14D4  A7           	ANA A                           ;Test the value
 3147  14D5  C8           	RZ                              ;If zero, then no exponent portion. Exit to caller.
 3148  14D6  3E C5        	MVI A,0C5H                      ;Else, load ACC with ASCII code for letter E.
 3149  14D8  CD 58 02     	CALL ECHO                       ;Display E for Exponent via user's display driver rtn
 3150  14DB  7E           	MOV A,M                         ;Get decimal exponent value back into ACC
 3151  14DC  A7           	ANA A                           ;Test again
 3152  14DD  FA E5 14     	JM EXOUTN                       ;If value is negative, skip ahead
 3153  14E0  3E AB        	MVI A,0ABH                      ;If positive, load ASCII code for + sign
 3154  14E2  C3 EC 14     	JMP AHEAD2                      ;Jump to display the + sign
 3155  14E5  EE FF        EXOUTN:	XRI 0FFH                        ;When decimal exponent is negative, must negate
 3156  14E7  C6 01        	ADI 001H                        ;Value for display purposes. Perform two's complement
 3157  14E9  77           	MOV M,A                         ;And restore the negated value to storage location
 3158  14EA  3E AD        	MVI A,0ADH                      ;Load ASCII code for minus sign
 3159  14EC  CD 58 02     AHEAD2:	CALL ECHO                       ;Display the ASCII character in ACC
 3160  14EF  06 00        	MVI B,000H                      ;Clear register B
 3161  14F1  7E           	MOV A,M                         ;Fetch the decimal exponent value back into ACC
 3162  14F2  D6 0A        SUB12:	SUI 00AH                        ;Subtract 10 (decimal) from value in ACC
 3163  14F4  FA FC 14     	JM TOMUCH                       ;Break out of loop when accumulator goes negative
 3164  14F7  77           	MOV M,A                         ;Else restore value to storage location
 3165  14F8  04           	INR B                           ;Increment register B as a counter
 3166  14F9  C3 F2 14     	JMP SUB12                       ;Repeat loop to form tens value of decimal exponent
 3167  14FC  3E B0        TOMUCH:	MVI A,0B0H                      ;Load base ASCII value for digit into the accumulator
 3168  14FE  80           	ADD B                           ;Add to the count in B to forin tens digit of decimal
 3169  14FF  CD 58 02     	CALL ECHO                       ;Exponent. Display via user's driver subroutine
 3170  1502  7E           	MOV A,M                         ;Fetch remainder of decimal exponent value
 3171  1503  C6 B0        	ADI 0B0H                        ;Add in ASCII base value to form final digit
 3172  1505  CD 58 02     	CALL ECHO                       ;Display second digit of decirnal exponent
 3173  1508  C9           	RET                             ;Finished outputting. Return to caller.
