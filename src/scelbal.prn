 2413  101A  4F                      MOV	C,A                      ;Else place result in register C as counter for number
 2414  101B  2E 56        FPFIXL:	MVI	L,OFS_FPACC_MSW                      ;Of rotate ops. Set pointer to MSW of FPACC
