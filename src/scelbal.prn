 2938                                                       ;The next subroutine will transfer the four byte
 2939                                                       ;register string (generally a number in floating point
 2940                                                       ;format) from the starting address pointed to by CPU
 2941                                                       ;registers H & L when the subroutine is entered to
 2942                                                       ;the FPACC (floating point accumulator registers).
 2943                     
 2944  12A4  16 01        FLOAD:	MVI	D,HIGH OLDPG1                ;** Set page address of FPACC
 2945  12A6  1E 54                   MVI	E,054H                   ;Set address of least signficant byte of FPACC
 2946  12A8  06 04                   MVI	B,004H                   ;Set precision counter to four bytes (mantissa bytes
 2947  12AA  C3 0B 11                JMP	MOVEIT                   ;Plus Exponent) and exit via the transfer routine
 2948                     
