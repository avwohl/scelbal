  229                     ;;; =========================================================================
  230                     ;;; Keywords
  231                     ;;; =========================================================================
  232                     
  233                     KW_SAVE:                                ; "SAVE" keyword (length + chars)
  234  0078  04           	DB	004H
  235  0079  53 41 56 45  	DB	"SAVE"
  236                     KW_LOAD:                                ; "LOAD" keyword (length + chars)
  237  007D  04           	DB	004H
  238  007E  4C 4F 41 44  	DB	"LOAD"
  239                     KW_THEN:
  240  0082  04           	DB	004H
  241  0083  54 48 45 4E  	DB	"THEN"
  242                     KW_TO:
  243  0087  02           	DB	002H
  244  0088  54 4F        	DB	"TO"
  245                     KW_STEP:
  246  008A  04           	DB	004H
  247  008B  53 54 45 50  	DB	"STEP"
  248                     KW_LIST:
  249  008F  04           	DB	004H
  250  0090  4C 49 53 54  	DB	"LIST"
  251                     KW_RUN:
  252  0094  03           	DB	003H
  253  0095  52 55 4E     	DB	"RUN"
  254                     KW_SCR:
  255  0098  03           	DB	003H
  256  0099  53 43 52     	DB	"SCR"
  257                     KW_FOR:
  258  009C  03           	DB	003H
  259  009D  46 4F 52     	DB	"FOR"
  260                     
  261                     ;;; =========================================================================
  262                     ;;; Messages
  263                     ;;; =========================================================================
  264                     
  265                     MSG_READY:                              ; "READY" message with control chars
  266  00A0  0B           	DB	00BH                    ; Length = 11
  267  00A1  94 8D 8A     	DB	094H,08DH,08AH          ; CTRL-T, CR, LF
  268  00A4  52 45 41 44  	DB	"READY"
       00A8  59         
  269  00A9  8D 8A 8A     	DB	08DH,08AH,08AH          ; CR, LF, LF
  270                     MSG_AT_LINE:                            ; " AT LINE " message
  271  00AC  09           	DB	009H                    ; Length = 9
  272  00AD  20 41 54 20  	DB	" AT LINE "
       00B1  4C 49 4E 45
       00B5  20         
  273                     
  274                     ;;; =========================================================================
  275                     ;;; CP/M I/O Routines
  276                     ;;; These replace the original bit-banged serial I/O with CP/M BDOS calls
  277                     ;;; =========================================================================
  278                     
  279                     save:
  280  00B6  C3 99 07     load:	JMP EXEC                        ; By default, save and load isn't implemented.
  281                     
  282                     ;;; CP/M CHARACTER INPUT - uses BDOS function 1 (C_READ)
  283                     ;;; Returns character in A
  284                     
  285  00B9  C5           CINP:	PUSH B
  286  00BA  D5           	PUSH D
  287  00BB  E5           	PUSH H
  288  00BC  0E 01        	MVI C,C_READ                    ; BDOS function 1: console input
  289  00BE  CD 05 00     	CALL BDOS                       ; Call BDOS, char returned in A
  290  00C1  E1           	POP H
  291  00C2  D1           	POP D
  292  00C3  C1           	POP B
  293  00C4  C9           	RET
  294                     
  295                     ;;; no user defined functions yet, stop here if we see one.
  296  00C5  C3 00 00     UDEFX:	JMP 0                           ; Warm boot on undefined function
  297                     
  298                     ;;; CP/M CHARACTER OUTPUT - uses BDOS function 2 (C_WRITE)
  299                     ;;; Character to print in A
  300                     
  301  00C8  C5           CPRINT:	PUSH B
  302  00C9  D5           	PUSH D
  303  00CA  E5           	PUSH H
  304  00CB  5F           	MOV E,A                         ; Character to E for BDOS
  305  00CC  0E 02        	MVI C,C_WRITE                   ; BDOS function 2: console output
  306  00CE  CD 05 00     	CALL BDOS                       ; Call BDOS
  307  00D1  E1           	POP H
  308  00D2  D1           	POP D
  309  00D3  C1           	POP B
  310  00D4  C9           	RET
  311                     
  312                     ;;; =========================================================================
  313                     ;;; Main Code
  314                     ;;; =========================================================================
  315                     
  316                     
  317  00D5  CD 8B 01     SYNTAX:	CALL CLESYM                     ;Clear the SYMBOL BUFFER area
  318  00D8  AF           	XRA A                           ;Clear accumulator
  319  00D9  32 E5 15     	STA LINENUM_BUF                 ;Initialize line number buff by placing zero as (cc)
  320  00DC  21 86 15     	LXI H,SYNTAX_PTR                ;Change pointer to syntax counter/pointer storage loc.
  321  00DF  36 01        	MVI M,001H                      ;Set pointer to first character (after cc) in line buffer
  322  00E1  21 86 15     SYNTX1:	LXI H,SYNTAX_PTR                ;Set pointer to syntax cntr/pntr storage location
  323  00E4  CD 7A 01     	CALL GETCHR                     ;Fetch the character pointed to by contents of syntax
  324  00E7  CA FA 00     	JZ SYNTX2                       ;Cntr/pntr from the line input buffer. If character was
  325  00EA  FE B0        	CPI 0B0H                        ;A space, ignore. Else, test to see if character was ASCII
  326  00EC  FA 08 01     	JM SYNTX3                       ;Code for a decimal digit. If not a decimal digit, consider
  327  00EF  FE BA        	CPI 0BAH                        ;Line number to have been processed by jumping
  328  00F1  F2 08 01     	JP SYNTX3                       ;Over the remainder of this SYNTX1 section.
  329  00F4  21 E5 15     	LXI H,LINENUM_BUF               ;If have decimal digit, set pointer to start of LINE
  330  00F7  CD A7 01     	CALL CONCT1                     ;NUMBER BUFFER and append incoming digit there.
  331  00FA  21 86 15     SYNTX2:	LXI H,SYNTAX_PTR                ;Reset L to syntax cntr/pntr storage location. Call sub-
  332  00FD  CD DC 01     	CALL LOOP                       ;Routine to advance pntr and test for end of inr)ut buffer
  333  0100  C2 E1 00     	JNZ SYNTX1                      ;If not end of input buffer, go back for next digit
  334  0103  AF           	XRA A                           ;If end of buffer, only had a line number in the line.
  335  0104  32 88 15     	STA TOKEN_STORE                 ;Set TOKEN storage location. Set TOKEN = 000.
  336  0107  C9           	RET                             ;Return to caller.
  337  0108  21 86 15     SYNTX3:	LXI H,SYNTAX_PTR                ;Reset pointer to syntax cntr/pntr and fetch
  338  010B  46           	MOV B,M                         ;Position of next character after the line number
  339  010C  21 87 15     	LXI H,SCAN_PTR                  ;Change pntr to SCAN pntr storage location
  340  010F  70           	MOV M,B                         ;Store address when SCAN takes up after line number
  341  0110  21 87 15     SYNTX4:	LXI H,SCAN_PTR                  ;Set pntr to SCAN pntr stomge location
  342  0113  CD 7A 01     	CALL GETCHR                     ;Fetch the character pointed to by contents of the SCAN
  343  0116  CA 2F 01     	JZ SYNTX6                       ;Pointer storage location. If character was ASCII code
  344  0119  FE BD        	CPI 0BDH                        ;For space, ignore. Else, compare character with "=" sign
  345  011B  CA 60 01     	JZ SYNTX7                       ;If is an equal sign, go set TOKEN for IMPLIED LET.
  346  011E  FE A8        	CPI 0A8H                        ;Else, compare character with left parenthesis " ( "
  347  0120  CA 66 01     	JZ SYNTX8                       ;If left parenthesis, go set TOKEN for implied array LET
  348  0123  CD A4 01     	CALL CONCTS                     ;Otherwise, concatenate the character onto the string
  349                     ; MGA 4/2012 begin "fast SYNTX5" patch:
  350                     ; the following patch doubles the overall speed of execution.
  351                     ; It is similar to the approach taken on 8080 SCELBAL II in 1978
  352                     ; it adhears to the rules for patches in issue 1 of SCELBAL update
  353                     ;SYNTX6:   these four lines moved up w/o label
  354  0126  21 87 15     	LXI H,SCAN_PTR                  ;Set L to SCAN pointer storage location
  355                     ;MGA 4/2012 LHI was needed at original place, not here
  356  0129  CD DC 01     	CALL LOOP                       ;Call routine to advance pntr & test for end of In buffer
  357  012C  C2 10 01     	JNZ SYNTX4                      ;Go back and add another character to SYMBOL BUFF
  358                     SYNTX6:                                 ; MGA 4/2012 label here
  359                     
  360  012F  21 88 15     	LXI H,TOKEN_STORE               ;Being constructed in the SYMBOL BUFFER. Now set
  361  0132  36 01        	MVI M,001H                      ;Up TOKEN storage location to an initial value of 001.
  362  0134  21 05 16     	LXI H,KEYWORD_TBL               ;Set L to point to start of KEYWORD TABLE.
  363  0137  11 59 15     SYNTX5:	LXI D,SYMBOL_BUF                ;Set DE to start of SYMBOL BUFFER
  364  013A  CD B5 01     	CALL STRCP                      ;Compare char string presently in SYMBOL BUFFER
  365  013D  C8           	RZ                              ;With entry in KEYWORD TABLE. Exit if match.
  366  013E  CD CC 11     	CALL SWITCH                     ;TOKEN will be set to keyword found. Else, switch
  367  0141  23           SYNTXL:	INX H                           ;Pointers to get table address back and advance pntr to
  368  0142  7E           	MOV A,M                         ;KEYWORD TABLE. Now look for start of next entry
  369  0143  E6 C0        	ANI 0C0H                        ;In KEYWORD TABLE by looking for (cc) byte which
  370  0145  C2 41 01     	JNZ SYNTXL                      ;Will NOT have a one in the two most sig. bits. Advance
  371  0148  CD CC 11     	CALL SWITCH                     ;Pntr til next entry found. Then switch pointers apin so
  372  014B  21 88 15     	LXI H,TOKEN_STORE               ;Table pointer is in D&E. Put addr of TOKEN in L.
  373  014E  46           	MOV B,M                         ;In TOKEN and advance it to account for going on to
  374  014F  04           	INR B                           ;The next entry in the KEYWORD TABLE.
  375  0150  70           	MOV M,B                         ;Restore the updated TOKEN value back to storage.
  376  0151  CD CC 11     	CALL SWITCH                     ;Restore the keyword table pointer back to H&L.
  377  0154  78           	MOV A,B                         ;Put TOKEN count in ACC.
  378  0155  FE 0D        	CPI 00DH                        ;See if have tested all entries in the keyword table.
  379  0157  C2 37 01     	JNZ SYNTX5                      ;If not, continue checking the keyword table.
  380  015A  21 88 15     	LXI H,TOKEN_STORE               ;And search table for KEYWORD again. Unless reach
  381  015D  36 FF        	MVI M,0FFH                      ;End of line input buffer. In which case set TOKEN=377
  382  015F  C9           	RET                             ;As an error indicator and exit to calling routine.
  383  0160  21 88 15     SYNTX7:	LXI H,TOKEN_STORE               ;Set pointer to TOKEN storage register. Set TOKEN
  384  0163  36 0D        	MVI M,00DH                      ;Equal to 015 when "=" sign found for IMPLIED LET.
  385  0165  C9           	RET                             ;Exit to calling routine.
  386  0166  21 88 15     SYNTX8:	LXI H,TOKEN_STORE               ;Set pointer to TOKEN storage register. Set TOKEN
  387  0169  36 0E        	MVI M,00EH                      ;Equal to 016 when "(" found for IMPLIED array LET.
  388  016B  C9           	RET                             ;Exit to calling routine.
  389                     
  390                                                       ;The following are subroutines used by SYNTAX and
  391                                                       ;other routines in SCELBAL.
  392                     
  393  016C  3E C2        BIGERR:	MVI A,0C2H                      ;Load ASCII code for letters B and G to indicate BIG
  394  016E  0E C7        	MVI C,0C7H                      ;ERROR (for when buffer, stack,etc., overflows).
  395  0170  CD 58 02     ERROR:	CALL ECHO                       ;Call user provided display routine to print ASCII code
  396  0173  79           	MOV A,C                         ;In accumulator. Transfer ASCII code from C to ACC
  397  0174  CD 58 02     	CALL ECHO                       ;And repeat to display error codes.
  398  0177  C3 84 09     	JMP FINERR                      ;Go cpmplete error message (AT LINE) as required.
  399  017A  7E           GETCHR:	MOV A,M                         ;Get pointer offset from memory location pointed to by H&L
  400  017B  FE 50        	CPI 050H                        ;See if within range of line input buffer.
  401  017D  F2 6C 01     	JP BIGERR                       ;If not then have an overflow condition = error.
  402  0180  4F           	MOV C,A                         ;Save offset in C
  403  0181  21 09 15     	LXI H,LINE_INP_BUF              ;Load base address of LINE INPUT BUFFER
  404  0184  06 00        	MVI B,000H                      ;Clear B for 16-bit add
  405  0186  09           	DAD B                           ;Add offset (BC) to base address (HL)
  406  0187  7E           	MOV A,M                         ;Fetch the character from the line input buffer.
  407  0188  FE A0        	CPI 0A0H                        ;See if it is ASCII code for space.
  408  018A  C9           	RET                             ;Return to caller with flags set according to comparison.
  409  018B  AF           CLESYM:	XRA A                           ;Clear the accumulator
  410  018C  32 59 15     	STA SYMBOL_BUF                  ;Place a zero byte at start of SYMBOL BUFFER.
  411  018F  C9           	RET                             ;To effectively clear the buffer. Then exit to caller.
  412                     
  413                     
  414                                                       ;Subroutine to concatenate (append) a character to the
  415                                                       ;SYMBOL BUFFER. Character must be alphanumeric.
  416                     
  417  0190  FE C1        CONCTA:	CPI 0C1H                        ;See if character code less than that for letter A.
  418  0192  FA 9A 01     	JM CONCTN                       ;If so, go see if it is numeric.
  419  0195  FE DB        	CPI 0DBH                        ;See if character code greater than that for letter Z.
  420  0197  FA A4 01     	JM CONCTS                       ;If not, have valid alphabetical character.
  421  019A  FE B0        CONCTN:	CPI 0B0H                        ;Else, see if character in valid numeric range.
  422  019C  FA B2 01     	JM CONCTE                       ;If not, have an error condition.
  423  019F  FE BA        	CPI 0BAH                        ;Continue to check for valid number.
  424  01A1  F2 B2 01     	JP CONCTE                       ;If not, have an error condition.
  425  01A4  21 59 15     CONCTS:	LXI H,SYMBOL_BUF                ;If character alphanumeric, can concatenate. Set pointer
  426  01A7  4E           CONCT1:	MOV C,M                         ;Fetch old character count in SYMBOL BUFFER.
  427  01A8  0C           	INR C                           ;Increment the value to account for adding new
  428  01A9  71           	MOV M,C                         ;Character to the buffer. Restore updated (cc).
