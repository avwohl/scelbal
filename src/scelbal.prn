    1                     ;;; This is the Scelbi Basic Program from 1974 known as
    2                     ;;; SCELBAL by Mark G. Arnold (MGA) and Nat Wadsworth  
    3                     ;;;
    4                     ;;;  Copyright 1975 Scelbi Computer Consulting, Inc.
    5                     ;;;  All rights reserved
    6                     ;;;
    7                     ;;; MGA gives permission to use SCELBAL for 
    8                     ;;; educational, historical, non-commercial purposes.
    9                     ;;; Versions of this have been circulating on the web since
   10                     ;;; about 2000; this version is authorized by MGA (Mar 2012)
   11                     ;;; with the understanding no warranty is expressed or implied.
   12                     ;;; As stated in the original, "no responsibility is assumed for
   13                     ;;; for inaccuracies or for the success or failure of
   14                     ;;; various applications to which the information herein
   15                     ;;; may be applied."
   16                     ;;; 
   17                     ;;; SCELBAL is the only open-source, floating-point 
   18                     ;;; high-level language ever implemented on Intel's first
   19                     ;;; general-purpose microprocessor, the 8008.  It was
   20                     ;;; published in book form:
   21                     ;;;
   22                     ;;;  SCELBAL: A Higher-Level Language for 8008/8080 Systems
   23                     ;;;
   24                     ;;; (Tiny BASIC only used 16-bit integers; the MCM\70
   25                     ;;; was a closed system; calculators implemented with 8008
   26                     ;;; were floating-point, but not high-level.)
   27                     ;;;
   28                     ;;; This version is modified to assemble with the
   29                     ;;; as8 assembler (using the -octal option) 
   30                     ;;; for the Intel 8008 by Thomas E. Jones.
   31                     ;;; This current form is made up non-relocatable so that
   32                     ;;; locations of all code and data is identical to the
   33                     ;;; original SCELBAL documents and patches.  It should be
   34                     ;;; reasonable after debugging code to convert this to a
   35                     ;;; relocatable and ROMable code with variables in RAM.
   36                     ;;; This code originates from a version made by 
   37                     ;;;
   38                     ;;;    Steve Loboyko in 2001.
   39                     ;;;
   40                     ;;; This version has all 3 patches for SCELBAL (the two
   41                     ;;; pasted in the original manual, and a third which was
   42                     ;;; written in SCELBAL UPDATE publication, as well as
   43                     ;;; a couple changes to constants which didn't actually
   44                     ;;; require a patch, just changes to bytes of data or
   45                     ;;; arguments to an instruction--one of these (Tucker) was 
   46                     ;;; incorrect and restored to original by MGA March 2012).
   47                     ;;; 
   48                     ;;; This comment must be incorporated with any version of SCELBAL
   49                     ;;; downloaded, distributed, posted or disemenated.
   50                     	
   51                     
   52                     ENDPGRAM:	EQU	02DH                      ;MGA 4/10/12 as in orig; for his ROMable Loboyko said 077       [077]
   53                     BGNPGRAM:	EQU	01BH                      ;MGA 4/10/12 as in orig; for his ROMable Loboyko said 044       [044]
   54                     	
   55                     ;;; Here are labels originally attempting to make the code
   56                     ;;; relocatable.  These 4 pages contain variable data
   57                     ;;; which needs to be relocated from ROM to RAM.
   58                     ;;; I can't vouch for ALL references to these pages in
   59                     ;;; the code being switched to these labels, but they
   60                     ;;; seem to be.
   61                     	
   62                     OLDPG1:	EQU	00100H
   63                     OLDPG26:	EQU	01600H
   64                     OLDPG27:	EQU	01700H
   65                     OLDPG57:	EQU	02F00H
   66                     
   67                     ;;; CP/M BDOS equates
   68                     BDOS:	EQU	0005H	; BDOS entry point
   69                     C_READ:	EQU	1	; Console input
   70                     C_WRITE:	EQU	2	; Console output
   71                     P_TERMCPM:	EQU	0	; Warm boot / exit
   72                     
   73                     ;;; =========================================================================
   74                     ;;; Page 1 (0100H-01FFH) Variable/Constant Offset Definitions
   75                     ;;; These are LOW BYTE offsets used with H=HIGH OLDPG1
   76                     ;;; =========================================================================
   77                     
   78                     ;;; Floating Point Constants
   79                     OFS_FP_CONST_1:	EQU	004H	; FP constant +1.0 (4 bytes)
   80                     OFS_EXP_COUNTER:	EQU	00BH	; Exponent counter (1 byte)
   81                     OFS_FP_TEMP:	EQU	00CH	; FP temp storage (4 bytes)
   82                     OFS_FP_CONST_NEG1:	EQU	014H	; FP constant -1.0 (4 bytes)
   83                     OFS_SCRATCH_PAD1:	EQU	018H	; Scratch pad area (16 bytes)
   84                     OFS_RND_CONST1:	EQU	028H	; Random number constant 1
   85                     OFS_RND_CONST2:	EQU	030H	; Random number constant 2
   86                     OFS_SCRATCH_PAD2:	EQU	034H	; Scratch pad area (12 bytes)
   87                     
   88                     ;;; Sign and Mode Indicators
   89                     OFS_SIGN_IND1:	EQU	040H	; Sign indicator 1 (2 bytes)
   90                     OFS_BITS_COUNTER:	EQU	042H	; Bits counter (1 byte)
   91                     OFS_SIGN_IND2:	EQU	043H	; Sign indicator 2 (2 bytes)
   92                     OFS_INP_DIG_CNT:	EQU	045H	; Input digit counter
   93                     OFS_TEMP_STORE:	EQU	046H	; Temporary storage
   94                     OFS_OUT_DIG_CNT:	EQU	047H	; Output digit counter
   95                     OFS_FP_MODE_IND:	EQU	048H	; FP mode indicator
   96                     
   97                     ;;; Floating Point Accumulator (FPACC)
   98                     OFS_FPACC_EXT:	EQU	050H	; FPACC extension (4 bytes)
   99                     OFS_FPACC:	EQU	054H	; FPACC LSW (start of 4-byte FPACC)
  100                     OFS_FPACC_LSW:	EQU	054H	; FPACC Least Significant Word
  101                     OFS_FPACC_NSW:	EQU	055H	; FPACC Next Significant Word
  102                     OFS_FPACC_MSW:	EQU	056H	; FPACC Most Significant Word
  103                     OFS_FPACC_EXP:	EQU	057H	; FPACC Exponent
  104                     
  105                     ;;; Floating Point Operand (FPOP)
  106                     OFS_FPOP_EXT:	EQU	058H	; FPOP extension (4 bytes)
  107                     OFS_FPOP:	EQU	05CH	; FPOP LSW (start of 4-byte FPOP)
  108                     OFS_FPOP_LSW:	EQU	05CH	; FPOP Least Significant Word
  109                     OFS_FPOP_NSW:	EQU	05DH	; FPOP Next Significant Word
  110                     OFS_FPOP_MSW:	EQU	05EH	; FPOP Most Significant Word
  111                     OFS_FPOP_EXP:	EQU	05FH	; FPOP Exponent
  112                     
  113                     ;;; Additional page 1 offsets (early addresses)
  114                     OFS_EXP_TEMP:	EQU	003H	; Exponent temp storage
  115                     OFS_FP_TEMP_0F:	EQU	00FH	; FP temp +3
  116                     OFS_SCRATCH_1F:	EQU	01FH	; Scratch pad +7
  117                     
  118                     ;;; FPACC/FPOP adjacent offsets for E register
  119                     OFS_FPACC_LSW_M1:	EQU	053H	; FPACC LSW minus 1
  120                     OFS_FPOP_EXT_59:	EQU	059H	; FPOP extension +1 (working area)
  121                     OFS_FP_WORK_61:	EQU	061H	; FP work +1 (partial product)
  122                     
  123                     ;;; Floating Point Working Area (24 bytes at 060H-077H)
  124                     OFS_FP_WORK:	EQU	060H	; FP working area start
  125                     OFS_FP_WORK_63:	EQU	063H	; FP working area +3
  126                     OFS_FP_WORK_65:	EQU	065H	; FP working area +5
  127                     OFS_FP_WORK_66:	EQU	066H	; FP working area +6
  128                     OFS_FP_WORK_68:	EQU	068H	; FP working area +8
  129                     OFS_FP_WORK_6A:	EQU	06AH	; FP working area +A
  130                     OFS_FP_WORK_6B:	EQU	06BH	; FP working area +B
  131                     OFS_FP_WORK_6C:	EQU	06CH	; FP working area +C
  132                     OFS_FP_WORK_6E:	EQU	06EH	; FP working area +E
  133                     OFS_FP_WORK_6F:	EQU	06FH	; FP working area +F
  134                     OFS_FP_WORK_70:	EQU	070H	; FP working area +10
  135                     OFS_FP_WORK_74:	EQU	074H	; FP working area +14
  136                     OFS_FP_WORK_76:	EQU	076H	; FP working area +16 (output MSW)
  137                     OFS_FP_WORK_77:	EQU	077H	; FP working area +17
  138                     
  139                     ;;; Temporary Register Storage and Constants
  140                     OFS_TEMP_REGS:	EQU	080H	; Temp register storage (D,E,H,L)
  141                     OFS_FP_CONST_10:	EQU	088H	; FP constant +10.0
  142                     OFS_FP_CONST_0P1:	EQU	08CH	; FP constant +0.1
  143                     
  144                     ;;; Counters and Stack Pointers
  145                     OFS_GETINP_CNT:	EQU	090H	; GETINP counter
  146                     OFS_ARITH_STKPTR:	EQU	097H	; Arithmetic stack pointer
  147                     OFS_FA_STKPTR:	EQU	098H	; FUN/ARRAY stack pointer
  148                     OFS_ARITH_STACK:	EQU	098H	; Arithmetic stack (variable)
  149                     
  150                     ;;; FOR/NEXT Storage (in TEMP_AREA2 at 0C4H-0CFH)
  151                     OFS_FN_STEP:	EQU	0C4H	; FOR/NEXT step size (4 bytes)
  152                     OFS_FN_STEP_C6:	EQU	0C6H	; FOR/NEXT step +2
  153                     OFS_FN_LIMIT:	EQU	0C8H	; FOR/NEXT limit value (4 bytes)
  154                     OFS_FN_TEMP:	EQU	0CCH	; FOR/NEXT temp (4 bytes)
  155                     
  156                     ;;; Keyword lookup table entries (in page 1)
  157                     OFS_KW_THEN:	EQU	0D0H	; THEN keyword
  158                     OFS_KW_TO:	EQU	0D5H	; TO keyword
  159                     OFS_KW_STEP:	EQU	0D8H	; STEP keyword
  160                     OFS_KW_LIST:	EQU	0DDH	; LIST keyword
  161                     OFS_KW_RUN:	EQU	0E2H	; RUN keyword
  162                     OFS_KW_SCR:	EQU	0E6H	; SCR keyword
  163                     OFS_MSG_READY:	EQU	0EAH	; READY message
  164                     
  165                     ;;; Temporary and Working Storage
  166                     OFS_TEMP_F0:	EQU	0F0H	; Temp storage at F0H
  167                     OFS_TEMP_F3:	EQU	0F3H	; Temp storage at F3H
  168                     OFS_TEMP_F4:	EQU	0F4H	; Temp storage at F4H
  169                     OFS_TEMP_F6:	EQU	0F6H	; Temp storage at F6H
  170                     OFS_TEMP_F7:	EQU	0F7H	; Temp storage at F7H
  171                     OFS_LOOKUP_CNT:	EQU	0F8H	; Look-up counter
  172                     OFS_TEMP_OP:	EQU	0F9H	; Temp OP storage
  173                     
  174                     ;;; =========================================================================
  175                     ;;; Page 26 (1600H-16FFH) Line Buffer and Pointer Offset Definitions
  176                     ;;; These are LOW BYTE offsets used with H=HIGH OLDPG26
  177                     ;;; =========================================================================
  178                     
  179                     OFS_LINE_INP_BUF:	EQU	000H	; Line input buffer start (CC + 79 chars)
  180                     OFS_PARSER_TOKEN:	EQU	07EH	; Parser token storage
  181                     OFS_EVAL_CURRENT:	EQU	080H	; EVAL current pointer
  182                     OFS_SYNTAX_PTR:	EQU	081H	; Syntax counter/pointer
  183                     OFS_SCAN_PTR:	EQU	082H	; SCAN pointer
  184                     OFS_TOKEN_STORE:	EQU	083H	; TOKEN storage location
  185                     OFS_TEMP_ARRAY:	EQU	084H	; Temp array pointer
  186                     OFS_TEMP_085:	EQU	085H	; Temp storage at 85H
  187                     OFS_ARRAY_SETUP:	EQU	086H	; Array setup pointer
  188                     OFS_LOOP_COUNTER:	EQU	087H	; Loop counter
  189                     OFS_OP_STKPTR:	EQU	088H	; Operator stack pointer
  190                     OFS_TAB_FLAG:	EQU	07FH	; TAB flag
  191                     OFS_FUNC_TBL_BASE:	EQU	0BCH	; Function lookup table base (less 4)
  192                     OFS_EVAL_PTR:	EQU	0BEH	; EVAL pointer
  193                     OFS_EVAL_FINISH:	EQU	0BFH	; EVAL finish pointer
  194                     OFS_LINENUM_BUF:	EQU	0E0H	; Line number buffer
  195                     OFS_AUX_LINENUM:	EQU	0E8H	; Auxiliary line number buffer
  196                     OFS_COL_COUNTER:	EQU	023H	; Column counter
  197                     OFS_COL_024:	EQU	024H	; Column area +1
  198                     
  199                     ;;; Page 26 Symbol Buffer (at offset 050H, same as Page 27 start)
  200                     OFS_SYMBOL_BUF:	EQU	050H	; Symbol buffer start
  201                     OFS_SYMBOL_CHAR1:	EQU	051H	; Symbol buffer 1st character
  202                     OFS_SYMBOL_CHAR2:	EQU	052H	; Symbol buffer 2nd character
  203                     
  204                     ;;; =========================================================================
  205                     ;;; Page 27 (1700H-17FFH) Keyword Table and Variables Offset Definitions
  206                     ;;; These are LOW BYTE offsets used with H=HIGH OLDPG27
  207                     ;;; =========================================================================
  208                     
  209                     OFS_KEYWORD_TBL:	EQU	000H	; Keyword table start
  210                     OFS_GOSUB_STK_BASE:	EQU	03BH	; GOSUB stack base (page 26)
  211                     OFS_ARRAY_TEMP:	EQU	03EH	; Array temp / GOSUB stack offset
  212                     OFS_SYMVAR_CNT:	EQU	03FH	; Symbol variables counter
  213                     OFS_ARRAY_VAR:	EQU	04CH	; Array variables table
  214                     OFS_SYMBOL_BUF_64:	EQU	064H	; Symbol buffer in page 27 (alternate)
  215                     OFS_FA_STACK_TEMP:	EQU	083H	; F/A stack temp storage
  216                     OFS_VARIABLES_TBL:	EQU	088H	; Variables lookup table start
  217                     
  218                     ;;; =========================================================================
  219                     ;;; User Program Buffer Offset (used with BGNPGRAM page)
  220                     ;;; =========================================================================
  221                     
  222                     OFS_USER_PROG:	EQU	000H	; User program buffer start
  223                     
  224                     ;;; =========================================================================
  225                     ;;; CP/M Entry Point - Program starts here at 0100H
  226                     ;;; =========================================================================
  227                     
  228                     	ORG	00100H
  229  0100  C3 B6 08     	JMP	EXEC		; Jump to main entry point
  230                     
  231                     ;;; Page one has many constants and variables.
  232                     ;;; See docs/variable_map.txt for detailed address mapping
  233                     ;;; Note: First 3 bytes are the JMP EXEC, then 1 byte padding
  234                     
  235                     	DS	1                                   ; (reserved padding, total 4 bytes from 100H)
  236                     FP_CONST_1:                                     ; Floating point constant +1.0
  237  0104  00 00 40 01  	DB	000H,000H,040H,001H
  238                     	DS	3                                   ; (reserved padding)
  239                     EXP_COUNTER:                                    ; Exponent counter
  240  010B  00           	DB	000H
  241                     FP_TEMP:                                        ; Floating point number temp storage
  242  010C  00 00 00 00  	DB	000H,000H,000H,000H
  243                     	DS	4                                   ; (reserved padding)
  244                     FP_CONST_NEG1:                                  ; Floating point constant -1.0
  245  0114  00 00 C0 01  	DB	000H,000H,0C0H,001H
  246                     SCRATCH_PAD1:                                   ; Scratch pad area (16 bytes)
  247  0118  00 00 00 00  	DB	000H,000H,000H,000H
  248  011C  00 00 00 00  	DB	000H,000H,000H,000H
  249  0120  00 00 00 00  	DB	000H,000H,000H,000H
  250  0124  00 00 00 00  	DB	000H,000H,000H,000H
  251                     RND_CONST1:                                     ; Random number generator constant
  252  0128  01 50 72 02  	DB	001H,050H,072H,002H
  253                     	DS	4                                   ; (reserved padding)
  254                     RND_CONST2:                                     ; Random number generator constant
  255  0130  03 68 6F 0C  	DB	003H,068H,06FH,00CH
  256                     SCRATCH_PAD2:                                   ; Scratch pad area (12 bytes)
  257  0134  00 00 00 00  	DB	000H,000H,000H,000H
  258  0138  00 00 00 00  	DB	000H,000H,000H,000H
  259  013C  00 00 00 00  	DB	000H,000H,000H,000H
  260                     SIGN_IND1:                                      ; Sign indicator
  261  0140  00 00        	DB	000H,000H
  262                     BITS_COUNTER:                                   ; Bits counter
  263  0142  00           	DB	000H
  264                     SIGN_IND2:                                      ; Sign indicator
  265  0143  00 00        	DB	000H,000H
  266                     INP_DIG_CNT:                                    ; Input digit counter
  267  0145  00           	DB	000H
  268                     TEMP_STORE:                                     ; Temporary storage
  269  0146  00           	DB	000H
  270                     OUT_DIG_CNT:                                    ; Output digit counter
  271  0147  00           	DB	000H
  272                     FP_MODE_IND:                                    ; FP mode indicator
  273  0148  00           	DB	000H
  274                     	DS	7                                   ; (not assigned - 0149H-014FH)
  275                     FPACC_EXT:                                      ; FPACC extension
  276  0150  00 00 00 00  	DB	000H,000H,000H,000H
  277                     FPACC:                                          ; FPACC (LSW, NSW, MSW, Exponent)
  278  0154  00 00 00 00  	DB	000H,000H,000H,000H
  279                     FPOP_EXT:                                       ; FPOP extension
  280  0158  00 00 00 00  	DB	000H,000H,000H,000H
  281                     FPOP:                                           ; FPOP (LSW, NSW, MSW, Exponent)
  282  015C  00 00 00 00  	DB	000H,000H,000H,000H
  283                     FP_WORK_AREA:                                   ; Floating point working area (24 bytes)
  284  0160  00 00 00 00  	DB	000H,000H,000H,000H
  285  0164  00 00 00 00  	DB	000H,000H,000H,000H
  286  0168  00 00 00 00  	DB	000H,000H,000H,000H
  287  016C  00 00 00 00  	DB	000H,000H,000H,000H
  288  0170  00 00 00 00  	DB	000H,000H,000H,000H
  289  0174  00 00 00 00  	DB	000H,000H,000H,000H
  290                     	DS	8                                   ; (not assigned - 0178H-017FH)
  291                     TEMP_REGS:                                      ; Temporary register storage (D,E,H,L)
  292  0180  00 00 00 00  	DB	000H,000H,000H,000H
  293                     	DS	4                                   ; (not assigned - 0184H-0187H)
  294                     FP_CONST_10:                                    ; Floating point constant +10.0
  295  0188  00 00 50 04  	DB	000H,000H,050H,004H
  296                     FP_CONST_0P1:                                   ; Floating point constant +0.1
  297  018C  67 66 66 FD  	DB	067H,066H,066H,0FDH
  298                     GETINP_CNT:                                     ; GETINP counter
  299  0190  00           	DB	000H
  300                     	DS	6                                   ; (not assigned - 0191H-0196H)
  301                     ARITH_STKPTR:                                   ; Arithmetic stack pointer
  302  0197  00           	DB	000H
  303                     ARITH_STACK:                                    ; Arithmetic stack (variable length)
  304  0198  00           	DB	000H
  305                     
  306                     	ORG	001BAH
  307                     KW_SAVE:                                        ; "SAVE" keyword (length + chars)
  308  01BA  04           	DB	004H
  309  01BB  53 41 56 45  	DB	"SAVE"
  310                     KW_LOAD:                                        ; "LOAD" keyword (length + chars)
  311  01BF  04           	DB	004H
  312  01C0  4C 4F 41 44  	DB	"LOAD"
  313                     TEMP_AREA2:                                     ; Temp area (STEP, FOR/NEXT, ARRAY PTR)
  314  01C4  00 00 00 00  	DB	000H,000H,000H,000H
  315  01C8  00 00 00 00  	DB	000H,000H,000H,000H
  316  01CC  00 00 00 00  	DB	000H,000H,000H,000H
  317                     
  318                     ;;; Keyword table at location 01D0H (01#320 octal)
  319                     KW_THEN:
  320  01D0  04           	DB	004H
  321  01D1  54 48 45 4E  	DB	"THEN"
  322                     KW_TO:
  323  01D5  02           	DB	002H
  324  01D6  54 4F        	DB	"TO"
  325                     KW_STEP:
  326  01D8  04           	DB	004H
  327  01D9  53 54 45 50  	DB	"STEP"
  328                     KW_LIST:
  329  01DD  04           	DB	004H
  330  01DE  4C 49 53 54  	DB	"LIST"
  331                     KW_RUN:
  332  01E2  03           	DB	003H
  333  01E3  52 55 4E     	DB	"RUN"
  334                     KW_SCR:
  335  01E6  03           	DB	003H
  336  01E7  53 43 52     	DB	"SCR"
  337                     
  338                     ;;; Messages
  339                     MSG_READY:                                      ; "READY" message with control chars
  340  01EA  0B           	DB	00BH                                ; Length = 11
  341  01EB  94 8D 8A     	DB	094H,08DH,08AH                      ; CTRL-T, CR, LF
  342  01EE  52 45 41 44  	DB	"READY"
       01F2  59         
  343  01F3  8D 8A 8A     	DB	08DH,08AH,08AH                      ; CR, LF, LF
  344                     MSG_AT_LINE:                                    ; " AT LINE " message
  345  01F6  09           	DB	009H                                ; Length = 9
  346  01F7  20 41 54 20  	DB	" AT LINE "
       01FB  4C 49 4E 45
       01FF  20         
  347                     ;;; END OF PAGE 01
  348                     
  349                     ;;; =========================================================================
  350                     ;;; CP/M I/O Routines (placed at end of page 1 area)
  351                     ;;; These replace the original bit-banged serial I/O with CP/M BDOS calls
  352                     ;;; =========================================================================
  353                     
  354                     save:
  355  0200  C3 B6 08     load:	JMP	EXEC                          ; By default, save and load isn't implemented.
  356                     
  357                     ;;; CP/M CHARACTER INPUT - uses BDOS function 1 (C_READ)
  358                     ;;; Returns character in A
  359                     
  360  0203  C5           CINP:	PUSH	B
  361  0204  D5           	PUSH	D
  362  0205  E5           	PUSH	H
  363  0206  0E 01        	MVI	C,C_READ	; BDOS function 1: console input
  364  0208  CD 05 00     	CALL	BDOS		; Call BDOS, char returned in A
  365  020B  E1           	POP	H
  366  020C  D1           	POP	D
  367  020D  C1           	POP	B
  368  020E  C9           	RET
  369                     
  370                     ;;; no user defined functions yet, stop here if we see one.
  371  020F  C3 00 00     UDEFX:	JMP	0		; Warm boot on undefined function
  372                     
  373                     ;;; CP/M CHARACTER OUTPUT - uses BDOS function 2 (C_WRITE)
  374                     ;;; Character to print in A
  375                     
  376  0212  C5           CPRINT:	PUSH	B
  377  0213  D5           	PUSH	D
  378  0214  E5           	PUSH	H
  379  0215  5F           	MOV	E,A		; Character to E for BDOS
  380  0216  0E 02        	MVI	C,C_WRITE	; BDOS function 2: console output
  381  0218  CD 05 00     	CALL	BDOS		; Call BDOS
  382  021B  E1           	POP	H
  383  021C  D1           	POP	D
  384  021D  C1           	POP	B
  385  021E  C9           	RET
  386                     
  387                     ;;; END OF CP/M I/O ROUTINES
  388                     
  389                     	ORG	00200H                             ; START PAGE 02, THE CODE
  390                     	
  391                     
  392  0200  CD AD 02     SYNTAX:	CALL	CLESYM                     ;Clear the SYMBOL BUFFER area
  393  0203  2E E0                   MVI	L,OFS_LINENUM_BUF                   ;Set L to start of LINE NUMBER BUFFER
  394  0205  26 16                   MVI	H,HIGH OLDPG26           ;** Set H to page of LINE NUMBER BUFFER
  395  0207  36 00                   MVI	M,000H                   ;Initialize line number buff by placing zero as (cc)
  396  0209  2E 81                   MVI	L,OFS_SYNTAX_PTR                   ;Change pointer to syntax counter/pointer storage loc.
  397  020B  36 01                   MVI	M,001H                   ;Set pointer to first character (after cc) in line buffer
  398  020D  2E 81        SYNTX1:	MVI	L,OFS_SYNTAX_PTR                      ;Set pointer to syntax cntr/pntr storage location
  399  020F  CD A0 02                CALL	GETCHR                  ;Fetch the character pointed to by contents of syntax
  400  0212  CA 24 02                JZ	SYNTX2                    ;Cntr/pntr from the line input buffer. If character was
  401  0215  FE B0                   CPI	0B0H                     ;A space, ignore. Else, test to see if character was ASCII
  402  0217  FA 31 02                JM	SYNTX3                    ;Code for a decimal digit. If not a decimal digit, consider
  403  021A  FE BA                   CPI	0BAH                     ;Line number to have been processed by jumping
  404  021C  F2 31 02                JP	SYNTX3                    ;Over the remainder of this SYNTX1 section.
  405  021F  2E E0                   MVI	L,OFS_LINENUM_BUF                   ;If have decimal digit, set pointer to start of LINE
  406  0221  CD CC 02                CALL	CONCT1                  ;NUMBER BUFFER and append incoming digit there.
  407  0224  2E 81        SYNTX2:	MVI	L,OFS_SYNTAX_PTR                      ;Reset L to syntax cntr/pntr storage location. Call sub-
  408  0226  CD 03 03                CALL	LOOP                    ;Routine to advance pntr and test for end of inr)ut buffer
  409  0229  C2 0D 02                JNZ	SYNTX1                   ;If not end of input buffer, go back for next digit
  410  022C  2E 83                   MVI	L,OFS_TOKEN_STORE                   ;If end of buffer, only had a line number in the line.
  411  022E  36 00                   MVI	M,000H                   ;Set pntr to TOKEN storage location. Set TOKEN = 000.
  412  0230  C9                      RET                          ;Return to caller.
  413  0231  2E 81        SYNTX3:	MVI	L,OFS_SYNTAX_PTR                      ;Reset pointer to syntax cntr/pntr and fetch
  414  0233  46                      MOV	B,M                      ;Position of next character after the line number
  415  0234  2E 82                   MVI	L,OFS_SCAN_PTR                   ;Change pntr to SCAN pntr storage location
  416  0236  70                      MOV	M,B                      ;Store address when SCAN takes up after line number
  417  0237  2E 82        SYNTX4:	MVI	L,OFS_SCAN_PTR                      ;Set pntr to SCAN pntr stomge location
  418  0239  CD A0 02                CALL	GETCHR                  ;Fetch the character pointed to by contents of the SCAN
  419  023C  CA 54 02                JZ	SYNTX6                    ;Pointer storage location. If character was ASCII code
  420  023F  FE BD                   CPI	0BDH                     ;For space, ignore. Else, compare character with "=" sign
  421  0241  CA 88 02                JZ	SYNTX7                    ;If is an equal sign, go set TOKEN for IMPLIED LET.
  422  0244  FE A8                   CPI	0A8H                     ;Else, compare character with left parenthesis " ( "
  423  0246  CA 8D 02                JZ	SYNTX8                    ;If left parenthesis, go set TOKEN for implied array LET
  424  0249  CD C8 02                CALL	CONCTS                  ;Otherwise, concatenate the character onto the string
  425                     ; MGA 4/2012 begin "fast SYNTX5" patch: 
  426                     ; the following patch doubles the overall speed of execution.  
  427                     ; It is similar to the approach taken on 8080 SCELBAL II in 1978 
  428                     ; it adhears to the rules for patches in issue 1 of SCELBAL update 
  429                     ;SYNTX6:   these four lines moved up w/o label
  430  024C  2E 82                   MVI	L,OFS_SCAN_PTR                   ;Set L to SCAN pointer storage location
  431                     ;           LHI \HB\OLDPG26        ;** Set H to page of SCAN pointer stomge location
  432                     ;MGA 4/2012 except LHI needed at original place, not here 
  433  024E  CD 03 03                CALL	LOOP                    ;Call routine to advance pntr & test for end of In buffer
  434  0251  C2 37 02                JNZ	SYNTX4                   ;Go back and add another character to SYMBOL BUFF
  435                     SYNTX6:   ; MGA 4/2012 label here 
  436                     
  437  0254  2E 83                   MVI	L,OFS_TOKEN_STORE                   ;Being constructed in the SYMBOL BUFFER. Now set
  438  0256  36 01                   MVI	M,001H                   ;Up TOKEN storage location to an initial value of 001.
  439  0258  26 17                   MVI	H,HIGH OLDPG27           ;** Set H to point to start of KEYWORD TABLE.
  440  025A  2E 00                   MVI	L,OFS_KEYWORD_TBL        ;Set L to point to start of KEYWORD TABLE.
  441  025C  16 16        SYNTX5:	MVI	D,HIGH OLDPG26              ;** Set D to page of SYMBOL BUFFER
  442  025E  1E 50                   MVI	E,OFS_SYMBOL_BUF                   ;Set E to start of SYMBOL BUFFER
  443  0260  CD DA 02                CALL	STRCP                   ;Compare char string presently in SYMBOL BUFFER
  444  0263  C8                      RZ                           ;With entry in KEYWORD TABLE. Exit if match.
  445  0264  CD EE 12                CALL	SWITCH                  ;TOKEN will be set to keyword found. Else, switch
  446  0267  2C           SYNTXL:	INR	L                           ;Pointers to get table address back and advance pntr to
  447  0268  7E                      MOV	A,M                      ;KEYWORD TABLE. Now look for start of next entry
  448  0269  E6 C0                   ANI	0C0H                     ;In KEYWORD TABLE by looking for (cc) byte which
  449  026B  C2 67 02                JNZ	SYNTXL                   ;Will NOT have a one in the two most sig. bits. Advance
  450  026E  CD EE 12                CALL	SWITCH                  ;Pntr til next entry found. Then switch pointers apin so
  451  0271  2E 83                   MVI	L,OFS_TOKEN_STORE                   ;Table pointer is in D&E. Put addr of TOKEN in L.
  452  0273  26 16                   MVI	H,HIGH OLDPG26           ;** And page of TOKEN in H. Fetch the value currently
  453  0275  46                      MOV	B,M                      ;In TOKEN and advance it to account for going on to
  454  0276  04                      INR	B                        ;The next entry in the KEYWORD TABLE.
  455  0277  70                      MOV	M,B                      ;Restore the updated TOKEN value back to storage.
  456  0278  CD EE 12                CALL	SWITCH                  ;Restore the keyword table pointer back to H&L.
  457  027B  78                      MOV	A,B                      ;Put TOKEN count in ACC.
  458  027C  FE 0D                   CPI	00DH                     ;See if have tested all entries in the keyword table.
  459  027E  C2 5C 02                JNZ	SYNTX5                   ;If not, continue checking the keyword table.
  460                     ;MGA 4/2012 3 of 4 lines removed below (keep LHI)
  461  0281  26 16                   MVI	H,HIGH OLDPG26           ;** Set H to page of SCAN pointer stomge location
  462                     ; MGA 4/2012 end of "fast SYNTX5" patch: 
  463  0283  2E 83                   MVI	L,OFS_TOKEN_STORE                   ;And search table for KEYWORD again. Unless reach
  464  0285  36 FF                   MVI	M,0FFH                   ;End of line input buffer. In which case set TOKEN=377
  465  0287  C9                      RET                          ;As an error indicator and exit to calling routine.
  466  0288  2E 83        SYNTX7:	MVI	L,OFS_TOKEN_STORE                      ;Set pointer to TOKEN storage register. Set TOKEN
  467  028A  36 0D                   MVI	M,00DH                   ;Equal to 015 when "=" sign found for IMPLIED LET.
  468  028C  C9                      RET                          ;Exit to calling routine.
  469  028D  2E 83        SYNTX8:	MVI	L,OFS_TOKEN_STORE                      ;Set pointer to TOKEN storage register. Set TOKEN
  470  028F  36 0E                   MVI	M,00EH                   ;Equal to 016 when "(" found for IMPLIED array LET.
  471  0291  C9                      RET                          ;Exit to calling routine.
  472                     
  473                                                       ;The following are subroutines used by SYNTAX and
  474                                                       ;other routines in SCELBAL.
  475                     
  476  0292  3E C2        BIGERR:	MVI	A,0C2H                      ;Load ASCII code for letters B and G to indicate BIG
  477  0294  0E C7                   MVI	C,0C7H                   ;ERROR (for when buffer, stack,etc., overflows).
  478  0296  CD 82 03     ERROR:	CALL	ECHO                        ;Call user provided display routine to print ASCII code
  479  0299  79                      MOV	A,C                      ;In accumulator. Transfer ASCII code from C to ACC
  480  029A  CD 82 03                CALL	ECHO                    ;And repeat to display error codes.
  481  029D  C3 D2 0A                JMP	FINERR                   ;Go cpmplete error message (AT LINE) as required.
  482  02A0  7E           GETCHR:	MOV	A,M                         ;Get pointer from memory location pointed to by H&L
  483  02A1  FE 50                   CPI	050H                     ;See if within range of line input buffer.
  484  02A3  F2 92 02                JP	BIGERR                    ;If not then have an overflow condition = error.
  485  02A6  6F                      MOV	L,A                      ;Else can use it as addr of character to fetch from the
  486  02A7  26 16                   MVI	H,HIGH OLDPG26           ;** LINE INPUT BUFFER by setting up H too.
  487  02A9  7E                      MOV	A,M                      ;Fetch the character from the line input buffer.
  488  02AA  FE A0                   CPI	0A0H                     ;See if it is ASCII code for space.
  489  02AC  C9                      RET                          ;Return to caller with flags set according to comparison.
  490  02AD  2E 50        CLESYM:	MVI	L,OFS_SYMBOL_BUF                      ;Set L to start of SYMBOL BUFFER.
  491  02AF  26 16                   MVI	H,HIGH OLDPG26           ;** Set H to page of SYMBOL BUFFER.
  492  02B1  36 00                   MVI	M,000H                   ;Place a zero byte at start of SYMBOL BUFFER.
  493  02B3  C9                      RET                          ;To effectively clear the buffer. Then exit to caller.
  494                     
  495                     
  496                                                       ;Subroutine to concatenate (append) a character to the
  497                                                       ;SYMBOL BUFFER. Character must be alphanumeric.
  498                     
  499  02B4  FE C1        CONCTA:	CPI	0C1H                        ;See if character code less than that for letter A.
  500  02B6  FA BE 02                JM	CONCTN                    ;If so, go see if it is numeric.
  501  02B9  FE DB                   CPI	0DBH                     ;See if character code greater than that for letter Z.
  502  02BB  FA C8 02                JM	CONCTS                    ;If not, have valid alphabetical character.
  503  02BE  FE B0        CONCTN:	CPI	0B0H                        ;Else, see if character in valid numeric range.
  504  02C0  FA D7 02                JM	CONCTE                    ;If not, have an error condition.
  505  02C3  FE BA                   CPI	0BAH                     ;Continue to check for valid number.
  506  02C5  F2 D7 02                JP	CONCTE                    ;If not, have an error condition.
  507  02C8  2E 50        CONCTS:	MVI	L,OFS_SYMBOL_BUF                      ;If character alphanumeric, can concatenate. Set pointer
  508  02CA  26 16                   MVI	H,HIGH OLDPG26           ;** To starting address of SYMBOL BUFFER.
  509  02CC  4E           CONCT1:	MOV	C,M                         ;Fetch old character count in SYMBOL BUFFER.
  510  02CD  0C                      INR	C                        ;Increment the value to account for adding new
  511  02CE  71                      MOV	M,C                      ;Character to the buffer. Restore updated (cc).
  512  02CF  47                      MOV	B,A                      ;Save character to be appended in register B.
  513  02D0  CD 1E 13                CALL	INDEXC                  ;Add (cc) to address in H & L to get new end of buffer
  514  02D3  70                      MOV	M,B                      ;Address and append the new character to buffer
  515  02D4  3E 00                   MVI	A,000H                   ;Clear the accumulator
  516  02D6  C9                      RET                          ;Exit to caller
  517  02D7  C3 6A 09     CONCTE:	JMP	SYNERR                      ;If character to be appended not alphanumeric, ERROR!
  518                     
  519                                                       ;Subroutine to compare
  520                                                       ;character strings pointed to by
  521                                                       ;register pairs D & E and H & L.
  522                     
  523  02DA  7E           STRCP:	MOV	A,M                          ;Fetch (cc) of first string.
  524  02DB  CD EE 12                CALL	SWITCH                  ;Switch pointers and fetch length of second string (cc)
  525  02DE  46                      MOV	B,M                      ;Into register B. Compare the lengths of the two strings.
  526  02DF  B8                      CMP	B                        ;If they are not the same
  527  02E0  C0                      RNZ                          ;Return to caller with flags set to non-zero condition
  528  02E1  CD EE 12                CALL	SWITCH                  ;Else, exchange the pointers back to first string.
  529  02E4  CD FF 02     STRCPL:	CALL	ADV                        ;Advance the pointer to string number 1 and fetch a
  530  02E7  7E                      MOV	A,M                      ;Character from that string into the accumulator.
  531  02E8  CD EE 12                CALL	SWITCH                  ;Now switch the pointers to string number 2.
  532  02EB  CD FF 02                CALL	ADV                     ;Advance the pointer in line number 2.
  533  02EE  BE           STRCPE:	CMP	M                           ;Compare char in stxing 1 (ACC) to string 2 (memory)
  534  02EF  C0                      RNZ                          ;If not equal, return to cauer with flags set to non-zero
  535  02F0  CD EE 12                CALL	SWITCH                  ;Else, exchange pointers to restore pntr to string 1
  536  02F3  05                      DCR	B                        ;Decrement the string length counter in register B
  537  02F4  C2 E4 02                JNZ	STRCPL                   ;If not finiahed, continue testing entire string
  538  02F7  C9                      RET                          ;If complete match, return with flag in zero condition
  539  02F8  7E           STRCPC:	MOV	A,M                         ;Fetch character pointed to by pointer to string 1
  540  02F9  CD EE 12                CALL	SWITCH                  ;Exchange pointer to examine string 2
  541  02FC  C3 EE 02                JMP	STRCPE                   ;Continue the string comparison loop
  542                     
  543                                                       ;Subroutine to advance the two byte
  544                                                       ;value in CPU registers H and L.
  545                     
  546  02FF  2C           ADV:	INR	L                              ;Advance value in register L.
  547  0300  C0                      RNZ                          ;If new value not zero, return to caller.
  548  0301  24                      INR	H                        ;Else must increment value in H
  549  0302  C9                      RET                          ;Before retuming to caller
  550                     
  551                                                       ;Subroutine to advance a buffer pointer
  552                                                       ;and test to see if the end of the buffer
  553                                                       ;has been reached.
  554                     
  555  0303  46           LOOP:	MOV	B,M                           ;Fetch memory location pointed to by H & L into B.
  556  0304  04                      INR	B                        ;Increment the value.
  557  0305  70                      MOV	M,B                      ;Restore it back to memory.
  558  0306  2E 00                   MVI	L,OFS_LINE_INP_BUF       ;Change pointer to start of INPUT LINE BUFFER
  559  0308  7E                      MOV	A,M                      ;Fetch buffer length (cc) value into the accumulator
  560  0309  05                      DCR	B                        ;Make value in B original value
  561  030A  B8                      CMP	B                        ;See if buffer length same as that in B
  562  030B  C9                      RET                          ;Return with flags yielding results of the comparison
  563                     
  564                                                       ;The following subroutine is used to
  565                                                       ;input characters from the system's
  566                                                       ;input device (such as a keyboard)
  567                                                       ;into the LINE INPUT BUFFER. Routine has limited
  568                                                       ;editing capability included.
  569                                                       ;(Rubout = delete previous character(s) entered.)
  570                     ;;; This label, STRIN:	should be location 03 014
  571  030C  0E 00        STRIN:	MVI	C,000H                       ;Initialize register C to zero.
  572  030E  CD 91 03     STRIN1:	CALL	CINPUT                     ;Call user provided device input subroutine to fetch one
  573  0311  FE FF                   CPI	0FFH                     ;Character from the input device. Is it ASCII code for
  574  0313  C2 25 03                JNZ	NOTDEL                   ;Rubout? Skip to next section if not rubout.
  575  0316  3E DC                   MVI	A,0DCH                   ;Else, load ASCII code for backslash into ACC.
  576  0318  CD 82 03                CALL	ECHO                    ;Call user display driver to present backslash as a delete
  577  031B  0D                      DCR	C                        ;Indicator. Now decrement the input character counter.
  578  031C  FA 0C 03                JM	STRIN                     ;If at beginning of line do NOT decrement H and L.
  579  031F  CD 74 03                CALL	DEC                     ;Else, decrement H & L line pointer to erase previous
  580  0322  C3 0E 03                JMP	STRIN1                   ;Entry, then go back for a new input.
  581  0325  FE 83        NOTDEL:	CPI	083H                        ;See if character inputted was'CONTROL C'
  582  0327  CA CB 0A                JZ	CTRLC                     ;If so, stop inputting and go back to the EXECutive
  583  032A  FE 8D                   CPI	08DH                     ;If not, see if character was carriage-return
  584  032C  CA 42 03                JZ	STRINF                    ;If so, have end of line of input
  585  032F  FE 8A                   CPI	08AH                     ;If not, see if character was line-feed
  586  0331  CA 0E 03                JZ	STRIN1                    ;If so, ignore the input, get another character
  587  0334  CD FF 02                CALL	ADV                     ;If none of the above, advance contents of H & L
  588  0337  0C                      INR	C                        ;Increment the character counter
  589  0338  77                      MOV	M,A                      ;Store the new character in the line input buffer
  590  0339  79                      MOV	A,C                      ;Put new character count in the accumulator
  591  033A  FE 50                   CPI	050H                     ;Make sure maximum buffer size not exceeded
  592  033C  F2 92 02                JP	BIGERR                    ;If buffer size exceeded, go display BG error message
  593  033F  C3 0E 03                JMP	STRIN1                   ;Else can go back to look for next input
  594  0342  41           STRINF:	MOV	B,C                         ;Transfer character count from C to B
  595  0343  CD 4B 03                CALL	SUBHL                   ;Subtract B from H & L to get starting address of
  596  0346  71                      MOV	M,C                      ;The string and place the character count (cc) there
  597  0347  CD 61 03                CALL	CRLF                    ;Provide a line ending CR & LF combination on the
  598  034A  C9                      RET                          ;Display device. Then exit to caller.
  599                     
  600                                                       ;Subroutine to subtract contents of CPU register B from
  601                                                       ;the two byte value in CPU registers H & L.
  602                     
  603  034B  7D           SUBHL:	MOV	A,L                          ;Load contents of register L into the accumulator
  604  034C  90                      SUB	B                        ;Subtract the contents of register B
  605  034D  6F                      MOV	L,A                      ;Restore the new value back to L
  606  034E  D0                      RNC                          ;If no carry, then no underflow. Exit to caller.
  607  034F  25                      DCR	H                        ;Else must also decrement contents of H.
  608  0350  C9                      RET                          ;Before retuming to caller.
  609                     
  610                                                       ;Subroutine to display a character string on the system's
  611                                                       ;display device.
  612                     
  613  0351  4E           TEXTC:	MOV	C,M                          ;Fetch (cc) from the first location in the buffer (H & L
  614  0352  7E                      MOV	A,M                      ;Pointing there upon entry) into register B and ACC.
  615  0353  A7                      ANA	A                        ;Test the character count value.
  616  0354  C8                      RZ                           ;No display if (cc) is zero.
  617  0355  CD FF 02     TEXTCL:	CALL	ADV                        ;Advance pointer to next location in buffer
  618  0358  7E                      MOV	A,M                      ;Fetch a character from the buffer into ACC
  619  0359  CD 82 03                CALL	ECHO                    ;Call the user's display driver subroutine
  620  035C  0D                      DCR	C                        ;Decrement the (cc)
  621  035D  C2 55 03                JNZ	TEXTCL                   ;If character counter not zero, continue display
  622  0360  C9                      RET                          ;Exit to caller when (cc) is zero.
  623                     
  624                                                       ;Subroutine to provide carriage-return and line-feed
  625                                                       ;combination to system's display device. Routine also
  626                                                       ;initializes a column counter to zero. Column counter
  627                                                       ;is used by selected output routines to count the num-
  628                                                       ;ber of characters that have been displayed on a line.
  629                     
  630  0361  3E 8D        CRLF:	MVI	A,08DH                        ;Load ASCII code for carriage-return into ACC
  631  0363  CD 82 03                CALL	ECHO                    ;Call user provided display driver subroutine
  632  0366  3E 8A                   MVI	A,08AH                   ;Load ASCII code for line-feed into ACC
  633  0368  CD 82 03                CALL	ECHO                    ;Call user provided display driver subroutine
  634  036B  2E 23                   MVI	L,OFS_COL_COUNTER                   ;Set L to point to COLUMN COUNTER storage location
  635  036D  26 01                   MVI	H,HIGH OLDPG1            ;** Set H to page of COLUMN COUNTER
  636  036F  36 01                   MVI	M,001H                   ;Initialize COLUMN COUNTER to a value of one
  637  0371  62                      MOV	H,D                      ;Restore H from D (saved by ECHO subroutine)
  638  0372  6B                      MOV	L,E                      ;Restore L from E (saved by ECHO subroutine)
  639  0373  C9                      RET                          ;Then exit to calling routine
  640                     
  641                                                       ;Subroutine to decrement double-byte value in CPU
  642                                                       ;registers H and L.
  643                     
  644  0374  2D           DEC:	DCR	L                              ;Decrement contents of L
  645  0375  2C                      INR	L                        ;Now increment to exercise CPU flags
  646  0376  C2 7A 03                JNZ	DECNO                    ;If L not presently zero, skip decrementing H
  647  0379  25                      DCR	H                        ;Else decrement H
  648  037A  2D           DECNO:	DCR	L                            ;Do the actual decrement of L
  649  037B  C9                      RET                          ;Return to caller
  650                     
  651                     
  652                                                       ;Subroutine to index the value in CPU registers H and L
  653                                                       ;by the contents of CPU register B.
  654                     
  655  037C  7D           INDEXB:	MOV	A,L                         ;Load L into the accumulator
  656  037D  80                      ADD	B                        ;Add B to that value
  657  037E  6F                      MOV	L,A                      ;Restore the new value to L
  658  037F  D0                      RNC                          ;If no carry,  return to caller
  659  0380  24                      INR	H                        ;Else, increment value in H
  660  0381  C9                      RET                          ;Before returning to caller
  661                     
  662                                                       ;The following subroutine is used to
  663                                                       ;display the ASCII encoded character in the ACC on the
  664                                                       ;system's display device. This routine calls a routine
  665                                                       ;labeled CINPUT which must be provided by the user to
  666                                                       ;actually drive the system's output device. The subroutine
  667                                                       ;below also increments an output column counter each time
  668                                                       ;it is used.
  669                     
  670  0382  54           ECHO:	MOV	D,H                           ;Save entry value of H in register D
  671  0383  5D                      MOV	E,L                      ;And save entry value of L in register E
  672  0384  2E 23                   MVI	L,OFS_COL_COUNTER                   ;Set L to point to COLUMN COUNTER storage location
  673  0386  26 01                   MVI	H,HIGH OLDPG1            ;** Set H to page of COLUMN COUNTER
  674  0388  46                      MOV	B,M                      ;Fetch the value in the COLUMN COUNTER
  675  0389  04                      INR	B                        ;And increment it for each character displayed
  676  038A  70                      MOV	M,B                      ;Restore the updated count in memory
  677  038B  CD 12 02                CALL	CPRINT                  ;tt Call the user's device driver subroutine
  678  038E  62                      MOV	H,D                      ;Restore entry value of H from D
  679  038F  6B                      MOV	L,E                      ;Restore entry value of L from E
  680  0390  C9                      RET                          ;Return to calling routine
  681  0391  C3 03 02     CINPUT:	JMP	CINP                        ;Reference to user defined input subroutine
  682                     
  683                     ;;; The label EVAL: SHOULD BE AT 03 224
  684  0394  2E 97        EVAL:	MVI	L,OFS_ARITH_STKPTR                        ;Load L with address of ARITHMETIC STACK pointer
  685  0396  26 01                   MVI	H,HIGH OLDPG1            ;** Set H to page of ARITHMETIC STACK pointer
  686  0398  36 94                   MVI	M,094H                   ;Initialize ARITH STACK pointer value to addr minus 4
  687  039A  2C                      INR	L                        ;Advance memory pointer to FUN/ARRAY STACK pntr
  688  039B  26 16                   MVI	H,HIGH OLDPG26           ;** Set H to page of FUN/ARRAY STACK pointer
  689  039D  36 00                   MVI	M,000H                   ;Initialize FUNIARRAY STACK pointer to start of stack
  690  039F  CD AD 02                CALL	CLESYM                  ;Initialize the SYMBOL BUFFER to empty condition
  691  03A2  2E 88                   MVI	L,OFS_OP_STKPTR                   ;Load L with address of OPERATOR STACK pointer
  692  03A4  36 00                   MVI	M,000H                   ;Initialize OPERATOR STACK pointer value
  693  03A6  2E BE                   MVI	L,OFS_EVAL_PTR                   ;Set L to address of EVAL pointer (start of expression)
  694  03A8  46                      MOV	B,M                      ;Fetch the EVAL pointer value into register B
  695  03A9  2E 80                   MVI	L,OFS_EVAL_CURRENT                   ;Set up a working pointer register in this location
  696  03AB  70                      MOV	M,B                      ;And initialize EVAL CURRENT pointer
  697  03AC  2E 80        SCAN1:	MVI	L,OFS_EVAL_CURRENT                       ;Load L with address of EVAL CURRENT pointer
  698  03AE  CD A0 02                CALL	GETCHR                  ;Fetch a character in the expression being evaluated
  699  03B1  CA C1 04                JZ	SCAN10                    ;If character is a space, jump out of this section
  700  03B4  FE AB                   CPI	0ABH                     ;See if character is a "+" sign
  701  03B6  C2 C0 03                JNZ	SCAN2                    ;If not, continue checking for an operator
  702  03B9  2E 7E                   MVI	L,OFS_PARSER_TOKEN                   ;If yes, set pointer to PARSER TOKEN storage location
  703  03BB  36 01                   MVI	M,001H                   ;Place TOKEN value for "+" sign in PARSER TOKEN
  704  03BD  C3 E9 03                JMP	SCANFN                   ;Go to PARSER subroutine entry point
  705  03C0  FE AD        SCAN2:	CPI	0ADH                         ;See if character is a minus ("-") sign
  706  03C2  C2 EF 03                JNZ	SCAN4                    ;If not, continue checking for an operator
  707  03C5  2E 50                   MVI	L,OFS_SYMBOL_BUF                   ;If yes, check the length of the symbol stored in the
  708  03C7  7E                      MOV	A,M                      ;SYMBOL BUFFER by fetching the (cc) byte
  709  03C8  A7                      ANA	A                        ;And testing to see if (cc) is zero
