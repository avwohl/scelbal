 2462  1033  C9                      RET                          ;Exit to calling routine
 2463                     
 2464                                                       ;The next instruction is a special entry point to
 2465                                                       ;the FPNORM subroutine that is used when a number is
 2466                                                       ;converted from fixed to floating point. The FPNORM
 2467                                                       ;label is the entry point when a number already in float-
 2468                                                       ;ing point fonnat is to be normalized.
 2469                     
 2470  1034  06 17        FPFLT:	MVI	B,017H                       ;For fixed to float set CPU register B to 23 decimal
 2471  1036  78           FPNORM:	MOV	A,B                         ;Get CPU register B into ACC to check for special case
 2472  1037  26 01                   MVI	H,HIGH OLDPG1            ;** Set H to page of FPACC
 2473  1039  2E 57                   MVI	L,OFS_FPACC_EXP                   ;Set L to FPACC Exponent byte
 2474  103B  A7                      ANA	A                        ;Set CPU flags to test what was in CPU register B
 2475  103C  CA 40 10                JZ	NOEXC0                    ;If B was zero then do standard normalization
 2476  103F  70                      MOV	M,B                      ;Else set Exponent of FPACC to 23 decimal
 2477  1040  2D           NOEXC0:	DCR	L                           ;Change pointer to MSW of FPACC
 2478  1041  7E                      MOV	A,M                      ;Fetch MSW of FPACC into accumulator
 2479  1042  2E 40                   MVI	L,OFS_SIGN_IND1                   ;Change pointer to SIGN indicator storage location
 2480  1044  77                      MOV	M,A                      ;Place the MSW of FPACC there for future reference
