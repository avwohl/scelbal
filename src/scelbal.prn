 2421                                                       ;Following subroutine clears the FPACC to the zero
 2422                                                       ;condition.
 2423                     
 2424  1029  2E 56        FPZERO:	MVI	L,OFS_FPACC_MSW                      ;Set L to point to MSW of FPACC
 2425  102B  AF                      XRA	A                        ;Clear the accumulator
 2426  102C  77                      MOV	M,A                      ;Set the MSW of FPACC to zero
 2427  102D  2D                      DCR	L                        ;Decrement the pointer
 2428  102E  77                      MOV	M,A                      ;Set the next significant word of FPACC to zero
 2429  102F  2D                      DCR	L                        ;Decrement the pointer
 2430  1030  77                      MOV	M,A                      ;Set the LSW of FPACC to zero
 2431  1031  2D                      DCR	L                        ;Decrement the pointer
