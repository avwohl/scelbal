 3691  1953  CD 9D 05     	CALL CFALSE                     ;Now clear the FPACC registers
 3692  1956  21 4F 00     	LXI H,COL_024                   ;Load L with address of LAST SQR APPROX temp regs.
 3693  1959  CD BA 11     	CALL FSTORE                     ;Initialize the LAST SQR APPROX regs to value of zero
 3694  195C  21 47 00     SQRLOP:	LXI H,FPACC_SAVE                ;Load L with address of SQR APPROX working registers
