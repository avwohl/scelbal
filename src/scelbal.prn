 3691  183B  26 17                   MVI	H,HIGH OLDPG27           ;** Set H to page of FOR/NEXT STACK pointer
 3692  183D  7E                      MOV	A,M                      ;Fetch the FOR/NEXT STACK pointer value to ACC
 3693  183E  07                      RLC                          ;Rotate value left to multiply by two. Then rotate it
 3694  183F  07                      RLC                          ;Left again to multiply by four. Add base address plus
 3695  1840  C6 5E                   ADI	05EH                     ;Two to form pointer to variable name in top of stack
 3696  1842  26 17                   MVI	H,HIGH OLDPG27           ;** Set H to page of FOR/NEXT STACK
 3697  1844  6F                      MOV	L,A                      ;Move pointer value from ACC to CPU register L
