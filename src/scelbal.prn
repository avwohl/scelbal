 2433  1033  C9                      RET                          ;Exit to calling routine
 2434                     
 2435                                                       ;The next instruction is a special entry point to
 2436                                                       ;the FPNORM subroutine that is used when a number is
 2437                                                       ;converted from fixed to floating point. The FPNORM
 2438                                                       ;label is the entry point when a number already in float-
 2439                                                       ;ing point fonnat is to be normalized.
 2440                     
 2441  1034  06 17        FPFLT:	MVI	B,017H                       ;For fixed to float set CPU register B to 23 decimal
 2442  1036  78           FPNORM:	MOV	A,B                         ;Get CPU register B into ACC to check for special case
 2443  1037  26 01                   MVI	H,HIGH OLDPG1            ;** Set H to page of FPACC
 2444  1039  2E 57                   MVI	L,OFS_FPACC_EXP                   ;Set L to FPACC Exponent byte
 2445  103B  A7                      ANA	A                        ;Set CPU flags to test what was in CPU register B
 2446  103C  CA 40 10                JZ	NOEXC0                    ;If B was zero then do standard normalization
 2447  103F  70                      MOV	M,B                      ;Else set Exponent of FPACC to 23 decimal
 2448  1040  2D           NOEXC0:	DCR	L                           ;Change pointer to MSW of FPACC
 2449  1041  7E                      MOV	A,M                      ;Fetch MSW of FPACC into accumulator
 2450  1042  2E 40                   MVI	L,OFS_SIGN_IND1                   ;Change pointer to SIGN indicator storage location
