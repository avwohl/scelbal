 1317  083E  21 24 16     	LXI H,USER_PGM_PTR              ;If not LOAD then set pointer to address of storage loc
 1318  0841  36 1A        	MVI M,HIGH USER_PROG_BUF        ;Store high byte of USER_PROG_BUF start
 1319  0843  23           	INX H                           ;Advance memory pntr. Since pointer storage requires
 1320  0844  36 15        	MVI M,LOW USER_PROG_BUF         ;Two locations, initialize the low addr portion also.
