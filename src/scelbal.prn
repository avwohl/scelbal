 2464  105B  C2 54 10                JNZ	LOOK0                    ;Continue checking to see if FPACC contains anything
 2465  105E  2E 57                   MVI	L,OFS_FPACC_EXP                   ;Until precision counter is zero. If reach here then
 2466  1060  AF                      XRA	A                        ;Reset pointer to FPACC Exponent. Clear the ACC and
 2467  1061  77                      MOV	M,A                      ;Clear out the FPACC Exponent. Value of FPACC is zip!
 2468  1062  C9                      RET                          ;Exit to calling routine
 2469  1063  2E 53        ACNONZ:	MVI	L,OFS_SYMBOL_BUF+3                      ;If FPACC has any value set pointer to LSW minus one
 2470  1065  06 04                   MVI	B,004H                   ;Set precision counter to number of bytes in FPACC
 2471  1067  CD 7F 12                CALL	ROTATL                  ;Plus one for special cases. Rotate the contents of the
 2472  106A  7E                      MOV	A,M                      ;FPACC to the LEFT. Pointer will be set to MSW after
 2473  106B  A7                      ANA	A                        ;Rotate ops. Fetch MSW and see if have anything in
 2474  106C  FA 76 10                JM	ACCSET                    ;Most significant bit position. If so, have rotated enough
