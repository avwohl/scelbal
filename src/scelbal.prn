 3077  137A  70                      MOV	M,B                      ;Restore updated count to storage location.
 3078  137B  CD 2E 14                CALL	DECBIN                  ;Call the DECimal to BINary conversion routine to add
 3079  137E  C3 4D 13                JMP	NINPUT                   ;In the new digit in holding registers. Continue inputting.
