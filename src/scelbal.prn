  636  02F8  36 70        	MVI M,LOW ARITH_STACK - 4       ;Initialize ARITH STACK pointer value to addr minus 4
  637  02FA  21 7B 16     	LXI H,FA_STKPTR                 ;Load HL with address of FUN/ARRAY STACK pointer
  638  02FD  36 00        	MVI M,000H                      ;Initialize FUN/ARRAY STACK pointer to start of stack
  639  02FF  CD 03 02     	CALL CLESYM                     ;Initialize the SYMBOL BUFFER to empty condition
  640  0302  AF           	XRA A                           ;Clear accumulator
