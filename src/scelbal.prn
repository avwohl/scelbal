 3183  1404  FA 1B 14                JM	MINEXP                    ;If new value is minus, skip over next subroutine
 3184  1407  C8                      RZ                           ;If new value is zero, no further processing required
 3185                     
 3186                                                       ;Following subroutine will multiply the floating point
 3187                                                       ;binary number stored in FPACC by ten tirnes the
 3188                                                       ;value stored in the deciinal exponent storage location.
 3189                     
 3190  1408  2E 88        FPX10:	MVI	L,OFS_OP_STKPTR                       ;Set pointer to registers containing floating point
 3191  140A  26 01                   MVI	H,HIGH OLDPG1            ;** Binary representation of 10 (decimal).
 3192  140C  CD BF 12                CALL	FACXOP                  ;Transfer FPACC to FPOP and 10 (dec) to FPACC
 3193  140F  CD 26 11                CALL	FPMULT                  ;Multiply FPOP (formerly FPACC) by 10 (decimal)
 3194  1412  2E 6F                   MVI	L,OFS_FP_WORK_6F                   ;Set pointer to decimal exponent storage location
 3195  1414  4E                      MOV	C,M                      ;Fetch the exponent value
 3196  1415  0D                      DCR	C                        ;Decrement
 3197  1416  71                      MOV	M,C                      ;Restore to storage
 3198  1417  C2 08 14                JNZ	FPX10                    ;If exponent value is not zero, continue multiplication
 3199  141A  C9                      RET                          ;When exponent is zero can exit. Conversion completed.
 3200                     
 3201                                                       ;Following subroutine will multiply the floating point
 3202                                                       ;binary number stored in PPACC by 0.1 times the value
 3203                                                       ;(negative) stored in the decimal exponent storage location
 3204                     
 3205                     MINEXP:
 3206  141B  2E 8C        FPD10:	MVI	L,OFS_FP_CONST_0P1                       ;Set pointer to registers containing floating point
 3207  141D  26 01                   MVI	H,HIGH OLDPG1            ;** Binary representation of 0.1 (decimal).
 3208  141F  CD BF 12                CALL	FACXOP                  ;Transfer FPACC to FPOP and 0.1 (dec) to FPACC
 3209  1422  CD 26 11                CALL	FPMULT                  ;Multitply FPOP (formerly FPACC) by 0.1 (decimal)
 3210  1425  2E 6F                   MVI	L,OFS_FP_WORK_6F                   ;Set pointer to decimal exponent storage location
 3211  1427  46                      MOV	B,M                      ;Fetch the exponent value
 3212  1428  04                      INR	B                        ;Increment
 3213  1429  70                      MOV	M,B                      ;Restore to storage
 3214  142A  C2 1B 14                JNZ	FPD10                    ;If exponent value is not zero, continue multiplication
 3215  142D  C9                      RET                          ;When exponent is zero can exit. Conversion completed.
 3216                     
 3217                                                       ;Following subroutine is used
 3218                                                       ;to convert decimal charac-
 3219                                                       ;ters to binary fixed point forinat
 3220                                                       ;in a triple-precision format.
 3221                     
 3222  142E  CD CF 12     DECBIN:	CALL	SAVEHL                     ;Save entry value of D, E, H and L in memory
 3223  1431  2E 6B                   MVI	L,OFS_FP_WORK_6B                   ;Set pointer to temporary storage location
