 3619  18DC  21 B3 16     FOR5:	LXI H,TEMP_085                  ;Load HL with address of the FOR/NEXT STACK pointer
 3620  18DF  7E           	MOV A,M                         ;Fetch the stack pointer to the ACC.
 3621  18E0  07           	RLC                             ;Rotate it left to multiply by two, then rotate it again to
 3622  18E1  07           	RLC                             ;Multiply by four for stack entry offset
 3623  18E2  C6 02        	ADI 002H                        ;Add 2 to point to variable name location in stack entry
 3624  18E4  4F           	MOV C,A                         ;Save offset in C
 3625  18E5  06 00        	MVI B,000H                      ;Clear B for 16-bit add
 3626  18E7  11 93 16     	LXI D,FN_STACK                  ;Load DE with base of FOR/NEXT STACK
 3627  18EA  79           	MOV A,C                         ;Get offset
 3628  18EB  83           	ADD E                           ;Add to low byte of base
 3629  18EC  5F           	MOV E,A                         ;Result in E
 3630  18ED  78           	MOV A,B                         ;Get 0
 3631  18EE  8A           	ADC D                           ;Add carry to high byte
 3632  18EF  57           	MOV D,A                         ;Result in D (DE now points to stack location)
 3633  18F0  21 98 15     	LXI H,AUX_SYMBOL_BUF+1          ;Load HL with first character in AUX SYMBOL BUFFER
 3634  18F3  06 02        	MVI B,002H                      ;Set up register B as a number of bytes to move counter.
 3635  18F5  CD F4 0F     	CALL MOVEIT                     ;Move the variable name into the FOR/NEXT STACK.
 3636  18F8  CD 25 07     	CALL STOSYM                     ;Store initial variable value in the VARIABLES TABLE.
 3637  18FB  C3 11 0A     	JMP NXTLIN                      ;Continue with next line in user program buffer.
