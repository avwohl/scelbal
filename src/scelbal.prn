 2895                                                       ;Following subroutine will multiply the floating point
 2896                                                       ;binary number stored in FPACC by ten tirnes the
 2897                                                       ;value stored in the deciinal exponent storage location.
 2898                     
 2899  131C  21 0B 00     FPX10:	LXI H,FP_CONST_10               ;Set pointer to registers containing floating point 10
 2900  131F  CD C9 11     	CALL FACXOP                     ;Transfer FPACC to FPOP and 10 (dec) to FPACC
 2901  1322  CD 0E 10     	CALL FPMULT                     ;Multiply FPOP (formerly FPACC) by 10 (decimal)
