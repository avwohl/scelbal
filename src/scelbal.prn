  498  0206  CA 95 09     	JZ CTRLC                        ;If so, stop inputting and go back to the EXECutive
  499  0209  FE 8D        	CPI 08DH                        ;If not, see if character was carriage-return
  500  020B  CA 21 02     	JZ STRINF                       ;If so, have end of line of input
  501  020E  FE 8A        	CPI 08AH                        ;If not, see if character was line-feed
  502  0210  CA ED 01     	JZ STRIN1                       ;If so, ignore the input, get another character
  503  0213  CD DD 01     	CALL ADV                        ;If none of the above, advance contents of H & L
  504  0216  0C           	INR C                           ;Increment the character counter
  505  0217  77           	MOV M,A                         ;Store the new character in the line input buffer
  506  0218  79           	MOV A,C                         ;Put new character count in the accumulator
  507  0219  FE 50        	CPI 050H                        ;Make sure maximum buffer size not exceeded
  508  021B  F2 6E 01     	JP BIGERR                       ;If buffer size exceeded, go display BG error message
  509  021E  C3 ED 01     	JMP STRIN1                      ;Else can go back to look for next input
