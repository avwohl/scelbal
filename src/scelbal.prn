 2521                                                       ;Floating point ADDITION. Adds contents of FPACC to
 2522                                                       ;FPOP and leaves result in FPACC. Routine first checks
 2523                                                       ;to see if either register contains zero. If so addition
 2524                                                       ;result is already present!
 2525                     
 2526  1089  2E 56        FPADD:	MVI	L,OFS_FPACC_MSW                       ;Set L to point to MSW of FPACC
 2527  108B  26 01                   MVI	H,HIGH OLDPG1            ;** Do same for register H
 2528  108D  7E                      MOV	A,M                      ;Fetch MSW of FPACC to accumulator
 2529  108E  A7                      ANA	A                        ;Set CPU flags after loading op
 2530  108F  C2 9D 10                JNZ	NONZAC                   ;If accumulator non-zero then FPACC has some value
 2531  1092  2E 54        MOVOP:	MVI	L,OFS_FPACC                       ;But, if accumulator was zero then normalized FPACC
 2532  1094  54                      MOV	D,H                      ;Must also be zero. Thus answer to addition is simply the
 2533  1095  5D                      MOV	E,L                      ;Value in FPOP. Set up pointers to transfer contents of
 2534  1096  2E 5C                   MVI	L,OFS_FPOP                   ;FPOP to FPACC by pointing to the LSW of both
 2535  1098  06 04                   MVI	B,004H                   ;Registers and perform the transfer. Then exit to calling
 2536  109A  C3 0B 11                JMP	MOVEIT                   ;Routine with answer in FPACC via MOVEIT.
 2537  109D  2E 5E        NONZAC:	MVI	L,OFS_FPOP_MSW                      ;If FPACC was non-zero then check to see if FPOP has
 2538  109F  7E                      MOV	A,M                      ;Some value by obtaining MSW of FPOP
 2539  10A0  A7                      ANA	A                        ;Set CPU flags after loading op. If MSW zero then
 2540  10A1  C8                      RZ                           ;Normalized FPOP must be zero. Answer is in FPACC!
 2541                     
 2542                                                       ;If neither FPACC or FPOP was zero then must perform
 2543                                                       ;addition operation. Must first check to see if two num-
 2544                                                       ;bers are within significant mnge. If not, largest number
 2545                                                       ;is answer. If numbers within range, then must align ex-
 2546                                                       ;ponents before perforrning the addition of the man-
 2547                                                       ;tissa.
