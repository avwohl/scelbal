 1502  097F  56           	MOV D,M                         ;Storage location on same page and fetch page address
 1503  0980  2C           	INR L                           ;Of this pointer into D. Then advance memory pointer
 1504  0981  5E           	MOV E,M                         ;And get low part of this pointer into CPU register E.
