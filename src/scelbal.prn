 1459  0930  CD 5A 02     REMOVE:	CALL INDEXB                     ;Add (cc) plus one to addr of start of line
 1460  0933  4E           	MOV C,M                         ;Obtain byte from indexed location and
 1461  0934  CD 2A 02     	CALL SUBHL                      ;Subtract character count to obtain old location
 1462  0937  71           	MOV M,C                         ;Put new byte in old location
