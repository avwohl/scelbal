 2923  1325  21 3A 00     	LXI H,FP_WORK_6C                ;Set another pointer to LSW of conversion register
 2924  1328  54           	MOV D,H                         ;Make sure D set to page of working area
 2925  1329  06 03        	MVI B,003H                      ;Set precision counter
 2926  132B  CD CB 0F     	CALL MOVEIT                     ;Move original value of conversion register to working
 2927  132E  21 3A 00     	LXI H,FP_WORK_6C                ;Register. Reset pointer to LSW of conversion register.
 2928  1331  06 03        	MVI B,003H                      ;Set precision counter
 2929  1333  CD 63 11     	CALL ROTATL                     ;Rotate register left, (Multiplies value by two.)
 2930  1336  21 3A 00     	LXI H,FP_WORK_6C                ;Reset pointer to LSW.
