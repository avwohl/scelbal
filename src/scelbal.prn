 3726  1986  21 13 00     	LXI H,RND_CONST1                ;Load L with address of random constant A
 3727  1989  CD 98 11     	CALL OPLOAD                     ;Transfer random constant A into the FPOP
 3728  198C  CD E5 0F     	CALL FPMULT                     ;Multiply to form (SEED * A)
 3729  198F  21 17 00     	LXI H,RND_CONST2                ;Load L with address of random constant C
