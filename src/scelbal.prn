  221  006C  00 00        	DB	000H,000H
  222                     FN_STEP_C6:                             ; FOR/NEXT step MSW (offset 2)
  223  006E  00 00        	DB	000H,000H
  224                     FN_LIMIT:                               ; FOR/NEXT limit value (4 bytes)
  225  0070  00 00 00 00  	DB	000H,000H,000H,000H
  226                     FN_TEMP:                                ; FOR/NEXT temp (4 bytes)
  227  0074  00 00 00 00  	DB	000H,000H,000H,000H
