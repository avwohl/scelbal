 2833  12A7  21 65 00     	LXI H,EXP_SIGNS                 ;For minus sign, set pointer to EXP SIGN indicator
 2834  12AA  77           	MOV M,A                         ;Set the EXP SIGN indicator for a minus exponent
 2835  12AB  CD FC 11     EXPINP:	CALL GETINP                     ;Fetch the next character in the decimal exponent
 2836  12AE  A7           NOEXPS:	ANA A                           ;Exercise the CPU flags
 2837  12AF  CA D4 12     	JZ ENDINP                       ;If character inputted was zero, then end of input string
 2838  12B2  FE B0        	CPI 0B0H                        ;If not end of string, check to see
 2839  12B4  FA C5 09     	JM NUMERR                       ;If character represents
 2840  12B7  FE BA        	CPI 0BAH                        ;A valid decimal number (0 to 9)
 2841  12B9  F2 C5 09     	JP NUMERR                       ;Display error message if not a valid digit at this point!
