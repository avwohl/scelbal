 3744  19CA  CD 66 0F     	CALL FPADD                      ;Add to fom (SEED * A) + C
 3745  19CD  21 4F 00     	LXI H,SCRATCH_PAD2              ;Load L with address of SEED storage registers
 3746  19D0  CD B9 11     	CALL FSTORE                     ;Store I (SEED * A) + C] in former SEED registers
 3747  19D3  21 22 00     	LXI H,FPACC_EXP                 ;Load L with address of FPACC Exponent register
 3748  19D6  7E           	MOV A,M                         ;Fetch Exponent value into the accumulator
 3749  19D7  D6 10        	SUI 010H                        ;Subtract 16 (decimal) to effectively divide by 65,536
 3750  19D9  77           	MOV M,A                         ;Now FPACC = [((SEED * A) + C)/65,536]
 3751  19DA  CD D3 0E     	CALL FPFIX                      ;Convert floating to fixed point to obtain integer part
 3752  19DD  21 1E 00     	LXI H,FPACC_LSW_M1              ;Load L with address of FPACC Extension register
 3753  19E0  36 00        	MVI M,000H                      ;Clear the FPACC Extension register
