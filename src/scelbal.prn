 2905  1326  21 3D 00     	LXI H,FP_WORK_6F                ;Set pointer to decimal exponent storage location
 2906  1329  4E           	MOV C,M                         ;Fetch the exponent value
 2907  132A  0D           	DCR C                           ;Decrement
 2908  132B  71           	MOV M,C                         ;Restore to storage
 2909  132C  C2 1D 13     	JNZ FPX10                       ;If exponent value is not zero, continue multiplication
 2910  132F  C9           	RET                             ;When exponent is zero can exit. Conversion completed.
 2911                     
 2912                                                       ;Following subroutine will multiply the floating point
 2913                                                       ;binary number stored in PPACC by 0.1 times the value
 2914                                                       ;(negative) stored in the decimal exponent storage location
 2915                     
 2916                     MINEXP:
 2917  1330  21 0F 00     FPD10:	LXI H,FP_CONST_0P1              ;Set pointer to registers containing floating point
 2918  1333  CD CA 11     	CALL FACXOP                     ;Transfer FPACC to FPOP and 0.1 (dec) to FPACC
 2919  1336  CD 0F 10     	CALL FPMULT                     ;Multitply FPOP (formerly FPACC) by 0.1 (decimal)
 2920  1339  21 3D 00     	LXI H,FP_WORK_6F                ;Set pointer to decimal exponent storage location
 2921  133C  46           	MOV B,M                         ;Fetch the exponent value
 2922  133D  04           	INR B                           ;Increment
 2923  133E  70           	MOV M,B                         ;Restore to storage
 2924  133F  C2 30 13     	JNZ FPD10                       ;If exponent value is not zero, continue multiplication
 2925  1342  C9           	RET                             ;When exponent is zero can exit. Conversion completed.
