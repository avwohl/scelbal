 1764                                                       ;The following subroutine, used by various sections of
 1765                                                       ;SCELBAL, will search the LINE INPUT BUGGER for
 1766                                                       ;a character string which is contained in a buffer starting
 1767                                                       ;at the address pointed to by CPU registers H & L when
 1768                                                       ;the subroutine is entered.
 1769                     
 1770  0B0A  16 16        INSTR:	MVI	D,HIGH OLDPG26               ;**Set D to starting page of LINE INPUT BUFFER
 1771  0B0C  1E 00                   MVI	E,OFS_LINE_INP_BUF                   ;Load E with starting location of LINE INPUT BUFFER
 1772  0B0E  CD 34 0B     INSTR1:	CALL	ADVDE                      ;Advancer D & E pointer to the next location (input
 1773  0B11  CD CF 12                CALL	SAVEHL                  ;Buffer). Now save contents of d, E, H & L vefore the
 1774  0B14  46                      MOV	B,M                      ;Compare operations. Get length of TEST buffer in B.
 1775  0B15  CD FF 02                CALL	ADV                     ;Advance H & L buffer to first char in TEST buffer.
 1776  0B18  CD F8 02                CALL	STRCPC                  ;Compare contents of TEST buffer against input buffer
