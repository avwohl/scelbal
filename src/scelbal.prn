 3716  1865  26 17                   MVI	H,HIGH OLDPG27           ;** Set H to page of FOR/NEXT STACK pointer
 3717  1867  7E                      MOV	A,M                      ;Fetch the FOR/NEXT STACK pointer value to ACC
 3718  1868  07                      RLC                          ;Rotate value left to multiply by two. Then rotate it
 3719  1869  07                      RLC                          ;Left again to multiply by four. Add base address to
 3720  186A  C6 5C                   ADI	05CH                     ;Form pointer to top of FOR/NEXT STACK and place
 3721  186C  6F                      MOV	L,A                      ;The pointer value into CPU register L. Fetch the page
