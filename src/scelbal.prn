 3650  1910  21 2B 00     SQRX:	LXI H,FP_TEMP                   ;Load L with address of FP TEMP registers
 3651  1913  CD B9 11     	CALL FSTORE                     ;[Argument of SQR(X)] into FP TEMP for storage.
 3652  1916  21 21 00     	LXI H,FPACC_MSW                 ;Load L with MSW of FPACC
 3653  1919  7E           	MOV A,M                         ;Fetch the MSW into the accumulator
 3654  191A  A7           	ANA A                           ;Check the sign of the number in the FPACC
 3655  191B  FA AE 19     	JM SQRERR                       ;If number negative, cannot take square root
 3656  191E  CA 9B 05     	JZ CFALSE                       ;If number is zero, return with zero value in FPACC
 3657  1921  21 2E 00     	LXI H,FP_TEMP_0F                ;Load L with address of FP TEMP Exponent register
 3658  1924  7E           	MOV A,M                         ;Fetch the Exponent value into the ACC
 3659  1925  A7           	ANA A                           ;Check sign of the Fxponent
 3660  1926  FA 32 19     	JM NEGEXP                       ;If Exponent less than zero, process negative Exponent
 3661  1929  1F           	RAR                             ;If Exponent positive, rotate right to divide by two
 3662  192A  47           	MOV B,A                         ;And save the result in CPU register B
 3663  192B  3E 00        	MVI A,000H                      ;Clear the accumulator without disturbing Carry bit
 3664  192D  17           	RAL                             ;Rotate Carry bit into the ACC to save remainder
 3665  192E  77           	MOV M,A                         ;Store the remainder back in FP TEMP Exponent reg.
 3666  192F  C3 43 19     	JMP SQREXP                      ;Jump to continue processing
 3667  1932  47           NEGEXP:	MOV B,A                         ;For negative Exponent, form two Is complement by
 3668  1933  AF           	XRA A                           ;Placing the positive value in CPU register B, clearing
 3669  1934  90           	SUB B                           ;The accumulator, and then subtracting B from the ACC
 3670  1935  A7           	ANA A                           ;Clear the Carry bit after the complementing operation
 3671  1936  1F           	RAR                             ;Rotate the value right to divide by two
 3672  1937  47           	MOV B,A                         ;Save the result in CPU register B
 3673  1938  3E 00        	MVI A,000H                      ;Clear the accumulator without disturbing Carry bit
 3674  193A  8F           	ADC A                           ;Add Carry bit to the accumulator as remainder
 3675  193B  77           	MOV M,A                         ;Store the remainder back in FP TEMP Exponent reg
 3676  193C  CA 40 19     	JZ NOREMD                       ;If remainder was zero skip ahead. If not, increment the
 3677  193F  04           	INR B                           ;Result of the divide by two ops to compen for negative
 3678  1940  AF           NOREMD:	XRA A                           ;Clear the accumulator
 3679  1941  90           	SUB B                           ;Subtract the quotient of the divide by two op to
 3680  1942  47           	MOV B,A                         ;Form two's complement and save the result in register B
 3681  1943  21 5F 00     SQREXP:	LXI H,EXP_COUNTER               ;Load L with address of TEMP register
 3682  1946  70           	MOV M,B                         ;Store Fxponent quotient from above ops in TEMP
 3683  1947  21 03 00     	LXI H,FP_CONST_1                ;Load L with address of FP registers containing +1.0
 3684  194A  1E 1C        	MVI E,01CH                      ;Load E with address of SQR APPROX working registers
 3685  194C  54           	MOV D,H                         ;Set D to same page as H
 3686  194D  06 04        	MVI B,004H                      ;Set up register B as a number of bytes to move counter
 3687  194F  CD F4 0F     	CALL MOVEIT                     ;Transfer value +1.0 into SQR APPROX registers
 3688  1952  CD 9B 05     	CALL CFALSE                     ;Now clear the FPACC registers
 3689  1955  21 4F 00     	LXI H,COL_024                   ;Load L with address of LAST SQR APPROX temp regs.
 3690  1958  CD B9 11     	CALL FSTORE                     ;Initialize the LAST SQR APPROX regs to value of zero
 3691  195B  21 47 00     SQRLOP:	LXI H,FPACC_SAVE                ;Load L with address of SQR APPROX working registers
 3692  195E  CD B1 11     	CALL FLOAD                      ;Transfer SQR APPROX into the FPACC
 3693  1961  21 2B 00     	LXI H,FP_TEMP                   ;Load L with address of SQR ARG storage registers
 3694  1964  CD C1 11     	CALL OPLOAD                     ;Transfer SQR ARG into the FPOP
 3695  1967  CD CE 10     	CALL FPDIV                      ;Divde SQR ARG by SQR APPROX (Fon-n X/A)
 3696  196A  21 47 00     	LXI H,FPACC_SAVE                ;Load L with address of SQR APPROX registers
 3697  196D  CD C1 11     	CALL OPLOAD                     ;Transfer SQR APPROX into the FPOP
 3698  1970  CD 66 0F     	CALL FPADD                      ;Add to form value (X/A + A)
 3699  1973  21 22 00     	LXI H,FPACC_EXP                 ;Load L with address of FPACC Exponent register
 3700  1976  46           	MOV B,M                         ;Fetch Exponent value into CPU register B
 3701  1977  05           	DCR B                           ;Subtract one to effectively divide FPACC by two
 3702  1978  70           	MOV M,B                         ;Restore to memory. (Now have ((X/A + A) /2)
 3703  1979  21 47 00     	LXI H,FPACC_SAVE                ;Load L with address of SQR APPROX registers
 3704  197C  CD B9 11     	CALL FSTORE                     ;Store contents of FPACC as new SQR APPROX
 3705  197F  21 4F 00     	LXI H,COL_024                   ;Load L with address of LAST SQR APPROX registers
 3706  1982  CD C1 11     	CALL OPLOAD                     ;Transfer LAST SQR APPROX into the FPOP
 3707  1985  CD 03 10     	CALL FPSUB                      ;Subtract (LAST SQR APPROX - SQR APPROX)
 3708  1988  21 22 00     	LXI H,FPACC_EXP                 ;Load L with address of FPACC Exponent
 3709  198B  7E           	MOV A,M                         ;Fetch the Exponent into the accumulator
 3710  198C  FE F7        	CPI 0F7H                        ;See if difference less than 2 to the minus ninth
