 3478  15F1  7E                      MOV	A,M                      ;Fetch remainder of decimal exponent value
 3479  15F2  C6 B0                   ADI	0B0H                     ;Add in ASCII base value to form final digit
 3480  15F4  CD 82 03                CALL	ECHO                    ;Display second digit of decirnal exponent
 3481  15F7  C9                      RET                          ;Finished outputting. Return to caller.
