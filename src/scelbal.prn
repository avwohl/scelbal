 2743  120E  21 6A 00     NOT0:	LXI H,GETINP_CNT                ;Set L back to address of GETINP counter which is used
 2744  1211  4E           	MOV C,M                         ;Fetch the value of GETINP counter into register C
 2745  1212  0C           	INR C                           ;Increment the value in C
