 1388                                                       ;The subroutines below are used by some of the routines
 1389                                                       ;in this chapter as well as other parts of the program.
 1390                     
 1391  08A0  2E 50        SAVESY:	MVI	L,OFS_SYMBOL_BUF                      ;Load L with the address of the start of the SYMBOL
 1392  08A2  26 16                   MVI	H,HIGH OLDPG26           ;** BUFFER. Load H with the page of the buffer.
 1393  08A4  54                      MOV	D,H                      ;Load register D with the page of the AUX SYMBOL
 1394  08A5  1E 64                   MVI	E,064H                   ;BUFFER and set register E to start of that buffer.
 1395  08A7  C3 B1 08                JMP	MOVECP                   ;Transfer SYMBOL BF contents to AUX SYMBOL BF
 1396                     
 1397  08AA  2E 64        RESTSY:	MVI	L,OFS_FP_WORK+4                      ;Load L with address of start of AUX SYMBOL BUFF
 1398  08AC  26 16                   MVI	H,HIGH OLDPG26           ;** Load H with page of AUX SYMBOL BUFFER
 1399  08AE  54                      MOV	D,H                      ;Set D to page of SYMBOL BUFFER (same as H)
 1400  08AF  1E 50                   MVI	E,OFS_SYMBOL_BUF                   ;Load E with start of SYMBOL BUFFER
 1401  08B1  46           MOVECP:	MOV	B,M                         ;Load (cc) for source string (first byte in source buffer)
 1402  08B2  04                      INR	B                        ;Add one to (cc) to include (cc) byte itself
 1403  08B3  C3 0B 11                JMP	MOVEIT                   ;Move the source string to destination buffer
 1404                     
 1405                     ;;; The label Exec SHOULD BE AT 10 266 (This is the start of the code)
 1406  08B6  2E EA        EXEC:	MVI	L,OFS_MSG_READY                        ;Load L with address of READY message
 1407  08B8  26 01                   MVI	H,HIGH OLDPG1            ;** Load H with page of READY message
 1408  08BA  CD 51 03                CALL	TEXTC                   ;Call subroutine to display the READY message
 1409                     
 1410  08BD  2E 00        EXEC1:	MVI	L,OFS_LINE_INP_BUF           ;Load L with starting address of INPUT LINE BUFFER
 1411  08BF  26 16                   MVI	H,HIGH OLDPG26           ;** Load H with page of INPUT LINE BUFFER
 1412  08C1  CD 0C 03                CALL	STRIN                   ;Call subroutine to input a line into the buffer
 1413  08C4  7E                      MOV	A,M                      ;The STRIN subroutine will exit with pointer set to the
 1414  08C5  A7                      ANA	A                        ;CHARACTER COUNT for the line inputted. Fetch the
 1415  08C6  CA BD 08                JZ	EXEC1                     ;Value of the counter, if it is zero then line was blank.
 1416  08C9  2E DD                   MVI	L,OFS_KW_LIST                   ;Load L with address of LIST in look up table
 1417  08CB  26 01                   MVI	H,HIGH OLDPG1            ;Load H with address of LIST in look up table
 1418  08CD  16 16                   MVI	D,HIGH OLDPG26           ;Load D with page of line input buffer
 1419  08CF  1E 00                   MVI	E,OFS_LINE_INP_BUF                   ;Load E with start of line input buffer
 1420  08D1  CD DA 02                CALL	STRCP                   ;Call string compare subroutine to see if first word in
 1421  08D4  C2 EC 08                JNZ	NOLIST                   ;Input buffer is LIST. Jump 3 ahead if not LIST.
 1422  08D7  2E 00                   MVI	L,OFS_USER_PROG          ;If LIST, set up pointers to start of USER PROGRAM
 1423  08D9  26 1B                   MVI	H,BGNPGRAM               ;BUFFER. (Note user could alter this starting addr)   *****
 1424                     
 1425                                                       ;Next portion of program will LIST the contents of the
 1426                                                       ;USER PROGRAM BUFFER until an end of buffer
 1427                                                       ;(zero byte) indicator is detected.
 1428                     
 1429  08DB  7E           LIST:	MOV	A,M                           ;Fetch the first byte of a line in the USER PROGRAM
 1430  08DC  A7                      ANA	A                        ;BUFFER and see if it is zero. If so, have finished LIST
 1431  08DD  CA B6 08                JZ	EXEC                      ;So go back to start of Executive and display READY.
 1432  08E0  CD 51 03                CALL	TEXTC                   ;Else call subroutine to display a line of information
 1433  08E3  CD FF 02                CALL	ADV                     ;Now call subroutine to advance buffer pointer to
 1434  08E6  CD 61 03                CALL	CRLF                    ;Character count in next line. Also display a CR & LF.
 1435  08E9  C3 DB 08                JMP	LIST                     ;Continue LISTing process
 1436                     
 1437                                                       ;If line inputted by operator did not contain a LIST comman
 1438                                                       ;continue program to see if RUN or SCRatch command.
 1439                     
 1440  08EC  2E E2        NOLIST:	MVI	L,OFS_KW_RUN                      ;Load L with address of RUN in look up table
 1441  08EE  26 01                   MVI	H,HIGH OLDPG1            ;** Load H with address of RUN in look up table
 1442  08F0  1E 00                   MVI	E,OFS_LINE_INP_BUF                   ;Load E with start of line input buffer
 1443  08F2  16 16                   MVI	D,HIGH OLDPG26           ;** Load D with page of line input buffer
 1444  08F4  1E 00                   MVI	E,OFS_LINE_INP_BUF                   ;(Reserve 2 locs in case of patching by duplicating above)
 1445  08F6  CD DA 02                CALL	STRCP                   ;Call string compare subroutine to see if first word in
 1446  08F9  CA 38 0B                JZ	RUN                       ;Input buffer is RUN. Go to RUN routine if match.
 1447  08FC  16 16                   MVI	D,HIGH OLDPG26           ;** If not RUN command, reset address pointers back
 1448  08FE  1E 00                   MVI	E,OFS_LINE_INP_BUF                   ;To the start of the line input buffer
 1449  0900  2E E6                   MVI	L,OFS_KW_SCR                   ;Load L with address of SCR in look up table
 1450  0902  26 01                   MVI	H,HIGH OLDPG1            ;** Load H with page of SCR in look up table
 1451  0904  CD DA 02                CALL	STRCP                   ;Call string compare subroutine to see if first word in
 1452  0907  C2 39 09                JNZ	NOSCR                    ;Input buffer is SCR. If not then jump ahead.
 1453  090A  26 16                   MVI	H,HIGH OLDPG26           ;** If found SCR command then load memory pointer
 1454  090C  2E F4                   MVI	L,OFS_TEMP_F4                   ;With address of a pointer storage location. Set that
 1455  090E  36 1B                   MVI	M,BGNPGRAM               ;tt Storage location to page of start of USER PRO-  *******
 1456  0910  2C                      INR	L                        ;GRAM BUFFER. (Buffer start loc may be altered).
 1457  0911  36 00                   MVI	M,000H                   ;Then adv pntr and do same for low addr portion of pntr
 1458  0913  2E 3F                   MVI	L,OFS_SYMVAR_CNT                   ;Now set pointer to address of VARIABLES counter
 1459  0915  26 17                   MVI	H,HIGH OLDPG27           ;** Storage location. Initialize this counter by placing
 1460  0917  36 01                   MVI	M,001H                   ;The count of one into it. Now change the memory pntr
 1461                     ;MGA 3/31/12 put it back to 001; solves nested FOR/NEXT, but limits vars to 19
 1462                     ;   as the letter from James Tucker (1/77) mentioned
 1463                     ;   apparently, James didn't test FOR/NEXT; original Loboyko didn't have this
 1464                     ;;;           LMI 001                ;The count of one into it. Now change the memory pntr
 1465                     ;;; Apparently, in Page 3 of Issue 4 of Scelbal update (1/77) they say the above should change.
 1466                     ;;; This makes the SCR command clear the whole variable space, otherwise one space is lost.  
 1467  0919  2E 3D                   MVI	L,OFS_SYMVAR_CNT-2                   ;To storage location for number of dimensioned arrays
 1468  091B  36 00                   MVI	M,000H                   ;@@ And initialize to zero. (@@ = Substitute NOPs if
 1469  091D  2E 50                   MVI	L,OFS_SYMBOL_BUF                   ;@@ DIMension capability not used in package.) Also
 1470  091F  36 00                   MVI	M,000H                   ;@@ Initialize l'st byte of array name table to zero.
 1471  0921  2E 88                   MVI	L,OFS_OP_STKPTR                   ;Set pointer to storage location for the first byte of the
 1472  0923  36 00                   MVI	M,000H                   ;VARIABLES symbol table. Initialize it to zero too.
 1473  0925  2C                      INR	L                        ;Advance the pointer and zero the second location
 1474  0926  36 00                   MVI	M,000H                   ;In the Variables table also.
 1475  0928  26 1B                   MVI	H,BGNPGRAM               ;tt Load H with page of start of USER PROGRAM    **********
 1476  092A  2E 00                   MVI	L,OFS_USER_PROG          ;BUFFER. (Buffer start location could be altered.)
 1477  092C  36 00                   MVI	M,000H                   ;Clear first location to indicate end of user program.
 1478  092E  26 2F                   MVI	H,HIGH OLDPG57           ;@@ Load H with page of ARRAYS storage
 1479  0930  36 00        SCRLOP:	MVI	M,000H                      ;@@ And form a loop to clear out all the locations
 1480  0932  2C                      INR	L                        ;@@ On the ARRAYS storage page. (@@ These become
 1481  0933  C2 30 09                JNZ	SCRLOP                   ;@@ NOPs if DIMension capability deleted fm package.)
 1482  0936  C3 B6 08                JMP	EXEC                     ;SCRatch operations completed, go back to EXEC.
 1483                     
 1484                                                       ;If line inputted did not contain RUN or SCRatch com-
 1485                                                       ;mand, program continues by testing for SAVE or LOAD
 1486                                                       ;commands. If it does not find either of these com-
 1487                                                       ;mands, then operator did not input an executive com-
 1488                                                       ;mand. Program then sets up to see if the first entry in
 1489                                                       ;the line inputted is a LINE NUMBER.
 1490                     
 1491  0939  1E BA        NOSCR:	MVI	E,0BAH                       ;Load E with address of SAVE in look up table
 1492  093B  16 01                   MVI	D,HIGH OLDPG1            ;Load D with page of look up table
 1493  093D  26 16                   MVI	H,HIGH OLDPG26           ;Load H with page of input line buffer
 1494  093F  2E 00                   MVI	L,OFS_LINE_INP_BUF       ;Set L to start of input line buffer
 1495  0941  CD DA 02                CALL	STRCP                   ;Call string compare subroutine to see if first word in
 1496  0944  CA 40 00                JZ	SAVE                      ;tt Input buffer is SAVE. If so, go to user's SAVE rtn
 1497  0947  2E BF                   MVI	L,OFS_EVAL_FINISH                   ;If not SAVE then load L with address of LOAD in look
 1498  0949  26 01                   MVI	H,HIGH OLDPG1            ;Up table and load H with page of look up table
 1499  094B  16 16                   MVI	D,HIGH OLDPG26           ;Load D with page of input line buffer
 1500  094D  1E 00                   MVI	E,OFS_LINE_INP_BUF                   ;And L to start of input line buffer
 1501  094F  CD DA 02                CALL	STRCP                   ;Call string compare subroutine to see if first word in
 1502  0952  CA 40 00                JZ	LOAD                      ;tt Input buffer is LOAD. If so, go to user's LOAD rtn
 1503  0955  2E F0                   MVI	L,OFS_TEMP_F0                   ;If not LOAD then set pointer to address of storage loc
 1504  0957  26 16                   MVI	H,HIGH OLDPG26           ;** For USER PROGRAM BUFFER pointer. Initialize this
 1505  0959  36 1B                   MVI	M,BGNPGRAM               ;tt Pointer to the starting address of the program buffer.
 1506  095B  2C                      INR	L                        ;Advance memory pntr. Since pointer storage requires
 1507  095C  36 00                   MVI	M,000H                   ;Two locations, initialize the low addr portion also.
