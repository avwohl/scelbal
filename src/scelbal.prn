 2549  10A2  2E 57        CKEQEX:	MVI	L,OFS_FPACC_EXP                      ;Set pointer to FPACC Exponent storage location.
 2550  10A4  7E                      MOV	A,M                      ;Fetch the Exponent value to the accumulator.
 2551  10A5  2E 5F                   MVI	L,OFS_FPOP_EXP                   ;Change the pointer to the FPOP Exponent
 2552  10A7  BE                      CMP	M                        ;Compare the values of the exponents. If they are the
 2553  10A8  CA E1 10                JZ	SHACOP                    ;Same then can immediately proceed to add operations.
 2554  10AB  47                      MOV	B,A                      ;If not the same, store FPACC Exponent size in regis B
 2555  10AC  7E                      MOV	A,M                      ;Fetch the FPOP Exponent size into the ACC
 2556  10AD  98                      SBB	B                        ;Subtract the FPACC Exponent from the FPOP Exp.
 2557  10AE  F2 B4 10                JP	SKPNEG                    ;If result is positive jump over the next few instructions
 2558  10B1  47                      MOV	B,A                      ;If result was negative, store the result in B
 2559  10B2  AF                      XRA	A                        ;Clear the accumulator
 2560  10B3  98                      SBB	B                        ;Subtract register B to negate the original value
 2561  10B4  FE 18        SKPNEG:	CPI	018H                        ;See if difference is less than 24 decimal.
 2562  10B6  FA C3 10                JM	LINEUP                    ;If so, can align exponents. Go do it.
 2563  10B9  7E                      MOV	A,M                      ;If not, find out which number is largest. Fetch FPOP
 2564  10BA  2E 57                   MVI	L,OFS_FPACC_EXP                   ;Exponent into ACC. Change pointer to FPACC Exp.
 2565  10BC  96                      SUB	M                        ;Subtract FPACC from FPOP. If result is negative then
 2566  10BD  F8                      RM                           ;was larger. Return with answer in FPACC.
 2567  10BE  2E 54                   MVI	L,OFS_FPACC                   ;If result was positive, larger value in FPOP. Set pointers
 2568  10C0  C3 92 10                JMP	MOVOP                    ;To transfer FPOP into FPACC and then exit to caller.
 2569  10C3  7E           LINEUP:	MOV	A,M                         ;Fetch FPOP Exponent into accumulator.
 2570  10C4  2E 57                   MVI	L,OFS_FPACC_EXP                   ;Change pointer to FPACC Exponent.
 2571  10C6  96                      SUB	M                        ;Subtract FPACC Exponent from FPOP Exponent. If
 2572  10C7  FA D7 10                JM	SHIFT0                    ;Result is negative FPACC is larger. Go shift FPOP.
 2573  10CA  4F                      MOV	C,A                      ;If result positive FPOP larger, must shift FPACC. Store
 2574  10CB  2E 57        MORACC:	MVI	L,OFS_FPACC_EXP                      ;Difference count in C. Reset pointer to FPACC Exp
 2575  10CD  CD FC 10                CALL	SHLOOP                  ;Call the SHift LOOP to rotate FPACC mantissa RIGHT
 2576  10D0  0D                      DCR	C                        ;And INCREMENT Exponent. Decr difference counter
 2577  10D1  C2 CB 10                JNZ	MORACC                   ;Continue rotate operations until diff counter is zero
 2578  10D4  C3 E1 10                JMP	SHACOP                   ;Go do final alignment and perform addition process
 2579  10D7  4F           SHIFT0:	MOV	C,A                         ;Routine to shift FPOP. Set difference count into reg. C
 2580  10D8  2E 5F        MOROP:	MVI	L,OFS_FPOP_EXP                       ;Set pointer to FPOP Exponent.
 2581  10DA  CD FC 10                CALL	SHLOOP                  ;Call the SHift LOOP to rotate FPOP mantissa RIGHT
 2582  10DD  0C                      INR	C                        ;And INCREMENT Exponent. Then incr difference cntr
 2583  10DE  C2 D8 10                JNZ	MOROP                    ;Continue rotate opemtions until diff counter is zero
 2584                     ;;; The below two instructions are changed by PATCH NR.1
 2585                     ;;;SHACOP:    LLI 123                ;Set pointer to FPACC LSW minus one to provide extra
 2586                     ;;;           LMI 000                ;Byte for addition ops. Clear that location to zero.
 2587  10E1  CD 00 18     SHACOP:	CALL	PATCH1                     ; patch 1 inserts a few lines at 30-000
 2588  10E4  7F           	   MOV	A,A
 2589                     	
 2590                     ;;;           LLI 133
 2591                     ;;;           LMI 000                ;THIS IS PATCH #1
 2592  10E5  2E 57                   MVI	L,OFS_FPACC_EXP                   ;Change pointer to FPACC Exponent
 2593  10E7  CD FC 10                CALL	SHLOOP                  ;Rotate FPACC mantissa RIGHT & Increment Exponent
 2594  10EA  2E 5F                   MVI	L,OFS_FPOP_EXP                   ;Change pointer to FPOP Exponent
 2595  10EC  CD FC 10                CALL	SHLOOP                  ;Rotate FPOP mantissa RIGHT & Increment Exponent
 2596  10EF  54                      MOV	D,H                      ;Rotate ops provide room for overflow. Now set up
 2597  10F0  1E 53                   MVI	E,053H                   ;Pointers to LSW minus one for both FPACC & FPOP
 2598  10F2  06 04                   MVI	B,004H                   ;(FPOP already set after SHLOOP). Set precision counter
 2599  10F4  CD 57 12                CALL	ADDER                   ;Call quad precision ADDITION subroutine.
 2600  10F7  06 00                   MVI	B,000H                   ;Set CPU register B to indicate standard normalization
 2601  10F9  C3 36 10                JMP	FPNORM                   ;Go normalize the result and exit to caller.
 2602  10FC  46           SHLOOP:	MOV	B,M                         ;Shifting loop. First fetch Exponent currently being
 2603  10FD  04                      INR	B                        ;Pointed to and Increment the value by one.
 2604  10FE  70                      MOV	M,B                      ;Return the updated Exponent value to memory.
 2605  10FF  2D                      DCR	L                        ;Decrement the pointer to mantissa portion MSW
 2606  1100  06 04                   MVI	B,004H                   ;Set precision counter
 2607  1102  7E           FSHIFT:	MOV	A,M                         ;Fetch MSW of mantissa
 2608  1103  A7                      ANA	A                        ;Set CPU flags after load ops
 2609  1104  F2 89 12                JP	ROTATR                    ;If MSB not a one can do normal rotate ops
 2610  1107  17           BRING1:	RAL                             ;If MSB is a one need to set up carrv bit for the negative
 2611  1108  C3 8A 12                JMP	ROTR                     ;Number case. Then make special entry to ROTATR sub
 2612                     
 2613                                                       ;The following subroutine moves the contents of a string
 2614                                                       ;of memory locations from the address pointed to by
 2615                                                       ;CPU registers H & L to the address specified by the con-
 2616                                                       ;tents of registers D & E when the routine is entered. The
 2617                                                       ;process continues until the counter in register B is zero.
 2618                     
 2619  110B  7E           MOVEIT:	MOV	A,M                         ;Fetch a word from memory string A
 2620  110C  2C                      INR	L                        ;Advance A string pointer
 2621  110D  CD EE 12                CALL	SWITCH                  ;Switch pointer to string B
 2622  1110  77                      MOV	M,A                      ;Put word from string A into string B
 2623  1111  2C                      INR	L                        ;Advance B string pointer
 2624  1112  CD EE 12                CALL	SWITCH                  ;Switch pointer back to string A
 2625  1115  05                      DCR	B                        ;Decrement loop counter
 2626  1116  C8                      RZ                           ;Return to calling routine when counter reaches zero
 2627  1117  C3 0B 11                JMP	MOVEIT                   ;Else continue transfer operations
 2628                     
 2629                                                       ;The following subroutine SUBTRACTS the
 2630                                                       ;contents of the FLOATING POINT ACCUMULATOR from the
 2631                                                       ;contents of the FLOATING POINT OPERAND and
 2632                                                       ;leaves the result in the FPACC. The routine merely
 2633                                                       ;negates the value in the FPACC and then goes to the
 2634                                                       ;FPADD subroutine just presented.
 2635                     
 2636  111A  2E 54        FPSUB:	MVI	L,OFS_FPACC                       ;Set L to address of LSW of FPACC
 2637  111C  26 01                   MVI	H,HIGH OLDPG1            ;** Set H to page of FPACC
 2638  111E  06 03                   MVI	B,003H                   ;Set precision counter
 2639  1120  CD 68 12                CALL	COMPLM                  ;Two's complement the value in the FPACC
 2640  1123  C3 89 10                JMP	FPADD                    ;Now go add the negated value to perform subtraction!
 2641                     
 2642                                                       ;The first part of the FLOATING POINT MULTIPLI-
 2643                                                       ;CATION subroutine calls a subroutine to check the
 2644                                                       ;original signs of the numbers that are to be multi-
 2645                                                       ;plied and perform working register clearing functions.
 2646                                                       ;Next the exponents of the numbers to be multiplied
 2647                                                       ;are added together.
 2648                     
 2649  1126  CD 76 11     FPMULT:	CALL	CKSIGN                     ;Call routine to set up registers & ck signs of numbers
 2650  1129  2E 5F        ADDEXP:	MVI	L,OFS_FPOP_EXP                      ;Set pointer to FPOP Exponent
 2651  112B  7E                      MOV	A,M                      ;Fetch FPOP Exponent into the accumulator
 2652  112C  2E 57                   MVI	L,OFS_FPACC_EXP                   ;Change pointer to FPACC Exponent
 2653  112E  86                      ADD	M                        ;Add FPACC Exponent to FPOP Exponent
 2654  112F  C6 01                   ADI	001H                     ;Add one more to total for algorithm compensation
 2655  1131  77                      MOV	M,A                      ;Store result in FPACC Exponent location
 2656  1132  2E 42        SETMCT:	MVI	L,OFS_BITS_COUNTER                      ;Change pointer to bit counter storage location
 2657  1134  36 17                   MVI	M,017H                   ;Initialize bit counter to 23 decimal
 2658                     
 2659                                                       ;Next portion of the FPMULT routine is the iinplernen-
 2660                                                       ;tation of the algorithm illustrated in the flow chart
 2661                                                       ;above. This portion multiplies the values of the two
 2662                                                       ;mantissas. The final value is rounded off to leave the
 2663                                                       ;23 most significant bits as the answer that is stored
 2664                                                       ;back in the FPACC.
 2665                     
 2666  1136  2E 56        MULTIP:	MVI	L,OFS_FPACC_MSW                      ;Set pointer to MSW of FPACC mantissa
 2667  1138  06 03                   MVI	B,003H                   ;Set precision counter
 2668  113A  CD 89 12                CALL	ROTATR                  ;Rotate FPACC (multiplier) RIGHT into carry bit
 2669  113D  DC B8 11                CC	ADOPPP                    ;If carry is a one, add multiplicand to partial-product
 2670  1140  2E 66                   MVI	L,OFS_FP_WORK_66                   ;Set pointer to partial-product most significant byte
 2671  1142  06 06                   MVI	B,006H                   ;Set precision counter (p-p register is double length)
 2672  1144  CD 89 12                CALL	ROTATR                  ;Shift partial-product RIGHT
 2673  1147  2E 42                   MVI	L,OFS_BITS_COUNTER                   ;Set pointer to bit counter storage location
 2674  1149  4E                      MOV	C,M                      ;Fetch current value of bit counter
 2675  114A  0D                      DCR	C                        ;Decrement the value of the bit counter
 2676  114B  71                      MOV	M,C                      ;Restore the updated bit counter to its storage location
 2677  114C  C2 36 11                JNZ	MULTIP                   ;If have not multiplied for 23 (deciinal) bits, keep going
 2678  114F  2E 66                   MVI	L,OFS_FP_WORK_66                   ;If have done 23 (decimal) bits, set pntr to p-p MSW
 2679  1151  06 06                   MVI	B,006H                   ;Set precision counter (for double length)
 2680  1153  CD 89 12                CALL	ROTATR                  ;Shift partial-product once more to the RIGHT
 2681  1156  2E 63                   MVI	L,OFS_FP_WORK_63                   ;Set pointer to access 24'th bit in partial-product
 2682  1158  7E                      MOV	A,M                      ;Fetch the byte containing the 24'th bit
 2683  1159  17                      RAL                          ;Position the 24'th bit to be MSB in the accumulator
 2684  115A  A7                      ANA	A                        ;Set the CPU flags after to rotate operation and test to
 2685  115B  FC C2 11                CM	MROUND                    ;See if 24'th bit of p-p is a ONE. If so, must round-off
 2686  115E  2E 53                   MVI	L,OFS_SYMBOL_BUF+3                   ;Now set up pointers
 2687  1160  5D                      MOV	E,L                      ;To perform transfer
 2688  1161  54                      MOV	D,H                      ;Of the multiplication results
 2689  1162  2E 63                   MVI	L,OFS_FP_WORK_63                   ;From the partial-product location
 2690  1164  06 04                   MVI	B,004H                   ;To the FPACC
 2691                     
 2692                     	
 2693  1166  CD 0B 11     EXMLDV:	CALL	MOVEIT                     ;Perform the transfer from p-p to FPACC
 2694  1169  06 00                   MVI	B,000H                   ;Set up CPU register B to indicate regular normalization
 2695  116B  CD 36 10                CALL	FPNORM                  ;Normalize the result of multiplication
 2696  116E  2E 41                   MVI	L,OFS_SIGN_IND1+1                   ;Now set the pointer to the original SIGNS indicator
 2697  1170  7E                      MOV	A,M                      ;Fetch the indicator
 2698  1171  A7                      ANA	A                        ;Exercise the CPU flags
 2699  1172  C0                      RNZ                          ;If indicator is non-zero, answer is positive, can exit her
 2700  1173  C3 82 10                JMP	FPCOMP                   ;If not, answer must be negated, exit via 2's complement.
 2701                     
 2702                                                       ;The following portions of the FPMULT
 2703                                                       ;routine set up working locations in memory by clearing
 2704                                                       ;locations for an expanded FPOP area and the partial-produc
 2705                                                       ;area. Next, the signs of the two numbers to be multiplied
 2706                                                       ;are examined. Negative numbers are negated
 2707                                                       ;in preparation for the multiplication
 2708                                                       ;algorithm. A SIGNS indicator register is set up during
 2709                                                       ;this process to indicate whether the final result of the
 2710                                                       ;multiplication should be positive or negative. (Negative
 2711                                                       ;if original signs of the two numbers to be multiplied are
 2712                                                       ;different.)
 2713                     
 2714  1176  2E 60        CKSIGN:	MVI	L,OFS_FP_WORK                      ;Set pointer to start of partial-product working area
 2715  1178  26 01                   MVI	H,HIGH OLDPG1            ;** Set H to proper page
 2716  117A  06 08                   MVI	B,008H                   ;Set up a loop counter in CPU register B
 2717  117C  AF                      XRA	A                        ;Clear the accumulator
 2718                     
 2719  117D  77           CLRNEX:	MOV	M,A                         ;Now clear out locations for the partial-product
 2720  117E  2C                      INR	L                        ;Working registers
 2721  117F  05                      DCR	B                        ;Until the loop counter
 2722  1180  C2 7D 11                JNZ	CLRNEX                   ;Is zero
 2723  1183  06 04        CLROPL:	MVI	B,004H                      ;Set a loop counter
 2724  1185  2E 58                   MVI	L,OFS_FPOP_EXT                   ;Set up pointer
 2725  1187  77           CLRNX1:	MOV	M,A                         ;Clear out some extra registers so that the
 2726  1188  2C                      INR	L                        ;FPOP may be extended in length
 2727  1189  05                      DCR	B                        ;Perform clearing ops until loop counter
 2728  118A  C2 87 11                JNZ	CLRNX1                   ;Is zero
 2729  118D  2E 41                   MVI	L,OFS_SIGN_IND1+1                   ;Set pointer to M/D SIGNS indicator storage location
 2730  118F  36 01                   MVI	M,001H                   ;Set initial value of SIGNS indicator to plus one
 2731  1191  2E 56                   MVI	L,OFS_FPACC_MSW                   ;Change pointer to MSW of FPACC
 2732  1193  7E                      MOV	A,M                      ;Fetch MSW of mantissa into accumulator
 2733  1194  A7                      ANA	A                        ;Test flags
 2734  1195  FA A9 11                JM	NEGFPA                    ;If MSB in MSW of FPACC is a one, number is negative
 2735  1198  2E 5E        OPSGNT:	MVI	L,OFS_FPOP_MSW                      ;Set pointer to MSW of FPOP
 2736  119A  7E                      MOV	A,M                      ;Fetch MSW of mantissa into accumulator
 2737  119B  A7                      ANA	A                        ;Test flags
 2738  119C  F0                      RP                           ;Return to caller if number in FPOP is positive
 2739  119D  2E 41                   MVI	L,OFS_SIGN_IND1+1                   ;Else change pointer to M/D SIGNS indicator
 2740  119F  4E                      MOV	C,M                      ;Fetch the value in the SIGNS indicator
 2741  11A0  0D                      DCR	C                        ;Decrement the value by one
 2742  11A1  71                      MOV	M,C                      ;Restore the new value back to storage location
 2743  11A2  2E 5C                   MVI	L,OFS_FPOP                   ;Set pointer to LSW of FPOP
 2744  11A4  06 03                   MVI	B,003H                   ;Set precision counter
 2745  11A6  C3 68 12                JMP	COMPLM                   ;Two's complement value of FPOP & return to caller
 2746  11A9  2E 41        NEGFPA:	MVI	L,OFS_SIGN_IND1+1                      ;Set pointer to M/D SIGNS indicator
 2747  11AB  4E                      MOV	C,M                      ;Fetch the value in the SIGNS indicator
 2748  11AC  0D                      DCR	C                        ;Decrement the value by one
 2749  11AD  71                      MOV	M,C                      ;Restore the new value back to storage location
 2750  11AE  2E 54                   MVI	L,OFS_FPACC                   ;Set pointer to LSW of FPACC
 2751  11B0  06 03                   MVI	B,003H                   ;Set precision counter
 2752  11B2  CD 68 12                CALL	COMPLM                  ;Two's complement value of FPACC
 2753  11B5  C3 98 11                JMP	OPSGNT                   ;Proceed to check sign of FPOP
 2754                     
 2755                                                       ;The following subroutine adds the double length (six regis
 2756                                                       ;multiplicand in FPOP to the partial-product register when
 2757                                                       ;called on by the multiplication algorithm.
 2758                     
 2759  11B8  1E 61        ADOPPP:	MVI	E,061H                      ;Pointer to LSW of partial-product
 2760  11BA  54                      MOV	D,H                      ;On same page as FPOP
 2761  11BB  2E 59                   MVI	L,OFS_FPOP_EXT+1                   ;LSIV of FPOP which contains extended multiplicand
 2762  11BD  06 06                   MVI	B,006H                   ;Set precision counter (double length working registers)
 2763  11BF  C3 57 12                JMP	ADDER                    ;Add multiplicand to partial-product & return to caller
 2764                     
 2765  11C2  06 03        MROUND:	MVI	B,003H                      ;Set up precision counter
 2766  11C4  3E 40                   MVI	A,040H                   ;Prepare to add one to 24'th bit of partial-product
 2767  11C6  86                      ADD	M                        ;Add one to the 24'th bit of the partial-product
 2768  11C7  77           CROUND:	MOV	M,A                         ;Restore the updated byte to memory
 2769  11C8  2C                      INR	L                        ;Advance the memory pointer to next most significant
 2770  11C9  3E 00                   MVI	A,000H                   ;Byte of partial-product, then clear ACC without
 2771  11CB  8E                      ADC	M                        ;Disturbing carry bit. Now perform add with carry to
 2772  11CC  05                      DCR	B                        ;Propagate any rounding in the partial-product registers.
 2773  11CD  C2 C7 11                JNZ	CROUND                   ;If cotinter is not zero continue propagating any carry
 2774  11D0  77                      MOV	M,A                      ;Restore final byte to memory
 2775  11D1  C9                      RET                          ;Exit to calling routine
 2776                     
 2777  11D2  CD 76 11     FPDIV:	CALL	CKSIGN                      ;Call routine to set up registers & ck signs of numbers
 2778  11D5  2E 56                   MVI	L,OFS_FPACC_MSW                   ;Set pointer to MSW of FPACC (divisor)
 2779  11D7  7E                      MOV	A,M                      ;Fetch MSW of FPACC to accumulator
 2780  11D8  A7                      ANA	A                        ;Exercise CPU flags
 2781  11D9  CA EF 0A                JZ	DVERR                     ;If MSW of FPACC is zero go display 'DZ' error message
 2782  11DC  2E 5F        SUBEXP:	MVI	L,OFS_FPOP_EXP                      ;Set pointer to FPOP (dividend) Exponent
 2783  11DE  7E                      MOV	A,M                      ;Get FPOP Exponent into accumulator
 2784  11DF  2E 57                   MVI	L,OFS_FPACC_EXP                   ;Change pointer to FPACC (divisor) Exponent
 2785  11E1  96                      SUB	M                        ;Subtract divisor exponent from dividend exponent
 2786  11E2  C6 01                   ADI	001H                     ;Add one for algorithm compensation
 2787  11E4  77                      MOV	M,A                      ;Place result in FPACC Exponent
 2788  11E5  2E 42        SETDCT:	MVI	L,OFS_BITS_COUNTER                      ;Set pointer to bit counter storage location
 2789  11E7  36 17                   MVI	M,017H                   ;Initialize bit counter to 23 decimal
 2790                     
 2791                                                       ;Main division algorithm for mantissas
 2792                     
 2793  11E9  CD 41 12     DIVIDE:	CALL	SETSUB                     ;Go subtmct divisor from dividend
 2794  11EC  FA FE 11                JM	NOGO                      ;If result is negative then place a zero bit in quotient
 2795  11EF  1E 5C                   MVI	E,05CH                   ;If result zero or positive then move remainder after
 2796  11F1  2E 59                   MVI	L,OFS_FPOP_EXT+1                   ;Subtraction from working area to become new dividend
 2797  11F3  06 03                   MVI	B,003H                   ;Set up moving pointers and initialize precision counter
 2798  11F5  CD 0B 11                CALL	MOVEIT                  ;Perform the transfer
 2799  11F8  3E 01                   MVI	A,001H                   ;Place a one into least significant bit of accumulator
 2800  11FA  1F                      RAR                          ;And rotate it out into the carry bit
 2801  11FB  C3 FF 11                JMP	QUOROT                   ;Proceed to rotate the carry bit into the current quotient
 2802  11FE  AF           NOGO:	XRA	A                             ;When result is negative, put a zero in the carry bit, then
 2803  11FF  2E 64        QUOROT:	MVI	L,OFS_FP_WORK+4                      ;Set up pointer to LSW of quotient register
 2804  1201  06 03                   MVI	B,003H                   ;Set precision counter
 2805  1203  CD 80 12                CALL	ROTL                    ;Rotate carry bit into quotient by using special entry to
 2806  1206  2E 5C                   MVI	L,OFS_FPOP                   ;ROTATL subroutine. Now set up pointer to dividend
 2807  1208  06 03                   MVI	B,003H                   ;LSW and set precision counter
 2808  120A  CD 7F 12                CALL	ROTATL                  ;Rotate the current dividend to the left
 2809  120D  2E 42                   MVI	L,OFS_BITS_COUNTER                   ;Set pointer to bit counter storage location
 2810  120F  4E                      MOV	C,M                      ;Fetch the value of the bit counter
 2811  1210  0D                      DCR	C                        ;Decrement the value by one
 2812  1211  71                      MOV	M,C                      ;Restore the new counter value to storage
 2813  1212  C2 E9 11                JNZ	DIVIDE                   ;If bit counter is not zero, continue division process
 2814  1215  CD 41 12                CALL	SETSUB                  ;After 23 (decimal) bits, do subtraction once more for
 2815  1218  FA 38 12                JM	DVEXIT                    ;Possible rounding. Jump ahead if no rounding required.
 2816  121B  2E 64                   MVI	L,OFS_FP_WORK+4                   ;If rounding required set pointer to LSW of quotient
 2817  121D  7E                      MOV	A,M                      ;Fetch LSW of quotient to accumulator
 2818  121E  C6 01                   ADI	001H                     ;Add one to 23rd bit of quotient
 2819  1220  77                      MOV	M,A                      ;Restore updated LSW of quotient
 2820  1221  3E 00                   MVI	A,000H                   ;Clear accumulator without disturbing carry bit
 2821  1223  2C                      INR	L                        ;Advance pointer to next significant byte of quotient
 2822  1224  8E                      ADC	M                        ;Propagate any carry as part of rounding process
 2823  1225  77                      MOV	M,A                      ;Restore the updated byte of quotient
 2824  1226  3E 00                   MVI	A,000H                   ;Clear ACC again without disturbing carry bit
 2825  1228  2C                      INR	L                        ;Advance pointer to MSW of quotient
 2826  1229  8E                      ADC	M                        ;Propagate any carry to finish rounding process
 2827  122A  77                      MOV	M,A                      ;Restore the updated byte of quotient
 2828  122B  F2 38 12                JP	DVEXIT                    ;If most significant bit of quotient is zero, go finish up
 2829  122E  06 03                   MVI	B,003H                   ;If not, set precision counter
 2830  1230  CD 89 12                CALL	ROTATR                  ;And rotate quotient to the right to clear the sign bit
 2831  1233  2E 57                   MVI	L,OFS_FPACC_EXP                   ;Set pointer to FPACC Exponent
 2832  1235  46                      MOV	B,M                      ;Fetch FPACC exponent
 2833  1236  04                      INR	B                        ;Increment the value to compensate for the rotate right
 2834  1237  70                      MOV	M,B                      ;Restore the updated exponent value
 2835  1238  2E 63        DVEXIT:	MVI	L,OFS_FP_WORK_63                      ;Set up pointers
 2836  123A  1E 53                   MVI	E,053H                   ;To transfer the quotient into the FPACC
 2837  123C  06 04                   MVI	B,004H                   ;Set precision counter
 2838                                                       ;THIS IS A CORRECTION FOUND IN THE NOTES
 2839  123E  C3 66 11                JMP	EXMLDV                   ;And exit through FPMULT routine at EXMLDV
 2840                     
 2841                                                       ;Subroutine to subtract divisor from dividend. Used by
 2842                                                       ;main DIVIDE subroutine.
 2843                     
 2844  1241  1E 59        SETSUB:	MVI	E,059H                      ;Set pointer to LSW of working area
 2845  1243  54                      MOV	D,H                      ;On same page as FPACC
 2846  1244  2E 54                   MVI	L,OFS_FPACC                   ;Set pointer to LSW of FPACC (divisor)
 2847  1246  06 03                   MVI	B,003H                   ;Set precision counter
 2848  1248  CD 0B 11                CALL	MOVEIT                  ;Perform transfer
 2849  124B  1E 59                   MVI	E,059H                   ;Reset pointer to LSW of working area (now divisor)
 2850  124D  2E 5C                   MVI	L,OFS_FPOP                   ;Reset pointer to LSW of FPOP (dividend)
 2851  124F  06 03                   MVI	B,003H                   ;Set precision counter
 2852  1251  CD 93 12                CALL	SUBBER                  ;Subtract divisor from dividend
 2853  1254  7E                      MOV	A,M                      ;Get MSW of the result of the subtraction operations
 2854  1255  A7                      ANA	A                        ;Exercise CPU flags
 2855  1256  C9                      RET                          ;Return to caller with status
 2856  1257  A7           ADDER:	ANA	A                            ;Initialize the carry bit to zero upon entry
 2857  1258  7E           ADDMOR:	MOV	A,M                         ;Fetch byte from register group A
 2858  1259  CD EE 12                CALL	SWITCH                  ;Switch memory pointer to register group B
 2859  125C  8E                      ADC	M                        ;Add byte from A to byte from B with carry
 2860  125D  77                      MOV	M,A                      ;Leave result in register group B
 2861  125E  05                      DCR	B                        ;Decrement number of bytes (precision) counter
 2862  125F  C8                      RZ                           ;Return to caller when all bytes in group processed
 2863  1260  2C                      INR	L                        ;Else advance pointer for register group B
 2864  1261  CD EE 12                CALL	SWITCH                  ;Switch memory pointer back to register group A
 2865  1264  2C                      INR	L                        ;Advance the pointer for register group A
 2866  1265  C3 58 12                JMP	ADDMOR                   ;Continue the multi-byte addition operation
 2867                     
 2868                                                       ;N'th precision two's complement (negate)
 2869                                                       ;subroutine. Performs a two's complement on the multi-byte
 2870                                                       ;registers tarting at the address pointed
 2871                                                       ; to by H & L (least significant byte) upon entry.
 2872                     
 2873  1268  7E           COMPLM:	MOV	A,M                         ;Fetch the least significant byte of the number to ACC
 2874  1269  EE FF                   XRI	0FFH                     ;Exclusive OR to complement the byte
 2875  126B  C6 01                   ADI	001H                     ;Add one to form two's complement of byte
 2876  126D  77           MORCOM:	MOV	M,A                         ;Restore the negated byte to memory
 2877  126E  1F                      RAR                          ;Save the carry bit
 2878  126F  57                      MOV	D,A                      ;In CPU register D
 2879  1270  05                      DCR	B                        ;Decrement number of bytes (precision) counter
 2880  1271  C8                      RZ                           ;Return to caller when all bytes in number processed
 2881  1272  2C                      INR	L                        ;Else advance the pointer
 2882  1273  7E                      MOV	A,M                      ;Fetch the next byte of the number to ACC
 2883  1274  EE FF                   XRI	0FFH                     ;Exclusive OR to complement the byte
 2884  1276  5F                      MOV	E,A                      ;Save complemented value in register E temporarily
 2885  1277  7A                      MOV	A,D                      ;Restore previous carry status to ACC
 2886  1278  17                      RAL                          ;And rotate it out to the carry bit
 2887  1279  3E 00                   MVI	A,000H                   ;Clear ACC without disturbing carry status
 2888  127B  8B                      ADC	E                        ;Add in any carry to complemented value
 2889  127C  C3 6D 12                JMP	MORCOM                   ;Continue the two's complement procedure as req'd
 2890                     
 2891                                                       ;N'th precision rotate left subroutine. Rotates a multi-
 2892                                                       ;byte number left starting at the address initially
 2893                                                       ;specified by the contents of CPU registers H & L upon
 2894                                                       ;subroutine entry (LSW). First entry point will clear
 2895                                                       ;the carry bit before beginning rotate operations. Second
 2896                                                       ;entry point does not clear the carry bit.
 2897                     
 2898  127F  A7           ROTATL:	ANA	A                           ;Clear the carry bit at this entry point
 2899  1280  7E           ROTL:	MOV	A,M                           ;Fetch a byte from memory
 2900  1281  17                      RAL                          ;Rotate it left (bring carry into LSB, push MSB to carry)
 2901  1282  77                      MOV	M,A                      ;Restore rotated word to memory
 2902  1283  05                      DCR	B                        ;Decrement precision counter
 2903  1284  C8                      RZ                           ;Exit to caller when finished
 2904  1285  2C                      INR	L                        ;Else advance pointer to next byte
 2905  1286  C3 80 12                JMP	ROTL                     ;Continue rotate left operations
 2906                     
