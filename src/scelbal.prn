 3758  19ED  7E           	MOV A,M                         ;Fetch FPACC Exponent into the accumulator
 3759  19EE  C6 10        	ADI 010H                        ;Add 16 (decimal) to effectively multiply by 65,536
 3760  19F0  77           	MOV M,A                         ;(65,536 * INT[ ((SEED * A) + C)/65,5361) in FPACC
 3761  19F1  21 4F 00     	LXI H,SCRATCH_PAD2              ;Load L with address of [(SEED * A) + C]
 3762  19F4  CD C1 11     	CALL OPLOAD                     ;Transfer it into FPOP. Subtract FPACC to form
 3763  19F7  CD 03 10     	CALL FPSUB                      ;[(SEED * A) + C] MOD 65,536
 3764  19FA  21 4F 00     	LXI H,SCRATCH_PAD2              ;Load L with address of former SEED registers
 3765  19FD  CD B9 11     	CALL FSTORE                     ;Store SEED MOD 65,536 in place of [(SEED * A) + Cl
 3766  1A00  21 22 00     	LXI H,FPACC_EXP                 ;Load L with address of FPACC Exponent
 3767  1A03  7E           	MOV A,M                         ;Fetch FPACC Exponent into the ACC and subtract
 3768  1A04  D6 10        	SUI 010H                        ;16 (decimal) to form (SEED MOD 65,536)/65,536
 3769  1A06  77           	MOV M,A                         ;So that random number in FPACC is between
 3770  1A07  C9           	RET                             ;0.0 and +1.0 and exit to calling routine
