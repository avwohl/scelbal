 2977  13B1  CD 5B 02     AHEAD1:	CALL ECHO                       ;Call user display driver to output space or minus sign
 2978  13B4  21 69 00     	LXI H,FP_MODE_IND               ;Set pointer to FIXED/FLOAT indicator
 2979  13B7  7E           	MOV A,M                         ;Fetch value of FIXED/FLOAT indicator
 2980  13B8  A7           	ANA A                           ;Test contents of indicator. If contents are zero, calling
 2981  13B9  CA CE 13     	JZ OUTFLT                       ;Routine has directed floating point output format.
 2982  13BC  21 22 00     	LXI H,FPACC_EXP                 ;If indicator non-zero, fixed point fonnat requested if
 2983  13BF  3E 17        	MVI A,017H                      ;Possible. Point to FPACC Exponent. Put 23 decimal in
 2984  13C1  46           	MOV B,M                         ;Accumulator. Fetch FPACC Exponent into register B
 2985  13C2  04           	INR B                           ;And exercise the register to test its
 2986  13C3  05           	DCR B                           ;Original contents. If FPACC Exponent is negative in
 2987  13C4  FA CE 13     	JM OUTFLT                       ;Value then go to floating point output forrnat. If value
 2988  13C7  90           	SUB B                           ;Is positive, subtract value from 23 (decimal). If result
 2989  13C8  FA CE 13     	JM OUTFLT                       ;Negative, number is too big to use fixed format.
 2990  13CB  C3 DD 13     	JMP OUTFIX                      ;Else, can use fixed format so skip next routine
 2991  13CE  21 69 00     OUTFLT:	LXI H,FP_MODE_IND               ;Set pointer to FIXED/FLOAT indicator.
 2992  13D1  36 00        	MVI M,000H                      ;Clear indicator to indicate floating point output format
 2993  13D3  3E B0        	MVI A,0B0H                      ;Load ASCII code for '0' into accumulator
 2994  13D5  CD 5B 02     	CALL ECHO                       ;Call user display driver to output '0' as first character
 2995  13D8  3E AE        	MVI A,0AEH                      ;Number string. Now load ASCII code for decimal point.
 2996  13DA  CD 5B 02     	CALL ECHO                       ;Call user display driver to output '.'as second character.
 2997  13DD  21 22 00     OUTFIX:	LXI H,FPACC_EXP                 ;Set pointer to FPACC Exponent
 2998  13E0  3E FF        	MVI A,0FFH                      ;Load accumulator with minus one
 2999  13E2  86           	ADD M                           ;Add value in FPACC Exponent
 3000  13E3  77           	MOV M,A                         ;Restore compensated exponent value
 3001                     
 3002                                                       ;Next portion of routine establishes the value for the
 3003                                                       ;decimal exponent that will be outputted by processing
 3004                                                       ;the binary exponent value in the FPACC.
 3005                     
 3006  13E4  F2 04 14     DECEXT:	JP DECEXD                       ;If compensated exponent value is zero or positive
 3007  13E7  3E 04        	MVI A,004H                      ;Then go multiply FPACC by 0.1 (decimal). Else,
 3008  13E9  86           	ADD M                           ;Add four to the exponent value.
 3009  13EA  F2 16 14     	JP DECOUT                       ;If exponent now zero or positive, ready to output
 3010  13ED  21 0B 00     	LXI H,FP_CONST_10               ;If exponent negative, multiply FPACC by 10 (decimal)
 3011  13F0  CD C9 11     	CALL FACXOP                     ;Floating point format. Set up for multiplication.
 3012  13F3  CD 0E 10     	CALL FPMULT                     ;Perform the multiplication. Answer in FPACC.
 3013  13F6  21 3D 00     	LXI H,FP_WORK_6F                ;Set pointer to decimal exponent storage location.
 3014  13F9  4E           	MOV C,M                         ;Each time the FPACC is multiplied by ten, need to
 3015  13FA  0D           	DCR C                           ;Decrement the value in the decinial exponent storage
 3016  13FB  71           	MOV M,C                         ;Location. (This establishes decimal exponent value!)
 3017  13FC  21 22 00     DECREP:	LXI H,FPACC_EXP                 ;Reset pointer to FPACC Exponent
 3018  13FF  7E           	MOV A,M                         ;Fetch value in exponent
 3019  1400  A7           	ANA A                           ;Test value
 3020  1401  C3 E4 13     	JMP DECEXT                      ;Repeat process as required
 3021  1404  21 0F 00     DECEXD:	LXI H,FP_CONST_0P1              ;If exponent is positive, multiply FPACC by 0.1
 3022  1407  CD C9 11     	CALL FACXOP                     ;Floating point format. Set up for multipli(-ation.
 3023  140A  CD 0E 10     	CALL FPMULT                     ;Perform the multiplication. Answer in FPACC.
 3024  140D  21 3D 00     	LXI H,FP_WORK_6F                ;Set pointer to decimal exponent storage location.
 3025  1410  46           	MOV B,M                         ;Each time the FPACC is multiplied by one tenth, need
 3026  1411  04           	INR B                           ;To increment the value in the decimal exponent storage
 3027  1412  70           	MOV M,B                         ;Location. (This establishes decimal exponent value!)
 3028  1413  C3 FC 13     	JMP DECREP                      ;Repeat process as required
 3029                     
 3030                                                       ;The next section outputs the mantissa
 3031                                                       ;(or fixed point number) by converting the value remaining
 3032                                                       ;in the FPACC (after the decimal exponent equivalent has
 3033                                                       ;been extracted from the original value if required by the
 3034                                                       ;previous routines) to a string of decirnal digits.
 3035  1416  1E 74        DECOUT:	MVI E,074H                      ;Set pointer to LSW of output working register
 3036  1418  54           	MOV D,H                         ;Set D to same page value as H
 3037  1419  21 1F 00     	LXI H,FPACC                     ;Set pointer to LSW of FPACC
 3038  141C  06 03        	MVI B,003H                      ;Set precision counter
 3039  141E  CD F4 0F     	CALL MOVEIT                     ;Move value in FPACC to output working register
 3040  1421  21 45 00     	LXI H,FP_WORK_77                ;Set pointer to MSW plus one of output working register
 3041  1424  36 00        	MVI M,000H                      ;Clear that location to 0
 3042  1426  21 42 00     	LXI H,FP_WORK_74                ;Set pointer to LSW of output working register
 3043  1429  06 03        	MVI B,003H                      ;Set precision counter
 3044  142B  CD 8C 11     	CALL ROTATL                     ;Rotate register left once to compensate for sign bit
 3045  142E  CD CB 14     	CALL OUTX10                     ;Multiply output register by 10, overflow into N4SW+ 1
 3046  1431  21 22 00     COMPEN:	LXI H,FPACC_EXP                 ;Set pointer back to FPACC Exponent
 3047  1434  46           	MOV B,M                         ;Compensate for any remainder in the binary exponent
 3048  1435  04           	INR B                           ;By performing a rotate right on the output working
 3049  1436  70           	MOV M,B                         ;Register until the binary exponent becomes zero
 3050  1437  CA 45 14     	JZ OUTDIG                       ;Go output decimal digits when this loop is finished
 3051  143A  21 45 00     	LXI H,FP_WORK_77                ;Binary exponent compensating loop. Setpointe'r to
 3052  143D  06 04        	MVI B,004H                      ;Working register MSW+L. Set precision counter.
 3053  143F  CD 96 11     	CALL ROTATR                     ;Rotate working register to the right.
 3054  1442  C3 31 14     	JMP COMPEN                      ;Repeat loop as required.
 3055  1445  21 68 00     OUTDIG:	LXI H,OUT_DIG_CNT               ;Set pointer to output digit counter storage location
 3056  1448  36 07        	MVI M,007H                      ;Initialize to value of seven
 3057  144A  21 45 00     	LXI H,FP_WORK_77                ;Change pointer to output working register MSW+L
 3058  144D  7E           	MOV A,M                         ;Fetch MSW+L byte containing BCD of digit to be
 3059  144E  A7           	ANA A                           ;Displayed. Test the contents of this byte.
 3060  144F  CA AA 14     	JZ ZERODG                       ;If zero jump to ZERODG routine.
 3061  1452  21 45 00     OUTDGS:	LXI H,FP_WORK_77                ;Reset pointer to working register MSW+L
 3062  1455  7E           	MOV A,M                         ;Fetch BCD of digit to be outputted
 3063  1456  A7           	ANA A                           ;Exercise CPU flags
 3064  1457  C2 76 14     	JNZ OUTDGX                      ;If not zero, go display the digit
 3065  145A  21 69 00     	LXI H,FP_MODE_IND               ;If zero, change pointer to FIXED/FLOAT indicator
 3066  145D  7E           	MOV A,M                         ;Fetch the indicator into the accumulator
 3067  145E  A7           	ANA A                           ;Test value of indicator
 3068  145F  CA 75 14     	JZ OUTZER                       ;If in floating point mode, go display the digit
 3069  1462  21 3D 00     	LXI H,FP_WORK_6F                ;Else change pointer to decimal exponent storage
 3070  1465  4E           	MOV C,M                         ;Location, which, for fixed point, will have a positive
 3071  1466  0D           	DCR C                           ;Value for all digits before the decimal point. Decrement
 3072  1467  0C           	INR C                           ;And increment to exercise flags. See if count is positive.
 3073  1468  F2 75 14     	JP OUTZER                       ;If positive, must display any zero digit.
 3074  146B  21 44 00     	LXI H,FP_WORK_76                ;If not, change pointer to MSW of working register
 3075  146E  7E           	MOV A,M                         ;And test to see if any significant digits coming up
 3076  146F  E6 E0        	ANI 0E0H                        ;By forming a mask and testing for presence of bits
 3077  1471  C2 75 14     	JNZ OUTZER                      ;If more significant digits coming up soon, display the
 3078  1474  C9           	RET                             ;Zero digit. Else, exit to calling routine. Finished.
 3079  1475  AF           OUTZER:	XRA A                           ;Clear the accumulator to restore zero digit value
 3080  1476  C6 B0        OUTDGX:	ADI 0B0H                        ;Add 260 (octal) to BCD code in ACC to form ASCII
 3081  1478  CD 5B 02     	CALL ECHO                       ;Code and call the user's display driver subroutine
 3082  147B  21 69 00     DECRDG:	LXI H,FP_MODE_IND               ;Set pointer to FIXED/FLOAT indicator storage
 3083  147E  7E           	MOV A,M                         ;Fetch the indicator to the accumulator
 3084  147F  A7           	ANA A                           ;Exercise the CPU flags
 3085  1480  C2 92 14     	JNZ CKDECP                      ;If indicator non-zero, doing fixed point output
 3086  1483  21 68 00     	LXI H,OUT_DIG_CNT               ;Else, get output digit counter
 3087  1486  4E           	MOV C,M
 3088  1487  0D           	DCR C                           ;Decrement the digit counter & restore to storage
 3089  1488  71           	MOV M,C
 3090  1489  CA FE 14     	JZ EXPOUT                       ;When digit counter is zero, go take care of exponent
 3091  148C  CD CB 14     PUSHIT:	CALL OUTX10                     ;Else push next BCD digit out of working register
 3092  148F  C3 52 14     	JMP OUTDGS                      ;And continue the outputting process
 3093  1492  21 3D 00     CKDECP:	LXI H,FP_WORK_6F                ;For fixed point output, decimal exponent serves as
 3094  1495  4E           	MOV C,M                         ;Counter for number of digits before decimal point
 3095  1496  0D           	DCR C                           ;Fetch the counter and decrement it to account for
 3096  1497  71           	MOV M,C                         ;Current digit being processed. Restore to storage.
 3097  1498  C2 A0 14     	JNZ NODECP                      ;If count does not go to zero, jump ahead.
 3098  149B  3E AE        	MVI A,0AEH                      ;When count reaches zero, load ASCII code for period
 3099  149D  CD 5B 02     	CALL ECHO                       ;And call user's display driver to display decimal point
 3100  14A0  21 68 00     NODECP:	LXI H,OUT_DIG_CNT               ;Set pointer to output digit counter storage location
 3101  14A3  4E           	MOV C,M                         ;Fetch the digit counter
 3102  14A4  0D           	DCR C                           ;Decrement the value
 3103  14A5  71           	MOV M,C                         ;Restore to storage
 3104  14A6  C8           	RZ                              ;If counter reaches zero, exit to caller. Finished.
 3105  14A7  C3 8C 14     	JMP PUSHIT                      ;Else continue to output the number.
 3106  14AA  21 3D 00     ZERODG:	LXI H,FP_WORK_6F                ;If first digit of floating point number is a zero, set
 3107  14AD  4E           	MOV C,M                         ;Pointer to decimal exponent storage location.
 3108  14AE  0D           	DCR C                           ;Decrement the value to compensate for skipping
 3109  14AF  71           	MOV M,C                         ;Display of first digit. Restore to storage.
 3110  14B0  21 44 00     	LXI H,FP_WORK_76                ;Change pointer to MSW of output working register
 3111  14B3  7E           	MOV A,M                         ;Fetch MSW of output working register
 3112  14B4  A7           	ANA A                           ;Test the contents
 3113  14B5  C2 7B 14     	JNZ DECRDG                      ;If non-zero, continue outputting
 3114  14B8  2B           	DCX H                           ;Else decrement pointer to next byte in working register
 3115  14B9  7E           	MOV A,M                         ;Fetch its contents
 3116  14BA  A7           	ANA A                           ;Test
 3117  14BB  C2 7B 14     	JNZ DECRDG                      ;If non-zero, continue outputting
 3118  14BE  2B           	DCX H                           ;Else decrement pointer to LSW of working register
 3119  14BF  7E           	MOV A,M                         ;Fetch its contents
 3120  14C0  A7           	ANA A                           ;Test
 3121  14C1  C2 7B 14     	JNZ DECRDG                      ;If non-zero, continue outputting
 3122  14C4  21 3D 00     	LXI H,FP_WORK_6F                ;If decimal mantissa is zero, set pointer to decirnal
 3123  14C7  77           	MOV M,A                         ;Exponent storage and clear it
 3124  14C8  C3 7B 14     	JMP DECRDG                      ;Finish outputting
 3125                     
 3126                                                       ;Following routine multiplies the binary number in the
 3127                                                       ;output working register by ten to push the most signifi-
 3128                                                       ;cant digit out to the MSW+L byte.
 3129                     
 3130  14CB  21 45 00     OUTX10:	LXI H,FP_WORK_77                ;Set pointer to work ing register M SW+ 1
 3131  14CE  36 00        	MVI M,000H                      ;Clear it in preparation for receiving next digit pushed
 3132  14D0  21 42 00     	LXI H,FP_WORK_74                ;Into it. Change pointer to working register LSW.
 3133  14D3  54           	MOV D,H                         ;Set up register D to same page as H.
 3134  14D4  1E 70        	MVI E,070H                      ;Set second pointer to LSW of second working register
 3135  14D6  06 04        	MVI B,004H                      ;Set precision counter
 3136  14D8  CD F4 0F     	CALL MOVEIT                     ;Move first working register into second
 3137  14DB  21 42 00     	LXI H,FP_WORK_74                ;Reset pointer to LSW of first working register
 3138  14DE  06 04        	MVI B,004H                      ;Set precision counter
 3139  14E0  CD 8C 11     	CALL ROTATL                     ;Rotate contents of first working register left (X 2)
 3140  14E3  21 42 00     	LXI H,FP_WORK_74                ;Reset pointer to LSW
 3141  14E6  06 04        	MVI B,004H                      ;Reset precision counter
 3142  14E8  CD 8C 11     	CALL ROTATL                     ;Rotate contents left again (X 4)
 3143  14EB  21 3E 00     	LXI H,FP_WORK_70                ;Set pointer to LSW of original value in 2'nd register
 3144  14EE  1E 74        	MVI E,074H                      ;Set pointer to LSW of rotated value
 3145  14F0  06 04        	MVI B,004H                      ;Set precision counter
 3146  14F2  CD 64 11     	CALL ADDER                      ;Add rotated value to original value (X 5)
 3147  14F5  21 42 00     	LXI H,FP_WORK_74                ;Reset pointer to LSW of first working register
 3148  14F8  06 04        	MVI B,004H                      ;Set precision counter
 3149  14FA  CD 8C 11     	CALL ROTATL                     ;Rotate contents left again (X 10)
 3150  14FD  C9           	RET                             ;Exit to calling routine
 3151                     
 3152                                                       ;The final group of routines in the floating point output
 3153                                                       ;section take care of outputting the decimal exponent
 3154                                                       ;portion of floating point numbers.
 3155                     
 3156  14FE  21 3D 00     EXPOUT:	LXI H,FP_WORK_6F                ;Set pointer to decimal exponent storage location
 3157  1501  7E           	MOV A,M                         ;Fetch value to the accumulator
 3158  1502  A7           	ANA A                           ;Test the value
 3159  1503  C8           	RZ                              ;If zero, then no exponent portion. Exit to caller.
 3160  1504  3E C5        	MVI A,0C5H                      ;Else, load ACC with ASCII code for letter E.
 3161  1506  CD 5B 02     	CALL ECHO                       ;Display E for Exponent via user's display driver rtn
 3162  1509  7E           	MOV A,M                         ;Get decimal exponent value back into ACC
 3163  150A  A7           	ANA A                           ;Test again
 3164  150B  FA 13 15     	JM EXOUTN                       ;If value is negative, skip ahead
 3165  150E  3E AB        	MVI A,0ABH                      ;If positive, load ASCII code for + sign
 3166  1510  C3 1A 15     	JMP AHEAD2                      ;Jump to display the + sign
 3167  1513  EE FF        EXOUTN:	XRI 0FFH                        ;When decimal exponent is negative, must negate
 3168  1515  C6 01        	ADI 001H                        ;Value for display purposes. Perform two's complement
 3169  1517  77           	MOV M,A                         ;And restore the negated value to storage location
 3170  1518  3E AD        	MVI A,0ADH                      ;Load ASCII code for minus sign
 3171  151A  CD 5B 02     AHEAD2:	CALL ECHO                       ;Display the ASCII character in ACC
 3172  151D  06 00        	MVI B,000H                      ;Clear register B
 3173  151F  7E           	MOV A,M                         ;Fetch the decimal exponent value back into ACC
 3174  1520  D6 0A        SUB12:	SUI 00AH                        ;Subtract 10 (decimal) from value in ACC
 3175  1522  FA 2A 15     	JM TOMUCH                       ;Break out of loop when accumulator goes negative
 3176  1525  77           	MOV M,A                         ;Else restore value to storage location
 3177  1526  04           	INR B                           ;Increment register B as a counter
 3178  1527  C3 20 15     	JMP SUB12                       ;Repeat loop to form tens value of decimal exponent
 3179  152A  3E B0        TOMUCH:	MVI A,0B0H                      ;Load base ASCII value for digit into the accumulator
 3180  152C  80           	ADD B                           ;Add to the count in B to forin tens digit of decimal
 3181  152D  CD 5B 02     	CALL ECHO                       ;Exponent. Display via user's driver subroutine
 3182  1530  7E           	MOV A,M                         ;Fetch remainder of decimal exponent value
 3183  1531  C6 B0        	ADI 0B0H                        ;Add in ASCII base value to form final digit
 3184  1533  CD 5B 02     	CALL ECHO                       ;Display second digit of decirnal exponent
 3185  1536  C9           	RET                             ;Finished outputting. Return to caller.
