 4068                     	;; OPTIONAL ARRAY ROUTINES ASSEMBLED FOR OPERATION
 4069                     	;; IN THE UPPER 3 PAGES OF A 12K SYSTEM ARE LISTED HERE.
 4070                     
 4071                     	ORG	02D00H
 4072                     	
 4073  2D00  2E 56        PRIGH1:	MVI	L,OFS_FPACC_MSW                      ;Load L with address of the MSW in the FPACC
 4074  2D02  26 01                   MVI	H,HIGH OLDPG1            ;** Set H to page of FPACC
 4075  2D04  7E                      MOV	A,M                      ;Fetch MSW of FPACC into the ACC.
 4076  2D05  A7                      ANA	A                        ;Test to see if value in FPACC is positive.
 4077  2D06  FA 5E 2D                JM	OUTRNG                    ;If not, go display error message.
 4078  2D09  CD 00 10                CALL	FPFIX                   ;If O.K. then convert floating point to fixed point
 4079  2D0C  2E 54                   MVI	L,OFS_FPACC                   ;Load L with address of LSAL of converted value
 4080  2D0E  7E                      MOV	A,M                      ;Fetch the LSW of the value into the ACC
 4081  2D0F  D6 01                   SUI	001H                     ;Subtract one from the value to establish proper
 4082  2D11  07                      RLC                          ;Origin for future ops. Now rotate the value twice
 4083  2D12  07                      RLC                          ;To effectively multiply by four. Save the
 4084  2D13  4F                      MOV	C,A                      ;Calculated result in CPU register C
 4085  2D14  2E 83                   MVI	L,OFS_TOKEN_STORE                   ;Load L with address of F/A STACK TEMP
 4086  2D16  26 17                   MVI	H,HIGH OLDPG27           ;** Load H with page of F/A STACK TEMP
 4087  2D18  7E                      MOV	A,M                      ;Fetch the value into the accumulator
 4088  2D19  EE FF                   XRI	0FFH                     ;Complement the value
 4089  2D1B  07                      RLC                          ;Rotate the value twice to multiply by four (the number
 4090  2D1C  07                      RLC                          ;Of bytes per entry in the ARRAY VARIABLES table).
 4091  2D1D  C6 50                   ADI	050H                     ;Add the starting address of the ARRAY VARIABLES
 4092  2D1F  26 17                   MVI	H,HIGH OLDPG27           ;** TABLE to forin pointer. Set page address in H.
 4093  2D21  6F                      MOV	L,A                      ;Point to the name in the ARRAY VARIABLES
 4094  2D22  2C                      INR	L                        ;Increment the pointer value twice to move over the
 4095  2D23  2C                      INR	L                        ;Name in the table and point to starting address for the
 4096  2D24  7E                      MOV	A,M                      ;Array values in the ARRAY VALUES table. Fetch this
 4097  2D25  81                      ADD	C                        ;Address to the ACC. Now add in the figure calculated
 4098  2D26  6F                      MOV	L,A                      ;To reach desired subscripted data storage location. Set
 4099  2D27  26 2F                   MVI	H,HIGH OLDPG57           ;tt The pointer to that location. Load the floating point
 4100  2D29  C3 A4 12                JMP	FLOAD                    ;Value stored there into the FPACC and exit to caller.
 4101                     	
 4102                     	
 4103                     ;;; The label FUNAR2 SHOULD START AT 55-054
 4104  2D2C  2E 82        FUNAR2:	MVI	L,OFS_SCAN_PTR                      ;Load L with address of TEMP COUNTER
 4105  2D2E  26 17                   MVI	H,HIGH OLDPG27           ;** Load H with page of counter
 4106  2D30  46                      MOV	B,M                      ;Fetch the counter value
 4107  2D31  04                      INR	B                        ;Increment the value
 4108  2D32  70                      MOV	M,B                      ;Restore the value to memory
 4109  2D33  0E 02                   MVI	C,002H                   ;Initialize register C to a value of two for future ops
 4110  2D35  2E 4C                   MVI	L,OFS_ARRAY_VAR                   ;Load L with address of start of ARRAY VARIABLES
 4111  2D37  26 17                   MVI	H,HIGH OLDPG27           ;** TABLE (less four). Set H to page of the table.
 4112  2D39  CD 98 07                CALL	TABADR                  ;Calculate address of start of next narne in table.
 4113  2D3C  16 16                   MVI	D,HIGH OLDPG26           ;** Load D with page of the SYMBOL BUFFER
 4114  2D3E  1E 50                   MVI	E,OFS_SYMBOL_BUF                   ;Set E to starting address of the SYMBOL BUFFER
 4115  2D40  CD DA 02                CALL	STRCP                   ;Compare name in ARRAY VARIABLES table to the
 4116  2D43  CA 54 2D                JZ	FUNAR3                    ;Contents of the SYMBOL BUFFER. If match, go set up
 4117  2D46  2E 82                   MVI	L,OFS_SCAN_PTR                   ;Array token value. Else, reset L to address of TEMP
 4118  2D48  26 17                   MVI	H,HIGH OLDPG27           ;** COUNTER. Set H to page of TEMP COUNTER.
 4119  2D4A  7E                      MOV	A,M                      ;Fetch the counter value into the accumulator.
 4120  2D4B  2E 3D                   MVI	L,OFS_SYMVAR_CNT-2                   ;Change L to number of arrays storage location.
 4121  2D4D  BE                      CMP	M                        ;Compare number of entries checked against number
 4122  2D4E  C2 2C 2D                JNZ	FUNAR2                   ;Possible. Keep searching table if not finished.
 4123  2D51  C3 7A 07                JMP	FAERR                    ;If finished and no match than have F/A error condx.
 4124  2D54  2E 82        FUNAR3:	MVI	L,OFS_SCAN_PTR                      ;Load L with address of TEMP COUNTER
 4125  2D56  26 17                   MVI	H,HIGH OLDPG27           ;** Load H with page of counter.
 4126  2D58  AF                      XRA	A                        ;Clear the accumulator. Subtract the value in the TEMP
 4127  2D59  9E                      SBB	M                        ;COUNTER from zero to obtain two's complement.
 4128  2D5A  77                      MOV	M,A                      ;Place this back in counter location as ARRAY TOKEN
 4129  2D5B  C3 87 07                JMP	FUNAR4                   ;VALUE (negative). Go place the value on F/A STACK.
 4130                     	
 4131                     
 4132                     ;;; The label OUTRNG STARTS AT 55 136
 4133  2D5E  3E CF        OUTRNG:	MVI	A,0CFH                      ;Load the ASCII code for letter 0 into the accumulator
 4134  2D60  0E D2                   MVI	C,0D2H                   ;Load the ASCII code for letter R into register C
 4135  2D62  C3 96 02                JMP	ERROR                    ;Go display Out of Range (OR) error message.
 4136                     	
 4137                     
 4138                     
 4139                     	
 4140  2D65  CD AA 08     ARRAY:	CALL	RESTSY                      ;Transfer contents of AUX SYMBOL BUFFER into the
 4141  2D68  C3 70 2D                JMP	ARRAY2                   ;SYMBOL BUFFER. (Entry when have actual LET)
 4142  2D6B  2E 82        ARRAY1:	MVI	L,OFS_SCAN_PTR                      ;Load L with address of SCAN pointer
 4143  2D6D  C3 72 2D                JMP	ARRAY3                   ;Proceed to process. (Entry point for IMPLIED LET)
 4144  2D70  2E 83        ARRAY2:	MVI	L,OFS_TOKEN_STORE                      ;Load L with address of LET pointer
 4145  2D72  26 16        ARRAY3:	MVI	H,HIGH OLDPG26              ;** Set H to pointer page
 4146  2D74  46                      MOV	B,M                      ;Fetch pointer to location where "(" found in statement
 4147  2D75  04                      INR	B                        ;Line. Increment it to point to next character in the line.
 4148  2D76  2E BE                   MVI	L,OFS_EVAL_PTR                   ;Load L with address of EVAL pointer and load it with
 4149  2D78  70                      MOV	M,B                      ;The starting address for the EVAL routine
 4150  2D79  2E 86                   MVI	L,OFS_ARRAY_SETUP                   ;Change L to address of ARRAY SETUP pointer
 4151  2D7B  70                      MOV	M,B                      ;And also store address in that location
 4152  2D7C  2E 86        ARRAY4:	MVI	L,OFS_ARRAY_SETUP                      ;Load L with address of ARRAY SETUP pointer
 4153  2D7E  CD A0 02                CALL	GETCHR                  ;Fetch character pointed to by ARRAY SETUP pntr
 4154  2D81  FE A9                   CPI	0A9H                     ;See if character is ")" ? If so, then have located
 4155  2D83  CA 95 2D                JZ	ARRAY5                    ;End of the subscript. If not, reset
 4156  2D86  2E 86                   MVI	L,OFS_ARRAY_SETUP                   ;to the ARRAY SETUP pointer. Increment the
 4157  2D88  CD 03 03                CALL	LOOP                    ;Pointer and test for the end of the statement line.
 4158  2D8B  C2 7C 2D                JNZ	ARRAY4                   ;If not end of line, continue looking for right paren.
 4159  2D8E  3E C1                   MVI	A,0C1H                   ;If reach end of line before right parenthesis than load
 4160  2D90  0E C6                   MVI	C,0C6H                   ;ASCII code for letters A and F and display message
 4161  2D92  C3 96 02                JMP	ERROR                    ;Indicating Array Forrnat (AF) error condition
 4162  2D95  2E 86        ARRAY5:	MVI	L,OFS_ARRAY_SETUP                      ;Load L with address of ARRAY SETUP pointer
 4163  2D97  46                      MOV	B,M                      ;Fetch pointer (pointing to ")"sign) into register B
 4164  2D98  05                      DCR	B                        ;Decrement it to move back to end of subscript number
 4165  2D99  2E BF                   MVI	L,OFS_EVAL_FINISH                   ;Load L with address of EVAL FINISH pointer location
 4166  2D9B  70                      MOV	M,B                      ;Place the pointer value in the EVAL FINISH pointer
 4167  2D9C  2E 87                   MVI	L,OFS_LOOP_COUNTER                   ;Load L with address of LOOP COUNTER
 4168  2D9E  36 00                   MVI	M,000H                   ;Initialize LOOP COUNTER to value of zero
 4169  2DA0  2E 87        ARRAY6:	MVI	L,OFS_LOOP_COUNTER                      ;Load L with address of LOOP COUNTER
 4170  2DA2  26 16                   MVI	H,HIGH OLDPG26           ;** Load H with page of LOOP COUNTER
 4171  2DA4  46                      MOV	B,M                      ;Fetch the counter value
 4172  2DA5  04                      INR	B                        ;Increment it
 4173  2DA6  70                      MOV	M,B                      ;Restore the counter value to memory
 4174  2DA7  0E 02                   MVI	C,002H                   ;Set up counter in register C for future ops
 4175  2DA9  2E 4C                   MVI	L,OFS_ARRAY_VAR                   ;Load L with address of start of ARRAY VARIABLES
 4176  2DAB  26 17                   MVI	H,HIGH OLDPG27           ;** Table less four). Set H to page of the table.
 4177  2DAD  CD 98 07                CALL	TABADR                  ;Calculate the address of next entry in the table
 4178  2DB0  1E 50                   MVI	E,OFS_SYMBOL_BUF                   ;Load register E with starting address of SYMBOL BUFF
 4179  2DB2  16 16                   MVI	D,HIGH OLDPG26           ;** Set D to page of SYMBOL BUFFER
 4180  2DB4  CD DA 02                CALL	STRCP                   ;Compare entry in table against contents of SYMBOL BF
 4181  2DB7  CA CA 2D                JZ	ARRAY7                    ;If match, have found array naine in the table.
 4182  2DBA  2E 87                   MVI	L,OFS_LOOP_COUNTER                   ;Else, set L to address of the LOOP COUNTER
 4183  2DBC  26 16                   MVI	H,HIGH OLDPG26           ;** Set H to page of the LOOP COUNTER
 4184  2DBE  7E                      MOV	A,M                      ;Fetch the counter value to the ACC
 4185  2DBF  2E 3D                   MVI	L,OFS_SYMVAR_CNT-2                   ;Change L to the counter containing number of arrays
 4186  2DC1  26 17                   MVI	H,HIGH OLDPG27           ;** Set H to the proper page
 4187  2DC3  BE                      CMP	M                        ;Compare number of arrays to count in LOOP CNTR
 4188  2DC4  C2 A0 2D                JNZ	ARRAY6                   ;If more entries in the table, continue looking for match
 4189  2DC7  C3 7A 07                JMP	FAERR                    ;If no matching name in table then have an error condx.
 4190  2DCA  CD 94 03     ARRAY7:	CALL	EVAL                       ;Call subroutine to evaluate subscript expression
 4191  2DCD  CD 00 10                CALL	FPFIX                   ;Convert the subscript value obtained to fixed forrnat
 4192  2DD0  2E 87                   MVI	L,OFS_LOOP_COUNTER                   ;Load L with address of LOOP COUNTER
 4193  2DD2  26 16                   MVI	H,HIGH OLDPG26           ;** Set H to page of the LOOP COUNTER
 4194  2DD4  46                      MOV	B,M                      ;Fetch the value in the LOOP COUNTER into the ACC
 4195  2DD5  0E 02                   MVI	C,002H                   ;Set up counter in register C future ops
 4196  2DD7  2E 4C                   MVI	L,OFS_ARRAY_VAR                   ;Load L with address of ARRAY VARIABLES
 4197  2DD9  26 17                   MVI	H,HIGH OLDPG27           ;** Table less four). Set H to page of the table.
 4198  2DDB  CD 98 07                CALL	TABADR                  ;Calculate the address of entry in the table
 4199  2DDE  2C                      INR	L                        ;Advance the ARRAY VARIABLES table pointer twice
 4200  2DDF  2C                      INR	L                        ;To advance pointer over array name.
 4201  2DE0  4E                      MOV	C,M                      ;Fetch array base address in ARRAY VALUES table
 4202  2DE1  2E 54                   MVI	L,OFS_FPACC                   ;Load L with address of subscript value
 4203  2DE3  26 01                   MVI	H,HIGH OLDPG1            ;** Set H to page of subscript value
 4204  2DE5  7E                      MOV	A,M                      ;Fetch the subscript value into the accumulator
 4205  2DE6  D6 01                   SUI	001H                     ;Subtract one from subscript value to allow for zero
 4206  2DE8  07                      RLC                          ;Origin. Now multiply by four
 4207  2DE9  07                      RLC                          ;Using rotates (number of bytes required for each entry
 4208  2DEA  81                      ADD	C                        ;In the ARRAY VALUES table). Add in base address to
 4209  2DEB  2E 84                   MVI	L,OFS_TEMP_ARRAY                   ;The calculated value to form final address in the
 4210  2DED  26 17                   MVI	H,HIGH OLDPG27           ;** ARRAY VALUES table. Now set H & L to TEMP
 4211  2DEF  77                      MOV	M,A                      ;ARRAY ELEMENT storage location & store the addr.
 4212  2DF0  2E 81                   MVI	L,OFS_SYNTAX_PTR                   ;Change L to point to ARRAY FLAG
 4213  2DF2  36 FF                   MVI	M,0FFH                   ;Set the ARRAY FLAG for future use
 4214  2DF4  C9                      RET                          ;Exit to calling routine
 4215                     
 4216                     	
 4217                     ;;; The label DIM SHOULD START AT 55 365
 4218  2DF5  CD AD 02     DIM:	CALL	CLESYM                        ;Initialize the SYMBOL BUFFER to cleared condition
 4219  2DF8  2E 82                   MVI	L,OFS_SCAN_PTR                   ;Load L with address of SCAN pointer
 4220  2DFA  46                      MOV	B,M                      ;Fetch SCAN pointer value into register B
 4221  2DFB  04                      INR	B                        ;Add one to the SCAN pointer value
 4222  2DFC  2E 83                   MVI	L,OFS_TOKEN_STORE                   ;Change L to DIM pointer (formerly TOKEN) storage
 4223  2DFE  70                      MOV	M,B                      ;Store the updated SCAN pointer as the DIM pointer
 4224  2DFF  2E 83        DIM1:	MVI	L,OFS_TOKEN_STORE                        ;Load L with the address of DIM pointer storage location
 4225  2E01  CD A0 02                CALL	GETCHR                  ;Fetch a character from the line input buffer
 4226  2E04  CA 0F 2E                JZ	DIM2                      ;If character fetched is a space, ignore it
 4227  2E07  FE A8                   CPI	0A8H                     ;Else see if character is "(" left parenthesis
 4228  2E09  CA 1A 2E                JZ	DIM3                      ;If so, should have ARRAY VARIABLE naine in buffer
 4229  2E0C  CD C8 02                CALL	CONCTS                  ;If not, append the character to the SYMBOL BUFFER
 4230  2E0F  2E 83        DIM2:	MVI	L,OFS_TOKEN_STORE                        ;Load L with the address of DIM pointer stomge location
 4231  2E11  CD 03 03                CALL	LOOP                    ;Increment the pointer and see if end of line
 4232  2E14  C2 FF 2D                JNZ	DIM1                     ;If not end of line, fetch next character
 4233  2E17  C3 DF 2E                JMP	DIMERR                   ;Else have a DIMension error condition
 4234  2E1A  2E 86        DIM3:	MVI	L,OFS_ARRAY_SETUP                        ;Load L with address of ARRAY pointer storage loc
 4235  2E1C  36 00                   MVI	M,000H                   ;Initialize ARRAY pointer to starting value of zero
 4236  2E1E  2E 86        DIM4:	MVI	L,OFS_ARRAY_SETUP                        ;Load L with address of ARRAY pointer storage loc
 4237  2E20  26 16                   MVI	H,HIGH OLDPG26           ;** Set H to page of ARRAY pointer storage location
 4238  2E22  7E                      MOV	A,M                      ;Fetch value in ARRAY pointer to ACC (effectively
 4239  2E23  07                      RLC                          ;Represents number of arrays defined in pgm). Rotate
 4240  2E24  07                      RLC                          ;Left twice to multiply by four (niunber of bytes per
 4241  2E25  C6 4C                   ADI	04CH                     ;entry in ARRAY VARIABLES table). Add to base
 4242  2E27  26 17                   MVI	H,HIGH OLDPG27           ;** Address to form pointer to ARRAY VARIA.BLES
 4243  2E29  6F                      MOV	L,A                      ;Table and set up H & L as the memory pointer.
 4244  2E2A  1E 50                   MVI	E,OFS_SYMBOL_BUF                   ;Load E with starting address of the SYMBOL BUFFER
 4245  2E2C  16 16                   MVI	D,HIGH OLDPG26           ;** Load D with the page address of the SYMBOL BUFF
 4246  2E2E  CD DA 02                CALL	STRCP                   ;Compare contents of SYMBOL BF to entry in ARRAY
 4247  2E31  CA C1 2E                JZ	DIM9                      ;VARIABLES table. If same, have duplicate array name.
 4248  2E34  2E 86                   MVI	L,OFS_ARRAY_SETUP                   ;Else, load L with address of ARRAY pointer storage
 4249  2E36  26 16                   MVI	H,HIGH OLDPG26           ;** Load H with page of ARRAY pointer storage
 4250  2E38  46                      MOV	B,M                      ;Fetch the ARRAY pointer value to register B
 4251  2E39  04                      INR	B                        ;Increment the value
 4252  2E3A  70                      MOV	M,B                      ;Restore it to ARRAY pointer storage location
 4253  2E3B  2E 3D                   MVI	L,OFS_SYMVAR_CNT-2                   ;Change L to number of arrays storage location
 4254  2E3D  26 17                   MVI	H,HIGH OLDPG27           ;** Set H to page of the number of arrays stomge loc
 4255  2E3F  7E                      MOV	A,M                      ;Fetch the number of arrays value to the ACC
 4256  2E40  05                      DCR	B                        ;Restore B to previous count
 4257  2E41  B8                      CMP	B                        ;Compare number of arrays tested against nr defined
 4258  2E42  C2 1E 2E                JNZ	DIM4                     ;If not equal, continue searching ARRAY VARIABLES
 4259  2E45  2E 3D                   MVI	L,OFS_SYMVAR_CNT-2                   ;Table. When table searched with no match, then must
 4260  2E47  26 17                   MVI	H,HIGH OLDPG27           ;** Append naine to table. First set pointer to number
 4261  2E49  46                      MOV	B,M                      ;Of arrays storage location. Fetch that value and
 4262  2E4A  04                      INR	B                        ;Add one to account for new name being added.
 4263  2E4B  70                      MOV	M,B                      ;Restore the updated value back to memory.
 4264  2E4C  2E 3E                   MVI	L,OFS_ARRAY_TEMP                   ;Change pointer to ARRAY TEMP pointer storage
 4265  2E4E  70                      MOV	M,B                      ;Store pointer to current array in ARRAY TEMP too.
 4266  2E4F  2E 86                   MVI	L,OFS_ARRAY_SETUP                   ;Load L with address of ARRAY pointer stomge loc.
 4267  2E51  26 16                   MVI	H,HIGH OLDPG26           ;** Set H to page of ARRAY pointer storage location
 4268  2E53  70                      MOV	M,B                      ;And update it also for new array being added.
 4269  2E54  7E                      MOV	A,M                      ;Fetch the current ARRAY pointer value to the ACC
 4270  2E55  07                      RLC                          ;Multiply it times four by performing two rotate left
 4271  2E56  07                      RLC                          ;Operations and add it to base value to form address in
 4272  2E57  C6 4C                   ADI	04CH                     ;The ARRAY VARIABLES table. Place the low part
 4273  2E59  5F                      MOV	E,A                      ;Of this calculated address value into register E.
 4274  2E5A  16 17                   MVI	D,HIGH OLDPG27           ;** Set register D to the page of the table.
 4275  2E5C  2E 50                   MVI	L,OFS_SYMBOL_BUF                   ;Load L with the start of the SYMBOL BUFFER
 4276  2E5E  26 16                   MVI	H,HIGH OLDPG26           ;** Load H with the page of the SYMBOL BUFFER
 4277  2E60  CD 26 0A                CALL	MOVEC                   ;Move the array name from the SYMBOL BUFFER to
 4278  2E63  CD AD 02                CALL	CLESYM                  ;The ARRAY VARIABLES table. Then clear the
 4279  2E66  2E 83                   MVI	L,OFS_TOKEN_STORE                   ;SYMBOL BUFFER. Reset L to the DIM pointer storage
 4280  2E68  26 16                   MVI	H,HIGH OLDPG26           ;** Location. Set H to the DIM pointer page.
 4281  2E6A  46                      MOV	B,M                      ;Fetch the pointer value (points to "(" part of DIM
 4282  2E6B  04                      INR	B                        ;Statement). Increment the pointer to next character in
 4283  2E6C  2E 84                   MVI	L,OFS_TEMP_ARRAY                   ;The line input buffer. Cbange L to DIMEN pointer.
 4284  2E6E  70                      MOV	M,B                      ;Store the updated DIM pointer in DIMEN storage loc.
 4285  2E6F  2E 84        DIM5:	MVI	L,OFS_TEMP_ARRAY                        ;Set L to DIMEN pointer storage location
 4286  2E71  CD A0 02                CALL	GETCHR                  ;Fetch character in line input buffer
 4287  2E74  CA 89 2E                JZ	DIM6                      ;Ignore character for space
 4288  2E77  FE A9                   CPI	0A9H                     ;If not space, see if character is right parenthesis
 4289  2E79  CA 94 2E                JZ	DIM7                      ;If yes, process DIMension size (array length)
 4290  2E7C  FE B0                   CPI	0B0H                     ;If not, see if character is a valid decimal number
 4291  2E7E  FA DF 2E                JM	DIMERR                    ;If not valid number, have DIMension error condition
 4292  2E81  FE BA                   CPI	0BAH                     ;Continue testing for valid decitnal number
 4293  2E83  F2 DF 2E                JP	DIMERR                    ;If not valid number, then DIMension error condition
 4294  2E86  CD C8 02                CALL	CONCTS                  ;If valid decirnal number, append digit to SYMBOL BF
 4295  2E89  2E 84        DIM6:	MVI	L,OFS_TEMP_ARRAY                        ;Set L to DIMEN pointer storage location
 4296  2E8B  CD 03 03                CALL	LOOP                    ;Advance the pointer value and check for end of the line
 4297  2E8E  C2 6F 2E                JNZ	DIM5                     ;If not end of line, continue fetching DIMension size
 4298  2E91  C3 DF 2E                JMP	DIMERR                   ;If end of line before right parenthesis, have error condx.
 4299  2E94  2E 50        DIM7:	MVI	L,OFS_SYMBOL_BUF                        ;Load L with address of start of SYMBOL BUFFER
 4300  2E96  26 16                   MVI	H,HIGH OLDPG26           ;** Load H with page of SYMBOL BUFFER. (Now
 4301  2E98  CD 24 13                CALL	DINPUT                  ;Contains DIMension size.) Convert buffer to floating
 4302  2E9B  CD 00 10                CALL	FPFIX                   ;Point number and then reformat to fixed point.
 4303  2E9E  2E 54                   MVI	L,OFS_FPACC                   ;Load L with address of LSW of fixed point number
 4304  2EA0  7E                      MOV	A,M                      ; And fetch the low order byte of the nr into the ACC
 4305  2EA1  07                      RLC                          ;Rotate it left two tirnes to multiply it by four (the
 4306  2EA2  07                      RLC                          ;Number of bytes required to store a floating point nr).
 4307  2EA3  4F                      MOV	C,A                      ;Store this value in CPU register C temporarily
 4308  2EA4  2E 3E                   MVI	L,OFS_ARRAY_TEMP                   ;Set L to ARRAY TEMP storage location.
 4309  2EA6  26 17                   MVI	H,HIGH OLDPG27           ;** Set H to ARRAY TEMP pointer page.
 4310  2EA8  7E                      MOV	A,M                      ;Fetch the value in ARRAY TEMP (points to ARRAY
 4311  2EA9  D6 01                   SUI	001H                     ;VARIABLES table). Subtract one from the pointer
 4312  2EAB  07                      RLC                          ;Value and multiply the result by four using rotate left
 4313  2EAC  07                      RLC                          ;Instructions. Add this value to a base address
 4314  2EAD  C6 52                   ADI	052H                     ;(Augmented by two) to point to ARRAY VALUES
 4315  2EAF  6F                      MOV	L,A                      ;Pointer storage location in the ARRAY VARIABLES
 4316  2EB0  26 17                   MVI	H,HIGH OLDPG27           ;Table and set the pointer up in registers H & L.
 4317  2EB2  46                      MOV	B,M                      ;Fetch the starting address in the ARRAY VALUES
 4318  2EB3  C6 04                   ADI	004H                     ;Table for the previous array into register B. Now add
 4319  2EB5  6F                      MOV	L,A                      ;Four to the ARRAY VARIABLES table pointer to
 4320  2EB6  78                      MOV	A,B                      ;Point to curront ARRAY VALUES starting address.
 4321  2EB7  81                      ADD	C                        ;Add the previous array starting address plus number of
 4322  2EB8  77                      MOV	M,A                      ;Bytes required and store as starting loc for next array
 4323  2EB9  2E 84        DIM8:	MVI	L,OFS_TEMP_ARRAY                        ;Set L to address of DIMEN pointer storage location
 4324  2EBB  26 16                   MVI	H,HIGH OLDPG26           ;** Set H to page of DIMEN pointer
 4325  2EBD  46                      MOV	B,M                      ;Fetch pointer value (points to ") " in line)
 4326  2EBE  2E 83                   MVI	L,OFS_TOKEN_STORE                   ;Change L to DIM pointer storage location
 4327  2EC0  70                      MOV	M,B                      ;Store former DIMEN value back in DIM pointer
 4328  2EC1  2E 83        DIM9:	MVI	L,OFS_TOKEN_STORE                        ;Load L with address of DIM pointer storage location
 4329  2EC3  CD A0 02                CALL	GETCHR                  ;Fetch a character from the line input buffer
 4330  2EC6  FE AC                   CPI	0ACH                     ;See if character is a comma (,) sign
 4331  2EC8  CA D6 2E                JZ	DIM10                     ;If yes, have another array being defined on the line
 4332  2ECB  2E 83                   MVI	L,OFS_TOKEN_STORE                   ;If not, reset L to the DIM pointer
 4333  2ECD  CD 03 03                CALL	LOOP                    ;Increment the pointer and see if end of the line
 4334  2ED0  C2 C1 2E                JNZ	DIM9                     ;If not end of the line, keep looking for a comma
 4335  2ED3  C3 4E 0B                JMP	NXTLIN                   ;Else exit the DIM statement routine to continue pgm
 4336  2ED6  2E 83        DIM10:	MVI	L,OFS_TOKEN_STORE                       ;Set L to DIM pointer storage location
 4337  2ED8  46                      MOV	B,M                      ;Fetch pointer value (points to comma sign just found)
 4338  2ED9  2E 82                   MVI	L,OFS_SCAN_PTR                   ;Load L with address of SCAN pointer storage location
 4339  2EDB  70                      MOV	M,B                      ;Place DIM pointer into the-SCAN pointer
 4340  2EDC  C3 F5 2D                JMP	DIM                      ;Continue processing DIM statement line for next array
 4341  2EDF  3E C4        DIMERR:	MVI	A,0C4H                      ;On error condition, load ASCII code for letter D in ACC
 4342  2EE1  0E C5                   MVI	C,0C5H                   ;And ASCII code for letter E in CPU register C
 4343  2EE3  C3 96 02                JMP	ERROR                    ;Go display the Dirnension Error (DE) message.
