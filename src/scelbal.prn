  726  03C3  70           	MOV M,B                         ;Restore the updated pointer value
  727  03C4  CD F2 01     	CALL GETCHR                     ;Fetch the next character in the expression
  728  03C7  FE BD        	CPI 0BDH                        ;Is the character the "= 9 $ sign?
