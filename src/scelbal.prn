 4307  2ED6  2E 83        DIM10:	MVI	L,OFS_TOKEN_STORE                       ;Set L to DIM pointer storage location
 4308  2ED8  46                      MOV	B,M                      ;Fetch pointer value (points to comma sign just found)
 4309  2ED9  2E 82                   MVI	L,OFS_SCAN_PTR                   ;Load L with address of SCAN pointer storage location
 4310  2EDB  70                      MOV	M,B                      ;Place DIM pointer into the-SCAN pointer
 4311  2EDC  C3 F5 2D                JMP	DIM                      ;Continue processing DIM statement line for next array
