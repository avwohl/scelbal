 3623  18E0  7E           	MOV A,M                         ;Fetch the stack pointer to the ACC.
 3624  18E1  07           	RLC                             ;Rotate it left to multiply by two, then rotate it again to
 3625  18E2  07           	RLC                             ;Multiply by four for stack entry offset
 3626  18E3  C6 02        	ADI 002H                        ;Add 2 to point to variable name location in stack entry
 3627  18E5  4F           	MOV C,A                         ;Save offset in C
 3628  18E6  06 00        	MVI B,000H                      ;Clear B for 16-bit add
 3629  18E8  11 94 16     	LXI D,FN_STACK                  ;Load DE with base of FOR/NEXT STACK
 3630  18EB  79           	MOV A,C                         ;Get offset
 3631  18EC  83           	ADD E                           ;Add to low byte of base
 3632  18ED  5F           	MOV E,A                         ;Result in E
 3633  18EE  78           	MOV A,B                         ;Get 0
 3634  18EF  8A           	ADC D                           ;Add carry to high byte
 3635  18F0  57           	MOV D,A                         ;Result in D (DE now points to stack location)
