 2971  1394  3E 17        	MVI A,017H                      ;Possible. Point to FPACC Exponent. Put 23 decimal in
 2972  1396  46           	MOV B,M                         ;Accumulator. Fetch FPACC Exponent into register B
 2973  1397  04           	INR B                           ;And exercise the register to test its
