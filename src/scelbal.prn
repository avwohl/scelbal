 2909                                                       ;right subroutine. Opposite of
 2910                                                       ;above subroutine.
 2911                     
 2912  1289  A7           ROTATR:	ANA	A                           ;Clear the carry bit at this entry point
 2913  128A  7E           ROTR:	MOV	A,M                           ;Fetch a byte from memory
