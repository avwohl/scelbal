 2844  12BF  21 3D 00     	LXI H,FP_WORK_6F                ;Set pointer to input exponent storage location
 2845  12C2  3E 03        	MVI A,003H                      ;Set accumulator equal to three
 2846  12C4  BE           	CMP M                           ;See if any previous digit in exponent greater than three
 2847  12C5  FA C5 09     	JM NUMERR                       ;Display error message if yes
 2848  12C8  4E           	MOV C,M                         ;Else save any previous value in register C
 2849  12C9  7E           	MOV A,M                         ;And also place any previous value in accumulator
 2850  12CA  A7           	ANA A                           ;Clear the carry bit with this instruction
 2851  12CB  17           	RAL                             ;Single precision multiply by ten algorithm
 2852  12CC  17           	RAL                             ;Two rotate lefts equals times four
