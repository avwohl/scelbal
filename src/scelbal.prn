 2865  12E4  21 39 00     FININP:	LXI H,FP_WORK_6B                ;Set pointer to input storage LS~V minus one
 2866  12E7  AF           	XRA A                           ;Clear the accumulator
 2867  12E8  77           	MOV M,A                         ;Clear the LSW minus one location
 2868  12E9  54           	MOV D,H                         ;Set register D to floating point working page
 2869  12EA  11 1E 00     	LXI D,FPACC_LSW_M1              ;Set E to address of FPACC LSW minus one
