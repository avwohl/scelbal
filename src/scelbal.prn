  995  05B4  CA C7 05                JZ	PARSE1                    ;OUT value. If heirarchy of current operator equal to or
  996  05B7  FA C7 05                JM	PARSE1                    ;Less than operator on top of OS stack, perfo
  997  05BA  2E 7E                   MVI	L,OFS_PARSER_TOKEN                   ;Operation indicated in top of OS stack. Else, fetch the
  998  05BC  46                      MOV	B,M                      ;Current operator token value into register B.
