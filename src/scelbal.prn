 3357  1525  2E 77        OUTDGS:	MVI	L,OFS_FP_WORK_77                      ;Reset pointer to working register MSW+L
 3358  1527  7E                      MOV	A,M                      ;Fetch BCD of digit to be outputted
 3359  1528  A7                      ANA	A                        ;Exercise CPU flags
