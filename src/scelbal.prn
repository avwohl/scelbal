 3001  12E7  56                      MOV	D,M                      ;Fetch stored value for T.)
 3002  12E8  2C                      INR	L                        ;Advance pointer
 3003  12E9  5E                      MOV	E,M                      ;Fetch stored value for
 3004  12EA  67                      MOV	H,A                      ;Restore  saved value for H
 3005  12EB  68                      MOV	L,B                      ;Restore saved value for L
 3006  12EC  7E                      MOV	A,M                      ;Leave stored value for E in ACC
 3007  12ED  C9                      RET                          ;Exit to calling routine
