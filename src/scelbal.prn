 2476  1070  46                      MOV	B,M                      ;The value of the Exponent and decrement it by one
 2477  1071  05                      DCR	B                        ;To compensate for the rotate left of the mantissa
 2478  1072  70                      MOV	M,B                      ;Restore the new value of the Exponent
 2479  1073  C3 63 10                JMP	ACNONZ                   ;Continue rotating ops to normalize the FPACC
 2480  1076  2E 56        ACCSET:	MVI	L,OFS_FPACC_MSW                      ;Set pntr to FPACC MSW. Now must provide room for
 2481  1078  06 03                   MVI	B,003H                   ;Sign bit in nonnalized FPACC. Set precision counter.
 2482  107A  CD 89 12                CALL	ROTATR                  ;Rotate the FPACC once to the right now.
 2483  107D  2E 40        RESIGN:	MVI	L,OFS_SIGN_IND1                      ;Set the pointer to SIGN indicator storage location
 2484  107F  7E                      MOV	A,M                      ;Fetch the original sign of the FPACC
 2485  1080  A7                      ANA	A                        ;Set CPU flags
 2486  1081  F0                      RP                           ;If original sign of FPACC was positive, can exit now.
 2487                     
 2488  1082  2E 54        FPCOMP:	MVI	L,OFS_FPACC                      ; However, if original sign was negative, must now restore
 2489  1084  06 03                   MVI	B,003H                   ;The FPACC to negative by performing two's comple-
 2490  1086  C3 68 12                JMP	COMPLM                   ;Ment on FPACC. Return to caring rtn via COMPLM.
 2491                     
 2492                                                       ;Floating point ADDITION. Adds contents of FPACC to
 2493                                                       ;FPOP and leaves result in FPACC. Routine first checks
 2494                                                       ;to see if either register contains zero. If so addition
 2495                                                       ;result is already present!
 2496                     
 2497  1089  2E 56        FPADD:	MVI	L,OFS_FPACC_MSW                       ;Set L to point to MSW of FPACC
 2498  108B  26 01                   MVI	H,HIGH OLDPG1            ;** Do same for register H
 2499  108D  7E                      MOV	A,M                      ;Fetch MSW of FPACC to accumulator
 2500  108E  A7                      ANA	A                        ;Set CPU flags after loading op
 2501  108F  C2 9D 10                JNZ	NONZAC                   ;If accumulator non-zero then FPACC has some value
 2502  1092  2E 54        MOVOP:	MVI	L,OFS_FPACC                       ;But, if accumulator was zero then normalized FPACC
 2503  1094  54                      MOV	D,H                      ;Must also be zero. Thus answer to addition is simply the
 2504  1095  5D                      MOV	E,L                      ;Value in FPOP. Set up pointers to transfer contents of
 2505  1096  2E 5C                   MVI	L,OFS_FPOP                   ;FPOP to FPACC by pointing to the LSW of both
 2506  1098  06 04                   MVI	B,004H                   ;Registers and perform the transfer. Then exit to calling
 2507  109A  C3 0B 11                JMP	MOVEIT                   ;Routine with answer in FPACC via MOVEIT.
 2508  109D  2E 5E        NONZAC:	MVI	L,OFS_FPOP_MSW                      ;If FPACC was non-zero then check to see if FPOP has
 2509  109F  7E                      MOV	A,M                      ;Some value by obtaining MSW of FPOP
 2510  10A0  A7                      ANA	A                        ;Set CPU flags after loading op. If MSW zero then
 2511  10A1  C8                      RZ                           ;Normalized FPOP must be zero. Answer is in FPACC!
 2512                     
 2513                                                       ;If neither FPACC or FPOP was zero then must perform
 2514                                                       ;addition operation. Must first check to see if two num-
 2515                                                       ;bers are within significant mnge. If not, largest number
 2516                                                       ;is answer. If numbers within range, then must align ex-
 2517                                                       ;ponents before perforrning the addition of the man-
 2518                                                       ;tissa.
 2519                     
 2520  10A2  2E 57        CKEQEX:	MVI	L,OFS_FPACC_EXP                      ;Set pointer to FPACC Exponent storage location.
 2521  10A4  7E                      MOV	A,M                      ;Fetch the Exponent value to the accumulator.
 2522  10A5  2E 5F                   MVI	L,OFS_FPOP_EXP                   ;Change the pointer to the FPOP Exponent
 2523  10A7  BE                      CMP	M                        ;Compare the values of the exponents. If they are the
 2524  10A8  CA E1 10                JZ	SHACOP                    ;Same then can immediately proceed to add operations.
 2525  10AB  47                      MOV	B,A                      ;If not the same, store FPACC Exponent size in regis B
 2526  10AC  7E                      MOV	A,M                      ;Fetch the FPOP Exponent size into the ACC
 2527  10AD  98                      SBB	B                        ;Subtract the FPACC Exponent from the FPOP Exp.
 2528  10AE  F2 B4 10                JP	SKPNEG                    ;If result is positive jump over the next few instructions
 2529  10B1  47                      MOV	B,A                      ;If result was negative, store the result in B
 2530  10B2  AF                      XRA	A                        ;Clear the accumulator
 2531  10B3  98                      SBB	B                        ;Subtract register B to negate the original value
 2532  10B4  FE 18        SKPNEG:	CPI	018H                        ;See if difference is less than 24 decimal.
 2533  10B6  FA C3 10                JM	LINEUP                    ;If so, can align exponents. Go do it.
 2534  10B9  7E                      MOV	A,M                      ;If not, find out which number is largest. Fetch FPOP
 2535  10BA  2E 57                   MVI	L,OFS_FPACC_EXP                   ;Exponent into ACC. Change pointer to FPACC Exp.
 2536  10BC  96                      SUB	M                        ;Subtract FPACC from FPOP. If result is negative then
 2537  10BD  F8                      RM                           ;was larger. Return with answer in FPACC.
 2538  10BE  2E 54                   MVI	L,OFS_FPACC                   ;If result was positive, larger value in FPOP. Set pointers
 2539  10C0  C3 92 10                JMP	MOVOP                    ;To transfer FPOP into FPACC and then exit to caller.
 2540  10C3  7E           LINEUP:	MOV	A,M                         ;Fetch FPOP Exponent into accumulator.
 2541  10C4  2E 57                   MVI	L,OFS_FPACC_EXP                   ;Change pointer to FPACC Exponent.
 2542  10C6  96                      SUB	M                        ;Subtract FPACC Exponent from FPOP Exponent. If
 2543  10C7  FA D7 10                JM	SHIFT0                    ;Result is negative FPACC is larger. Go shift FPOP.
 2544  10CA  4F                      MOV	C,A                      ;If result positive FPOP larger, must shift FPACC. Store
 2545  10CB  2E 57        MORACC:	MVI	L,OFS_FPACC_EXP                      ;Difference count in C. Reset pointer to FPACC Exp
 2546  10CD  CD FC 10                CALL	SHLOOP                  ;Call the SHift LOOP to rotate FPACC mantissa RIGHT
 2547  10D0  0D                      DCR	C                        ;And INCREMENT Exponent. Decr difference counter
 2548  10D1  C2 CB 10                JNZ	MORACC                   ;Continue rotate operations until diff counter is zero
 2549  10D4  C3 E1 10                JMP	SHACOP                   ;Go do final alignment and perform addition process
 2550  10D7  4F           SHIFT0:	MOV	C,A                         ;Routine to shift FPOP. Set difference count into reg. C
 2551  10D8  2E 5F        MOROP:	MVI	L,OFS_FPOP_EXP                       ;Set pointer to FPOP Exponent.
 2552  10DA  CD FC 10                CALL	SHLOOP                  ;Call the SHift LOOP to rotate FPOP mantissa RIGHT
 2553  10DD  0C                      INR	C                        ;And INCREMENT Exponent. Then incr difference cntr
 2554  10DE  C2 D8 10                JNZ	MOROP                    ;Continue rotate opemtions until diff counter is zero
 2555                     ;;; The below two instructions are changed by PATCH NR.1
 2556                     ;;;SHACOP:    LLI 123                ;Set pointer to FPACC LSW minus one to provide extra
 2557                     ;;;           LMI 000                ;Byte for addition ops. Clear that location to zero.
 2558  10E1  CD 00 18     SHACOP:	CALL	PATCH1                     ; patch 1 inserts a few lines at 30-000
 2559  10E4  7F           	   MOV	A,A
 2560                     	
 2561                     ;;;           LLI 133
 2562                     ;;;           LMI 000                ;THIS IS PATCH #1
 2563  10E5  2E 57                   MVI	L,OFS_FPACC_EXP                   ;Change pointer to FPACC Exponent
 2564  10E7  CD FC 10                CALL	SHLOOP                  ;Rotate FPACC mantissa RIGHT & Increment Exponent
 2565  10EA  2E 5F                   MVI	L,OFS_FPOP_EXP                   ;Change pointer to FPOP Exponent
 2566  10EC  CD FC 10                CALL	SHLOOP                  ;Rotate FPOP mantissa RIGHT & Increment Exponent
 2567  10EF  54                      MOV	D,H                      ;Rotate ops provide room for overflow. Now set up
 2568  10F0  1E 53                   MVI	E,OFS_FPACC_LSW_M1                   ;Pointers to LSW minus one for both FPACC & FPOP
 2569  10F2  06 04                   MVI	B,004H                   ;(FPOP already set after SHLOOP). Set precision counter
 2570  10F4  CD 57 12                CALL	ADDER                   ;Call quad precision ADDITION subroutine.
 2571  10F7  06 00                   MVI	B,000H                   ;Set CPU register B to indicate standard normalization
 2572  10F9  C3 36 10                JMP	FPNORM                   ;Go normalize the result and exit to caller.
 2573  10FC  46           SHLOOP:	MOV	B,M                         ;Shifting loop. First fetch Exponent currently being
 2574  10FD  04                      INR	B                        ;Pointed to and Increment the value by one.
 2575  10FE  70                      MOV	M,B                      ;Return the updated Exponent value to memory.
 2576  10FF  2D                      DCR	L                        ;Decrement the pointer to mantissa portion MSW
 2577  1100  06 04                   MVI	B,004H                   ;Set precision counter
 2578  1102  7E           FSHIFT:	MOV	A,M                         ;Fetch MSW of mantissa
 2579  1103  A7                      ANA	A                        ;Set CPU flags after load ops
 2580  1104  F2 89 12                JP	ROTATR                    ;If MSB not a one can do normal rotate ops
 2581  1107  17           BRING1:	RAL                             ;If MSB is a one need to set up carrv bit for the negative
 2582  1108  C3 8A 12                JMP	ROTR                     ;Number case. Then make special entry to ROTATR sub
 2583                     
 2584                                                       ;The following subroutine moves the contents of a string
 2585                                                       ;of memory locations from the address pointed to by
 2586                                                       ;CPU registers H & L to the address specified by the con-
 2587                                                       ;tents of registers D & E when the routine is entered. The
 2588                                                       ;process continues until the counter in register B is zero.
 2589                     
 2590  110B  7E           MOVEIT:	MOV	A,M                         ;Fetch a word from memory string A
 2591  110C  2C                      INR	L                        ;Advance A string pointer
 2592  110D  CD EE 12                CALL	SWITCH                  ;Switch pointer to string B
 2593  1110  77                      MOV	M,A                      ;Put word from string A into string B
 2594  1111  2C                      INR	L                        ;Advance B string pointer
 2595  1112  CD EE 12                CALL	SWITCH                  ;Switch pointer back to string A
 2596  1115  05                      DCR	B                        ;Decrement loop counter
 2597  1116  C8                      RZ                           ;Return to calling routine when counter reaches zero
 2598  1117  C3 0B 11                JMP	MOVEIT                   ;Else continue transfer operations
 2599                     
 2600                                                       ;The following subroutine SUBTRACTS the
 2601                                                       ;contents of the FLOATING POINT ACCUMULATOR from the
 2602                                                       ;contents of the FLOATING POINT OPERAND and
 2603                                                       ;leaves the result in the FPACC. The routine merely
 2604                                                       ;negates the value in the FPACC and then goes to the
 2605                                                       ;FPADD subroutine just presented.
 2606                     
 2607  111A  2E 54        FPSUB:	MVI	L,OFS_FPACC                       ;Set L to address of LSW of FPACC
 2608  111C  26 01                   MVI	H,HIGH OLDPG1            ;** Set H to page of FPACC
 2609  111E  06 03                   MVI	B,003H                   ;Set precision counter
 2610  1120  CD 68 12                CALL	COMPLM                  ;Two's complement the value in the FPACC
 2611  1123  C3 89 10                JMP	FPADD                    ;Now go add the negated value to perform subtraction!
 2612                     
 2613                                                       ;The first part of the FLOATING POINT MULTIPLI-
 2614                                                       ;CATION subroutine calls a subroutine to check the
 2615                                                       ;original signs of the numbers that are to be multi-
 2616                                                       ;plied and perform working register clearing functions.
 2617                                                       ;Next the exponents of the numbers to be multiplied
 2618                                                       ;are added together.
 2619                     
 2620  1126  CD 76 11     FPMULT:	CALL	CKSIGN                     ;Call routine to set up registers & ck signs of numbers
 2621  1129  2E 5F        ADDEXP:	MVI	L,OFS_FPOP_EXP                      ;Set pointer to FPOP Exponent
 2622  112B  7E                      MOV	A,M                      ;Fetch FPOP Exponent into the accumulator
 2623  112C  2E 57                   MVI	L,OFS_FPACC_EXP                   ;Change pointer to FPACC Exponent
 2624  112E  86                      ADD	M                        ;Add FPACC Exponent to FPOP Exponent
 2625  112F  C6 01                   ADI	001H                     ;Add one more to total for algorithm compensation
 2626  1131  77                      MOV	M,A                      ;Store result in FPACC Exponent location
 2627  1132  2E 42        SETMCT:	MVI	L,OFS_BITS_COUNTER                      ;Change pointer to bit counter storage location
 2628  1134  36 17                   MVI	M,017H                   ;Initialize bit counter to 23 decimal
 2629                     
 2630                                                       ;Next portion of the FPMULT routine is the iinplernen-
 2631                                                       ;tation of the algorithm illustrated in the flow chart
 2632                                                       ;above. This portion multiplies the values of the two
 2633                                                       ;mantissas. The final value is rounded off to leave the
 2634                                                       ;23 most significant bits as the answer that is stored
 2635                                                       ;back in the FPACC.
 2636                     
 2637  1136  2E 56        MULTIP:	MVI	L,OFS_FPACC_MSW                      ;Set pointer to MSW of FPACC mantissa
 2638  1138  06 03                   MVI	B,003H                   ;Set precision counter
 2639  113A  CD 89 12                CALL	ROTATR                  ;Rotate FPACC (multiplier) RIGHT into carry bit
 2640  113D  DC B8 11                CC	ADOPPP                    ;If carry is a one, add multiplicand to partial-product
 2641  1140  2E 66                   MVI	L,OFS_FP_WORK_66                   ;Set pointer to partial-product most significant byte
 2642  1142  06 06                   MVI	B,006H                   ;Set precision counter (p-p register is double length)
 2643  1144  CD 89 12                CALL	ROTATR                  ;Shift partial-product RIGHT
 2644  1147  2E 42                   MVI	L,OFS_BITS_COUNTER                   ;Set pointer to bit counter storage location
 2645  1149  4E                      MOV	C,M                      ;Fetch current value of bit counter
 2646  114A  0D                      DCR	C                        ;Decrement the value of the bit counter
 2647  114B  71                      MOV	M,C                      ;Restore the updated bit counter to its storage location
 2648  114C  C2 36 11                JNZ	MULTIP                   ;If have not multiplied for 23 (deciinal) bits, keep going
 2649  114F  2E 66                   MVI	L,OFS_FP_WORK_66                   ;If have done 23 (decimal) bits, set pntr to p-p MSW
 2650  1151  06 06                   MVI	B,006H                   ;Set precision counter (for double length)
 2651  1153  CD 89 12                CALL	ROTATR                  ;Shift partial-product once more to the RIGHT
 2652  1156  2E 63                   MVI	L,OFS_FP_WORK_63                   ;Set pointer to access 24'th bit in partial-product
 2653  1158  7E                      MOV	A,M                      ;Fetch the byte containing the 24'th bit
 2654  1159  17                      RAL                          ;Position the 24'th bit to be MSB in the accumulator
 2655  115A  A7                      ANA	A                        ;Set the CPU flags after to rotate operation and test to
 2656  115B  FC C2 11                CM	MROUND                    ;See if 24'th bit of p-p is a ONE. If so, must round-off
 2657  115E  2E 53                   MVI	L,OFS_SYMBOL_BUF+3                   ;Now set up pointers
 2658  1160  5D                      MOV	E,L                      ;To perform transfer
 2659  1161  54                      MOV	D,H                      ;Of the multiplication results
 2660  1162  2E 63                   MVI	L,OFS_FP_WORK_63                   ;From the partial-product location
 2661  1164  06 04                   MVI	B,004H                   ;To the FPACC
 2662                     
 2663                     	
 2664  1166  CD 0B 11     EXMLDV:	CALL	MOVEIT                     ;Perform the transfer from p-p to FPACC
 2665  1169  06 00                   MVI	B,000H                   ;Set up CPU register B to indicate regular normalization
 2666  116B  CD 36 10                CALL	FPNORM                  ;Normalize the result of multiplication
 2667  116E  2E 41                   MVI	L,OFS_SIGN_IND1+1                   ;Now set the pointer to the original SIGNS indicator
 2668  1170  7E                      MOV	A,M                      ;Fetch the indicator
 2669  1171  A7                      ANA	A                        ;Exercise the CPU flags
 2670  1172  C0                      RNZ                          ;If indicator is non-zero, answer is positive, can exit her
 2671  1173  C3 82 10                JMP	FPCOMP                   ;If not, answer must be negated, exit via 2's complement.
 2672                     
 2673                                                       ;The following portions of the FPMULT
 2674                                                       ;routine set up working locations in memory by clearing
 2675                                                       ;locations for an expanded FPOP area and the partial-produc
 2676                                                       ;area. Next, the signs of the two numbers to be multiplied
 2677                                                       ;are examined. Negative numbers are negated
 2678                                                       ;in preparation for the multiplication
 2679                                                       ;algorithm. A SIGNS indicator register is set up during
 2680                                                       ;this process to indicate whether the final result of the
 2681                                                       ;multiplication should be positive or negative. (Negative
 2682                                                       ;if original signs of the two numbers to be multiplied are
 2683                                                       ;different.)
 2684                     
 2685  1176  2E 60        CKSIGN:	MVI	L,OFS_FP_WORK                      ;Set pointer to start of partial-product working area
 2686  1178  26 01                   MVI	H,HIGH OLDPG1            ;** Set H to proper page
 2687  117A  06 08                   MVI	B,008H                   ;Set up a loop counter in CPU register B
 2688  117C  AF                      XRA	A                        ;Clear the accumulator
 2689                     
 2690  117D  77           CLRNEX:	MOV	M,A                         ;Now clear out locations for the partial-product
 2691  117E  2C                      INR	L                        ;Working registers
 2692  117F  05                      DCR	B                        ;Until the loop counter
 2693  1180  C2 7D 11                JNZ	CLRNEX                   ;Is zero
 2694  1183  06 04        CLROPL:	MVI	B,004H                      ;Set a loop counter
 2695  1185  2E 58                   MVI	L,OFS_FPOP_EXT                   ;Set up pointer
 2696  1187  77           CLRNX1:	MOV	M,A                         ;Clear out some extra registers so that the
 2697  1188  2C                      INR	L                        ;FPOP may be extended in length
 2698  1189  05                      DCR	B                        ;Perform clearing ops until loop counter
 2699  118A  C2 87 11                JNZ	CLRNX1                   ;Is zero
 2700  118D  2E 41                   MVI	L,OFS_SIGN_IND1+1                   ;Set pointer to M/D SIGNS indicator storage location
 2701  118F  36 01                   MVI	M,001H                   ;Set initial value of SIGNS indicator to plus one
 2702  1191  2E 56                   MVI	L,OFS_FPACC_MSW                   ;Change pointer to MSW of FPACC
 2703  1193  7E                      MOV	A,M                      ;Fetch MSW of mantissa into accumulator
 2704  1194  A7                      ANA	A                        ;Test flags
 2705  1195  FA A9 11                JM	NEGFPA                    ;If MSB in MSW of FPACC is a one, number is negative
 2706  1198  2E 5E        OPSGNT:	MVI	L,OFS_FPOP_MSW                      ;Set pointer to MSW of FPOP
 2707  119A  7E                      MOV	A,M                      ;Fetch MSW of mantissa into accumulator
 2708  119B  A7                      ANA	A                        ;Test flags
 2709  119C  F0                      RP                           ;Return to caller if number in FPOP is positive
 2710  119D  2E 41                   MVI	L,OFS_SIGN_IND1+1                   ;Else change pointer to M/D SIGNS indicator
 2711  119F  4E                      MOV	C,M                      ;Fetch the value in the SIGNS indicator
 2712  11A0  0D                      DCR	C                        ;Decrement the value by one
 2713  11A1  71                      MOV	M,C                      ;Restore the new value back to storage location
 2714  11A2  2E 5C                   MVI	L,OFS_FPOP                   ;Set pointer to LSW of FPOP
 2715  11A4  06 03                   MVI	B,003H                   ;Set precision counter
 2716  11A6  C3 68 12                JMP	COMPLM                   ;Two's complement value of FPOP & return to caller
 2717  11A9  2E 41        NEGFPA:	MVI	L,OFS_SIGN_IND1+1                      ;Set pointer to M/D SIGNS indicator
 2718  11AB  4E                      MOV	C,M                      ;Fetch the value in the SIGNS indicator
 2719  11AC  0D                      DCR	C                        ;Decrement the value by one
 2720  11AD  71                      MOV	M,C                      ;Restore the new value back to storage location
 2721  11AE  2E 54                   MVI	L,OFS_FPACC                   ;Set pointer to LSW of FPACC
 2722  11B0  06 03                   MVI	B,003H                   ;Set precision counter
 2723  11B2  CD 68 12                CALL	COMPLM                  ;Two's complement value of FPACC
 2724  11B5  C3 98 11                JMP	OPSGNT                   ;Proceed to check sign of FPOP
 2725                     
 2726                                                       ;The following subroutine adds the double length (six regis
 2727                                                       ;multiplicand in FPOP to the partial-product register when
 2728                                                       ;called on by the multiplication algorithm.
 2729                     
 2730  11B8  1E 61        ADOPPP:	MVI	E,OFS_FP_WORK_61                      ;Pointer to LSW of partial-product
 2731  11BA  54                      MOV	D,H                      ;On same page as FPOP
 2732  11BB  2E 59                   MVI	L,OFS_FPOP_EXT+1                   ;LSIV of FPOP which contains extended multiplicand
 2733  11BD  06 06                   MVI	B,006H                   ;Set precision counter (double length working registers)
 2734  11BF  C3 57 12                JMP	ADDER                    ;Add multiplicand to partial-product & return to caller
 2735                     
 2736  11C2  06 03        MROUND:	MVI	B,003H                      ;Set up precision counter
 2737  11C4  3E 40                   MVI	A,040H                   ;Prepare to add one to 24'th bit of partial-product
 2738  11C6  86                      ADD	M                        ;Add one to the 24'th bit of the partial-product
 2739  11C7  77           CROUND:	MOV	M,A                         ;Restore the updated byte to memory
 2740  11C8  2C                      INR	L                        ;Advance the memory pointer to next most significant
 2741  11C9  3E 00                   MVI	A,000H                   ;Byte of partial-product, then clear ACC without
 2742  11CB  8E                      ADC	M                        ;Disturbing carry bit. Now perform add with carry to
 2743  11CC  05                      DCR	B                        ;Propagate any rounding in the partial-product registers.
 2744  11CD  C2 C7 11                JNZ	CROUND                   ;If cotinter is not zero continue propagating any carry
 2745  11D0  77                      MOV	M,A                      ;Restore final byte to memory
 2746  11D1  C9                      RET                          ;Exit to calling routine
 2747                     
 2748  11D2  CD 76 11     FPDIV:	CALL	CKSIGN                      ;Call routine to set up registers & ck signs of numbers
 2749  11D5  2E 56                   MVI	L,OFS_FPACC_MSW                   ;Set pointer to MSW of FPACC (divisor)
 2750  11D7  7E                      MOV	A,M                      ;Fetch MSW of FPACC to accumulator
 2751  11D8  A7                      ANA	A                        ;Exercise CPU flags
 2752  11D9  CA EF 0A                JZ	DVERR                     ;If MSW of FPACC is zero go display 'DZ' error message
 2753  11DC  2E 5F        SUBEXP:	MVI	L,OFS_FPOP_EXP                      ;Set pointer to FPOP (dividend) Exponent
 2754  11DE  7E                      MOV	A,M                      ;Get FPOP Exponent into accumulator
 2755  11DF  2E 57                   MVI	L,OFS_FPACC_EXP                   ;Change pointer to FPACC (divisor) Exponent
 2756  11E1  96                      SUB	M                        ;Subtract divisor exponent from dividend exponent
 2757  11E2  C6 01                   ADI	001H                     ;Add one for algorithm compensation
 2758  11E4  77                      MOV	M,A                      ;Place result in FPACC Exponent
 2759  11E5  2E 42        SETDCT:	MVI	L,OFS_BITS_COUNTER                      ;Set pointer to bit counter storage location
 2760  11E7  36 17                   MVI	M,017H                   ;Initialize bit counter to 23 decimal
 2761                     
 2762                                                       ;Main division algorithm for mantissas
 2763                     
 2764  11E9  CD 41 12     DIVIDE:	CALL	SETSUB                     ;Go subtmct divisor from dividend
 2765  11EC  FA FE 11                JM	NOGO                      ;If result is negative then place a zero bit in quotient
 2766  11EF  1E 5C                   MVI	E,OFS_FPOP                   ;If result zero or positive then move remainder after
 2767  11F1  2E 59                   MVI	L,OFS_FPOP_EXT+1                   ;Subtraction from working area to become new dividend
 2768  11F3  06 03                   MVI	B,003H                   ;Set up moving pointers and initialize precision counter
 2769  11F5  CD 0B 11                CALL	MOVEIT                  ;Perform the transfer
 2770  11F8  3E 01                   MVI	A,001H                   ;Place a one into least significant bit of accumulator
 2771  11FA  1F                      RAR                          ;And rotate it out into the carry bit
 2772  11FB  C3 FF 11                JMP	QUOROT                   ;Proceed to rotate the carry bit into the current quotient
 2773  11FE  AF           NOGO:	XRA	A                             ;When result is negative, put a zero in the carry bit, then
 2774  11FF  2E 64        QUOROT:	MVI	L,OFS_FP_WORK+4                      ;Set up pointer to LSW of quotient register
 2775  1201  06 03                   MVI	B,003H                   ;Set precision counter
 2776  1203  CD 80 12                CALL	ROTL                    ;Rotate carry bit into quotient by using special entry to
 2777  1206  2E 5C                   MVI	L,OFS_FPOP                   ;ROTATL subroutine. Now set up pointer to dividend
 2778  1208  06 03                   MVI	B,003H                   ;LSW and set precision counter
 2779  120A  CD 7F 12                CALL	ROTATL                  ;Rotate the current dividend to the left
 2780  120D  2E 42                   MVI	L,OFS_BITS_COUNTER                   ;Set pointer to bit counter storage location
 2781  120F  4E                      MOV	C,M                      ;Fetch the value of the bit counter
 2782  1210  0D                      DCR	C                        ;Decrement the value by one
 2783  1211  71                      MOV	M,C                      ;Restore the new counter value to storage
 2784  1212  C2 E9 11                JNZ	DIVIDE                   ;If bit counter is not zero, continue division process
 2785  1215  CD 41 12                CALL	SETSUB                  ;After 23 (decimal) bits, do subtraction once more for
 2786  1218  FA 38 12                JM	DVEXIT                    ;Possible rounding. Jump ahead if no rounding required.
 2787  121B  2E 64                   MVI	L,OFS_FP_WORK+4                   ;If rounding required set pointer to LSW of quotient
 2788  121D  7E                      MOV	A,M                      ;Fetch LSW of quotient to accumulator
 2789  121E  C6 01                   ADI	001H                     ;Add one to 23rd bit of quotient
 2790  1220  77                      MOV	M,A                      ;Restore updated LSW of quotient
 2791  1221  3E 00                   MVI	A,000H                   ;Clear accumulator without disturbing carry bit
 2792  1223  2C                      INR	L                        ;Advance pointer to next significant byte of quotient
 2793  1224  8E                      ADC	M                        ;Propagate any carry as part of rounding process
 2794  1225  77                      MOV	M,A                      ;Restore the updated byte of quotient
 2795  1226  3E 00                   MVI	A,000H                   ;Clear ACC again without disturbing carry bit
 2796  1228  2C                      INR	L                        ;Advance pointer to MSW of quotient
 2797  1229  8E                      ADC	M                        ;Propagate any carry to finish rounding process
 2798  122A  77                      MOV	M,A                      ;Restore the updated byte of quotient
 2799  122B  F2 38 12                JP	DVEXIT                    ;If most significant bit of quotient is zero, go finish up
 2800  122E  06 03                   MVI	B,003H                   ;If not, set precision counter
 2801  1230  CD 89 12                CALL	ROTATR                  ;And rotate quotient to the right to clear the sign bit
 2802  1233  2E 57                   MVI	L,OFS_FPACC_EXP                   ;Set pointer to FPACC Exponent
 2803  1235  46                      MOV	B,M                      ;Fetch FPACC exponent
 2804  1236  04                      INR	B                        ;Increment the value to compensate for the rotate right
 2805  1237  70                      MOV	M,B                      ;Restore the updated exponent value
 2806  1238  2E 63        DVEXIT:	MVI	L,OFS_FP_WORK_63                      ;Set up pointers
 2807  123A  1E 53                   MVI	E,OFS_FPACC_LSW_M1                   ;To transfer the quotient into the FPACC
 2808  123C  06 04                   MVI	B,004H                   ;Set precision counter
 2809                                                       ;THIS IS A CORRECTION FOUND IN THE NOTES
 2810  123E  C3 66 11                JMP	EXMLDV                   ;And exit through FPMULT routine at EXMLDV
 2811                     
 2812                                                       ;Subroutine to subtract divisor from dividend. Used by
 2813                                                       ;main DIVIDE subroutine.
 2814                     
 2815  1241  1E 59        SETSUB:	MVI	E,OFS_FPOP_EXT_59                      ;Set pointer to LSW of working area
 2816  1243  54                      MOV	D,H                      ;On same page as FPACC
 2817  1244  2E 54                   MVI	L,OFS_FPACC                   ;Set pointer to LSW of FPACC (divisor)
 2818  1246  06 03                   MVI	B,003H                   ;Set precision counter
 2819  1248  CD 0B 11                CALL	MOVEIT                  ;Perform transfer
 2820  124B  1E 59                   MVI	E,OFS_FPOP_EXT_59                   ;Reset pointer to LSW of working area (now divisor)
 2821  124D  2E 5C                   MVI	L,OFS_FPOP                   ;Reset pointer to LSW of FPOP (dividend)
 2822  124F  06 03                   MVI	B,003H                   ;Set precision counter
 2823  1251  CD 93 12                CALL	SUBBER                  ;Subtract divisor from dividend
 2824  1254  7E                      MOV	A,M                      ;Get MSW of the result of the subtraction operations
 2825  1255  A7                      ANA	A                        ;Exercise CPU flags
 2826  1256  C9                      RET                          ;Return to caller with status
 2827  1257  A7           ADDER:	ANA	A                            ;Initialize the carry bit to zero upon entry
 2828  1258  7E           ADDMOR:	MOV	A,M                         ;Fetch byte from register group A
 2829  1259  CD EE 12                CALL	SWITCH                  ;Switch memory pointer to register group B
 2830  125C  8E                      ADC	M                        ;Add byte from A to byte from B with carry
 2831  125D  77                      MOV	M,A                      ;Leave result in register group B
 2832  125E  05                      DCR	B                        ;Decrement number of bytes (precision) counter
 2833  125F  C8                      RZ                           ;Return to caller when all bytes in group processed
 2834  1260  2C                      INR	L                        ;Else advance pointer for register group B
 2835  1261  CD EE 12                CALL	SWITCH                  ;Switch memory pointer back to register group A
 2836  1264  2C                      INR	L                        ;Advance the pointer for register group A
 2837  1265  C3 58 12                JMP	ADDMOR                   ;Continue the multi-byte addition operation
 2838                     
 2839                                                       ;N'th precision two's complement (negate)
 2840                                                       ;subroutine. Performs a two's complement on the multi-byte
 2841                                                       ;registers tarting at the address pointed
 2842                                                       ; to by H & L (least significant byte) upon entry.
 2843                     
 2844  1268  7E           COMPLM:	MOV	A,M                         ;Fetch the least significant byte of the number to ACC
 2845  1269  EE FF                   XRI	0FFH                     ;Exclusive OR to complement the byte
 2846  126B  C6 01                   ADI	001H                     ;Add one to form two's complement of byte
 2847  126D  77           MORCOM:	MOV	M,A                         ;Restore the negated byte to memory
 2848  126E  1F                      RAR                          ;Save the carry bit
 2849  126F  57                      MOV	D,A                      ;In CPU register D
 2850  1270  05                      DCR	B                        ;Decrement number of bytes (precision) counter
 2851  1271  C8                      RZ                           ;Return to caller when all bytes in number processed
 2852  1272  2C                      INR	L                        ;Else advance the pointer
 2853  1273  7E                      MOV	A,M                      ;Fetch the next byte of the number to ACC
 2854  1274  EE FF                   XRI	0FFH                     ;Exclusive OR to complement the byte
 2855  1276  5F                      MOV	E,A                      ;Save complemented value in register E temporarily
 2856  1277  7A                      MOV	A,D                      ;Restore previous carry status to ACC
 2857  1278  17                      RAL                          ;And rotate it out to the carry bit
 2858  1279  3E 00                   MVI	A,000H                   ;Clear ACC without disturbing carry status
 2859  127B  8B                      ADC	E                        ;Add in any carry to complemented value
 2860  127C  C3 6D 12                JMP	MORCOM                   ;Continue the two's complement procedure as req'd
 2861                     
 2862                                                       ;N'th precision rotate left subroutine. Rotates a multi-
 2863                                                       ;byte number left starting at the address initially
 2864                                                       ;specified by the contents of CPU registers H & L upon
 2865                                                       ;subroutine entry (LSW). First entry point will clear
 2866                                                       ;the carry bit before beginning rotate operations. Second
 2867                                                       ;entry point does not clear the carry bit.
 2868                     
 2869  127F  A7           ROTATL:	ANA	A                           ;Clear the carry bit at this entry point
 2870  1280  7E           ROTL:	MOV	A,M                           ;Fetch a byte from memory
 2871  1281  17                      RAL                          ;Rotate it left (bring carry into LSB, push MSB to carry)
 2872  1282  77                      MOV	M,A                      ;Restore rotated word to memory
 2873  1283  05                      DCR	B                        ;Decrement precision counter
 2874  1284  C8                      RZ                           ;Exit to caller when finished
 2875  1285  2C                      INR	L                        ;Else advance pointer to next byte
 2876  1286  C3 80 12                JMP	ROTL                     ;Continue rotate left operations
 2877                     
 2878                     
 2879                                                       ;N'th precision rotate
 2880                                                       ;right subroutine. Opposite of
 2881                                                       ;above subroutine.
 2882                     
 2883  1289  A7           ROTATR:	ANA	A                           ;Clear the carry bit at this entry point
 2884  128A  7E           ROTR:	MOV	A,M                           ;Fetch a byte from memory
 2885  128B  1F                      RAR                          ;Rotate it right (carry into MSB, LSB to carry)
 2886  128C  77                      MOV	M,A                      ;Restore rotated word to memory
 2887  128D  05                      DCR	B                        ;Decrement precision counter
 2888  128E  C8                      RZ                           ;Exit to caller when finished
 2889  128F  2D                      DCR	L                        ;Else decrement pointer to next byte
 2890  1290  C3 8A 12                JMP	ROTR                     ;Continue rotate right operations
 2891                     
 2892                                                       ;N'th precision subtraction subroutine.
 2893                                                       ;Number starting at location pointed to by D & E (least
 2894                                                       ;significant byte) is subtracted from number starting at
 2895                                                       ;address specified by contents of H & L.
 2896                     
 2897  1293  A7           SUBBER:	ANA	A                           ;Initialize the carry bit to zero upon entry
 2898  1294  7E           SUBTRA:	MOV	A,M                         ;Fetch byte from register group A
 2899  1295  CD EE 12                CALL	SWITCH                  ;Switch memory pointer to register group B
 2900  1298  9E                      SBB	M                        ;Subtract byte from group B ftom that in group A
 2901  1299  77                      MOV	M,A                      ;Leave result in register group B
 2902  129A  05                      DCR	B                        ;Decrement number of bytes (precision) counter
 2903  129B  C8                      RZ                           ;Return to caller when all bytes in group processed
 2904  129C  2C                      INR	L                        ;Else advance pointer for register group B
 2905  129D  CD EE 12                CALL	SWITCH                  ;Switch memory pointer back to register group A
 2906  12A0  2C                      INR	L                        ;Advance the pointer for register group A
 2907  12A1  C3 94 12                JMP	SUBTRA                   ;Continue the multi-byte subtraction operation
 2908                     
 2909                                                       ;The next subroutine will transfer the four byte
 2910                                                       ;register string (generally a number in floating point
 2911                                                       ;format) from the starting address pointed to by CPU
 2912                                                       ;registers H & L when the subroutine is entered to
 2913                                                       ;the FPACC (floating point accumulator registers).
 2914                     
 2915  12A4  16 01        FLOAD:	MVI	D,HIGH OLDPG1                ;** Set page address of FPACC
 2916  12A6  1E 54                   MVI	E,OFS_FPACC                   ;Set address of least signficant byte of FPACC
 2917  12A8  06 04                   MVI	B,004H                   ;Set precision counter to four bytes (mantissa bytes
 2918  12AA  C3 0B 11                JMP	MOVEIT                   ;Plus Exponent) and exit via the transfer routine
 2919                     
 2920                                                       ;The next several subroutines are used to perform
 2921                                                       ;floating pojnt register loading and transfer operations.
 2922                     
 2923  12AD  5D           FSTORE:	MOV	E,L                         ;Transfer contents of register L to E
 2924  12AE  54                      MOV	D,H                      ;Transfer contents of register H to D
 2925  12AF  2E 54                   MVI	L,OFS_FPACC                   ;Set L to least significant byte of FPACC mantissa
 2926  12B1  26 01                   MVI	H,HIGH OLDPG1            ;** Set page to FPACC storage area
 2927  12B3  C3 BA 12                JMP	SETIT                    ;Go transfer FPACC contents to area pointed to by D&E
 2928  12B6  16 01        OPLOAD:	MVI	D,HIGH OLDPG1               ;** Set page to FPOP storage area
 2929  12B8  1E 5C                   MVI	E,OFS_FPOP                   ;Set pointer to least significant byte of FPOP
 2930  12BA  06 04        SETIT:	MVI	B,004H                       ;Set precision counter. Transfer from H & L area to
 2931  12BC  C3 0B 11                JMP	MOVEIT                   ;Locations pointed to by D & E
 2932                     
 2933                                                       ;The next subroutine perforins a double transfer opera-
 2934                                                       ;tion. It first transfers the contents of the FPACC into
 2935                                                       ;the FPOP. It then transfers new data (as pointed to by
 2936                                                       ;H & L upon entry to the subroutine) into the FPACC.
 2937                     
 2938  12BF  CD CF 12     FACXOP:	CALL	SAVEHL                     ;Save contents of H & L upon entry to subroutine
 2939  12C2  2E 54                   MVI	L,OFS_FPACC                   ;Set pointer to FPACC LSW
 2940  12C4  26 01                   MVI	H,HIGH OLDPG1            ;** Set pointer to page of FPACC
 2941  12C6  CD B6 12                CALL	OPLOAD                  ;Transfer FPACC to FPOP
 2942  12C9  CD DF 12                CALL	RESTHL                  ;Recover original subroutine entry values for H & L
 2943  12CC  C3 A4 12                JMP	FLOAD                    ;Transfer registers pointed to by H & L into the FPACC
 2944                     
 2945                                                       ;Subroutine to save the contents of CPU registers D, E, H
 2946                                                       ;and L in a temporary storage area in memory.
 2947                     
 2948  12CF  7C           SAVEHL:	MOV	A,H                         ;Transfer value in H to ACC
 2949  12D0  45                      MOV	B,L                      ;And value in L to B
 2950  12D1  2E 80                   MVI	L,OFS_EVAL_CURRENT                   ;Now set L to start of tempomry storage locations
 2951  12D3  26 01                   MVI	H,HIGH OLDPG1            ;** And set H to storage area page
 2952  12D5  77                      MOV	M,A                      ;Save A (entry value of H) in memory
 2953  12D6  2C                      INR	L                        ;Advance pointer
 2954  12D7  70                      MOV	M,B                      ;Save B (entry value of L) in memory
 2955  12D8  2C                      INR	L                        ;Advance pointer
 2956  12D9  72                      MOV	M,D                      ;Save D in memory
 2957  12DA  2C                      INR	L                        ;Advance pointer
 2958  12DB  73                      MOV	M,E                      ;Save E in memory
 2959  12DC  67                      MOV	H,A                      ;Restore entry value of H
 2960  12DD  68                      MOV	L,B                      ;Restore entry value of L
 2961  12DE  C9                      RET                          ;Exit to calling routine
 2962                     
 2963                                                       ;Subroutine to restore the contents of CPU registers D,
 2964                                                       ;E, H and L from temporary storage in memory.
 2965                     
 2966  12DF  2E 80        RESTHL:	MVI	L,OFS_EVAL_CURRENT                      ;Set L to start of temporary storage locations
 2967  12E1  26 01                   MVI	H,HIGH OLDPG1            ;** Set H to storage area page
 2968  12E3  7E                      MOV	A,M                      ;Fetch stored value for li iii ACC
 2969  12E4  2C                      INR	L                        ;Advance pointer
 2970  12E5  46                      MOV	B,M                      ;Fetch stored value for L into B
 2971  12E6  2C                      INR	L                        ;Advance pointer
 2972  12E7  56                      MOV	D,M                      ;Fetch stored value for T.)
 2973  12E8  2C                      INR	L                        ;Advance pointer
 2974  12E9  5E                      MOV	E,M                      ;Fetch stored value for
 2975  12EA  67                      MOV	H,A                      ;Restore  saved value for H
 2976  12EB  68                      MOV	L,B                      ;Restore saved value for L
 2977  12EC  7E                      MOV	A,M                      ;Leave stored value for E in ACC
 2978  12ED  C9                      RET                          ;Exit to calling routine
 2979                     
 2980                                                       ;Subroutine to exchange the contents of H & L with
 2981                                                       ;D & E.
 2982                     
 2983  12EE  4C           SWITCH:	MOV	C,H                         ;Transfer register H to C temporarily
 2984  12EF  62                      MOV	H,D                      ;Place value of D into H
 2985  12F0  51                      MOV	D,C                      ;Now put former H from C into D
 2986  12F1  4D                      MOV	C,L                      ;Transfer register L to C temporarily
 2987  12F2  6B                      MOV	L,E                      ;Place value of E into L
 2988  12F3  59                      MOV	E,C                      ;Now put former L from C into E
 2989  12F4  C9                      RET                          ;Exit to calling routine
 2990  12F5  26 01        GETINP:	MVI	H,HIGH OLDPG1               ;** Set H to page of GETINP character counter
 2991  12F7  2E 90                   MVI	L,OFS_GETINP_CNT                   ;Set L to address of GETINP character counter
 2992  12F9  4E                      MOV	C,M                      ;Load counter value into CPU register C
 2993  12FA  0C                      INR	C                        ;Exercise the counter in order
 2994  12FB  0D                      DCR	C                        ;To set CPU flags. If counter is non-zero, then indexing
 2995  12FC  C2 08 13                JNZ	NOT0                     ;Register (GETINP counter) is all set so jump ahead.
 2996  12FF  6B                      MOV	L,E                      ;But, if counter zero, then starting to process a new
 2997  1300  62                      MOV	H,D                      ;Character string. Transfer char string buffer pointer into
 2998  1301  4E                      MOV	C,M                      ;H & L and fetch the string's character count value (cc)
 2999  1302  0C                      INR	C                        ;Increment the (cc) by one to take account of (cc) byte
 3000  1303  CD 1E 13                CALL	INDEXC                  ;Add contents of regis C to H & L to point to end of the
 3001  1306  36 00                   MVI	M,000H                   ;Character string in buffer and place a zero byte marker
 3002  1308  2E 90        NOT0:	MVI	L,OFS_GETINP_CNT                        ;Set L back to address of GETINP counter which is used
 3003  130A  26 01                   MVI	H,HIGH OLDPG1            ;** As an indexing value. Set H to correct page.
 3004  130C  4E                      MOV	C,M                      ;Fetch the value of GETINP counter into register C
 3005  130D  0C                      INR	C                        ;Increment the value in C
 3006  130E  71                      MOV	M,C                      ;Restore the updated value for future use
 3007  130F  6B                      MOV	L,E                      ;Bring the base address of the character string buffer into
 3008  1310  62                      MOV	H,D                      ;CPU registers H & L
 3009  1311  CD 1E 13                CALL	INDEXC                  ;Add contents of register C to form indexed address of
 3010  1314  7E                      MOV	A,M                      ;Next character to be fetched as input. Fetch the next
 3011  1315  A7                      ANA	A                        ;Character. Exercise the CPU flags.
 3012  1316  26 01                   MVI	H,HIGH OLDPG1            ;** Restore page pointer to floating point working area
 3013  1318  C0                      RNZ                          ;If character is non-zero, not end of string, exit to calle
 3014  1319  2E 90                   MVI	L,OFS_GETINP_CNT                   ;If zero character, must reset GETINP counter for next
 3015  131B  36 00                   MVI	M,000H                   ;String. Reset pointer and clear GETINP counter to zero
 3016  131D  C9                      RET                          ;Then exit to calling routine
 3017                     
 3018                                                       ;Following subroutine causes register C to be used as an
 3019                                                       ;indexing register. Value in C is added to address in H
 3020                                                       ;and L to form new address.
 3021                     
 3022  131E  7D           INDEXC:	MOV	A,L                         ;Place value from register L into accumulator
 3023  131F  81                      ADD	C                        ;Add quantity in register C
 3024  1320  6F                      MOV	L,A                      ;Restore updated value back to L
 3025  1321  D0                      RNC                          ;Exit to caller if no carry from addition
 3026  1322  24                      INR	H                        ;But, if have carry then must increment register H
 3027  1323  C9                      RET                          ;Before returning to calling routine
