 2450                                                       ;Following subroutine clears the FPACC to the zero
 2451                                                       ;condition.
 2452                     
 2453  1029  2E 56        FPZERO:	MVI	L,OFS_FPACC_MSW                      ;Set L to point to MSW of FPACC
 2454  102B  AF                      XRA	A                        ;Clear the accumulator
 2455  102C  77                      MOV	M,A                      ;Set the MSW of FPACC to zero
 2456  102D  2D                      DCR	L                        ;Decrement the pointer
 2457  102E  77                      MOV	M,A                      ;Set the next significant word of FPACC to zero
 2458  102F  2D                      DCR	L                        ;Decrement the pointer
 2459  1030  77                      MOV	M,A                      ;Set the LSW of FPACC to zero
 2460  1031  2D                      DCR	L                        ;Decrement the pointer
