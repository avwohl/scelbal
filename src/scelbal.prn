    1                     ;;; This is the Scelbi Basic Program from 1974 known as
    2                     ;;; SCELBAL by Mark G. Arnold (MGA) and Nat Wadsworth  
    3                     ;;;
    4                     ;;;  Copyright 1975 Scelbi Computer Consulting, Inc.
    5                     ;;;  All rights reserved
    6                     ;;;
    7                     ;;; MGA gives permission to use SCELBAL for 
    8                     ;;; educational, historical, non-commercial purposes.
    9                     ;;; Versions of this have been circulating on the web since
   10                     ;;; about 2000; this version is authorized by MGA (Mar 2012)
   11                     ;;; with the understanding no warranty is expressed or implied.
   12                     ;;; As stated in the original, "no responsibility is assumed for
   13                     ;;; for inaccuracies or for the success or failure of
   14                     ;;; various applications to which the information herein
   15                     ;;; may be applied."
   16                     ;;; 
   17                     ;;; SCELBAL is the only open-source, floating-point 
   18                     ;;; high-level language ever implemented on Intel's first
   19                     ;;; general-purpose microprocessor, the 8008.  It was
   20                     ;;; published in book form:
   21                     ;;;
   22                     ;;;  SCELBAL: A Higher-Level Language for 8008/8080 Systems
   23                     ;;;
   24                     ;;; (Tiny BASIC only used 16-bit integers; the MCM\70
   25                     ;;; was a closed system; calculators implemented with 8008
   26                     ;;; were floating-point, but not high-level.)
   27                     ;;;
   28                     ;;; This version is modified to assemble with the
   29                     ;;; as8 assembler (using the -octal option) 
   30                     ;;; for the Intel 8008 by Thomas E. Jones.
   31                     ;;; This current form is made up non-relocatable so that
   32                     ;;; locations of all code and data is identical to the
   33                     ;;; original SCELBAL documents and patches.  It should be
   34                     ;;; reasonable after debugging code to convert this to a
   35                     ;;; relocatable and ROMable code with variables in RAM.
   36                     ;;; This code originates from a version made by 
   37                     ;;;
   38                     ;;;    Steve Loboyko in 2001.
   39                     ;;;
   40                     ;;; This version has all 3 patches for SCELBAL (the two
   41                     ;;; pasted in the original manual, and a third which was
   42                     ;;; written in SCELBAL UPDATE publication, as well as
   43                     ;;; a couple changes to constants which didn't actually
   44                     ;;; require a patch, just changes to bytes of data or
   45                     ;;; arguments to an instruction--one of these (Tucker) was 
   46                     ;;; incorrect and restored to original by MGA March 2012).
   47                     ;;; 
   48                     ;;; This comment must be incorporated with any version of SCELBAL
   49                     ;;; downloaded, distributed, posted or disemenated.
   50                     	
   51                     
   52                     ENDPGRAM:	EQU	02DH                      ;MGA 4/10/12 as in orig; for his ROMable Loboyko said 077       [077]
   53                     BGNPGRAM:	EQU	01BH                      ;MGA 4/10/12 as in orig; for his ROMable Loboyko said 044       [044]
   54                     	
   55                     ;;; Here are labels originally attempting to make the code
   56                     ;;; relocatable.  These 4 pages contain variable data
   57                     ;;; which needs to be relocated from ROM to RAM.
   58                     ;;; I can't vouch for ALL references to these pages in
   59                     ;;; the code being switched to these labels, but they
   60                     ;;; seem to be.
   61                     	
   62                     OLDPG1:	EQU	00100H
   63                     OLDPG26:	EQU	01600H
   64                     OLDPG27:	EQU	01700H
   65                     OLDPG57:	EQU	02F00H
   66                     
   67                     ;;; =========================================================================
   68                     ;;; Page 1 (0100H-01FFH) Variable/Constant Offset Definitions
   69                     ;;; These are LOW BYTE offsets used with H=HIGH OLDPG1
   70                     ;;; =========================================================================
   71                     
   72                     ;;; Floating Point Constants
   73                     OFS_FP_CONST_1:	EQU	004H	; FP constant +1.0 (4 bytes)
   74                     OFS_EXP_COUNTER:	EQU	00BH	; Exponent counter (1 byte)
   75                     OFS_FP_TEMP:	EQU	00CH	; FP temp storage (4 bytes)
   76                     OFS_FP_CONST_NEG1:	EQU	014H	; FP constant -1.0 (4 bytes)
   77                     OFS_SCRATCH_PAD1:	EQU	018H	; Scratch pad area (16 bytes)
   78                     OFS_RND_CONST1:	EQU	028H	; Random number constant 1
   79                     OFS_RND_CONST2:	EQU	030H	; Random number constant 2
   80                     OFS_SCRATCH_PAD2:	EQU	034H	; Scratch pad area (12 bytes)
   81                     
   82                     ;;; Sign and Mode Indicators
   83                     OFS_SIGN_IND1:	EQU	040H	; Sign indicator 1 (2 bytes)
   84                     OFS_BITS_COUNTER:	EQU	042H	; Bits counter (1 byte)
   85                     OFS_SIGN_IND2:	EQU	043H	; Sign indicator 2 (2 bytes)
   86                     OFS_INP_DIG_CNT:	EQU	045H	; Input digit counter
   87                     OFS_TEMP_STORE:	EQU	046H	; Temporary storage
   88                     OFS_OUT_DIG_CNT:	EQU	047H	; Output digit counter
   89                     OFS_FP_MODE_IND:	EQU	048H	; FP mode indicator
   90                     
   91                     ;;; Floating Point Accumulator (FPACC)
   92                     OFS_FPACC_EXT:	EQU	050H	; FPACC extension (4 bytes)
   93                     OFS_FPACC:	EQU	054H	; FPACC LSW (start of 4-byte FPACC)
   94                     OFS_FPACC_LSW:	EQU	054H	; FPACC Least Significant Word
   95                     OFS_FPACC_NSW:	EQU	055H	; FPACC Next Significant Word
   96                     OFS_FPACC_MSW:	EQU	056H	; FPACC Most Significant Word
   97                     OFS_FPACC_EXP:	EQU	057H	; FPACC Exponent
   98                     
   99                     ;;; Floating Point Operand (FPOP)
  100                     OFS_FPOP_EXT:	EQU	058H	; FPOP extension (4 bytes)
  101                     OFS_FPOP:	EQU	05CH	; FPOP LSW (start of 4-byte FPOP)
  102                     OFS_FPOP_LSW:	EQU	05CH	; FPOP Least Significant Word
  103                     OFS_FPOP_NSW:	EQU	05DH	; FPOP Next Significant Word
  104                     OFS_FPOP_MSW:	EQU	05EH	; FPOP Most Significant Word
  105                     OFS_FPOP_EXP:	EQU	05FH	; FPOP Exponent
  106                     
  107                     ;;; Additional page 1 offsets (early addresses)
  108                     OFS_EXP_TEMP:	EQU	003H	; Exponent temp storage
  109                     OFS_FP_TEMP_0F:	EQU	00FH	; FP temp +3
  110                     OFS_SCRATCH_1F:	EQU	01FH	; Scratch pad +7
  111                     
  112                     ;;; Floating Point Working Area (24 bytes at 060H-077H)
  113                     OFS_FP_WORK:	EQU	060H	; FP working area start
  114                     OFS_FP_WORK_63:	EQU	063H	; FP working area +3
  115                     OFS_FP_WORK_65:	EQU	065H	; FP working area +5
  116                     OFS_FP_WORK_66:	EQU	066H	; FP working area +6
  117                     OFS_FP_WORK_68:	EQU	068H	; FP working area +8
  118                     OFS_FP_WORK_6A:	EQU	06AH	; FP working area +A
  119                     OFS_FP_WORK_6B:	EQU	06BH	; FP working area +B
  120                     OFS_FP_WORK_6C:	EQU	06CH	; FP working area +C
  121                     OFS_FP_WORK_6E:	EQU	06EH	; FP working area +E
  122                     OFS_FP_WORK_6F:	EQU	06FH	; FP working area +F
  123                     OFS_FP_WORK_70:	EQU	070H	; FP working area +10
  124                     OFS_FP_WORK_74:	EQU	074H	; FP working area +14
  125                     OFS_FP_WORK_76:	EQU	076H	; FP working area +16 (output MSW)
  126                     OFS_FP_WORK_77:	EQU	077H	; FP working area +17
  127                     
  128                     ;;; Temporary Register Storage and Constants
  129                     OFS_TEMP_REGS:	EQU	080H	; Temp register storage (D,E,H,L)
  130                     OFS_FP_CONST_10:	EQU	088H	; FP constant +10.0
  131                     OFS_FP_CONST_0P1:	EQU	08CH	; FP constant +0.1
  132                     
  133                     ;;; Counters and Stack Pointers
  134                     OFS_GETINP_CNT:	EQU	090H	; GETINP counter
  135                     OFS_ARITH_STKPTR:	EQU	097H	; Arithmetic stack pointer
  136                     OFS_FA_STKPTR:	EQU	098H	; FUN/ARRAY stack pointer
  137                     OFS_ARITH_STACK:	EQU	098H	; Arithmetic stack (variable)
  138                     
  139                     ;;; FOR/NEXT Storage (in TEMP_AREA2 at 0C4H-0CFH)
  140                     OFS_FN_STEP:	EQU	0C4H	; FOR/NEXT step size (4 bytes)
  141                     OFS_FN_STEP_C6:	EQU	0C6H	; FOR/NEXT step +2
  142                     OFS_FN_LIMIT:	EQU	0C8H	; FOR/NEXT limit value (4 bytes)
  143                     OFS_FN_TEMP:	EQU	0CCH	; FOR/NEXT temp (4 bytes)
  144                     
  145                     ;;; Keyword lookup table entries (in page 1)
  146                     OFS_KW_THEN:	EQU	0D0H	; THEN keyword
  147                     OFS_KW_TO:	EQU	0D5H	; TO keyword
  148                     OFS_KW_STEP:	EQU	0D8H	; STEP keyword
  149                     OFS_KW_LIST:	EQU	0DDH	; LIST keyword
  150                     OFS_KW_RUN:	EQU	0E2H	; RUN keyword
  151                     OFS_KW_SCR:	EQU	0E6H	; SCR keyword
  152                     OFS_MSG_READY:	EQU	0EAH	; READY message
  153                     
  154                     ;;; Temporary and Working Storage
  155                     OFS_TEMP_F0:	EQU	0F0H	; Temp storage at F0H
  156                     OFS_TEMP_F3:	EQU	0F3H	; Temp storage at F3H
  157                     OFS_TEMP_F4:	EQU	0F4H	; Temp storage at F4H
  158                     OFS_TEMP_F6:	EQU	0F6H	; Temp storage at F6H
  159                     OFS_TEMP_F7:	EQU	0F7H	; Temp storage at F7H
  160                     OFS_LOOKUP_CNT:	EQU	0F8H	; Look-up counter
  161                     OFS_TEMP_OP:	EQU	0F9H	; Temp OP storage
  162                     
  163                     ;;; =========================================================================
  164                     ;;; Page 26 (1600H-16FFH) Line Buffer and Pointer Offset Definitions
  165                     ;;; These are LOW BYTE offsets used with H=HIGH OLDPG26
  166                     ;;; =========================================================================
  167                     
  168                     OFS_LINE_INP_BUF:	EQU	000H	; Line input buffer start (CC + 79 chars)
  169                     OFS_PARSER_TOKEN:	EQU	07EH	; Parser token storage
  170                     OFS_EVAL_CURRENT:	EQU	080H	; EVAL current pointer
  171                     OFS_SYNTAX_PTR:	EQU	081H	; Syntax counter/pointer
  172                     OFS_SCAN_PTR:	EQU	082H	; SCAN pointer
  173                     OFS_TOKEN_STORE:	EQU	083H	; TOKEN storage location
  174                     OFS_TEMP_ARRAY:	EQU	084H	; Temp array pointer
  175                     OFS_TEMP_085:	EQU	085H	; Temp storage at 85H
  176                     OFS_ARRAY_SETUP:	EQU	086H	; Array setup pointer
  177                     OFS_LOOP_COUNTER:	EQU	087H	; Loop counter
  178                     OFS_OP_STKPTR:	EQU	088H	; Operator stack pointer
  179                     OFS_TAB_FLAG:	EQU	07FH	; TAB flag
  180                     OFS_FUNC_TBL_BASE:	EQU	0BCH	; Function lookup table base (less 4)
  181                     OFS_EVAL_PTR:	EQU	0BEH	; EVAL pointer
  182                     OFS_EVAL_FINISH:	EQU	0BFH	; EVAL finish pointer
  183                     OFS_LINENUM_BUF:	EQU	0E0H	; Line number buffer
  184                     OFS_AUX_LINENUM:	EQU	0E8H	; Auxiliary line number buffer
  185                     OFS_COL_COUNTER:	EQU	023H	; Column counter
  186                     OFS_COL_024:	EQU	024H	; Column area +1
  187                     
  188                     ;;; Page 26 Symbol Buffer (at offset 050H, same as Page 27 start)
  189                     OFS_SYMBOL_BUF:	EQU	050H	; Symbol buffer start
  190                     OFS_SYMBOL_CHAR1:	EQU	051H	; Symbol buffer 1st character
  191                     OFS_SYMBOL_CHAR2:	EQU	052H	; Symbol buffer 2nd character
  192                     
  193                     ;;; =========================================================================
  194                     ;;; Page 27 (1700H-17FFH) Keyword Table and Variables Offset Definitions
  195                     ;;; These are LOW BYTE offsets used with H=HIGH OLDPG27
  196                     ;;; =========================================================================
  197                     
  198                     OFS_KEYWORD_TBL:	EQU	000H	; Keyword table start
  199                     OFS_GOSUB_STK_BASE:	EQU	03BH	; GOSUB stack base (page 26)
  200                     OFS_ARRAY_TEMP:	EQU	03EH	; Array temp / GOSUB stack offset
  201                     OFS_SYMVAR_CNT:	EQU	03FH	; Symbol variables counter
  202                     OFS_ARRAY_VAR:	EQU	04CH	; Array variables table
  203                     OFS_FA_STACK_TEMP:	EQU	083H	; F/A stack temp storage
  204                     
  205                     ;;; =========================================================================
  206                     ;;; User Program Buffer Offset (used with BGNPGRAM page)
  207                     ;;; =========================================================================
  208                     
  209                     OFS_USER_PROG:	EQU	000H	; User program buffer start
  210                     
  211                     
  212                     ;;; Page zero will contain the I/O Routines.  These are actually
  213                     ;;; just as suggested by Scelbal Manual for Serial I/O.
  214                     
  215                     	ORG	00040H                             ; save a bit of space before this
  216                     	
  217                     save:	
  218  0040  C3 B6 08     load:	JMP	EXEC                          ; By default, save and load isn't implemented.
  219                     
  220                     INPORT:	EQU	005H
  221                     OUTPORT:	EQU	00EH
  222                     
  223                     ;;; HERE IS THE USER DEFINED CHARACTER INPUT TO READ FROM SERIAL PORT
  224                     	
  225  0043  DB 05        CINP:	IN	INPORT
  226  0045  A7           	ANA	A
  227  0046  FA 43 00     	JM	CINP
  228  0049  AF           	XRA	A
  229  004A  06 44        	MVI	B,044H
  230                     
  231  004C  05           MORE1:	DCR	B
  232  004D  C2 4C 00     	JNZ	MORE1
  233  0050  D3 0E        	OUT	OUTPORT
  234  0052  CD 84 00     	CALL	TIMER
  235  0055  CD 7A 00     	CALL	NEXBIT
  236  0058  CD 7A 00     	CALL	NEXBIT
  237  005B  CD 7A 00     	CALL	NEXBIT
  238  005E  CD 7A 00     	CALL	NEXBIT
  239  0061  CD 7A 00     	CALL	NEXBIT
  240  0064  CD 7A 00     	CALL	NEXBIT
  241  0067  CD 7A 00     	CALL	NEXBIT
  242  006A  CD 7A 00     	CALL	NEXBIT
  243                     
  244  006D  3E 01        STOP:	MVI	A,001H
  245  006F  D3 0E        	OUT	OUTPORT
  246  0071  78           	MOV	A,B
  247  0072  07           	RLC
  248  0073  06 CC        	MVI	B,0CCH
  249                     
  250  0075  05           MORE3:	DCR	B
  251  0076  C2 75 00     	JNZ	MORE3
  252  0079  C9           	RET
  253                     
  254  007A  DB 05        NEXBIT:	IN	INPORT
  255  007C  E6 80        	ANI	080H
  256  007E  07           	RLC
  257  007F  D3 0E        	OUT	OUTPORT
  258  0081  0F           	RRC
  259  0082  80           	ADD	B
  260  0083  0F           	RRC
  261  0084  06 8B        TIMER:	MVI	B,08BH
  262  0086  05           MORE2:	DCR	B
  263  0087  C2 86 00     	JNZ	MORE2
  264  008A  47           	MOV	B,A
  265  008B  C9           	RET
  266                     ;;; no user defined functions yet, stop here if we see one.
  267  008C  76           UDEFX:	HLT
  268                     
  269                     ;;; HERE IS THE USER DEFINED PRINT ROUTINE FOR A SERIAL PORT
  270                     	
  271  008D  A7           CPRINT:	ANA	A
  272  008E  17           	RAL
  273  008F  D3 0E        	OUT	OUTPORT
  274  0091  1F           	RAR
  275  0092  CD 84 00     	CALL	TIMER
  276  0095  CD BB 00     	CALL	BITOUT
  277  0098  CD BB 00     	CALL	BITOUT
  278  009B  CD BB 00     	CALL	BITOUT
  279  009E  CD BB 00     	CALL	BITOUT
  280  00A1  CD BB 00     	CALL	BITOUT
  281  00A4  CD BB 00     	CALL	BITOUT
  282  00A7  CD BB 00     	CALL	BITOUT
  283  00AA  CD BB 00     	CALL	BITOUT
  284  00AD  47           	MOV	B,A
  285  00AE  3E 01        	MVI	A,001H
  286  00B0  D3 0E        	OUT	OUTPORT
  287  00B2  78           	MOV	A,B
  288  00B3  CD 84 00     	CALL	TIMER
  289  00B6  06 43        	MVI	B,043H
  290  00B8  C3 75 00     	JMP	MORE3
  291                     
  292  00BB  D3 0E        BITOUT:	OUT	OUTPORT
  293  00BD  0F           	RRC
  294  00BE  CD 84 00     	CALL	TIMER
  295  00C1  C9           	RET
  296                     ;;; THE ABOVE MUST CONCLUDE BEFORE BY PAGE 1 STARTS
  297                     	
  298                     	
  299                     ;;; Page one has many constants and variables.
  300                     ;;; See docs/variable_map.txt for detailed address mapping
  301                     
  302                     	ORG	00100H
  303                     	DS	4                                   ; (reserved padding)
  304                     FP_CONST_1:                                     ; Floating point constant +1.0
  305  0104  00 00 40 01  	DB	000H,000H,040H,001H
  306                     	DS	3                                   ; (reserved padding)
  307                     EXP_COUNTER:                                    ; Exponent counter
  308  010B  00           	DB	000H
  309                     FP_TEMP:                                        ; Floating point number temp storage
  310  010C  00 00 00 00  	DB	000H,000H,000H,000H
  311                     	DS	4                                   ; (reserved padding)
  312                     FP_CONST_NEG1:                                  ; Floating point constant -1.0
  313  0114  00 00 C0 01  	DB	000H,000H,0C0H,001H
  314                     SCRATCH_PAD1:                                   ; Scratch pad area (16 bytes)
  315  0118  00 00 00 00  	DB	000H,000H,000H,000H
  316  011C  00 00 00 00  	DB	000H,000H,000H,000H
  317  0120  00 00 00 00  	DB	000H,000H,000H,000H
  318  0124  00 00 00 00  	DB	000H,000H,000H,000H
  319                     RND_CONST1:                                     ; Random number generator constant
  320  0128  01 50 72 02  	DB	001H,050H,072H,002H
  321                     	DS	4                                   ; (reserved padding)
  322                     RND_CONST2:                                     ; Random number generator constant
  323  0130  03 68 6F 0C  	DB	003H,068H,06FH,00CH
  324                     SCRATCH_PAD2:                                   ; Scratch pad area (12 bytes)
  325  0134  00 00 00 00  	DB	000H,000H,000H,000H
  326  0138  00 00 00 00  	DB	000H,000H,000H,000H
  327  013C  00 00 00 00  	DB	000H,000H,000H,000H
  328                     SIGN_IND1:                                      ; Sign indicator
  329  0140  00 00        	DB	000H,000H
  330                     BITS_COUNTER:                                   ; Bits counter
  331  0142  00           	DB	000H
  332                     SIGN_IND2:                                      ; Sign indicator
  333  0143  00 00        	DB	000H,000H
  334                     INP_DIG_CNT:                                    ; Input digit counter
  335  0145  00           	DB	000H
  336                     TEMP_STORE:                                     ; Temporary storage
  337  0146  00           	DB	000H
  338                     OUT_DIG_CNT:                                    ; Output digit counter
  339  0147  00           	DB	000H
  340                     FP_MODE_IND:                                    ; FP mode indicator
  341  0148  00           	DB	000H
  342                     	DS	7                                   ; (not assigned - 0149H-014FH)
  343                     FPACC_EXT:                                      ; FPACC extension
  344  0150  00 00 00 00  	DB	000H,000H,000H,000H
  345                     FPACC:                                          ; FPACC (LSW, NSW, MSW, Exponent)
  346  0154  00 00 00 00  	DB	000H,000H,000H,000H
  347                     FPOP_EXT:                                       ; FPOP extension
  348  0158  00 00 00 00  	DB	000H,000H,000H,000H
  349                     FPOP:                                           ; FPOP (LSW, NSW, MSW, Exponent)
  350  015C  00 00 00 00  	DB	000H,000H,000H,000H
  351                     FP_WORK_AREA:                                   ; Floating point working area (24 bytes)
  352  0160  00 00 00 00  	DB	000H,000H,000H,000H
  353  0164  00 00 00 00  	DB	000H,000H,000H,000H
  354  0168  00 00 00 00  	DB	000H,000H,000H,000H
  355  016C  00 00 00 00  	DB	000H,000H,000H,000H
  356  0170  00 00 00 00  	DB	000H,000H,000H,000H
  357  0174  00 00 00 00  	DB	000H,000H,000H,000H
  358                     	DS	8                                   ; (not assigned - 0178H-017FH)
  359                     TEMP_REGS:                                      ; Temporary register storage (D,E,H,L)
  360  0180  00 00 00 00  	DB	000H,000H,000H,000H
  361                     	DS	4                                   ; (not assigned - 0184H-0187H)
  362                     FP_CONST_10:                                    ; Floating point constant +10.0
  363  0188  00 00 50 04  	DB	000H,000H,050H,004H
  364                     FP_CONST_0P1:                                   ; Floating point constant +0.1
  365  018C  67 66 66 FD  	DB	067H,066H,066H,0FDH
  366                     GETINP_CNT:                                     ; GETINP counter
  367  0190  00           	DB	000H
  368                     	DS	6                                   ; (not assigned - 0191H-0196H)
  369                     ARITH_STKPTR:                                   ; Arithmetic stack pointer
  370  0197  00           	DB	000H
  371                     ARITH_STACK:                                    ; Arithmetic stack (variable length)
  372  0198  00           	DB	000H
  373                     
  374                     	ORG	001BAH
  375                     KW_SAVE:                                        ; "SAVE" keyword (length + chars)
  376  01BA  04           	DB	004H
  377  01BB  53 41 56 45  	DB	"SAVE"
  378                     KW_LOAD:                                        ; "LOAD" keyword (length + chars)
  379  01BF  04           	DB	004H
  380  01C0  4C 4F 41 44  	DB	"LOAD"
  381                     TEMP_AREA2:                                     ; Temp area (STEP, FOR/NEXT, ARRAY PTR)
  382  01C4  00 00 00 00  	DB	000H,000H,000H,000H
  383  01C8  00 00 00 00  	DB	000H,000H,000H,000H
  384  01CC  00 00 00 00  	DB	000H,000H,000H,000H
  385                     
  386                     ;;; Keyword table at location 01D0H (01#320 octal)
  387                     KW_THEN:
  388  01D0  04           	DB	004H
  389  01D1  54 48 45 4E  	DB	"THEN"
  390                     KW_TO:
  391  01D5  02           	DB	002H
  392  01D6  54 4F        	DB	"TO"
  393                     KW_STEP:
  394  01D8  04           	DB	004H
  395  01D9  53 54 45 50  	DB	"STEP"
  396                     KW_LIST:
  397  01DD  04           	DB	004H
  398  01DE  4C 49 53 54  	DB	"LIST"
  399                     KW_RUN:
  400  01E2  03           	DB	003H
  401  01E3  52 55 4E     	DB	"RUN"
  402                     KW_SCR:
  403  01E6  03           	DB	003H
  404  01E7  53 43 52     	DB	"SCR"
  405                     
  406                     ;;; Messages
  407                     MSG_READY:                                      ; "READY" message with control chars
  408  01EA  0B           	DB	00BH                                ; Length = 11
  409  01EB  94 8D 8A     	DB	094H,08DH,08AH                      ; CTRL-T, CR, LF
  410  01EE  52 45 41 44  	DB	"READY"
       01F2  59         
  411  01F3  8D 8A 8A     	DB	08DH,08AH,08AH                      ; CR, LF, LF
  412                     MSG_AT_LINE:                                    ; " AT LINE " message
  413  01F6  09           	DB	009H                                ; Length = 9
  414  01F7  20 41 54 20  	DB	" AT LINE "
       01FB  4C 49 4E 45
       01FF  20         
  415                     ;;; END OF PAGE 01
  416                     
  417                     	
  418                     	ORG	00200H                             ; START PAGE 02, THE CODE
  419                     	
  420                     
  421  0200  CD AD 02     SYNTAX:	CALL	CLESYM                     ;Clear the SYMBOL BUFFER area
  422  0203  2E E0                   MVI	L,OFS_LINENUM_BUF                   ;Set L to start of LINE NUMBER BUFFER
  423  0205  26 16                   MVI	H,HIGH OLDPG26           ;** Set H to page of LINE NUMBER BUFFER
  424  0207  36 00                   MVI	M,000H                   ;Initialize line number buff by placing zero as (cc)
  425  0209  2E 81                   MVI	L,OFS_SYNTAX_PTR                   ;Change pointer to syntax counter/pointer storage loc.
  426  020B  36 01                   MVI	M,001H                   ;Set pointer to first character (after cc) in line buffer
  427  020D  2E 81        SYNTX1:	MVI	L,OFS_SYNTAX_PTR                      ;Set pointer to syntax cntr/pntr storage location
  428  020F  CD A0 02                CALL	GETCHR                  ;Fetch the character pointed to by contents of syntax
  429  0212  CA 24 02                JZ	SYNTX2                    ;Cntr/pntr from the line input buffer. If character was
  430  0215  FE B0                   CPI	0B0H                     ;A space, ignore. Else, test to see if character was ASCII
  431  0217  FA 31 02                JM	SYNTX3                    ;Code for a decimal digit. If not a decimal digit, consider
  432  021A  FE BA                   CPI	0BAH                     ;Line number to have been processed by jumping
  433  021C  F2 31 02                JP	SYNTX3                    ;Over the remainder of this SYNTX1 section.
  434  021F  2E E0                   MVI	L,OFS_LINENUM_BUF                   ;If have decimal digit, set pointer to start of LINE
  435  0221  CD CC 02                CALL	CONCT1                  ;NUMBER BUFFER and append incoming digit there.
  436  0224  2E 81        SYNTX2:	MVI	L,OFS_SYNTAX_PTR                      ;Reset L to syntax cntr/pntr storage location. Call sub-
  437  0226  CD 03 03                CALL	LOOP                    ;Routine to advance pntr and test for end of inr)ut buffer
  438  0229  C2 0D 02                JNZ	SYNTX1                   ;If not end of input buffer, go back for next digit
  439  022C  2E 83                   MVI	L,OFS_TOKEN_STORE                   ;If end of buffer, only had a line number in the line.
  440  022E  36 00                   MVI	M,000H                   ;Set pntr to TOKEN storage location. Set TOKEN = 000.
  441  0230  C9                      RET                          ;Return to caller.
  442  0231  2E 81        SYNTX3:	MVI	L,OFS_SYNTAX_PTR                      ;Reset pointer to syntax cntr/pntr and fetch
  443  0233  46                      MOV	B,M                      ;Position of next character after the line number
  444  0234  2E 82                   MVI	L,OFS_SCAN_PTR                   ;Change pntr to SCAN pntr storage location
  445  0236  70                      MOV	M,B                      ;Store address when SCAN takes up after line number
  446  0237  2E 82        SYNTX4:	MVI	L,OFS_SCAN_PTR                      ;Set pntr to SCAN pntr stomge location
  447  0239  CD A0 02                CALL	GETCHR                  ;Fetch the character pointed to by contents of the SCAN
  448  023C  CA 54 02                JZ	SYNTX6                    ;Pointer storage location. If character was ASCII code
  449  023F  FE BD                   CPI	0BDH                     ;For space, ignore. Else, compare character with "=" sign
  450  0241  CA 88 02                JZ	SYNTX7                    ;If is an equal sign, go set TOKEN for IMPLIED LET.
  451  0244  FE A8                   CPI	0A8H                     ;Else, compare character with left parenthesis " ( "
  452  0246  CA 8D 02                JZ	SYNTX8                    ;If left parenthesis, go set TOKEN for implied array LET
  453  0249  CD C8 02                CALL	CONCTS                  ;Otherwise, concatenate the character onto the string
  454                     ; MGA 4/2012 begin "fast SYNTX5" patch: 
  455                     ; the following patch doubles the overall speed of execution.  
  456                     ; It is similar to the approach taken on 8080 SCELBAL II in 1978 
  457                     ; it adhears to the rules for patches in issue 1 of SCELBAL update 
  458                     ;SYNTX6:   these four lines moved up w/o label
  459  024C  2E 82                   MVI	L,OFS_SCAN_PTR                   ;Set L to SCAN pointer storage location
  460                     ;           LHI \HB\OLDPG26        ;** Set H to page of SCAN pointer stomge location
  461                     ;MGA 4/2012 except LHI needed at original place, not here 
  462  024E  CD 03 03                CALL	LOOP                    ;Call routine to advance pntr & test for end of In buffer
  463  0251  C2 37 02                JNZ	SYNTX4                   ;Go back and add another character to SYMBOL BUFF
  464                     SYNTX6:   ; MGA 4/2012 label here 
  465                     
  466  0254  2E 83                   MVI	L,OFS_TOKEN_STORE                   ;Being constructed in the SYMBOL BUFFER. Now set
  467  0256  36 01                   MVI	M,001H                   ;Up TOKEN storage location to an initial value of 001.
  468  0258  26 17                   MVI	H,HIGH OLDPG27           ;** Set H to point to start of KEYWORD TABLE.
  469  025A  2E 00                   MVI	L,OFS_KEYWORD_TBL        ;Set L to point to start of KEYWORD TABLE.
  470  025C  16 16        SYNTX5:	MVI	D,HIGH OLDPG26              ;** Set D to page of SYMBOL BUFFER
  471  025E  1E 50                   MVI	E,OFS_SYMBOL_BUF                   ;Set E to start of SYMBOL BUFFER
  472  0260  CD DA 02                CALL	STRCP                   ;Compare char string presently in SYMBOL BUFFER
  473  0263  C8                      RZ                           ;With entry in KEYWORD TABLE. Exit if match.
  474  0264  CD EE 12                CALL	SWITCH                  ;TOKEN will be set to keyword found. Else, switch
  475  0267  2C           SYNTXL:	INR	L                           ;Pointers to get table address back and advance pntr to
  476  0268  7E                      MOV	A,M                      ;KEYWORD TABLE. Now look for start of next entry
  477  0269  E6 C0                   ANI	0C0H                     ;In KEYWORD TABLE by looking for (cc) byte which
  478  026B  C2 67 02                JNZ	SYNTXL                   ;Will NOT have a one in the two most sig. bits. Advance
  479  026E  CD EE 12                CALL	SWITCH                  ;Pntr til next entry found. Then switch pointers apin so
  480  0271  2E 83                   MVI	L,OFS_TOKEN_STORE                   ;Table pointer is in D&E. Put addr of TOKEN in L.
  481  0273  26 16                   MVI	H,HIGH OLDPG26           ;** And page of TOKEN in H. Fetch the value currently
  482  0275  46                      MOV	B,M                      ;In TOKEN and advance it to account for going on to
  483  0276  04                      INR	B                        ;The next entry in the KEYWORD TABLE.
  484  0277  70                      MOV	M,B                      ;Restore the updated TOKEN value back to storage.
  485  0278  CD EE 12                CALL	SWITCH                  ;Restore the keyword table pointer back to H&L.
  486  027B  78                      MOV	A,B                      ;Put TOKEN count in ACC.
  487  027C  FE 0D                   CPI	00DH                     ;See if have tested all entries in the keyword table.
  488  027E  C2 5C 02                JNZ	SYNTX5                   ;If not, continue checking the keyword table.
  489                     ;MGA 4/2012 3 of 4 lines removed below (keep LHI)
  490  0281  26 16                   MVI	H,HIGH OLDPG26           ;** Set H to page of SCAN pointer stomge location
  491                     ; MGA 4/2012 end of "fast SYNTX5" patch: 
  492  0283  2E 83                   MVI	L,OFS_TOKEN_STORE                   ;And search table for KEYWORD again. Unless reach
  493  0285  36 FF                   MVI	M,0FFH                   ;End of line input buffer. In which case set TOKEN=377
  494  0287  C9                      RET                          ;As an error indicator and exit to calling routine.
  495  0288  2E 83        SYNTX7:	MVI	L,OFS_TOKEN_STORE                      ;Set pointer to TOKEN storage register. Set TOKEN
  496  028A  36 0D                   MVI	M,00DH                   ;Equal to 015 when "=" sign found for IMPLIED LET.
  497  028C  C9                      RET                          ;Exit to calling routine.
  498  028D  2E 83        SYNTX8:	MVI	L,OFS_TOKEN_STORE                      ;Set pointer to TOKEN storage register. Set TOKEN
  499  028F  36 0E                   MVI	M,00EH                   ;Equal to 016 when "(" found for IMPLIED array LET.
  500  0291  C9                      RET                          ;Exit to calling routine.
  501                     
  502                                                       ;The following are subroutines used by SYNTAX and
  503                                                       ;other routines in SCELBAL.
  504                     
  505  0292  3E C2        BIGERR:	MVI	A,0C2H                      ;Load ASCII code for letters B and G to indicate BIG
  506  0294  0E C7                   MVI	C,0C7H                   ;ERROR (for when buffer, stack,etc., overflows).
  507  0296  CD 82 03     ERROR:	CALL	ECHO                        ;Call user provided display routine to print ASCII code
  508  0299  79                      MOV	A,C                      ;In accumulator. Transfer ASCII code from C to ACC
  509  029A  CD 82 03                CALL	ECHO                    ;And repeat to display error codes.
  510  029D  C3 D2 0A                JMP	FINERR                   ;Go cpmplete error message (AT LINE) as required.
  511  02A0  7E           GETCHR:	MOV	A,M                         ;Get pointer from memory location pointed to by H&L
  512  02A1  FE 50                   CPI	050H                     ;See if within range of line input buffer.
  513  02A3  F2 92 02                JP	BIGERR                    ;If not then have an overflow condition = error.
  514  02A6  6F                      MOV	L,A                      ;Else can use it as addr of character to fetch from the
  515  02A7  26 16                   MVI	H,HIGH OLDPG26           ;** LINE INPUT BUFFER by setting up H too.
  516  02A9  7E                      MOV	A,M                      ;Fetch the character from the line input buffer.
  517  02AA  FE A0                   CPI	0A0H                     ;See if it is ASCII code for space.
  518  02AC  C9                      RET                          ;Return to caller with flags set according to comparison.
  519  02AD  2E 50        CLESYM:	MVI	L,OFS_SYMBOL_BUF                      ;Set L to start of SYMBOL BUFFER.
  520  02AF  26 16                   MVI	H,HIGH OLDPG26           ;** Set H to page of SYMBOL BUFFER.
  521  02B1  36 00                   MVI	M,000H                   ;Place a zero byte at start of SYMBOL BUFFER.
  522  02B3  C9                      RET                          ;To effectively clear the buffer. Then exit to caller.
  523                     
  524                     
  525                                                       ;Subroutine to concatenate (append) a character to the
  526                                                       ;SYMBOL BUFFER. Character must be alphanumeric.
  527                     
  528  02B4  FE C1        CONCTA:	CPI	0C1H                        ;See if character code less than that for letter A.
  529  02B6  FA BE 02                JM	CONCTN                    ;If so, go see if it is numeric.
  530  02B9  FE DB                   CPI	0DBH                     ;See if character code greater than that for letter Z.
  531  02BB  FA C8 02                JM	CONCTS                    ;If not, have valid alphabetical character.
  532  02BE  FE B0        CONCTN:	CPI	0B0H                        ;Else, see if character in valid numeric range.
  533  02C0  FA D7 02                JM	CONCTE                    ;If not, have an error condition.
  534  02C3  FE BA                   CPI	0BAH                     ;Continue to check for valid number.
  535  02C5  F2 D7 02                JP	CONCTE                    ;If not, have an error condition.
  536  02C8  2E 50        CONCTS:	MVI	L,OFS_SYMBOL_BUF                      ;If character alphanumeric, can concatenate. Set pointer
  537  02CA  26 16                   MVI	H,HIGH OLDPG26           ;** To starting address of SYMBOL BUFFER.
  538  02CC  4E           CONCT1:	MOV	C,M                         ;Fetch old character count in SYMBOL BUFFER.
  539  02CD  0C                      INR	C                        ;Increment the value to account for adding new
  540  02CE  71                      MOV	M,C                      ;Character to the buffer. Restore updated (cc).
  541  02CF  47                      MOV	B,A                      ;Save character to be appended in register B.
  542  02D0  CD 1E 13                CALL	INDEXC                  ;Add (cc) to address in H & L to get new end of buffer
  543  02D3  70                      MOV	M,B                      ;Address and append the new character to buffer
  544  02D4  3E 00                   MVI	A,000H                   ;Clear the accumulator
  545  02D6  C9                      RET                          ;Exit to caller
  546  02D7  C3 6A 09     CONCTE:	JMP	SYNERR                      ;If character to be appended not alphanumeric, ERROR!
  547                     
  548                                                       ;Subroutine to compare
  549                                                       ;character strings pointed to by
  550                                                       ;register pairs D & E and H & L.
  551                     
  552  02DA  7E           STRCP:	MOV	A,M                          ;Fetch (cc) of first string.
  553  02DB  CD EE 12                CALL	SWITCH                  ;Switch pointers and fetch length of second string (cc)
  554  02DE  46                      MOV	B,M                      ;Into register B. Compare the lengths of the two strings.
  555  02DF  B8                      CMP	B                        ;If they are not the same
  556  02E0  C0                      RNZ                          ;Return to caller with flags set to non-zero condition
  557  02E1  CD EE 12                CALL	SWITCH                  ;Else, exchange the pointers back to first string.
  558  02E4  CD FF 02     STRCPL:	CALL	ADV                        ;Advance the pointer to string number 1 and fetch a
  559  02E7  7E                      MOV	A,M                      ;Character from that string into the accumulator.
  560  02E8  CD EE 12                CALL	SWITCH                  ;Now switch the pointers to string number 2.
  561  02EB  CD FF 02                CALL	ADV                     ;Advance the pointer in line number 2.
  562  02EE  BE           STRCPE:	CMP	M                           ;Compare char in stxing 1 (ACC) to string 2 (memory)
  563  02EF  C0                      RNZ                          ;If not equal, return to cauer with flags set to non-zero
  564  02F0  CD EE 12                CALL	SWITCH                  ;Else, exchange pointers to restore pntr to string 1
  565  02F3  05                      DCR	B                        ;Decrement the string length counter in register B
  566  02F4  C2 E4 02                JNZ	STRCPL                   ;If not finiahed, continue testing entire string
  567  02F7  C9                      RET                          ;If complete match, return with flag in zero condition
  568  02F8  7E           STRCPC:	MOV	A,M                         ;Fetch character pointed to by pointer to string 1
  569  02F9  CD EE 12                CALL	SWITCH                  ;Exchange pointer to examine string 2
  570  02FC  C3 EE 02                JMP	STRCPE                   ;Continue the string comparison loop
  571                     
  572                                                       ;Subroutine to advance the two byte
  573                                                       ;value in CPU registers H and L.
  574                     
  575  02FF  2C           ADV:	INR	L                              ;Advance value in register L.
  576  0300  C0                      RNZ                          ;If new value not zero, return to caller.
  577  0301  24                      INR	H                        ;Else must increment value in H
  578  0302  C9                      RET                          ;Before retuming to caller
  579                     
  580                                                       ;Subroutine to advance a buffer pointer
  581                                                       ;and test to see if the end of the buffer
  582                                                       ;has been reached.
  583                     
  584  0303  46           LOOP:	MOV	B,M                           ;Fetch memory location pointed to by H & L into B.
  585  0304  04                      INR	B                        ;Increment the value.
  586  0305  70                      MOV	M,B                      ;Restore it back to memory.
  587  0306  2E 00                   MVI	L,OFS_LINE_INP_BUF       ;Change pointer to start of INPUT LINE BUFFER
  588  0308  7E                      MOV	A,M                      ;Fetch buffer length (cc) value into the accumulator
  589  0309  05                      DCR	B                        ;Make value in B original value
  590  030A  B8                      CMP	B                        ;See if buffer length same as that in B
  591  030B  C9                      RET                          ;Return with flags yielding results of the comparison
  592                     
  593                                                       ;The following subroutine is used to
  594                                                       ;input characters from the system's
  595                                                       ;input device (such as a keyboard)
  596                                                       ;into the LINE INPUT BUFFER. Routine has limited
  597                                                       ;editing capability included.
  598                                                       ;(Rubout = delete previous character(s) entered.)
  599                     ;;; This label, STRIN:	should be location 03 014
  600  030C  0E 00        STRIN:	MVI	C,000H                       ;Initialize register C to zero.
  601  030E  CD 91 03     STRIN1:	CALL	CINPUT                     ;Call user provided device input subroutine to fetch one
  602  0311  FE FF                   CPI	0FFH                     ;Character from the input device. Is it ASCII code for
  603  0313  C2 25 03                JNZ	NOTDEL                   ;Rubout? Skip to next section if not rubout.
  604  0316  3E DC                   MVI	A,0DCH                   ;Else, load ASCII code for backslash into ACC.
  605  0318  CD 82 03                CALL	ECHO                    ;Call user display driver to present backslash as a delete
  606  031B  0D                      DCR	C                        ;Indicator. Now decrement the input character counter.
  607  031C  FA 0C 03                JM	STRIN                     ;If at beginning of line do NOT decrement H and L.
  608  031F  CD 74 03                CALL	DEC                     ;Else, decrement H & L line pointer to erase previous
  609  0322  C3 0E 03                JMP	STRIN1                   ;Entry, then go back for a new input.
  610  0325  FE 83        NOTDEL:	CPI	083H                        ;See if character inputted was'CONTROL C'
  611  0327  CA CB 0A                JZ	CTRLC                     ;If so, stop inputting and go back to the EXECutive
  612  032A  FE 8D                   CPI	08DH                     ;If not, see if character was carriage-return
  613  032C  CA 42 03                JZ	STRINF                    ;If so, have end of line of input
  614  032F  FE 8A                   CPI	08AH                     ;If not, see if character was line-feed
  615  0331  CA 0E 03                JZ	STRIN1                    ;If so, ignore the input, get another character
  616  0334  CD FF 02                CALL	ADV                     ;If none of the above, advance contents of H & L
  617  0337  0C                      INR	C                        ;Increment the character counter
  618  0338  77                      MOV	M,A                      ;Store the new character in the line input buffer
  619  0339  79                      MOV	A,C                      ;Put new character count in the accumulator
  620  033A  FE 50                   CPI	050H                     ;Make sure maximum buffer size not exceeded
  621  033C  F2 92 02                JP	BIGERR                    ;If buffer size exceeded, go display BG error message
  622  033F  C3 0E 03                JMP	STRIN1                   ;Else can go back to look for next input
  623  0342  41           STRINF:	MOV	B,C                         ;Transfer character count from C to B
  624  0343  CD 4B 03                CALL	SUBHL                   ;Subtract B from H & L to get starting address of
  625  0346  71                      MOV	M,C                      ;The string and place the character count (cc) there
  626  0347  CD 61 03                CALL	CRLF                    ;Provide a line ending CR & LF combination on the
  627  034A  C9                      RET                          ;Display device. Then exit to caller.
  628                     
  629                                                       ;Subroutine to subtract contents of CPU register B from
  630                                                       ;the two byte value in CPU registers H & L.
  631                     
  632  034B  7D           SUBHL:	MOV	A,L                          ;Load contents of register L into the accumulator
  633  034C  90                      SUB	B                        ;Subtract the contents of register B
  634  034D  6F                      MOV	L,A                      ;Restore the new value back to L
  635  034E  D0                      RNC                          ;If no carry, then no underflow. Exit to caller.
  636  034F  25                      DCR	H                        ;Else must also decrement contents of H.
  637  0350  C9                      RET                          ;Before retuming to caller.
  638                     
  639                                                       ;Subroutine to display a character string on the system's
  640                                                       ;display device.
  641                     
  642  0351  4E           TEXTC:	MOV	C,M                          ;Fetch (cc) from the first location in the buffer (H & L
  643  0352  7E                      MOV	A,M                      ;Pointing there upon entry) into register B and ACC.
  644  0353  A7                      ANA	A                        ;Test the character count value.
  645  0354  C8                      RZ                           ;No display if (cc) is zero.
  646  0355  CD FF 02     TEXTCL:	CALL	ADV                        ;Advance pointer to next location in buffer
  647  0358  7E                      MOV	A,M                      ;Fetch a character from the buffer into ACC
  648  0359  CD 82 03                CALL	ECHO                    ;Call the user's display driver subroutine
  649  035C  0D                      DCR	C                        ;Decrement the (cc)
  650  035D  C2 55 03                JNZ	TEXTCL                   ;If character counter not zero, continue display
  651  0360  C9                      RET                          ;Exit to caller when (cc) is zero.
  652                     
  653                                                       ;Subroutine to provide carriage-return and line-feed
  654                                                       ;combination to system's display device. Routine also
  655                                                       ;initializes a column counter to zero. Column counter
  656                                                       ;is used by selected output routines to count the num-
  657                                                       ;ber of characters that have been displayed on a line.
  658                     
  659  0361  3E 8D        CRLF:	MVI	A,08DH                        ;Load ASCII code for carriage-return into ACC
  660  0363  CD 82 03                CALL	ECHO                    ;Call user provided display driver subroutine
  661  0366  3E 8A                   MVI	A,08AH                   ;Load ASCII code for line-feed into ACC
  662  0368  CD 82 03                CALL	ECHO                    ;Call user provided display driver subroutine
  663  036B  2E 23                   MVI	L,OFS_COL_COUNTER                   ;Set L to point to COLUMN COUNTER storage location
  664  036D  26 01                   MVI	H,HIGH OLDPG1            ;** Set H to page of COLUMN COUNTER
  665  036F  36 01                   MVI	M,001H                   ;Initialize COLUMN COUNTER to a value of one
  666  0371  62                      MOV	H,D                      ;Restore H from D (saved by ECHO subroutine)
  667  0372  6B                      MOV	L,E                      ;Restore L from E (saved by ECHO subroutine)
  668  0373  C9                      RET                          ;Then exit to calling routine
  669                     
  670                                                       ;Subroutine to decrement double-byte value in CPU
  671                                                       ;registers H and L.
  672                     
  673  0374  2D           DEC:	DCR	L                              ;Decrement contents of L
  674  0375  2C                      INR	L                        ;Now increment to exercise CPU flags
  675  0376  C2 7A 03                JNZ	DECNO                    ;If L not presently zero, skip decrementing H
  676  0379  25                      DCR	H                        ;Else decrement H
  677  037A  2D           DECNO:	DCR	L                            ;Do the actual decrement of L
  678  037B  C9                      RET                          ;Return to caller
  679                     
  680                     
  681                                                       ;Subroutine to index the value in CPU registers H and L
  682                                                       ;by the contents of CPU register B.
  683                     
  684  037C  7D           INDEXB:	MOV	A,L                         ;Load L into the accumulator
  685  037D  80                      ADD	B                        ;Add B to that value
  686  037E  6F                      MOV	L,A                      ;Restore the new value to L
  687  037F  D0                      RNC                          ;If no carry,  return to caller
  688  0380  24                      INR	H                        ;Else, increment value in H
  689  0381  C9                      RET                          ;Before returning to caller
  690                     
  691                                                       ;The following subroutine is used to
  692                                                       ;display the ASCII encoded character in the ACC on the
  693                                                       ;system's display device. This routine calls a routine
  694                                                       ;labeled CINPUT which must be provided by the user to
  695                                                       ;actually drive the system's output device. The subroutine
  696                                                       ;below also increments an output column counter each time
  697                                                       ;it is used.
  698                     
  699  0382  54           ECHO:	MOV	D,H                           ;Save entry value of H in register D
  700  0383  5D                      MOV	E,L                      ;And save entry value of L in register E
  701  0384  2E 23                   MVI	L,OFS_COL_COUNTER                   ;Set L to point to COLUMN COUNTER storage location
  702  0386  26 01                   MVI	H,HIGH OLDPG1            ;** Set H to page of COLUMN COUNTER
  703  0388  46                      MOV	B,M                      ;Fetch the value in the COLUMN COUNTER
  704  0389  04                      INR	B                        ;And increment it for each character displayed
  705  038A  70                      MOV	M,B                      ;Restore the updated count in memory
  706  038B  CD 8D 00                CALL	CPRINT                  ;tt Call the user's device driver subroutine
  707  038E  62                      MOV	H,D                      ;Restore entry value of H from D
  708  038F  6B                      MOV	L,E                      ;Restore entry value of L from E
  709  0390  C9                      RET                          ;Return to calling routine
  710  0391  C3 43 00     CINPUT:	JMP	CINP                        ;Reference to user defined input subroutine
  711                     
  712                     ;;; The label EVAL: SHOULD BE AT 03 224
  713  0394  2E 97        EVAL:	MVI	L,OFS_ARITH_STKPTR                        ;Load L with address of ARITHMETIC STACK pointer
  714  0396  26 01                   MVI	H,HIGH OLDPG1            ;** Set H to page of ARITHMETIC STACK pointer
  715  0398  36 94                   MVI	M,094H                   ;Initialize ARITH STACK pointer value to addr minus 4
  716  039A  2C                      INR	L                        ;Advance memory pointer to FUN/ARRAY STACK pntr
  717  039B  26 16                   MVI	H,HIGH OLDPG26           ;** Set H to page of FUN/ARRAY STACK pointer
  718  039D  36 00                   MVI	M,000H                   ;Initialize FUNIARRAY STACK pointer to start of stack
  719  039F  CD AD 02                CALL	CLESYM                  ;Initialize the SYMBOL BUFFER to empty condition
  720  03A2  2E 88                   MVI	L,OFS_OP_STKPTR                   ;Load L with address of OPERATOR STACK pointer
  721  03A4  36 00                   MVI	M,000H                   ;Initialize OPERATOR STACK pointer value
  722  03A6  2E BE                   MVI	L,OFS_EVAL_PTR                   ;Set L to address of EVAL pointer (start of expression)
  723  03A8  46                      MOV	B,M                      ;Fetch the EVAL pointer value into register B
  724  03A9  2E 80                   MVI	L,OFS_EVAL_CURRENT                   ;Set up a working pointer register in this location
  725  03AB  70                      MOV	M,B                      ;And initialize EVAL CURRENT pointer
  726  03AC  2E 80        SCAN1:	MVI	L,OFS_EVAL_CURRENT                       ;Load L with address of EVAL CURRENT pointer
  727  03AE  CD A0 02                CALL	GETCHR                  ;Fetch a character in the expression being evaluated
  728  03B1  CA C1 04                JZ	SCAN10                    ;If character is a space, jump out of this section
