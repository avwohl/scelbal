  698  0386  F1           	POP PSW                         ;Restore zero
  699  0387  77           	MOV M,A                         ;Initialize this FA_STACK slot to 0 (simple grouping)
  700  0388  CD D9 06     	CALL FUNARR                     ;Call subroutine to process possible FUNCTION or
  701  038B  21 61 16     	LXI H,PARSER_TOKEN              ;ARRAY variable subscript. Ihen set pointer to
  702  038E  36 06        	MVI M,006H                      ;PARSER TOKEN storage and set value for operator
  703  0390  C3 51 03     	JMP SCANFN                      ;Go to PARSER subroutine entry point.
  704  0393  FE A9        SCAN7:	CPI 0A9H                        ;See if character fetched from expression is
  705  0395  C2 AC 03     	JNZ SCAN8                       ;If not, continue checking for an operator
  706  0398  21 61 16     	LXI H,PARSER_TOKEN              ;If yes, load L with address of PARSER TOKEN
  707  039B  36 07        	MVI M,007H                      ;Set PARSER TOKEN value to reflect ")"
  708  039D  CD 59 04     	CALL PARSER                     ;Call the  PARSER subroutine to process current symbol
  709                     
  710  03A0  CD 9A 06     	CALL PRIGHT                     ;Call subroutine to handle FUNCTION or ARRAY
  711  03A3  21 7B 16     	LXI H,FA_STKPTR                 ;Load L with address of FUN/ARRAY STACK pointer
  712  03A6  46           	MOV B,M                         ;Fetch the value in the stack pointer. Decrement it
  713  03A7  05           	DCR B                           ;To account for left parenthesis just processed.
  714  03A8  70           	MOV M,B                         ;Restore the updated value back to memory.
  715  03A9  C3 46 04     	JMP SCAN10                      ;Jump to continue processing expression.
  716  03AC  FE DE        SCAN8:	CPI 0DEH                        ;See if character fetched from expression is " t
  717  03AE  C2 B9 03     	JNZ SCAN9                       ;If not, continue checking for an operator
  718  03B1  21 61 16     	LXI H,PARSER_TOKEN              ;If yes, load L with address of PARSER TOKEN
  719  03B4  36 05        	MVI M,005H                      ;Put in value for exponentiation
  720  03B6  C3 51 03     	JMP SCANFN                      ;Go to PARSER subroutine entry point.
  721  03B9  FE BC        SCAN9:	CPI 0BCH                        ;See if character fetched is the "less than" sign
  722  03BB  C2 DF 03     	JNZ SCAN11                      ;If not, continue checking for an operator
  723  03BE  21 63 16     	LXI H,EVAL_CURRENT              ;If yes, set L to the EVAL CURRENT pointer
  724  03C1  46           	MOV B,M                         ;Fetch the pointer
