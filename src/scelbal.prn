  674  0351  CD 59 04     SCANFN:	CALL PARSER                     ;Call the PARSER subroutine to process current symbol
  675  0354  C3 46 04     	JMP SCAN10                      ;And operator. Then jump to continue processing.
  676  0357  FE AA        SCAN4:	CPI 0AAH                        ;See if character fetched from expression is
  677  0359  C2 64 03     	JNZ SCAN5                       ;If not, continue checking for an operator
  678  035C  21 61 16     	LXI H,PARSER_TOKEN              ;If yes, set pointer to PARSER TOKEN storage location
  679  035F  36 03        	MVI M,003H                      ;Place TOKEN value for "*" (multiplication) operator in
  680  0361  C3 51 03     	JMP SCANFN                      ;PARSER TOKEN and go to PARSER subroutine entry
  681  0364  FE AF        SCAN5:	CPI 0AFH                        ;See if character fetched from expression is
  682  0366  C2 71 03     	JNZ SCAN6                       ;If not, continue checking for an operator
  683  0369  21 61 16     	LXI H,PARSER_TOKEN              ;If yes, set pointer to PARSER TOKEN storage location
  684  036C  36 04        	MVI M,004H                      ;Place TOKEN value for "/" (division) operator in
  685  036E  C3 51 03     	JMP SCANFN                      ;PARSER TOKEN and go to PARSER subroutine entry
  686  0371  FE A8        SCAN6:	CPI 0A8H                        ;See if character fetched from expression is
  687  0373  C2 93 03     	JNZ SCAN7                       ;If not, continue checking for an operator
  688  0376  21 7B 16     	LXI H,FA_STKPTR                 ;If yes, load HL with address of FUN/ARRAY STACK
  689  0379  46           	MOV B,M                         ;Pointer. Fetch the value in the stack pointer. Increment
  690  037A  04           	INR B                           ;It to indicate number of "(" operators encountered.
  691  037B  70           	MOV M,B                         ;Restore the updated stack pointer back to memory
  692  037C  48           	MOV C,B                         ;Copy stack index to C for 16-bit add
  693  037D  3E 00        	MVI A,000H                      ;Clear A (will be used to clear FA_STACK slot)
  694  037F  F5           	PUSH PSW                        ;Save zero on stack
  695  0380  21 7B 16     	LXI H,FA_STACK-1                ;Load HL with FA_STACK base minus 1 (index starts at 1)
  696  0383  06 00        	MVI B,000H                      ;Clear B for 16-bit add
