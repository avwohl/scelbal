 3029                                                       ;Main Decimal INPUT subroutine to convert strings of
 3030                                                       ;ASCII characters representing decimal fixed or floating
 3031                                                       ;point numbers to binary floating point numbers.
 3032                     
 3033  1324  5D           DINPUT:	MOV	E,L                         ;Save entry value of register L in E. (Pointer to buffer
 3034  1325  54                      MOV	D,H                      ;Containing ASCII character string.) Do same for H to D.
 3035  1326  26 01                   MVI	H,HIGH OLDPG1            ;** Set H to page of floating point working registers
 3036  1328  2E 68                   MVI	L,OFS_FP_WORK_68                   ;Set L to start of decirnal-to-binary working area
 3037  132A  AF                      XRA	A                        ;Clear the accumulator
 3038  132B  06 08                   MVI	B,008H                   ;Set up a loop counter
 3039  132D  77           CLRNX2:	MOV	M,A                         ;Deposit zero in working area to initialize
 3040  132E  2C                      INR	L                        ;Advance the memory pointer
 3041  132F  05                      DCR	B                        ;Decrement the loop counter
 3042  1330  C2 2D 13                JNZ	CLRNX2                   ;Clear working area until loop counter is zero
 3043  1333  2E 43                   MVI	L,OFS_SIGN_IND2                   ;Set pointer to floating point temporary registers and
 3044  1335  06 04                   MVI	B,004H                   ;Indicators working area. Set up a loop counter.
 3045  1337  77           CLRNX3:	MOV	M,A                         ;Deposit zero in working area to initialize
 3046  1338  2C                      INR	L                        ;Advance the memory pointer
 3047  1339  05                      DCR	B                        ;Decrement the loop counter
 3048  133A  C2 37 13                JNZ	CLRNX3                   ;Clear working area until loop counter is zero
 3049  133D  CD F5 12                CALL	GETINP                  ;Fetch a character from the ASCII chax string buffer
 3050  1340  FE AB                   CPI	0ABH                     ;(Typically the SYMBOL/TOKEN buffer). See if it is
 3051  1342  CA 4D 13                JZ	NINPUT                    ;Code for + sign. Jump ahead if code for + sign.
 3052  1345  FE AD                   CPI	0ADH                     ;See if code for minus (-) sign.
 3053  1347  C2 50 13                JNZ	NOTPLM                   ;Jump ahead if not code for minus sign. If code for
 3054  134A  2E 43                   MVI	L,OFS_SIGN_IND2                   ;Minus sign, set pointer to MINUS flag storage location.
 3055  134C  77                      MOV	M,A                      ;Set the MINUS flag to indicate a minus number
 3056  134D  CD F5 12     NINPUT:	CALL	GETINP                     ;Fetch another character from the ASCII char string
 3057  1350  FE AE        NOTPLM:	CPI	0AEH                        ;See if character represents a period (decimal point) in
 3058  1352  CA 81 13                JZ	PERIOD                    ;Input string. Jump ahead if yes.
 3059  1355  FE C5                   CPI	0C5H                     ;If not period, see if code for E as in Exponent
 3060  1357  CA 91 13                JZ	FNDEXP                    ;Jump ahead if yes.
 3061  135A  FE A0                   CPI	0A0H                     ;Else see if code for space.
 3062  135C  CA 4D 13                JZ	NINPUT                    ;Ignore space character, go fetch another character.
 3063  135F  A7                      ANA	A                        ;If none of the above see if zero byte
 3064  1360  CA C9 13                JZ	ENDINP                    ;Indicating end of input char string. If yes, jumn ahead.
 3065  1363  FE B0                   CPI	0B0H                     ;If not end of string, check to see
 3066  1365  FA FD 0A                JM	NUMERR                    ;If character represents
 3067  1368  FE BA                   CPI	0BAH                     ;A valid decimal number (0 to 9)
 3068  136A  F2 FD 0A                JP	NUMERR                    ;Display error message if not a valid digit at this point!
 3069  136D  2E 6E                   MVI	L,OFS_FP_WORK_6E                   ;For valid digit, set pointer to MSW of temporary
 3070  136F  4F                      MOV	C,A                      ;Decimal to binary holding registers. Save character in C.
 3071  1370  3E F8                   MVI	A,0F8H                   ;Form mask for sizing in accumulator. Now see if
 3072  1372  A6                      ANA	M                        ;Holding register has enough room for the conversion of
 3073  1373  C2 4D 13                JNZ	NINPUT                   ;Another digit. Ignore the input if no more room.
 3074  1376  2E 45                   MVI	L,OFS_INP_DIG_CNT                   ;If have room in register then set pointer to input digit
 3075  1378  46                      MOV	B,M                      ;Counter location. Fetch the present value.
