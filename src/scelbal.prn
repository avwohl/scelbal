 3365  1533  2E 6F                   MVI	L,OFS_FP_WORK_6F                   ;Else change pointer to decimal exponent storage
 3366  1535  4E                      MOV	C,M                      ;Location, which, for fixed point, will have a positive
 3367  1536  0D                      DCR	C                        ;Value for all digits before the decimal point. Decrement
 3368  1537  0C                      INR	C                        ;And increment to exercise flags. See if count is positive.
 3369  1538  F2 44 15                JP	OUTZER                    ;If positive, must display any zero digit.
 3370  153B  2E 76                   MVI	L,OFS_FP_WORK_76                   ;If not, change pointer to MSW of working register
 3371  153D  7E                      MOV	A,M                      ;And test to see if any significant digits coming up
 3372  153E  E6 E0                   ANI	0E0H                     ;By forming a mask and testing for presence of bits
 3373  1540  C2 44 15                JNZ	OUTZER                   ;If more significant digits coming up soon, display the
 3374  1543  C9                      RET                          ;Zero digit. Else, exit to calling routine. Finished.
 3375  1544  AF           OUTZER:	XRA	A                           ;Clear the accumulator to restore zero digit value
 3376  1545  C6 B0        OUTDGX:	ADI	0B0H                        ;Add 260 (octal) to BCD code in ACC to form ASCII
 3377  1547  CD 82 03                CALL	ECHO                    ;Code and call the user's display driver subroutine
 3378  154A  2E 48        DECRDG:	MVI	L,OFS_FP_MODE_IND                      ;Set pointer to FIXED/FLOAT indicator storage
 3379  154C  7E                      MOV	A,M                      ;Fetch the indicator to the accumulator
 3380  154D  A7                      ANA	A                        ;Exercise the CPU flags
 3381  154E  C2 5F 15                JNZ	CKDECP                   ;If indicator non-zero, doing fixed point output
 3382  1551  2E 47                   MVI	L,OFS_OUT_DIG_CNT                   ;Else, get output digit counter
 3383  1553  4E                      MOV	C,M
 3384  1554  0D                      DCR	C                        ;Decrement the digit counter & restore to storage
 3385  1555  71                      MOV	M,C
 3386  1556  CA C0 15                JZ	EXPOUT                    ;When digit counter is zero, go take care of exponent
 3387  1559  CD 93 15     PUSHIT:	CALL	OUTX10                     ;Else push next BCD digit out of working register
 3388  155C  C3 25 15                JMP	OUTDGS                   ;And continue the outputting process
 3389  155F  2E 6F        CKDECP:	MVI	L,OFS_FP_WORK_6F                      ;For fixed point output, decimal exponent serves as
 3390  1561  4E                      MOV	C,M                      ;Counter for number of digits before decimal point
 3391  1562  0D                      DCR	C                        ;Fetch the counter and decrement it to account for
 3392  1563  71                      MOV	M,C                      ;Current digit being processed. Restore to storage.
 3393  1564  C2 6C 15                JNZ	NODECP                   ;If count does not go to zero, jump ahead.
 3394  1567  3E AE                   MVI	A,0AEH                   ;When count reaches zero, load ASCII code for period
 3395  1569  CD 82 03                CALL	ECHO                    ;And call user's display driver to display decimal point
 3396  156C  2E 47        NODECP:	MVI	L,OFS_OUT_DIG_CNT                      ;Set pointer to output digit counter storage location
 3397  156E  4E                      MOV	C,M                      ;Fetch the digit counter
 3398  156F  0D                      DCR	C                        ;Decrement the value
 3399  1570  71                      MOV	M,C                      ;Restore to storage
 3400  1571  C8                      RZ                           ;If counter reaches zero, exit to caller. Finished.
 3401  1572  C3 59 15                JMP	PUSHIT                   ;Else continue to output the number.
 3402  1575  2E 6F        ZERODG:	MVI	L,OFS_FP_WORK_6F                      ;If first digit of floating point number is a zero, set
 3403  1577  4E                      MOV	C,M                      ;Pointer to decimal exponent storage location.
 3404  1578  0D                      DCR	C                        ;Decrement the value to compensate for skipping
 3405  1579  71                      MOV	M,C                      ;Display of first digit. Restore to storage.
 3406  157A  2E 76                   MVI	L,OFS_FP_WORK_76                   ;Change pointer to MSW of output working register
 3407  157C  7E                      MOV	A,M                      ;Fetch MSW of output working register
 3408  157D  A7                      ANA	A                        ;Test the contents
 3409  157E  C2 4A 15                JNZ	DECRDG                   ;If non-zero, continue outputting
 3410  1581  2D                      DCR	L                        ;Else decrement pointer to next byte in working register
 3411  1582  7E                      MOV	A,M                      ;Fetch its contents
 3412  1583  A7                      ANA	A                        ;Test
 3413  1584  C2 4A 15                JNZ	DECRDG                   ;If non-zero, continue outputting
 3414  1587  2D                      DCR	L                        ;Else decrement pointer to LSW of working register
 3415  1588  7E                      MOV	A,M                      ;Fetch its contents
 3416  1589  A7                      ANA	A                        ;Test
 3417  158A  C2 4A 15                JNZ	DECRDG                   ;If non-zero, continue outputting
 3418  158D  2E 6F                   MVI	L,OFS_FP_WORK_6F                   ;If decimal mantissa is zero, set pointer to decirnal
 3419  158F  77                      MOV	M,A                      ;Exponent storage and clear it
 3420  1590  C3 4A 15                JMP	DECRDG                   ;Finish outputting
 3421                     
 3422                                                       ;Following routine multiplies the binary number in the
 3423                                                       ;output working register by ten to push the most signifi-
 3424                                                       ;cant digit out to the MSW+L byte.
 3425                     
 3426  1593  2E 77        OUTX10:	MVI	L,OFS_FP_WORK_77                      ;Set pointer to work ing register M SW+ 1
 3427  1595  36 00                   MVI	M,000H                   ;Clear it in preparation for receiving next digit pushed
 3428  1597  2E 74                   MVI	L,OFS_FP_WORK_74                   ;Into it. Change pointer to working register LSW.
 3429  1599  54                      MOV	D,H                      ;Set up register D to same page as H.
 3430  159A  1E 70                   MVI	E,070H                   ;Set second pointer to LSW of second working register
 3431  159C  06 04                   MVI	B,004H                   ;Set precision counter
 3432  159E  CD 0B 11                CALL	MOVEIT                  ;Move first working register into second
 3433  15A1  2E 74                   MVI	L,OFS_FP_WORK_74                   ;Reset pointer to LSW of first working register
 3434  15A3  06 04                   MVI	B,004H                   ;Set precision counter
 3435  15A5  CD 7F 12                CALL	ROTATL                  ;Rotate contents of first working register left (X 2)
 3436  15A8  2E 74                   MVI	L,OFS_FP_WORK_74                   ;Reset pointer to LSW
 3437  15AA  06 04                   MVI	B,004H                   ;Reset precision counter
 3438  15AC  CD 7F 12                CALL	ROTATL                  ;Rotate contents left again (X 4)
 3439  15AF  2E 70                   MVI	L,OFS_FP_WORK_70                   ;Set pointer to LSW of original value in 2'nd register
 3440  15B1  1E 74                   MVI	E,074H                   ;Set pointer to LSW of rotated value
 3441  15B3  06 04                   MVI	B,004H                   ;Set precision counter
 3442  15B5  CD 57 12                CALL	ADDER                   ;Add rotated value to original value (X 5)
 3443  15B8  2E 74                   MVI	L,OFS_FP_WORK_74                   ;Reset pointer to LSW of first working register
 3444  15BA  06 04                   MVI	B,004H                   ;Set precision counter
 3445  15BC  CD 7F 12                CALL	ROTATL                  ;Rotate contents left again (X 10)
 3446  15BF  C9                      RET                          ;Exit to calling routine
 3447                     
 3448                                                       ;The final group of routines in the floating point output
 3449                                                       ;section take care of outputting the decimal exponent
 3450                                                       ;portion of floating point numbers.
 3451                     
 3452  15C0  2E 6F        EXPOUT:	MVI	L,OFS_FP_WORK_6F                      ;Set pointer to decimal exponent storage location
 3453  15C2  7E                      MOV	A,M                      ;Fetch value to the accumulator
 3454  15C3  A7                      ANA	A                        ;Test the value
 3455  15C4  C8                      RZ                           ;If zero, then no exponent portion. Exit to caller.
 3456  15C5  3E C5                   MVI	A,0C5H                   ;Else, load ACC with ASCII code for letter E.
 3457  15C7  CD 82 03                CALL	ECHO                    ;Display E for Exponent via user's display driver rtn
 3458  15CA  7E                      MOV	A,M                      ;Get decimal exponent value back into ACC
 3459  15CB  A7                      ANA	A                        ;Test again
 3460  15CC  FA D4 15                JM	EXOUTN                    ;If value is negative, skip ahead
 3461  15CF  3E AB                   MVI	A,0ABH                   ;If positive, load ASCII code for + sign
 3462  15D1  C3 DB 15                JMP	AHEAD2                   ;Jump to display the + sign
 3463  15D4  EE FF        EXOUTN:	XRI	0FFH                        ;When decimal exponent is negative, must negate
 3464  15D6  C6 01                   ADI	001H                     ;Value for display purposes. Perform two's complement
 3465  15D8  77                      MOV	M,A                      ;And restore the negated value to storage location
 3466  15D9  3E AD                   MVI	A,0ADH                   ;Load ASCII code for minus sign
 3467  15DB  CD 82 03     AHEAD2:	CALL	ECHO                       ;Display the ASCII character in ACC
 3468  15DE  06 00                   MVI	B,000H                   ;Clear register B
 3469  15E0  7E                      MOV	A,M                      ;Fetch the decimal exponent value back into ACC
 3470  15E1  D6 0A        SUB12:	SUI	00AH                         ;Subtract 10 (decimal) from value in ACC
 3471  15E3  FA EB 15                JM	TOMUCH                    ;Break out of loop when accumulator goes negative
 3472  15E6  77                      MOV	M,A                      ;Else restore value to storage location
 3473  15E7  04                      INR	B                        ;Increment register B as a counter
 3474  15E8  C3 E1 15                JMP	SUB12                    ;Repeat loop to form tens value of decimal exponent
 3475  15EB  3E B0        TOMUCH:	MVI	A,0B0H                      ;Load base ASCII value for digit into the accumulator
 3476  15ED  80                      ADD	B                        ;Add to the count in B to forin tens digit of decimal
