 3868  1A73  0E C6        	MVI C,0C6H                      ;ASCII code for letters A and F and display message
 3869  1A75  C3 70 01     	JMP ERROR                       ;Indicating Array Forrnat (AF) error condition
 3870  1A78  21 8B 15     ARRAY5:	LXI H,ARRAY_SETUP               ;Load L with address of ARRAY SETUP pointer
 3871  1A7B  46           	MOV B,M                         ;Fetch pointer (pointing to ")"sign) into register B
