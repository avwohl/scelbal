 2898                                                       ;Following subroutine will multiply the floating point
 2899                                                       ;binary number stored in FPACC by ten tirnes the
 2900                                                       ;value stored in the deciinal exponent storage location.
 2901                     
 2902  131D  21 0B 00     FPX10:	LXI H,FP_CONST_10               ;Set pointer to registers containing floating point 10
 2903  1320  CD CA 11     	CALL FACXOP                     ;Transfer FPACC to FPOP and 10 (dec) to FPACC
