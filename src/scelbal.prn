  182  004E  00 00 00 00  	DB	000H,000H,000H,000H
  183                     SCRATCH_PAD2:                           ; Scratch pad area (12 bytes)
  184                     COL_024:                                ; Column counter / SQR approx temp
  185  0052  00 00 00 00  	DB	000H,000H,000H,000H
  186  0056  00 00 00 00  	DB	000H,000H,000H,000H
  187  005A  00 00 00 00  	DB	000H,000H,000H,000H
  188                     TEMP_REGS:                              ; Temporary register storage (D,E,H,L)
  189  005E  00 00 00 00  	DB	000H,000H,000H,000H
