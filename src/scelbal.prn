 1509  0988  C9           	RET                             ;Then return to calling routine
 1510  0989  7C           CPHLDE:	MOV A,H                         ;Subroutine to compare if the contents of CPU registers
 1511  098A  BA           	CMP D                           ;H & L are equal to registers D & E. First compare
 1512  098B  C0           	RNZ                             ;Register H to D. Return with flags set if not equal. If
 1513  098C  7D           	MOV A,L                         ;Equal continue by comparing register L to E.
 1514  098D  BB           	CMP E                           ;IF L equals E then H & L equal to D & E so return to
 1515  098E  C9           	RET                             ;Calling routines with flags set to equality status
