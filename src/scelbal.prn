 3728  199D  C3 5C 19     	JMP SQRLOP                      ;Continue ops until approximation converges
 3729  19A0  21 5F 00     SQRCNV:	LXI H,EXP_COUNTER               ;Load L with address of TEMP register. Fetch the
 3730  19A3  7E           	MOV A,M                         ;Exponenent quotient store there into accumulator.
 3731  19A4  21 4B 00     	LXI H,SCRATCH_1F                ;Change L to point to SQR APPROX exponent.
