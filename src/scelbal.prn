 3316  14DE  2E 8C        DECEXD:	MVI	L,OFS_FP_CONST_0P1                      ;If exponent is positive, multiply FPACC by 0.1
 3317  14E0  26 01                   MVI	H,HIGH OLDPG1            ;** Set pointer to registers holding 0.1 dec in binary
 3318  14E2  CD BF 12                CALL	FACXOP                  ;Floating point format. Set up for multipli(-ation.
 3319  14E5  CD 26 11                CALL	FPMULT                  ;Perform the multiplication. Answer in FPACC.
 3320  14E8  2E 6F                   MVI	L,OFS_FP_WORK_6F                   ;Set pointer to decimal exponent storage location.
 3321  14EA  46                      MOV	B,M                      ;Each time the FPACC is multiplied by one tenth, need
 3322  14EB  04                      INR	B                        ;To increment the value in the decimal exponent storage
 3323  14EC  70                      MOV	M,B                      ;Location. (This establishes decimal exponent value!)
 3324  14ED  C3 D7 14                JMP	DECREP                   ;Repeat process as required
 3325                     
 3326                                                       ;The next section outputs the mantissa
 3327                                                       ;(or fixed point number) by converting the value remaining
 3328                                                       ;in the FPACC (after the decimal exponent equivalent has
 3329                                                       ;been extracted from the original value if required by the
 3330                                                       ;previous routines) to a string of decirnal digits.
 3331  14F0  1E 74        DECOUT:	MVI	E,074H                      ;Set pointer to LSW of output working register
 3332  14F2  54                      MOV	D,H                      ;Set D to same page value as H
