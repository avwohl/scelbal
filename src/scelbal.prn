 2960  1389  77           	MOV M,A                         ;Deposit the current digit in LSW of working register
 2961  138A  11 3A 00     	LXI D,FP_WORK_6C                ;Set pointer to conversion register LSW
 2962  138D  06 03        	MVI B,003H                      ;Set precision counter
 2963  138F  CD 64 11     	CALL ADDER                      ;Add current digit to conversion register to complete
 2964  1392  C3 E7 11     	JMP RESTHL                      ;Conversion. Exit to caller by restoring CPU registers.
 2965  1395  21 3D 00     FPOUT:	LXI H,FP_WORK_6F                ;Set HL to decimal exponent storage location
 2966  1398  36 00        	MVI M,000H                      ;Initialize storage location to zero
 2967  139A  21 21 00     	LXI H,FPACC_MSW                 ;Change pointer to FPACC (number to be outputted)
 2968  139D  7E           	MOV A,M                         ;And fetch MSW of FPACC
 2969  139E  A7           	ANA A                           ;Test the contents of MSW of FPACC
 2970  139F  FA A7 13     	JM OUTNEG                       ;If most significant bit of MSW is a one, have a minus nr.
 2971  13A2  3E A0        	MVI A,0A0H                      ;Else number is positive, set ASCII code for space for a
