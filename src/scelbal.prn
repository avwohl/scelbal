  606                                                       ;by the contents of CPU register B.
  607                     
  608  02DD  C5           INDEXB:	PUSH B                          ;Save BC
  609  02DE  48           	MOV C,B                         ;Put B in C
  610  02DF  06 00        	MVI B,000H                      ;Clear B for 16-bit add
  611  02E1  09           	DAD B                           ;Add BC to HL
  612  02E2  C1           	POP B                           ;Restore BC
  613  02E3  C9           	RET                             ;Return to caller
  614                     
  615                                                       ;The following subroutine is used to
  616                                                       ;display the ASCII encoded character in the ACC on the
  617                                                       ;system's display device. This routine calls a routine
  618                                                       ;labeled CINPUT which must be provided by the user to
  619                                                       ;actually drive the system's output device. The subroutine
  620                                                       ;below also increments an output column counter each time
  621                                                       ;it is used.
  622                     
  623  02E4  54           ECHO:	MOV D,H                         ;Save entry value of H in register D
  624  02E5  5D           	MOV E,L                         ;And save entry value of L in register E
  625  02E6  21 63 00     	LXI H,COL_COUNTER               ;Set L to point to COLUMN COUNTER storage location
  626  02E9  46           	MOV B,M                         ;Fetch the value in the COLUMN COUNTER
  627  02EA  04           	INR B                           ;And increment it for each character displayed
  628  02EB  70           	MOV M,B                         ;Restore the updated count in memory
  629  02EC  CD 3E 01     	CALL CPRINT                     ;tt Call the user's device driver subroutine
  630  02EF  62           	MOV H,D                         ;Restore entry value of H from D
  631  02F0  6B           	MOV L,E                         ;Restore entry value of L from E
  632  02F1  C9           	RET                             ;Return to calling routine
  633  02F2  C3 2D 01     CINPUT:	JMP CINP                        ;Reference to user defined input subroutine
  634                     
