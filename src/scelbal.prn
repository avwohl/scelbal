 1325  084E  F2 58 08     	JP SYNTOK                       ;Is positive then have a valid entry.
 1326  0851  3E D3        SYNERR:	MVI A,0D3H                      ;However, if SYNTAX returns a negative value TOKEN
 1327  0853  0E D9        	MVI C,0D9H                      ;Then have an error condition. Set up the letters SY in
 1328  0855  C3 72 01     	JMP ERROR                       ;ASCII code and go to display error message to operator.
 1329  0858  21 14 16     SYNTOK:	LXI H,LINENUM_BUF               ;Set pointer to start of LINE NUMBER storage area
