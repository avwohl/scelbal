 3304  14C8  2E 88                   MVI	L,OFS_OP_STKPTR                   ;If exponent negative, multiply FPACC by 10 (decimal)
 3305  14CA  26 01                   MVI	H,HIGH OLDPG1            ;** Set pointer to registers holding 10 (dec) in binary
 3306  14CC  CD BF 12                CALL	FACXOP                  ;Floating point format. Set up for multiplication.
 3307  14CF  CD 26 11                CALL	FPMULT                  ;Perform the multiplication. Answer in FPACC.
 3308  14D2  2E 6F                   MVI	L,OFS_FP_WORK_6F                   ;Set pointer to decimal exponent storage location.
 3309  14D4  4E                      MOV	C,M                      ;Each time the FPACC is multiplied by ten, need to
 3310  14D5  0D                      DCR	C                        ;Decrement the value in the decinial exponent storage
 3311  14D6  71                      MOV	M,C                      ;Location. (This establishes decimal exponent value!)
 3312  14D7  2E 57        DECREP:	MVI	L,OFS_FPACC_EXP                      ;Reset pointer to FPACC Exponent
 3313  14D9  7E                      MOV	A,M                      ;Fetch value in exponent
 3314  14DA  A7                      ANA	A                        ;Test value
