 1364  0888  CD AA 01     	CALL CONCT1                     ;Number storage area so call sub to concat a character.
 1365  088B  21 B5 15     GETAU1:	LXI H,SYNTAX_PTR                ;Reset memory pointer to line character pntr storage loc
 1366  088E  46           	MOV B,M
 1367  088F  04           	INR B                           ;Fetch the pointer, increment it, and restore new value
 1368  0890  70           	MOV M,B
 1369  0891  21 24 16     	LXI H,USER_PGM_PTR              ;Set memory pointer to pgm buff line pntr storage loc
 1370  0894  4E           	MOV C,M                         ;Bring the high order byte of this double byte pointer
 1371  0895  2C           	INR L                           ;Into CPU register C. Then advance the memory pntr
 1372  0896  6E           	MOV L,M                         ;And bring the low order byte into register L. Now trans-
 1373  0897  61           	MOV H,C                         ;Fer the higher order portion into memory pointer H.
 1374  0898  7E           	MOV A,M                         ;Obtain the char cntr (cc) which indicates the length of
 1375  0899  05           	DCR B                           ;The line being pointed to by the user program line pntr
 1376  089A  B8           	CMP B                           ;Compare this with the value of the chars processed so
 1377  089B  C2 72 08     	JNZ GETAU0                      ;Far in current line. If not equal, continue getting line n
 1378  089E  21 24 16     GETAU2:	LXI H,USER_PGM_PTR              ;Reset mem pntr to pgm buffer line pntr storage
 1379  08A1  56           	MOV D,M                         ;Of this pointer into CPU register D
 1380  08A2  2C           	INR L                           ;Advance the memory pointer, fetch the second
 1381  08A3  6E           	MOV L,M                         ;Byte of the pgm buffer line pointer into register L
 1382  08A4  62           	MOV H,D                         ;Now make the memory pointer equal to this value
 1383  08A5  7E           	MOV A,M                         ;Fetch the first byte of a line in the program buffer
 1384  08A6  A7           	ANA A                           ;Test to see if end of contents of pgm buff (zero byte)
 1385  08A7  C2 B5 08     	JNZ NOTEND                      ;If not zero continue processing. If zero have reached
