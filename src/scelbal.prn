 2909                                                       ;Following subroutine will multiply the floating point
 2910                                                       ;binary number stored in PPACC by 0.1 times the value
 2911                                                       ;(negative) stored in the decimal exponent storage location
 2912                     
 2913                     MINEXP:
 2914  132F  21 0F 00     FPD10:	LXI H,FP_CONST_0P1              ;Set pointer to registers containing floating point
 2915  1332  CD C9 11     	CALL FACXOP                     ;Transfer FPACC to FPOP and 0.1 (dec) to FPACC
 2916  1335  CD 0E 10     	CALL FPMULT                     ;Multitply FPOP (formerly FPACC) by 0.1 (decimal)
 2917  1338  21 3D 00     	LXI H,FP_WORK_6F                ;Set pointer to decimal exponent storage location
 2918  133B  46           	MOV B,M                         ;Fetch the exponent value
 2919  133C  04           	INR B                           ;Increment
 2920  133D  70           	MOV M,B                         ;Restore to storage
 2921  133E  C2 2F 13     	JNZ FPD10                       ;If exponent value is not zero, continue multiplication
 2922  1341  C9           	RET                             ;When exponent is zero can exit. Conversion completed.
