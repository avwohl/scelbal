 2981  13A7  3E B0        	MVI A,0B0H                      ;Load ASCII code for '0' into accumulator
 2982  13A9  CD 58 02     	CALL ECHO                       ;Call user display driver to output '0' as first character
 2983  13AC  3E AE        	MVI A,0AEH                      ;Number string. Now load ASCII code for decimal point.
 2984  13AE  CD 58 02     	CALL ECHO                       ;Call user display driver to output '.'as second character.
