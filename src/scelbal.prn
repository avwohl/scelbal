 2453  1046  F2 50 10                JP	ACZERT                    ;If sign bit not set then jump ahead to do next test
 2454  1049  06 04                   MVI	B,004H                   ;If sign bit set, number in FPACC is negative. Set up
 2455  104B  2E 53                   MVI	L,OFS_SYMBOL_BUF+3                   ;For two's complement operation
 2456  104D  CD 68 12                CALL	COMPLM                  ;And negate the value in the FPACC to make it positive
 2457  1050  2E 56        ACZERT:	MVI	L,OFS_FPACC_MSW                      ;Reset pointer to MSW of FPACC
 2458  1052  06 04                   MVI	B,004H                   ;Set precision counter to number of bytes in FPACC
 2459  1054  7E           LOOK0:	MOV	A,M                          ;Plus one. Fetch a byte of the FPACC.
