 3416                     ;;; PATCH NR.1
 3417  1733  21 1E 00     PATCH1:	LXI H,FPACC_LSW_M1
 3418  1736  36 00        	MVI M,000H
 3419  1738  21 25 00     	LXI H,FPOP_EXT_5B
 3420  173B  36 00        	MVI M,000H
 3421  173D  C9           	RET
 3422                     
 3423  173E  21 97 15     NEXT:	LXI H,AUX_SYMBOL_BUF            ;Load HL with start of AUX SYMBOL BUFFER
 3424  1741  36 00        	MVI M,000H                      ;Initialize AUX SYMBOL BUFFER by clearing first byte
 3425  1743  21 B5 15     	LXI H,SCAN_PTR                  ;Change L to address of SCAN pointer
 3426  1746  46           	MOV B,M                         ;Fetch pointer value to CPU register B
 3427  1747  04           	INR B                           ;Add one to the current pointer value
 3428  1748  21 B4 15     	LXI H,SYNTAX_PTR                ;Load L with address of NEXT pointer storage location
 3429  174B  70           	MOV M,B                         ;Place the updated SCAN pointer as the NEXT pointer
 3430  174C  21 B4 15     NEXT1:	LXI H,SYNTAX_PTR                ;Reset L to address of NEXT pointer storage location
 3431  174F  CD 7C 01     	CALL GETCHR                     ;Fetch the character pointed to by the NEXT pointer
 3432  1752  CA 5B 17     	JZ NEXT2                        ;If the character is a space, ignore it
 3433  1755  21 97 15     	LXI H,AUX_SYMBOL_BUF            ;Else, load L with start of AUX SYMBOL BUFFER
 3434  1758  CD AA 01     	CALL CONCT1                     ;Concatenate the character onto the AUX SYMBOL BF
 3435  175B  21 B4 15     NEXT2:	LXI H,SYNTAX_PTR                ;Reset L to address of NEXT pointer storage location
 3436  175E  CD DF 01     	CALL LOOP                       ;Advance the NEXT pointer and see if end of line
 3437  1761  C2 4C 17     	JNZ NEXT1                       ;Fetch next character in line if not end of line
 3438  1764  21 97 15     	LXI H,AUX_SYMBOL_BUF            ;When reach end of line, should have variable name
 3439  1767  7E           	MOV A,M                         ;In the AUX SYMBOL BUFFER. Fetch the (cc) for
 3440  1768  FE 01        	CPI 001H                        ;The buffer and see if variable name is just one letter
 3441  176A  C2 72 17     	JNZ NEXT3                       ;If more than one proceed directly to look for name
 3442  176D  21 34 00     	LXI H,FP_WORK_66                ;In FOR/NEXT STACK. If have just a one letter name
 3443  1770  36 00        	MVI M,000H                      ;Then set second character in buffer to zero
 3444  1772  21 B3 16     NEXT3:	LXI H,TEMP_085                  ;Load HL with address of FOR/NEXT STACK pointer
 3445  1775  7E           	MOV A,M                         ;Fetch the FOR/NEXT STACK pointer value to ACC
 3446  1776  07           	RLC                             ;Rotate value left to multiply by two. Then rotate it
 3447  1777  07           	RLC                             ;Left again to multiply by four for stack entry offset
 3448  1778  C6 02        	ADI 002H                        ;Add 2 to point to variable name in stack entry
 3449  177A  4F           	MOV C,A                         ;Save offset in C
 3450  177B  06 00        	MVI B,000H                      ;Clear B for 16-bit add
 3451  177D  21 93 16     	LXI H,FN_STACK                  ;Load HL with base of FOR/NEXT STACK
 3452  1780  09           	DAD B                           ;Add offset to get variable name location
 3453  1781  11 98 15     	LXI D,AUX_SYMBOL_BUF+1          ;Set DE to first character in the AUX SYMBOL BUFFER
 3454  1784  06 02        	MVI B,002H                      ;Set B to serve as a character counter
 3455  1786  CD D6 01     	CALL STRCPC                     ;See if variable name in the NEXT statement same as
 3456  1789  CA 93 17     	JZ NEXT4                        ;That stored in the top of the FOR/NEXT STACK
 3457  178C  3E C6        FORNXT:	MVI A,0C6H                      ;Load ACC with ASCII code for letter F
 3458  178E  0E CE        	MVI C,0CEH                      ;Load register C with ASCII code for letter N
 3459  1790  C3 72 01     	JMP ERROR                       ;Display For/Next (FN) error message if required
 3460  1793  21 23 16     NEXT4:	LXI H,USER_PGM_PTR              ;Load L with address of user program line pointer
 3461  1796  56           	MOV D,M                         ;Fetch the page portion of the line pointer into D
 3462  1797  23           	INX H                           ;Advance the memory pointer
 3463  1798  5E           	MOV E,M                         ;Fetch the low portion of the line pointer into E
 3464  1799  23           	INX H                           ;Advance pntr to AUXILIARY LINE POINTER storage
 3465  179A  72           	MOV M,D                         ;Location and store value of line pointer there too (page)
 3466  179B  23           	INX H                           ;Advance pointer to second byte of AUXILIARY line
 3467  179C  73           	MOV M,E                         ;Pointer and store value of line pointer (low portion)
 3468  179D  21 B3 16     	LXI H,TEMP_085                  ;Load HL with address of FOR/NEXT STACK pointer
 3469  17A0  7E           	MOV A,M                         ;Fetch the FOR/NEXT STACK pointer value to ACC
 3470  17A1  07           	RLC                             ;Rotate value left to multiply by two. Then rotate it
 3471  17A2  07           	RLC                             ;Left again to multiply by four for stack entry offset
 3472  17A3  4F           	MOV C,A                         ;Save offset in C
 3473  17A4  06 00        	MVI B,000H                      ;Clear B for 16-bit add
 3474  17A6  21 93 16     	LXI H,FN_STACK                  ;Load HL with base of FOR/NEXT STACK
 3475  17A9  09           	DAD B                           ;Add offset to point to top of stack entry
 3476  17AA  56           	MOV D,M                         ;Fetch page address of the associated FOR line pointer
 3477  17AB  23           	INX H                           ;Advance the pointer
 3478  17AC  5E           	MOV E,M                         ;Fetch the low address value into E
 3479  17AD  21 23 16     	LXI H,USER_PGM_PTR              ;Program line pointer to the FOR statement line by
 3480  17B0  72           	MOV M,D                         ;Place the page value in the pointer storage location
 3481  17B1  23           	INX H                           ;Advance the memory pointer
 3482  17B2  73           	MOV M,E                         ;Place the low value in the pointer storage location
 3483  17B3  62           	MOV H,D                         ;Now set up H and L to point to the start of the
 3484  17B4  6B           	MOV L,E                         ;Associated FOR statement line in the user pgm buffer
 3485  17B5  11 37 15     	LXI D,LINE_INP_BUF              ;And set L to the gtart of the line input buffer
 3486  17B8  CD F6 08     	CALL MOVEC                      ;Move the associated FOR statement line into the input
 3487  17BB  21 87 00     	LXI H,KW_TO                     ;Line buffer. Set L to point to start of TO string which is
 3488  17BE  CD D1 09     	CALL INSTR                      ;Search the statement line for the occurrence of TO
 3489  17C1  7B           	MOV A,E                         ;Register E will be zero if TO not found. Move E to ACC
 3490  17C2  A7           	ANA A                           ;To make a test. If TO found then proceed to set up for
 3491  17C3  CA 8C 17     	JZ FORNXT                       ;Evaluation. If TO not found, then have error condition.
 3492  17C6  C6 02        	ADI 002H                        ;Advance the pointer over the characters in TO string
 3493  17C8  21 F1 15     	LXI H,EVAL_PTR                  ;Change L to point to EVAL pointer storage location
 3494  17CB  77           	MOV M,A                         ;Position for the EVAL subroutine (after TO string)
 3495  17CC  21 8A 00     	LXI H,KW_STEP                   ;Set L to point to start of STEP string which is stored
 3496  17CF  CD D1 09     	CALL INSTR                      ;Statement line for the occurrence of STEP
 3497  17D2  7B           	MOV A,E                         ;Register E will be zero if STEP not found. Move E to
 3498  17D3  A7           	ANA A                           ;The accumulator to make a test. If STEP found must
 3499  17D4  C2 F7 17     	JNZ NEXT5                       ;Evaluate expression after STEP to get STEP SIZE.
 3500  17D7  21 03 00     	LXI H,FP_CONST_1                ;Else, have an IMPLIED STEP SIZE of 1.0. Set pointer
 3501  17DA  CD B1 11     	CALL FLOAD                      ;Format and call subroutine to load FPACC with 1.0
 3502  17DD  21 6C 00     	LXI H,FN_STEP                   ;Set L to start of FOR/NEXT STEP SIZE storage loc.
 3503  17E0  CD B9 11     	CALL FSTORE                     ;Store the value 1.0 in the F/N STEP SIZE registers
 3504  17E3  21 37 15     	LXI H,LINE_INP_BUF              ;Change L to the start of the input line buffer
 3505  17E6  46           	MOV B,M                         ;Fetch the (cc) into CPU register B (length of FOR line)
 3506  17E7  21 F2 15     	LXI H,EVAL_FINISH               ;Change L to EVAL FINISH pointer stomge location
 3507  17EA  70           	MOV M,B                         ;Set the EVAL FINISH pointer to the end of the line
 3508  17EB  CD 6C 02     	CALL EVAL                       ;Evaluate the LIMIT expression to obtain FOR LIMIT
 3509  17EE  21 70 00     	LXI H,FN_LIMIT                  ;Load L with address of start of F/N LIMIT registers
 3510  17F1  CD B9 11     	CALL FSTORE                     ;MGA 3/31/12 no lab here Store the FOR/NEXT LIMIT value
 3511  17F4  C3 1E 18     	JMP NEXT6                       ;Since have IMPLIED STEP jump ahead
 3512  17F7  1D           NEXT5:	DCR E                           ;MGA 3/21/12 lab here When have STEP directive, subtract one from pointer
 3513  17F8  21 F2 15     	LXI H,EVAL_FINISH               ;To get to character before S in STEP. Save this value in
 3514  17FB  73           	MOV M,E                         ;As evaluation end location when obtaining TO Iiinit
 3515  17FC  CD 6C 02     	CALL EVAL                       ;Evaluate the LIMIT expression to obtain FOR LIMIT
 3516  17FF  21 70 00     	LXI H,FN_LIMIT                  ;Load L with address of start of FIN LIMIT registers
 3517  1802  CD B9 11     	CALL FSTORE                     ;Store the FOR/NEXT LIMIT value
 3518  1805  21 F2 15     	LXI H,EVAL_FINISH               ;Reset L to EVAL FINISH pointer storage location
 3519  1808  7E           	MOV A,M                         ;Fetch the pointer value (character before S in STEP)
 3520  1809  C6 05        	ADI 005H                        ;Add five to change pointer to character after P in STEP
 3521  180B  2B           	DCX H                           ;Decrement L to point to EVAL (start) pointer
 3522  180C  77           	MOV M,A                         ;Set up the starting position for the EVAL subroutine
 3523  180D  21 37 15     	LXI H,LINE_INP_BUF              ; Load L with starting address of the line input buffer
 3524  1810  46           	MOV B,M                         ;Fetch the (cc) for the line input buffer (line length)
 3525  1811  21 F2 15     	LXI H,EVAL_FINISH               ;Change L to the EVAL FINISH storage location
 3526  1814  70           	MOV M,B                         ;Set the EVAL FINISH pointer
 3527  1815  CD 6C 02     	CALL EVAL                       ;Evaluate the STEP SIZE expression
 3528  1818  21 6C 00     	LXI H,FN_STEP                   ;Load L with address of start of F/N STEP registers
 3529  181B  CD B9 11     	CALL FSTORE                     ;Store the FOR/NEXT STEP SIZE value
 3530  181E  21 97 15     NEXT6:	LXI H,AUX_SYMBOL_BUF            ;Load HL with address of AUX SYMBOL BUFFER
 3531  1821  36 00        	MVI M,000H                      ;Initialize AUX SYMBOL BUFFER with a zero byte
 3532  1823  21 9C 00     	LXI H,KW_FOR                    ;Set HL to start of FOR string in keyword table
 3533  1826  CD D1 09     	CALL INSTR                      ;Search the statement line for the FOR directive
 3534  1829  7B           	MOV A,E                         ;Register E will be zero if FOR not found. Move E to
 3535  182A  A7           	ANA A                           ;ACC and -make test to see if FOR directive located
 3536  182B  21 B5 15     	LXI H,SCAN_PTR                  ;Load L with address of SCAN pointer
 3537  182E  77           	MOV M,A                         ;Set up pointer to occurrence of FOR directive in line
 3538  182F  CA 8C 17     	JZ FORNXT                       ;If FOR not found, have an error condition
 3539  1832  C6 03        	ADI 003H                        ;If have FOR, add three to advance pointer over FOR
 3540  1834  21 B6 15     	LXI H,TOKEN_STORE               ;Set L to point to F/N pointer storage location
 3541  1837  77           	MOV M,A                         ;Set F/N pointer to character after FOR directive
 3542  1838  21 B6 15     NEXT7:	LXI H,TOKEN_STORE               ;Set L to point to FIN pointer storage location
 3543  183B  CD 7C 01     	CALL GETCHR                     ;Fetch a character from position pointed to by FIN pntr
 3544  183E  CA 4C 18     	JZ NEXT8                        ;If character is a space, ignore it
 3545  1841  FE BD        	CPI 0BDH                        ;Else, test to see if character is "=" sign
 3546  1843  CA 58 18     	JZ NEXT9                        ;If yes, have picked up variable name, jump ahead
 3547  1846  21 97 15     	LXI H,AUX_SYMBOL_BUF            ;If not, set L to the start of the AUX SYMBOL BUFFER
 3548  1849  CD AA 01     	CALL CONCT1                     ;And store the character in the AUX SYMBOL BUFFER
 3549  184C  21 B6 15     NEXT8:	LXI H,TOKEN_STORE               ;Load L with address of the F/N pointer
 3550  184F  CD DF 01     	CALL LOOP                       ;Increment the pointer and see if end of the line
 3551  1852  C2 38 18     	JNZ NEXT7                       ;If not, continue fetching characters
 3552  1855  C3 8C 17     	JMP FORNXT                      ;If end of line before "=" sign then have error condx
 3553  1858  21 B5 15     NEXT9:	LXI H,SCAN_PTR                  ;Load L with address of SCAN pointer
 3554  185B  7E           	MOV A,M                         ;Fetch pointer value to ACC (points to start of FOR
 3555  185C  C6 03        	ADI 003H                        ;Directive) and add three to move pointer over FOR
 3556  185E  21 F1 15     	LXI H,EVAL_PTR                  ;Directive. Change L to EVAL pointer storage location
 3557  1861  77           	MOV M,A                         ;Set EVAL pointer to character after FOR in line
 3558  1862  21 B6 15     	LXI H,TOKEN_STORE               ;Load L with address of FIN pointer storage location
 3559  1865  46           	MOV B,M                         ;Fetch pointer to register B (points to "=" sign) and
 3560  1866  05           	DCR B                           ;Decrement the pointer (to character before "=" sign)
 3561  1867  21 F2 15     	LXI H,EVAL_FINISH               ;Load L with address of EVAL FINISH pointer
 3562  186A  70           	MOV M,B                         ;Set EVAL FINISH pointer
 3563  186B  CD 6C 02     	CALL EVAL                       ;Call subroutine to obtain current value of the variable
 3564  186E  21 6C 00     	LXI H,FN_STEP                   ;Load L with address of start of F/N STEP registers
 3565  1871  CD C9 11     	CALL FACXOP                     ;Call subroutine to set up FP registers for addition
 3566  1874  CD 66 0F     	CALL FPADD                      ;Add FIN STEP size to current VARIABLE value
 3567  1877  21 74 00     	LXI H,FN_TEMP                   ;Load L with address of FIN TEMP storage registers
 3568  187A  CD B9 11     	CALL FSTORE                     ;Save the result of the addition in F/N TEMP registers
 3569  187D  21 70 00     	LXI H,FN_LIMIT                  ;Load L with starting address of F/N LIMIT registers
 3570  1880  CD C9 11     	CALL FACXOP                     ;Call subroutine to set up FP registers for subtraction
 3571  1883  CD 03 10     	CALL FPSUB                      ;Subtract F/N LIMIT value from VARIABLE value
 3572  1886  21 6E 00     	LXI H,FN_STEP_C6                ;Set pointer to MSW of F/N STEP registers
 3573  1889  7E           	MOV A,M                         ;Fetch this value into the ACC
 3574  188A  A7           	ANA A                           ;Test to see if STEP value might be zero
 3575  188B  21 21 00     	LXI H,FPACC_MSW                 ;Load L with address of MSW of FPACC
 3576  188E  7E           	MOV A,M                         ;Fetch this value into the ACC
 3577  188F  CA 8C 17     	JZ FORNXT                       ;If STEP size was zero, then endless loop, an error condx
 3578  1892  FA AF 18     	JM NEXT11                       ;If STEP size less than zero make alternate test on limit
 3579  1895  A7           	ANA A                           ;Test the contents of the MSW of the FPACC
 3580  1896  FA B6 18     	JM NEXT12                       ;Continue FORINEXT loop if current variable value is
 3581  1899  CA B6 18     	JZ NEXT12                       ;Less than or equal to the F/N LIMIT value
 3582  189C  21 26 16     NEXT10:	LXI H,AUX_PGM_PTR+1             ;If out of LIMIT range, load HL with addr of the AUX
 3583  189F  5E           	MOV E,M                         ;PGM LINE pointer low byte. Fetch low part into E
 3584  18A0  2B           	DCX H                           ;Decrement to AUX PGM LINE pointer high byte
 3585  18A1  56           	MOV D,M                         ;Fetch the page part into D
 3586  18A2  2B           	DCX H                           ;Decrement to USER PGM PTR low byte
 3587  18A3  73           	MOV M,E                         ;Copy AUX low byte to USER low byte
 3588  18A4  2B           	DCX H                           ;Decrement to USER PGM PTR high byte
 3589  18A5  72           	MOV M,D                         ;Copy AUX high byte to USER high byte
 3590  18A6  21 B3 16     	LXI H,TEMP_085                  ;Set HL to address of FOR/NEXT STACK pointer
 3591  18A9  46           	MOV B,M                         ;Fetch and decrement the
 3592  18AA  05           	DCR B                           ;FOR/NEXT STACK pointer value
 3593  18AB  70           	MOV M,B                         ;To perform effective popping operation
 3594  18AC  C3 11 0A     	JMP NXTLIN                      ;Statement line after NEXT statement is done next
 3595  18AF  A7           NEXT11:	ANA A                           ;When F/N STEP is negative, reverse test so that if the
 3596  18B0  F2 B6 18     	JP NEXT12                       ;Variable value is greater than or equal to the F/N LIMIT
 3597  18B3  C3 9C 18     	JMP NEXT10                      ;The FOR/NEXT loop continues. Else it is finished.
 3598  18B6  21 74 00     NEXT12:	LXI H,FN_TEMP                   ;Load L with address of FIN TEMP storage registers
 3599  18B9  CD B1 11     	CALL FLOAD                      ;Transfer the updated variable value to the FPACC
 3600  18BC  CD 9D 07     	CALL RESTSY                     ;Restore the variable name and value
 3601  18BF  CD 25 07     	CALL STOSYM                     ;In the VARIABLES table. Exit routine so that
 3602  18C2  C3 11 0A     	JMP NXTLIN                      ;Statement line after FOR statement is done next
 3603                     
 3604                     
 3605  18C5  3E 8D        BACKSP:	MVI A,08DH                      ;Load ASCII code for carriage-return into the ACC
 3606  18C7  CD 5B 02     	CALL ECHO                       ;Display the carriage-return
 3607  18CA  CD 5B 02     	CALL ECHO                       ;Repeat to provide extra time if TTY
 3608  18CD  21 60 00     	LXI H,COL_COUNTER               ;Load L with address of COLUMN COUNTER
 3609  18D0  36 01        	MVI M,001H                      ;Set COLUMN COUNTER to first column
 3610  18D2  21 1F 00     	LXI H,FPACC                     ;Set L to address containing desired TAB position
 3611  18D5  7E           	MOV A,M                         ;Fetch the desired TAB position value
 3612  18D6  A7           	ANA A                           ;Test to see if it is
 3613  18D7  F8           	RM                              ;Negative or zero
 3614  18D8  C8           	RZ                              ;In which case return to caller
 3615  18D9  C3 09 07     	JMP TAB1                        ;Else, proceed to perform the TAB operation.
