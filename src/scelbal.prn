 2841                                                       ;Main Decimal INPUT subroutine to convert strings of
 2842                                                       ;ASCII characters representing decimal fixed or floating
 2843                                                       ;point numbers to binary floating point numbers.
 2844                     
 2845  12DD  5D           DINPUT:	MOV E,L                         ;Save entry value of register L in E. (Pointer to buffer
 2846  12DE  54           	MOV D,H                         ;Containing ASCII character string.) Do same for H to D.
 2847  12DF  21 36 00     	LXI H,FP_WORK_68                ;Set L to start of decirnal-to-binary working area
 2848  12E2  AF           	XRA A                           ;Clear the accumulator
 2849  12E3  06 08        	MVI B,008H                      ;Set up a loop counter
 2850  12E5  77           CLRNX2:	MOV M,A                         ;Deposit zero in working area to initialize
 2851  12E6  23           	INX H                           ;Advance the memory pointer
 2852  12E7  05           	DCR B                           ;Decrement the loop counter
 2853  12E8  C2 E5 12     	JNZ CLRNX2                      ;Clear working area until loop counter is zero
 2854  12EB  21 67 00     	LXI H,SIGN_IND2                 ;Set pointer to floating point temporary registers and
 2855  12EE  06 04        	MVI B,004H                      ;Indicators working area. Set up a loop counter.
 2856  12F0  77           CLRNX3:	MOV M,A                         ;Deposit zero in working area to initialize
 2857  12F1  23           	INX H                           ;Advance the memory pointer
 2858  12F2  05           	DCR B                           ;Decrement the loop counter
 2859  12F3  C2 F0 12     	JNZ CLRNX3                      ;Clear working area until loop counter is zero
 2860  12F6  CD B2 12     	CALL GETINP                     ;Fetch a character from the ASCII chax string buffer
 2861  12F9  FE AB        	CPI 0ABH                        ;(Typically the SYMBOL/TOKEN buffer). See if it is
 2862  12FB  CA 07 13     	JZ NINPUT                       ;Code for + sign. Jump ahead if code for + sign.
 2863  12FE  FE AD        	CPI 0ADH                        ;See if code for minus (-) sign.
 2864  1300  C2 0A 13     	JNZ NOTPLM                      ;Jump ahead if not code for minus sign. If code for
 2865  1303  21 67 00     	LXI H,SIGN_IND2                 ;Minus sign, set pointer to MINUS flag storage location.
 2866  1306  77           	MOV M,A                         ;Set the MINUS flag to indicate a minus number
 2867  1307  CD B2 12     NINPUT:	CALL GETINP                     ;Fetch another character from the ASCII char string
 2868  130A  FE AE        NOTPLM:	CPI 0AEH                        ;See if character represents a period (decimal point) in
 2869  130C  CA 3D 13     	JZ PERIOD                       ;Input string. Jump ahead if yes.
 2870  130F  FE C5        	CPI 0C5H                        ;If not period, see if code for E as in Exponent
 2871  1311  CA 4F 13     	JZ FNDEXP                       ;Jump ahead if yes.
 2872  1314  FE A0        	CPI 0A0H                        ;Else see if code for space.
 2873  1316  CA 07 13     	JZ NINPUT                       ;Ignore space character, go fetch another character.
 2874  1319  A7           	ANA A                           ;If none of the above see if zero byte
 2875  131A  CA 89 13     	JZ ENDINP                       ;Indicating end of input char string. If yes, jumn ahead.
 2876  131D  FE B0        	CPI 0B0H                        ;If not end of string, check to see
 2877  131F  FA 5B 0A     	JM NUMERR                       ;If character represents
 2878  1322  FE BA        	CPI 0BAH                        ;A valid decimal number (0 to 9)
 2879  1324  F2 5B 0A     	JP NUMERR                       ;Display error message if not a valid digit at this point!
 2880  1327  21 3C 00     	LXI H,FP_WORK_6E                ;For valid digit, set pointer to MSW of temporary
 2881  132A  4F           	MOV C,A                         ;Decimal to binary holding registers. Save character in C.
 2882  132B  3E F8        	MVI A,0F8H                      ;Form mask for sizing in accumulator. Now see if
 2883  132D  A6           	ANA M                           ;Holding register has enough room for the conversion of
 2884  132E  C2 07 13     	JNZ NINPUT                      ;Another digit. Ignore the input if no more room.
 2885  1331  21 6A 00     	LXI H,INP_DIG_CNT               ;If have room in register then set pointer to input digit
 2886  1334  46           	MOV B,M                         ;Counter location. Fetch the present value.
 2887  1335  04           	INR B                           ;Increment it to account for incoming digit.
 2888  1336  70           	MOV M,B                         ;Restore updated count to storage location.
 2889  1337  CD F6 13     	CALL DECBIN                     ;Call the DECimal to BINary conversion routine to add
 2890  133A  C3 07 13     	JMP NINPUT                      ;In the new digit in holding registers. Continue inputting.
 2891  133D  47           PERIOD:	MOV B,A                         ;Save character code in register B
 2892  133E  21 6B 00     	LXI H,TEMP_STORE                ;Set pointer to PERIOD indicator storage location
 2893  1341  7E           	MOV A,M                         ;Fetch value in PERIOD indicator
 2894  1342  A7           	ANA A                           ;Exercise CPU flags
 2895  1343  C2 5B 0A     	JNZ NUMERR                      ;If already have a period then display error message
 2896  1346  21 6A 00     	LXI H,INP_DIG_CNT               ;If not, change pointer to digit counter storage location
 2897  1349  77           	MOV M,A                         ;Clear the digit counter back to zero
 2898  134A  23           	INX H                           ;Advance pointer to PERIOD indicator
 2899  134B  70           	MOV M,B                         ;Set the PERIOD indicator
 2900  134C  C3 07 13     	JMP NINPUT                      ;Continue processing the input character string
 2901  134F  CD B2 12     FNDEXP:	CALL GETINP                     ;Get next character in Exponent
 2902  1352  FE AB        	CPI 0ABH                        ;See if it is code for + sign
 2903  1354  CA 60 13     	JZ EXPINP                       ;Jump ahead if yes.
 2904  1357  FE AD        	CPI 0ADH                        ;If not + sign, see if minus sign
 2905  1359  C2 63 13     	JNZ NOEXPS                      ;If not minus sign then jump ahead
 2906  135C  21 69 00     	LXI H,EXP_SIGNS                 ;For minus sign, set pointer to EXP SIGN indicator
 2907  135F  77           	MOV M,A                         ;Set the EXP SIGN indicator for a minus exponent
 2908  1360  CD B2 12     EXPINP:	CALL GETINP                     ;Fetch the next character in the decimal exponent
 2909  1363  A7           NOEXPS:	ANA A                           ;Exercise the CPU flags
 2910  1364  CA 89 13     	JZ ENDINP                       ;If character inputted was zero, then end of input string
 2911  1367  FE B0        	CPI 0B0H                        ;If not end of string, check to see
 2912  1369  FA 5B 0A     	JM NUMERR                       ;If character represents
 2913  136C  FE BA        	CPI 0BAH                        ;A valid decimal number (0 to 9)
 2914  136E  F2 5B 0A     	JP NUMERR                       ;Display error message if not a valid digit at this point!
 2915  1371  E6 0F        	ANI 00FH                        ;Else trim the ASCII code to BCD
 2916  1373  47           	MOV B,A                         ;And save in register B
 2917  1374  21 3D 00     	LXI H,FP_WORK_6F                ;Set pointer to input exponent storage location
 2918  1377  3E 03        	MVI A,003H                      ;Set accumulator equal to three
 2919  1379  BE           	CMP M                           ;See if any previous digit in exponent greater than three
 2920  137A  FA 5B 0A     	JM NUMERR                       ;Display error message if yes
 2921  137D  4E           	MOV C,M                         ;Else save any previous value in register C
 2922  137E  7E           	MOV A,M                         ;And also place any previous value in accumulator
 2923  137F  A7           	ANA A                           ;Clear the carry bit with this instruction
 2924  1380  17           	RAL                             ;Single precision multiply by ten algorithm
 2925  1381  17           	RAL                             ;Two rotate lefts equals times four
 2926  1382  81           	ADD C                           ;Adding in the digit makes total times five
 2927  1383  17           	RAL                             ;Rotating left again equals times ten
 2928  1384  80           	ADD B                           ;now add in digit just inputted
 2929  1385  77           	MOV M,A                         ;Restore the value to exponent storage location
 2930  1386  C3 60 13     	JMP EXPINP                      ;Go get any additional exponent int)ut
 2931  1389  21 67 00     ENDINP:	LXI H,SIGN_IND2                 ;Set pointer to mantissa SIGN indicator
 2932  138C  7E           	MOV A,M                         ;Fetch the SIGN indicator to the acclimulator
 2933  138D  A7           	ANA A                           ;Exercise the CPU flags
 2934  138E  CA 99 13     	JZ FININP                       ;If SIGN indicator is zero, go finish up as nr is positive
 2935  1391  21 3A 00     	LXI H,FP_WORK_6C                ;But, if indicator is non-zero, number is negative
 2936  1394  06 03        	MVI B,003H                      ;Set pntr to LSW of storage registers, set precision entr
 2937  1396  CD 2B 12     	CALL COMPLM                     ;Negate the triple-precision number in holding registers
 2938  1399  21 39 00     FININP:	LXI H,FP_WORK_6B                ;Set pointer to input storage LSW minus one
 2939  139C  AF           	XRA A                           ;Clear the accumulator
 2940  139D  77           	MOV M,A                         ;Clear the LSW minus one location
 2941  139E  11 1E 00     	LXI D,FPACC_LSW_M1              ;Set DE to address of FPACC LSW minus one
 2942  13A1  06 04        	MVI B,004H                      ;Set precision counter
 2943  13A3  CD 90 10     	CALL MOVEIT                     ;Move number from input register to FPACC
 2944  13A6  CD 90 0F     	CALL FPFLT                      ;Now convert the binary fixed point to floating point
 2945  13A9  21 69 00     	LXI H,EXP_SIGNS                 ;Set pointer to Exponent SIGN indicator location
 2946  13AC  7E           	MOV A,M                         ;Fetch the value of the EXP SIGN indicator
 2947  13AD  A7           	ANA A                           ;Exercise the CPU flags
 2948  13AE  21 3D 00     	LXI H,FP_WORK_6F                ;Reset pointer to input exponent storage location
 2949  13B1  CA BA 13     	JZ POSEXP                       ;If EXP SIGN indicator zero, exponent is positive
 2950  13B4  7E           	MOV A,M                         ;Else, exponent is negative so must negate
 2951  13B5  EE FF        	XRI 0FFH                        ;The value in the input exponent storage location
 2952  13B7  C6 01        	ADI 001H                        ;By performing this two's complement
 2953  13B9  77           	MOV M,A                         ;Restore the negated value to exponent storage location
 2954  13BA  21 6B 00     POSEXP:	LXI H,TEMP_STORE                ;Set pointer to PERIOD indicator storage location
 2955  13BD  7E           	MOV A,M                         ;Fetch the contents of the PERIOD indicator
 2956  13BE  A7           	ANA A                           ;Exercise the CPU flags
 2957  13BF  CA C7 13     	JZ EXPOK                        ;If PERIOD indicator clear, no decimal point involved
 2958  13C2  21 6A 00     	LXI H,INP_DIG_CNT               ;If have a decimal point, set pointer to digit counter
 2959  13C5  AF           	XRA A                           ;Storage location. Clear the accumulator.
 2960  13C6  96           	SUB M                           ;And get a negated value of the digit counter in ACC
 2961  13C7  21 3D 00     EXPOK:	LXI H,FP_WORK_6F                ;Change pointer to input exponent storage location
 2962  13CA  86           	ADD M                           ;Add this value to negated digit counter value
 2963  13CB  77           	MOV M,A                         ;Restore new value to storage location
 2964  13CC  FA E3 13     	JM MINEXP                       ;If new value is minus, skip over next subroutine
 2965  13CF  C8           	RZ                              ;If new value is zero, no further processing required
 2966                     
 2967                                                       ;Following subroutine will multiply the floating point
 2968                                                       ;binary number stored in FPACC by ten tirnes the
 2969                                                       ;value stored in the deciinal exponent storage location.
 2970                     
 2971  13D0  21 0B 00     FPX10:	LXI H,FP_CONST_10               ;Set pointer to registers containing floating point 10
 2972  13D3  CD 7F 12     	CALL FACXOP                     ;Transfer FPACC to FPOP and 10 (dec) to FPACC
 2973  13D6  CD AA 10     	CALL FPMULT                     ;Multiply FPOP (formerly FPACC) by 10 (decimal)
 2974  13D9  21 3D 00     	LXI H,FP_WORK_6F                ;Set pointer to decimal exponent storage location
 2975  13DC  4E           	MOV C,M                         ;Fetch the exponent value
 2976  13DD  0D           	DCR C                           ;Decrement
 2977  13DE  71           	MOV M,C                         ;Restore to storage
 2978  13DF  C2 D0 13     	JNZ FPX10                       ;If exponent value is not zero, continue multiplication
 2979  13E2  C9           	RET                             ;When exponent is zero can exit. Conversion completed.
 2980                     
 2981                                                       ;Following subroutine will multiply the floating point
 2982                                                       ;binary number stored in PPACC by 0.1 times the value
 2983                                                       ;(negative) stored in the decimal exponent storage location
 2984                     
 2985                     MINEXP:
 2986  13E3  21 0F 00     FPD10:	LXI H,FP_CONST_0P1              ;Set pointer to registers containing floating point
 2987  13E6  CD 7F 12     	CALL FACXOP                     ;Transfer FPACC to FPOP and 0.1 (dec) to FPACC
 2988  13E9  CD AA 10     	CALL FPMULT                     ;Multitply FPOP (formerly FPACC) by 0.1 (decimal)
 2989  13EC  21 3D 00     	LXI H,FP_WORK_6F                ;Set pointer to decimal exponent storage location
 2990  13EF  46           	MOV B,M                         ;Fetch the exponent value
 2991  13F0  04           	INR B                           ;Increment
 2992  13F1  70           	MOV M,B                         ;Restore to storage
 2993  13F2  C2 E3 13     	JNZ FPD10                       ;If exponent value is not zero, continue multiplication
 2994  13F5  C9           	RET                             ;When exponent is zero can exit. Conversion completed.
 2995                     
 2996                                                       ;Following subroutine is used
 2997                                                       ;to convert decimal charac-
 2998                                                       ;ters to binary fixed point forinat
 2999                                                       ;in a triple-precision format.
 3000                     
 3001  13F6  CD 8E 12     DECBIN:	CALL SAVEHL                     ;Save entry value of D, E, H and L in memory
 3002  13F9  21 39 00     	LXI H,FP_WORK_6B                ;Set pointer to temporary storage location
 3003  13FC  79           	MOV A,C                         ;Restore character inputted to accumulator
 3004  13FD  E6 0F        	ANI 00FH                        ;Trim ASCII code to BCD
 3005  13FF  77           	MOV M,A                         ;Store temporarily
 3006  1400  11 36 00     	LXI D,FP_WORK_68                ;Set pointer to working area LSW of multi-byte register
 3007  1403  21 3A 00     	LXI H,FP_WORK_6C                ;Set another pointer to LSW of conversion register
 3008  1406  06 03        	MVI B,003H                      ;Set precision counter
 3009  1408  CD 90 10     	CALL MOVEIT                     ;Move original value of conversion register to working
 3010  140B  21 3A 00     	LXI H,FP_WORK_6C                ;Register. Reset pointer to LSW of conversion register.
 3011  140E  06 03        	MVI B,003H                      ;Set precision counter
 3012  1410  CD 42 12     	CALL ROTATL                     ;Rotate register left, (Multiplies value by two.)
 3013  1413  21 3A 00     	LXI H,FP_WORK_6C                ;Reset pointer to LSW.
 3014  1416  06 03        	MVI B,003H                      ;Set precision counter
 3015  1418  CD 42 12     	CALL ROTATL                     ;Multiply by two again (total now times four).
 3016  141B  11 3A 00     	LXI D,FP_WORK_6C                ;Set pointer to LSW of conversion register.
 3017  141E  21 36 00     	LXI H,FP_WORK_68                ;Set pointer to LSW of working register (original value).
 3018  1421  06 03        	MVI B,003H                      ;Set precision counter.
 3019  1423  CD 1A 12     	CALL ADDER                      ;Add original value to rotated value (now times five).
 3020  1426  21 3A 00     	LXI H,FP_WORK_6C                ;Reset pointer to LSW
 3021  1429  06 03        	MVI B,003H                      ;Set precision counter
 3022  142B  CD 42 12     	CALL ROTATL                     ;Multiply by two once more (total now times ten).
 3023  142E  21 38 00     	LXI H,FP_WORK_6A                ;Set pointer to clear working register locatiotis
 3024  1431  AF           	XRA A                           ;Clear the accumulator
 3025  1432  77           	MOV M,A                         ;Clear MSW of working register
 3026  1433  2B           	DCX H                           ;Decrement pointer
 3027  1434  77           	MOV M,A                         ;Clear next byte
 3028  1435  21 39 00     	LXI H,FP_WORK_6B                ;Set pointer to current digit storage location
 3029  1438  7E           	MOV A,M                         ;Fetch the current digit
 3030  1439  21 36 00     	LXI H,FP_WORK_68                ;Change pointer to LSW of working register
 3031  143C  77           	MOV M,A                         ;Deposit the current digit in LSW of working register
 3032  143D  11 3A 00     	LXI D,FP_WORK_6C                ;Set pointer to conversion register LSW
 3033  1440  06 03        	MVI B,003H                      ;Set precision counter
 3034  1442  CD 1A 12     	CALL ADDER                      ;Add current digit to conversion register to complete
 3035  1445  C3 9D 12     	JMP RESTHL                      ;Conversion. Exit to caller by restoring CPU registers.
 3036  1448  AF           FPOUT:	XRA A                           ;Clear accumulator
 3037  1449  32 3D 00     	STA FP_WORK_6F                  ;Initialize decimal exponent storage to zero
 3038  144C  21 21 00     	LXI H,FPACC_MSW                 ;Change pointer to FPACC (number to be outputted)
 3039  144F  7E           	MOV A,M                         ;And fetch MSW of FPACC
 3040  1450  A7           	ANA A                           ;Test the contents of MSW of FPACC
 3041  1451  FA 59 14     	JM OUTNEG                       ;If most significant bit of MSW is a one, have a minus nr.
 3042  1454  3E A0        	MVI A,0A0H                      ;Else number is positive, set ASCII code for space for a
 3043  1456  C3 63 14     	JMP AHEAD1                      ;Positive number and go display a space
 3044  1459  21 1F 00     OUTNEG:	LXI H,FPACC                     ;If number in FPACC is negative must negate in order
 3045  145C  06 03        	MVI B,003H                      ;To display. Set pntr to LSW of FPACC & set prec. cntr.
 3046  145E  CD 2B 12     	CALL COMPLM                     ;Negate the number in the FPACC to make it positive
 3047  1461  3E AD        	MVI A,0ADH                      ;But load ACC with ASCII code for minus sign
 3048  1463  CD E4 02     AHEAD1:	CALL ECHO                       ;Call user display driver to output space or minus sign
 3049  1466  21 6D 00     	LXI H,FP_MODE_IND               ;Set pointer to FIXED/FLOAT indicator
 3050  1469  7E           	MOV A,M                         ;Fetch value of FIXED/FLOAT indicator
 3051  146A  A7           	ANA A                           ;Test contents of indicator. If contents are zero, calling
 3052  146B  CA 80 14     	JZ OUTFLT                       ;Routine has directed floating point output format.
 3053  146E  21 22 00     	LXI H,FPACC_EXP                 ;If indicator non-zero, fixed point fonnat requested if
 3054  1471  3E 17        	MVI A,017H                      ;Possible. Point to FPACC Exponent. Put 23 decimal in
 3055  1473  46           	MOV B,M                         ;Accumulator. Fetch FPACC Exponent into register B
 3056  1474  04           	INR B                           ;And exercise the register to test its
 3057  1475  05           	DCR B                           ;Original contents. If FPACC Exponent is negative in
 3058  1476  FA 80 14     	JM OUTFLT                       ;Value then go to floating point output forrnat. If value
 3059  1479  90           	SUB B                           ;Is positive, subtract value from 23 (decimal). If result
 3060  147A  FA 80 14     	JM OUTFLT                       ;Negative, number is too big to use fixed format.
 3061  147D  C3 8E 14     	JMP OUTFIX                      ;Else, can use fixed format so skip next routine
 3062  1480  AF           OUTFLT:	XRA A                           ;Clear accumulator
 3063  1481  32 6D 00     	STA FP_MODE_IND                 ;Clear FIXED/FLOAT indicator for floating point format
 3064  1484  3E B0        	MVI A,0B0H                      ;Load ASCII code for '0' into accumulator
 3065  1486  CD E4 02     	CALL ECHO                       ;Call user display driver to output '0' as first character
 3066  1489  3E AE        	MVI A,0AEH                      ;Number string. Now load ASCII code for decimal point.
 3067  148B  CD E4 02     	CALL ECHO                       ;Call user display driver to output '.'as second character.
 3068  148E  21 22 00     OUTFIX:	LXI H,FPACC_EXP                 ;Set pointer to FPACC Exponent
 3069  1491  3E FF        	MVI A,0FFH                      ;Load accumulator with minus one
 3070  1493  86           	ADD M                           ;Add value in FPACC Exponent
 3071  1494  77           	MOV M,A                         ;Restore compensated exponent value
 3072                     
 3073                                                       ;Next portion of routine establishes the value for the
 3074                                                       ;decimal exponent that will be outputted by processing
 3075                                                       ;the binary exponent value in the FPACC.
 3076                     
 3077  1495  F2 B5 14     DECEXT:	JP DECEXD                       ;If compensated exponent value is zero or positive
 3078  1498  3E 04        	MVI A,004H                      ;Then go multiply FPACC by 0.1 (decimal). Else,
 3079  149A  86           	ADD M                           ;Add four to the exponent value.
 3080  149B  F2 C7 14     	JP DECOUT                       ;If exponent now zero or positive, ready to output
 3081  149E  21 0B 00     	LXI H,FP_CONST_10               ;If exponent negative, multiply FPACC by 10 (decimal)
 3082  14A1  CD 7F 12     	CALL FACXOP                     ;Floating point format. Set up for multiplication.
 3083  14A4  CD AA 10     	CALL FPMULT                     ;Perform the multiplication. Answer in FPACC.
 3084  14A7  21 3D 00     	LXI H,FP_WORK_6F                ;Set pointer to decimal exponent storage location.
 3085  14AA  4E           	MOV C,M                         ;Each time the FPACC is multiplied by ten, need to
 3086  14AB  0D           	DCR C                           ;Decrement the value in the decinial exponent storage
 3087  14AC  71           	MOV M,C                         ;Location. (This establishes decimal exponent value!)
 3088  14AD  21 22 00     DECREP:	LXI H,FPACC_EXP                 ;Reset pointer to FPACC Exponent
 3089  14B0  7E           	MOV A,M                         ;Fetch value in exponent
 3090  14B1  A7           	ANA A                           ;Test value
 3091  14B2  C3 95 14     	JMP DECEXT                      ;Repeat process as required
 3092  14B5  21 0F 00     DECEXD:	LXI H,FP_CONST_0P1              ;If exponent is positive, multiply FPACC by 0.1
 3093  14B8  CD 7F 12     	CALL FACXOP                     ;Floating point format. Set up for multipli(-ation.
 3094  14BB  CD AA 10     	CALL FPMULT                     ;Perform the multiplication. Answer in FPACC.
 3095  14BE  21 3D 00     	LXI H,FP_WORK_6F                ;Set pointer to decimal exponent storage location.
 3096  14C1  46           	MOV B,M                         ;Each time the FPACC is multiplied by one tenth, need
 3097  14C2  04           	INR B                           ;To increment the value in the decimal exponent storage
 3098  14C3  70           	MOV M,B                         ;Location. (This establishes decimal exponent value!)
 3099  14C4  C3 AD 14     	JMP DECREP                      ;Repeat process as required
 3100                     
 3101                                                       ;The next section outputs the mantissa
 3102                                                       ;(or fixed point number) by converting the value remaining
 3103                                                       ;in the FPACC (after the decimal exponent equivalent has
 3104                                                       ;been extracted from the original value if required by the
 3105                                                       ;previous routines) to a string of decirnal digits.
 3106  14C7  11 42 00     DECOUT:	LXI D,FP_WORK_74                ;Set pointer to LSW of output working register
 3107  14CA  21 1F 00     	LXI H,FPACC                     ;Set pointer to LSW of FPACC
 3108  14CD  06 03        	MVI B,003H                      ;Set precision counter
 3109  14CF  CD 90 10     	CALL MOVEIT                     ;Move value in FPACC to output working register
 3110  14D2  AF           	XRA A                           ;Clear accumulator
 3111  14D3  32 45 00     	STA FP_WORK_77                  ;Clear MSW plus one of output working register
 3112  14D6  21 42 00     	LXI H,FP_WORK_74                ;Set pointer to LSW of output working register
 3113  14D9  06 03        	MVI B,003H                      ;Set precision counter
 3114  14DB  CD 42 12     	CALL ROTATL                     ;Rotate register left once to compensate for sign bit
 3115  14DE  CD 7B 15     	CALL OUTX10                     ;Multiply output register by 10, overflow into N4SW+ 1
 3116  14E1  21 22 00     COMPEN:	LXI H,FPACC_EXP                 ;Set pointer back to FPACC Exponent
 3117  14E4  46           	MOV B,M                         ;Compensate for any remainder in the binary exponent
 3118  14E5  04           	INR B                           ;By performing a rotate right on the output working
 3119  14E6  70           	MOV M,B                         ;Register until the binary exponent becomes zero
 3120  14E7  CA F5 14     	JZ OUTDIG                       ;Go output decimal digits when this loop is finished
 3121  14EA  21 45 00     	LXI H,FP_WORK_77                ;Binary exponent compensating loop. Setpointe'r to
 3122  14ED  06 04        	MVI B,004H                      ;Working register MSW+L. Set precision counter.
 3123  14EF  CD 4C 12     	CALL ROTATR                     ;Rotate working register to the right.
 3124  14F2  C3 E1 14     	JMP COMPEN                      ;Repeat loop as required.
 3125  14F5  21 6C 00     OUTDIG:	LXI H,OUT_DIG_CNT               ;Set pointer to output digit counter storage location
 3126  14F8  36 07        	MVI M,007H                      ;Initialize to value of seven
 3127  14FA  21 45 00     	LXI H,FP_WORK_77                ;Change pointer to output working register MSW+L
 3128  14FD  7E           	MOV A,M                         ;Fetch MSW+L byte containing BCD of digit to be
 3129  14FE  A7           	ANA A                           ;Displayed. Test the contents of this byte.
 3130  14FF  CA 5A 15     	JZ ZERODG                       ;If zero jump to ZERODG routine.
 3131  1502  21 45 00     OUTDGS:	LXI H,FP_WORK_77                ;Reset pointer to working register MSW+L
 3132  1505  7E           	MOV A,M                         ;Fetch BCD of digit to be outputted
 3133  1506  A7           	ANA A                           ;Exercise CPU flags
 3134  1507  C2 26 15     	JNZ OUTDGX                      ;If not zero, go display the digit
 3135  150A  21 6D 00     	LXI H,FP_MODE_IND               ;If zero, change pointer to FIXED/FLOAT indicator
 3136  150D  7E           	MOV A,M                         ;Fetch the indicator into the accumulator
 3137  150E  A7           	ANA A                           ;Test value of indicator
 3138  150F  CA 25 15     	JZ OUTZER                       ;If in floating point mode, go display the digit
 3139  1512  21 3D 00     	LXI H,FP_WORK_6F                ;Else change pointer to decimal exponent storage
 3140  1515  4E           	MOV C,M                         ;Location, which, for fixed point, will have a positive
 3141  1516  0D           	DCR C                           ;Value for all digits before the decimal point. Decrement
 3142  1517  0C           	INR C                           ;And increment to exercise flags. See if count is positive.
 3143  1518  F2 25 15     	JP OUTZER                       ;If positive, must display any zero digit.
 3144  151B  21 44 00     	LXI H,FP_WORK_76                ;If not, change pointer to MSW of working register
 3145  151E  7E           	MOV A,M                         ;And test to see if any significant digits coming up
 3146  151F  E6 E0        	ANI 0E0H                        ;By forming a mask and testing for presence of bits
 3147  1521  C2 25 15     	JNZ OUTZER                      ;If more significant digits coming up soon, display the
 3148  1524  C9           	RET                             ;Zero digit. Else, exit to calling routine. Finished.
 3149  1525  AF           OUTZER:	XRA A                           ;Clear the accumulator to restore zero digit value
 3150  1526  C6 B0        OUTDGX:	ADI 0B0H                        ;Add 260 (octal) to BCD code in ACC to form ASCII
 3151  1528  CD E4 02     	CALL ECHO                       ;Code and call the user's display driver subroutine
 3152  152B  21 6D 00     DECRDG:	LXI H,FP_MODE_IND               ;Set pointer to FIXED/FLOAT indicator storage
 3153  152E  7E           	MOV A,M                         ;Fetch the indicator to the accumulator
 3154  152F  A7           	ANA A                           ;Exercise the CPU flags
 3155  1530  C2 42 15     	JNZ CKDECP                      ;If indicator non-zero, doing fixed point output
 3156  1533  21 6C 00     	LXI H,OUT_DIG_CNT               ;Else, get output digit counter
 3157  1536  4E           	MOV C,M
 3158  1537  0D           	DCR C                           ;Decrement the digit counter & restore to storage
 3159  1538  71           	MOV M,C
 3160  1539  CA AE 15     	JZ EXPOUT                       ;When digit counter is zero, go take care of exponent
 3161  153C  CD 7B 15     PUSHIT:	CALL OUTX10                     ;Else push next BCD digit out of working register
 3162  153F  C3 02 15     	JMP OUTDGS                      ;And continue the outputting process
 3163  1542  21 3D 00     CKDECP:	LXI H,FP_WORK_6F                ;For fixed point output, decimal exponent serves as
 3164  1545  4E           	MOV C,M                         ;Counter for number of digits before decimal point
 3165  1546  0D           	DCR C                           ;Fetch the counter and decrement it to account for
 3166  1547  71           	MOV M,C                         ;Current digit being processed. Restore to storage.
 3167  1548  C2 50 15     	JNZ NODECP                      ;If count does not go to zero, jump ahead.
 3168  154B  3E AE        	MVI A,0AEH                      ;When count reaches zero, load ASCII code for period
 3169  154D  CD E4 02     	CALL ECHO                       ;And call user's display driver to display decimal point
 3170  1550  21 6C 00     NODECP:	LXI H,OUT_DIG_CNT               ;Set pointer to output digit counter storage location
 3171  1553  4E           	MOV C,M                         ;Fetch the digit counter
 3172  1554  0D           	DCR C                           ;Decrement the value
 3173  1555  71           	MOV M,C                         ;Restore to storage
 3174  1556  C8           	RZ                              ;If counter reaches zero, exit to caller. Finished.
 3175  1557  C3 3C 15     	JMP PUSHIT                      ;Else continue to output the number.
 3176  155A  21 3D 00     ZERODG:	LXI H,FP_WORK_6F                ;If first digit of floating point number is a zero, set
 3177  155D  4E           	MOV C,M                         ;Pointer to decimal exponent storage location.
 3178  155E  0D           	DCR C                           ;Decrement the value to compensate for skipping
 3179  155F  71           	MOV M,C                         ;Display of first digit. Restore to storage.
 3180  1560  21 44 00     	LXI H,FP_WORK_76                ;Change pointer to MSW of output working register
 3181  1563  7E           	MOV A,M                         ;Fetch MSW of output working register
 3182  1564  A7           	ANA A                           ;Test the contents
 3183  1565  C2 2B 15     	JNZ DECRDG                      ;If non-zero, continue outputting
 3184  1568  2B           	DCX H                           ;Else decrement pointer to next byte in working register
 3185  1569  7E           	MOV A,M                         ;Fetch its contents
 3186  156A  A7           	ANA A                           ;Test
 3187  156B  C2 2B 15     	JNZ DECRDG                      ;If non-zero, continue outputting
 3188  156E  2B           	DCX H                           ;Else decrement pointer to LSW of working register
 3189  156F  7E           	MOV A,M                         ;Fetch its contents
 3190  1570  A7           	ANA A                           ;Test
 3191  1571  C2 2B 15     	JNZ DECRDG                      ;If non-zero, continue outputting
 3192  1574  21 3D 00     	LXI H,FP_WORK_6F                ;If decimal mantissa is zero, set pointer to decirnal
 3193  1577  77           	MOV M,A                         ;Exponent storage and clear it
 3194  1578  C3 2B 15     	JMP DECRDG                      ;Finish outputting
 3195                     
 3196                                                       ;Following routine multiplies the binary number in the
 3197                                                       ;output working register by ten to push the most signifi-
 3198                                                       ;cant digit out to the MSW+L byte.
 3199                     
 3200  157B  AF           OUTX10:	XRA A                           ;Clear accumulator
 3201  157C  32 45 00     	STA FP_WORK_77                  ;Clear MSW+1 in preparation for receiving next digit
 3202  157F  21 42 00     	LXI H,FP_WORK_74                ;Set pointer to working register LSW.
 3203  1582  11 3E 00     	LXI D,FP_WORK_70                ;Set second pointer to LSW of second working register
 3204  1585  06 04        	MVI B,004H                      ;Set precision counter
 3205  1587  CD 90 10     	CALL MOVEIT                     ;Move first working register into second
 3206  158A  21 42 00     	LXI H,FP_WORK_74                ;Reset pointer to LSW of first working register
 3207  158D  06 04        	MVI B,004H                      ;Set precision counter
 3208  158F  CD 42 12     	CALL ROTATL                     ;Rotate contents of first working register left (X 2)
 3209  1592  21 42 00     	LXI H,FP_WORK_74                ;Reset pointer to LSW
 3210  1595  06 04        	MVI B,004H                      ;Reset precision counter
 3211  1597  CD 42 12     	CALL ROTATL                     ;Rotate contents left again (X 4)
 3212  159A  21 3E 00     	LXI H,FP_WORK_70                ;Set pointer to LSW of original value in 2'nd register
 3213  159D  11 42 00     	LXI D,FP_WORK_74                ;Set pointer to LSW of rotated value
 3214  15A0  06 04        	MVI B,004H                      ;Set precision counter
 3215  15A2  CD 1A 12     	CALL ADDER                      ;Add rotated value to original value (X 5)
 3216  15A5  21 42 00     	LXI H,FP_WORK_74                ;Reset pointer to LSW of first working register
 3217  15A8  06 04        	MVI B,004H                      ;Set precision counter
 3218  15AA  CD 42 12     	CALL ROTATL                     ;Rotate contents left again (X 10)
 3219  15AD  C9           	RET                             ;Exit to calling routine
 3220                     
 3221                                                       ;The final group of routines in the floating point output
 3222                                                       ;section take care of outputting the decimal exponent
 3223                                                       ;portion of floating point numbers.
 3224                     
 3225  15AE  21 3D 00     EXPOUT:	LXI H,FP_WORK_6F                ;Set pointer to decimal exponent storage location
 3226  15B1  7E           	MOV A,M                         ;Fetch value to the accumulator
 3227  15B2  A7           	ANA A                           ;Test the value
 3228  15B3  C8           	RZ                              ;If zero, then no exponent portion. Exit to caller.
 3229  15B4  3E C5        	MVI A,0C5H                      ;Else, load ACC with ASCII code for letter E.
 3230  15B6  CD E4 02     	CALL ECHO                       ;Display E for Exponent via user's display driver rtn
 3231  15B9  7E           	MOV A,M                         ;Get decimal exponent value back into ACC
 3232  15BA  A7           	ANA A                           ;Test again
 3233  15BB  FA C3 15     	JM EXOUTN                       ;If value is negative, skip ahead
 3234  15BE  3E AB        	MVI A,0ABH                      ;If positive, load ASCII code for + sign
 3235  15C0  C3 CA 15     	JMP AHEAD2                      ;Jump to display the + sign
 3236  15C3  EE FF        EXOUTN:	XRI 0FFH                        ;When decimal exponent is negative, must negate
 3237  15C5  C6 01        	ADI 001H                        ;Value for display purposes. Perform two's complement
 3238  15C7  77           	MOV M,A                         ;And restore the negated value to storage location
 3239  15C8  3E AD        	MVI A,0ADH                      ;Load ASCII code for minus sign
 3240  15CA  CD E4 02     AHEAD2:	CALL ECHO                       ;Display the ASCII character in ACC
 3241  15CD  06 00        	MVI B,000H                      ;Clear register B
 3242  15CF  7E           	MOV A,M                         ;Fetch the decimal exponent value back into ACC
 3243  15D0  D6 0A        SUB12:	SUI 00AH                        ;Subtract 10 (decimal) from value in ACC
 3244  15D2  FA DA 15     	JM TOMUCH                       ;Break out of loop when accumulator goes negative
 3245  15D5  77           	MOV M,A                         ;Else restore value to storage location
 3246  15D6  04           	INR B                           ;Increment register B as a counter
 3247  15D7  C3 D0 15     	JMP SUB12                       ;Repeat loop to form tens value of decimal exponent
 3248  15DA  3E B0        TOMUCH:	MVI A,0B0H                      ;Load base ASCII value for digit into the accumulator
 3249  15DC  80           	ADD B                           ;Add to the count in B to forin tens digit of decimal
 3250  15DD  CD E4 02     	CALL ECHO                       ;Exponent. Display via user's driver subroutine
 3251  15E0  7E           	MOV A,M                         ;Fetch remainder of decimal exponent value
 3252  15E1  C6 B0        	ADI 0B0H                        ;Add in ASCII base value to form final digit
 3253  15E3  CD E4 02     	CALL ECHO                       ;Display second digit of decirnal exponent
 3254  15E6  C9           	RET                             ;Finished outputting. Return to caller.
